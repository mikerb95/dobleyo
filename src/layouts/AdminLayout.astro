    <script is:inline src="/assets/js/auth-refresh.js"></script>
    <script>
      // Auth check (admin + caficultor)
      (async () => {
        const path = window.location.pathname;
        const ALLOWED_ROLES = ['admin', 'caficultor'];
        try {
          const res = await fetch('/api/auth/me', { credentials: 'include' });
          if (!res.ok) { window.location.href = '/login?redirect=' + encodeURIComponent(path); return; }
          const user = await res.json();
          if (!ALLOWED_ROLES.includes(user.role)) {
            alert('Acceso denegado.'); window.location.href = '/'; return;
          }

          // Filtrar nav items según rol (data-roles="admin,caficultor")
          document.querySelectorAll('[data-roles]').forEach((el) => {
            const roles = (el as HTMLElement).getAttribute('data-roles')!.split(',').map(s => s.trim());
            if (!roles.includes(user.role)) (el as HTMLElement).style.display = 'none';
          });

          // Ocultar secciones cuyo único contenido visible quedó vacío
          document.querySelectorAll('.nav-section').forEach((sec) => {
            const items = sec.querySelectorAll('.nav-item');
            const visibles = Array.from(items).filter(i => (i as HTMLElement).style.display !== 'none');
            if (items.length > 0 && visibles.length === 0) (sec as HTMLElement).style.display = 'none';
          });

          document.body.style.visibility = 'visible';

          const fullName = (user.first_name ? `${user.first_name} ${user.last_name ?? ''}`.trim() : user.email);
          const initials = fullName.split(' ').slice(0, 2).map((w: string) => w[0]).join('').toUpperCase();
          const roleLabel = user.role === 'caficultor' ? 'Caficultor' : 'Administrador';

          const avatarEl = document.getElementById('shellAvatar');
          if (avatarEl) avatarEl.textContent = initials;
          const nameEl = document.getElementById('shellUserName');
          if (nameEl) nameEl.textContent = user.first_name ?? user.email;
          const dropEl = document.getElementById('dropdownUserName');
          if (dropEl) dropEl.textContent = fullName;
          const roleEl = document.querySelector('.dropdown-user-role');
          if (roleEl) roleEl.textContent = roleLabel;
        } catch {
          window.location.href = '/login?redirect=' + encodeURIComponent(path);
        }
      })();

      // Active nav
      (() => {
        const seg = window.location.pathname.split('/').filter(Boolean);
        const section = seg[1] ?? 'dashboard';
        document.querySelectorAll('.nav-item[data-section]').forEach((a) => {
          if ((a as HTMLAnchorElement).getAttribute('data-section') === section)
            a.classList.add('active');
        });
      })();

      // Nav toggle
      (() => {
        const nav = document.getElementById('erpNav');
        const overlay = document.getElementById('navOverlay');
        const toggle = document.getElementById('navToggle');
        const isMobile = () => window.innerWidth < 1024;

        toggle?.addEventListener('click', () => {
          if (isMobile()) {
            nav?.classList.toggle('open');
            overlay?.classList.toggle('visible');
          } else {
            document.body.classList.toggle('nav-collapsed');
            localStorage.setItem('erpNavCollapsed', document.body.classList.contains('nav-collapsed') ? '1' : '0');
          }
        });

        overlay?.addEventListener('click', () => {
          nav?.classList.remove('open');
          overlay?.classList.remove('visible');
        });

        if (window.innerWidth >= 1024 && localStorage.getItem('erpNavCollapsed') === '1') {
          document.body.classList.add('nav-collapsed');
        }
      })();

      // User dropdown
      (() => {
        const btn = document.getElementById('userMenuBtn');
        const dropdown = document.getElementById('userDropdown');
        btn?.addEventListener('click', (e) => {
          e.stopPropagation();
          dropdown?.classList.toggle('open');
        });
        document.addEventListener('click', () => dropdown?.classList.remove('open'));
      })();

      // Logout
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
