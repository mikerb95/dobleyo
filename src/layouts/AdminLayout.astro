---
import Head from "../components/Head.astro";

export interface Props {
  title?: string;
  section?: string;
}

const { title = "Admin — DobleYo Café", section = "" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <Head title={title} isAdmin={true} />
    <style is:global>
      /* =================================================================
         DobleYo Admin — sistema visual basado en Claude Design
         3 variables base: --color-primary, --color-accent, --color-text
         Todo lo demás derivado con color-mix.
         ============================================================== */
      :root {
        /* === Paleta Claude Design (FUENTE DE VERDAD) === */
        --color-primary: #3a2618;
        --color-accent:  #c9893d;
        --color-text:    #1a1410;

        /* Derivados */
        --bg:       color-mix(in oklab, var(--color-primary) 4%,  #fbf8f3);
        --paper:    #ffffff;
        --rule:     color-mix(in oklab, var(--color-primary) 12%, #ffffff);
        --rule-2:   color-mix(in oklab, var(--color-primary) 20%, #ffffff);
        --muted:    color-mix(in oklab, var(--color-text)    50%, transparent);
        --muted-2:  color-mix(in oklab, var(--color-text)    35%, transparent);
        --hover:    color-mix(in oklab, var(--color-primary)  4%, white);
        --active-bg: color-mix(in oklab, var(--color-accent) 14%, white);

        /* Semánticos (mantengo para badges/alerts) */
        --danger:   #c0392b;
        --warn:     var(--color-accent);
        --ok:       #2e7d5b;
        --info:     color-mix(in oklab, var(--color-primary) 50%, white);

        /* === Compatibilidad con páginas Fiori existentes === */
        --shell-h: 56px;
        --nav-w: 232px;
        --nav-w-sm: 56px;

        --shell-bg: var(--paper);
        --shell-text: var(--color-primary);
        --shell-icon: var(--muted);
        --shell-icon-hover: var(--color-primary);

        --nav-bg: var(--paper);
        --nav-text: var(--color-text);
        --nav-text-2: var(--muted);
        --nav-hover-bg: var(--hover);
        --nav-active-bg: var(--active-bg);
        --nav-active-color: var(--color-primary);
        --nav-active-border: var(--color-accent);
        --nav-section-color: var(--muted-2);

        --erp-bg: var(--bg);
        --card-bg: var(--paper);
        --card-shadow: 0 1px 0 color-mix(in oklab, var(--color-primary) 6%, transparent),
                       0 8px 24px -16px color-mix(in oklab, var(--color-primary) 30%, transparent);
        --border: var(--rule);

        --text-1: var(--color-primary);
        --text-2: var(--muted);
        --text-3: var(--muted-2);

        --c-success: var(--ok);
        --c-success-bg: color-mix(in oklab, var(--ok) 12%, white);
        --c-success-border: color-mix(in oklab, var(--ok) 30%, white);
        --c-warning: var(--color-accent);
        --c-warning-bg: color-mix(in oklab, var(--color-accent) 14%, white);
        --c-warning-border: color-mix(in oklab, var(--color-accent) 30%, white);
        --c-error: var(--danger);
        --c-error-bg: color-mix(in oklab, var(--danger) 10%, white);
        --c-error-border: color-mix(in oklab, var(--danger) 30%, white);
        --c-info: color-mix(in oklab, var(--color-primary) 60%, white);
        --c-info-bg: color-mix(in oklab, var(--color-primary) 6%, white);

        --brand: var(--color-accent);
        --brand-dark: var(--color-primary);

        --radius:    10px;
        --radius-sm: 8px;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0; padding: 0;
        font-family: "Inter", system-ui, -apple-system, "Segoe UI", sans-serif;
        font-feature-settings: "ss01", "cv11";
        color: var(--color-text);
        background: var(--bg);
        min-height: 100vh;
      }

      body { visibility: hidden; }

      a { color: inherit; }
      button { font: inherit; }

      /* =========================================================
         SHELL — topbar + sidebar + main
         ========================================================= */
      .erp-shell {
        position: fixed; top: 0; left: 0; right: 0;
        height: var(--shell-h);
        background: var(--paper);
        border-bottom: 1px solid var(--rule);
        display: flex; align-items: center;
        padding: 0 18px;
        z-index: 30;
      }

      .shell-nav-toggle {
        appearance: none; border: 0; background: transparent;
        width: 36px; height: 36px;
        display: grid; place-items: center;
        cursor: pointer; color: var(--muted);
        border-radius: 8px;
      }
      .shell-nav-toggle:hover { background: var(--hover); color: var(--color-primary); }

      .shell-product {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; margin-left: 8px;
      }
      .shell-product-logo {
        width: 30px; height: 30px;
        background: var(--color-primary);
        border-radius: 8px;
        display: grid; place-items: center;
      }
      .shell-product-name {
        font-weight: 600; font-size: 14px;
        color: var(--color-primary); line-height: 1;
        letter-spacing: -0.01em;
      }
      .shell-product-sub {
        font-size: 10px; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.08em;
        margin-top: 2px;
      }

      .shell-spacer { flex: 1; }

      .shell-actions { display: flex; align-items: center; gap: 6px; }

      .shell-btn {
        appearance: none; border: 0; background: transparent;
        width: 36px; height: 36px;
        display: grid; place-items: center;
        color: var(--muted); cursor: pointer;
        border-radius: 8px;
        text-decoration: none;
      }
      .shell-btn:hover { background: var(--hover); color: var(--color-primary); }

      .shell-user-btn {
        display: flex; align-items: center; gap: 8px;
        background: transparent; border: 1px solid transparent;
        padding: 4px 10px 4px 4px; border-radius: 999px;
        cursor: pointer;
      }
      .shell-user-btn:hover { border-color: var(--rule); background: var(--hover); }

      .shell-avatar {
        width: 28px; height: 28px; border-radius: 999px;
        background: var(--color-primary); color: white;
        display: grid; place-items: center;
        font-size: 12px; font-weight: 600;
      }
      .shell-user-name {
        font-size: 13px; font-weight: 500; color: var(--color-primary);
        max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }

      .shell-user-dropdown {
        position: absolute; right: 0; top: calc(100% + 6px);
        background: var(--paper); border: 1px solid var(--rule);
        border-radius: var(--radius); min-width: 220px;
        box-shadow: 0 10px 32px -8px color-mix(in oklab, var(--color-primary) 30%, transparent);
        padding: 6px; opacity: 0; visibility: hidden;
        transform: translateY(-4px);
        transition: opacity .12s, transform .12s, visibility .12s;
        z-index: 40;
      }
      .shell-user-dropdown.open { opacity: 1; visibility: visible; transform: none; }

      .dropdown-user-info {
        padding: 10px 12px 12px;
        border-bottom: 1px solid var(--rule);
        margin-bottom: 4px;
      }
      .dropdown-user-name {
        font-size: 13px; font-weight: 600; color: var(--color-primary);
      }
      .dropdown-user-role {
        font-size: 11px; color: var(--muted); margin-top: 2px;
      }

      .dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; font-size: 13px;
        color: var(--color-text); text-decoration: none;
        border-radius: 6px; cursor: pointer;
        appearance: none; border: 0; background: transparent;
        width: 100%; text-align: left;
      }
      .dropdown-item:hover { background: var(--hover); }
      .dropdown-item.danger { color: var(--danger); }
      .dropdown-item.danger:hover { background: color-mix(in oklab, var(--danger) 8%, white); }

      /* ===== NAV ===== */
      .erp-nav {
        position: fixed; top: var(--shell-h); left: 0; bottom: 0;
        width: var(--nav-w);
        background: var(--paper);
        border-right: 1px solid var(--rule);
        display: flex; flex-direction: column;
        z-index: 20;
        transition: width .18s ease, transform .2s ease;
      }
      body.nav-collapsed .erp-nav { width: var(--nav-w-sm); }
      body.nav-collapsed .nav-label { display: none; }
      body.nav-collapsed .nav-section-label { display: none; }
      body.nav-collapsed .nav-section { padding-top: 8px; padding-bottom: 8px; }

      .nav-scroller { flex: 1; overflow-y: auto; padding: 14px 10px; }

      .nav-section { padding: 8px 0; }
      .nav-section-label {
        display: block;
        font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.1em;
        color: var(--muted-2);
        padding: 4px 12px 6px;
      }

      .nav-divider {
        height: 1px; background: var(--rule);
        margin: 4px 6px;
      }

      .nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px;
        margin: 1px 0;
        font-size: 13px; font-weight: 500;
        color: var(--color-text);
        text-decoration: none;
        border-radius: 8px;
        position: relative;
        transition: background .12s, color .12s;
      }
      .nav-item:hover { background: var(--hover); color: var(--color-primary); }
      .nav-item svg { flex-shrink: 0; opacity: 0.7; }
      .nav-item:hover svg { opacity: 1; }

      .nav-item.active {
        background: var(--active-bg);
        color: var(--color-primary);
        font-weight: 600;
      }
      .nav-item.active svg { opacity: 1; color: var(--color-accent); }
      .nav-item.active::before {
        content: ""; position: absolute;
        left: -10px; top: 8px; bottom: 8px;
        width: 3px; border-radius: 0 3px 3px 0;
        background: var(--color-accent);
      }

      .nav-footer {
        border-top: 1px solid var(--rule);
        padding: 8px 10px;
      }

      /* Overlay para mobile */
      .nav-overlay {
        position: fixed; inset: 0;
        background: color-mix(in oklab, var(--color-primary) 50%, transparent);
        opacity: 0; visibility: hidden;
        transition: opacity .15s, visibility .15s;
        z-index: 15;
      }
      .nav-overlay.visible { opacity: 1; visibility: visible; }

      /* ===== MAIN ===== */
      .erp-main {
        padding-top: var(--shell-h);
        padding-left: var(--nav-w);
        min-height: 100vh;
        transition: padding-left .18s ease;
      }
      body.nav-collapsed .erp-main { padding-left: var(--nav-w-sm); }

      .erp-content {
        min-height: calc(100vh - var(--shell-h));
      }

      /* ===== MOBILE ===== */
      @media (max-width: 1023px) {
        .erp-nav {
          width: 280px;
          transform: translateX(-100%);
          box-shadow: 0 10px 40px -10px color-mix(in oklab, var(--color-primary) 40%, transparent);
        }
        .erp-nav.open { transform: translateX(0); }
        .erp-main { padding-left: 0; }
        .shell-user-name { display: none; }
        body.nav-collapsed .erp-nav { width: 280px; }
        body.nav-collapsed .nav-label { display: inline; }
        body.nav-collapsed .nav-section-label { display: block; }
      }

      /* ===== UTILIDADES COMPARTIDAS (compat páginas Fiori) ===== */
      .card {
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--card-shadow);
      }
      .card-header {
        padding: 14px 18px;
        border-bottom: 1px solid var(--rule);
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px;
      }
      .card-title {
        font-size: 14px; font-weight: 600; color: var(--color-primary);
        margin: 0;
      }
      .card-subtitle {
        font-size: 12px; color: var(--muted); margin-top: 2px;
      }
      .card-action {
        font-size: 12px; color: var(--color-primary);
        text-decoration: none; font-weight: 500;
      }
      .card-action:hover { text-decoration: underline; }

      .btn {
        appearance: none; cursor: pointer;
        font: inherit; font-size: 13px; font-weight: 500;
        padding: 8px 14px; border-radius: 8px;
        border: 1px solid var(--rule); background: var(--paper); color: var(--color-text);
        display: inline-flex; align-items: center; gap: 6px;
        text-decoration: none;
      }
      .btn:hover { border-color: var(--rule-2); background: var(--hover); }
      .btn-primary { background: var(--color-primary); color: white; border-color: var(--color-primary); }
      .btn-primary:hover { background: color-mix(in oklab, var(--color-primary) 90%, black); }
      .btn-secondary { background: var(--paper); }

      .badge {
        display: inline-flex; align-items: center;
        font-size: 11px; font-weight: 600;
        padding: 2px 8px; border-radius: 999px;
      }
      .badge-success { background: var(--c-success-bg); color: var(--c-success); }
      .badge-warning { background: var(--c-warning-bg); color: var(--c-warning); }
      .badge-error   { background: var(--c-error-bg);   color: var(--c-error); }
      .badge-info    { background: var(--c-info-bg);    color: var(--c-info); }
      .badge-neutral { background: var(--hover);        color: var(--muted); }
      .badge-brand   { background: var(--active-bg);    color: var(--color-primary); }

      .erp-table {
        width: 100%; border-collapse: collapse; font-size: 13px;
      }
      .erp-table thead th {
        text-align: left;
        font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted);
        padding: 10px 18px;
        background: color-mix(in oklab, var(--color-primary) 3%, white);
        border-bottom: 1px solid var(--rule);
      }
      .erp-table tbody td {
        padding: 12px 18px;
        border-bottom: 1px solid var(--rule);
        color: var(--color-text);
      }
      .erp-table tbody tr:last-child td { border-bottom: 0; }
      .erp-table tbody tr:hover { background: var(--hover); }

      .empty-state {
        text-align: center; color: var(--muted);
        padding: 32px 16px; font-size: 13px;
      }

      .skeleton {
        display: inline-block;
        background: linear-gradient(90deg,
          color-mix(in oklab, var(--color-primary) 6%,  white) 0%,
          color-mix(in oklab, var(--color-primary) 12%, white) 50%,
          color-mix(in oklab, var(--color-primary) 6%,  white) 100%);
        background-size: 200% 100%;
        animation: shimmer 1.4s linear infinite;
        border-radius: 4px; height: 14px;
      }
      @keyframes shimmer {
        from { background-position: 200% 0; }
        to   { background-position: -200% 0; }
      }

      /* =========================================================
         ENCABEZADO DE PÁGINA + CUERPO (estructura compartida de
         las páginas nuevas: sistema, mercadolibre, inventario-valor,
         perfil). Las páginas que definen su propio .page-header
         scoped lo sobreescriben por mayor especificidad.
         ========================================================= */
      .page-header {
        background: var(--paper);
        border-bottom: 1px solid var(--rule);
        padding: 20px 24px 16px;
      }
      .page-header-top {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 16px; flex-wrap: wrap;
      }
      .page-breadcrumb {
        font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--muted-2); margin-bottom: 5px;
      }
      .page-title {
        font-size: 22px; font-weight: 600; letter-spacing: -0.01em;
        color: var(--color-primary); margin: 0;
      }
      .page-subtitle {
        font-size: 13px; color: var(--muted); margin-top: 4px;
      }
      .page-header-actions {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
      }

      .erp-body {
        padding: 24px;
        max-width: 1280px;
        margin: 0 auto;
      }
      @media (max-width: 640px) {
        .erp-body { padding: 16px; }
      }

      /* ===== KPI TILES (tarjetas de métrica destacada) ===== */
      .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
      }
      .kpi-tile {
        position: relative;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        padding: 16px 18px 16px 20px;
        box-shadow: var(--card-shadow);
        overflow: hidden;
      }
      .kpi-tile::before {
        content: ""; position: absolute;
        left: 0; top: 0; bottom: 0; width: 3px;
        background: var(--color-accent);
      }
      .kpi-tile.brand::before   { background: var(--color-accent); }
      .kpi-tile.success::before { background: var(--c-success); }
      .kpi-tile.info::before    { background: var(--c-info); }
      .kpi-tile.warning::before { background: var(--c-warning); }
      .kpi-tile.error::before   { background: var(--c-error); }
      .kpi-label {
        font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted); margin-bottom: 6px;
      }
      .kpi-value {
        font-size: 24px; font-weight: 700;
        color: var(--color-primary); line-height: 1.1;
        font-variant-numeric: tabular-nums;
      }
      .kpi-sub {
        font-size: 12px; color: var(--muted); margin-top: 4px;
      }

      /* ===== Tabla con scroll horizontal en mobile ===== */
      .table-wrapper { width: 100%; overflow-x: auto; }

      /* =========================================================
         FORMULARIOS Y UTILIDADES — Re-skin Claude Design
         (heredan páginas migradas: harvest, cupping, packaging, etc.)
         ========================================================= */

      /* Wrapper de página por defecto para páginas legacy */
      .erp-content > form,
      .erp-content > .page-wrap,
      .erp-content > .harvest,
      .erp-content > .packaging,
      .erp-content > .cupping,
      .erp-content > .etiquetas,
      .erp-content > .mi-finca,
      .erp-content > .inventory-storage,
      .erp-content > .send-roasting,
      .erp-content > .roast-retrieval,
      .erp-content > .roasted-storage,
      .erp-content > .lotes-entregados,
      .erp-content > .pages {
        padding: 24px;
        max-width: 1100px;
        margin: 0 auto;
      }
      @media (max-width: 640px) {
        .erp-content > form,
        .erp-content > .page-wrap,
        .erp-content > .harvest,
        .erp-content > .packaging,
        .erp-content > .cupping,
        .erp-content > .etiquetas,
        .erp-content > .mi-finca,
        .erp-content > .inventory-storage,
        .erp-content > .send-roasting,
        .erp-content > .roast-retrieval,
        .erp-content > .roasted-storage,
        .erp-content > .lotes-entregados,
        .erp-content > .pages { padding: 16px; }
      }

      /* Headings genéricos en páginas legacy */
      .erp-content h1 {
        font-size: 22px; font-weight: 600; letter-spacing: -0.01em;
        color: var(--color-primary); margin: 0 0 4px;
      }
      .erp-content h2 {
        font-size: 17px; font-weight: 600; letter-spacing: -0.01em;
        color: var(--color-primary); margin: 20px 0 12px;
      }
      .erp-content h3 {
        font-size: 14px; font-weight: 600; color: var(--color-primary);
        margin: 16px 0 10px;
      }

      /* Form group */
      .form-group {
        display: grid; gap: 6px; margin-bottom: 16px;
      }
      .form-group > label,
      .form-group > .form-label {
        font-size: 12px; font-weight: 600;
        color: var(--color-primary);
        text-transform: uppercase; letter-spacing: 0.06em;
        display: flex; align-items: center; gap: 4px;
      }
      .form-group input[type="text"],
      .form-group input[type="number"],
      .form-group input[type="email"],
      .form-group input[type="date"],
      .form-group input[type="time"],
      .form-group input[type="datetime-local"],
      .form-group input[type="tel"],
      .form-group input[type="url"],
      .form-group input[type="password"],
      .form-group input[type="search"],
      .form-group select,
      .form-group textarea,
      input[type="text"]:not([class]),
      input[type="number"]:not([class]),
      input[type="email"]:not([class]),
      input[type="date"]:not([class]),
      input[type="tel"]:not([class]),
      input[type="search"]:not([class]),
      select:not([class]),
      textarea:not([class]) {
        appearance: none;
        font: inherit; font-size: 14px;
        padding: 9px 12px;
        border: 1px solid var(--rule);
        border-radius: var(--radius-sm);
        background: var(--paper);
        color: var(--color-text);
        width: 100%;
        transition: border-color .12s, box-shadow .12s;
      }
      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus,
      input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-accent) 18%, transparent);
      }
      .form-group textarea { min-height: 80px; resize: vertical; }

      .form-hint {
        font-size: 11.5px; color: var(--muted);
      }
      .required {
        color: var(--danger); margin-left: 2px; font-weight: 600;
      }

      .form-grid {
        display: grid; gap: 14px;
        grid-template-columns: 1fr;
      }
      @media (min-width: 720px) {
        .form-grid { grid-template-columns: 1fr 1fr; }
      }
      .form-group--wide,
      .form-grid .wide { grid-column: 1 / -1; }

      .form-section {
        margin: 20px 0 12px;
      }
      .form-section > h3,
      .form-section > .form-section-title {
        font-size: 12px; font-weight: 600; color: var(--color-primary);
        text-transform: uppercase; letter-spacing: 0.08em;
        margin: 0 0 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--rule);
      }

      .form-actions {
        display: flex; gap: 8px; flex-wrap: wrap;
        margin-top: 20px;
        padding-top: 16px; border-top: 1px solid var(--rule);
      }

      /* Radio & checkbox — estilo card */
      .radio-group, .checkbox-group {
        display: grid; gap: 6px;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }
      .radio-item, .checkbox-item {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px;
        border: 1px solid var(--rule); border-radius: var(--radius-sm);
        background: var(--paper);
        cursor: pointer;
        transition: border-color .12s, background .12s;
        font-size: 13px;
      }
      .radio-item:hover, .checkbox-item:hover {
        border-color: var(--rule-2); background: var(--hover);
      }
      .radio-item input, .checkbox-item input {
        accent-color: var(--color-accent);
        width: auto;
      }
      .radio-item:has(input:checked),
      .checkbox-item:has(input:checked) {
        background: var(--active-bg);
        border-color: var(--color-accent);
        color: var(--color-primary);
        font-weight: 500;
      }

      /* Botones — variantes adicionales */
      .btn-save { background: var(--color-accent); color: var(--color-primary); border-color: var(--color-accent); font-weight: 600; }
      .btn-save:hover { background: color-mix(in oklab, var(--color-accent) 90%, black); border-color: color-mix(in oklab, var(--color-accent) 90%, black); }
      .btn-preview { background: var(--paper); color: var(--color-primary); border-color: var(--color-primary); }
      .btn-preview:hover { background: var(--hover); }
      .btn-danger { background: var(--danger); color: white; border-color: var(--danger); }
      .btn-danger:hover { background: color-mix(in oklab, var(--danger) 88%, black); }

      /* Detail grids (cupping, harvest detail, etc.) */
      .detail-grid {
        display: grid; gap: 12px 20px;
        grid-template-columns: repeat(2, 1fr);
      }
      @media (min-width: 700px) {
        .detail-grid { grid-template-columns: repeat(4, 1fr); }
      }
      .detail-item dt, .detail-label {
        font-size: 11px; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;
      }
      .detail-item dd, .detail-value {
        margin: 2px 0 0; font-weight: 600; color: var(--color-primary);
        font-variant-numeric: tabular-nums;
      }

      /* Alerts */
      .alert {
        padding: 12px 14px; border-radius: var(--radius-sm);
        display: flex; gap: 10px; align-items: flex-start;
        font-size: 13.5px; margin: 12px 0;
      }
      .alert--error {
        background: color-mix(in oklab, var(--danger) 8%, white);
        border: 1px solid color-mix(in oklab, var(--danger) 30%, white);
        color: var(--danger);
      }
      .alert--success {
        background: color-mix(in oklab, var(--ok) 8%, white);
        border: 1px solid color-mix(in oklab, var(--ok) 30%, white);
        color: var(--ok);
      }
      .alert--info {
        background: color-mix(in oklab, var(--color-primary) 5%, white);
        border: 1px solid var(--rule);
        color: var(--color-primary);
      }
      .info-box, .error-box {
        padding: 12px 14px; border-radius: var(--radius-sm);
        font-size: 13px; margin: 12px 0;
      }
      .info-box {
        background: color-mix(in oklab, var(--color-primary) 4%, white);
        border-left: 3px solid var(--color-accent);
      }
      .error-box {
        background: color-mix(in oklab, var(--danger) 8%, white);
        border-left: 3px solid var(--danger);
        color: var(--danger);
      }

      /* Badges */
      .badge-approved { background: color-mix(in oklab, var(--ok) 14%, white); color: var(--ok); padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
      .badge-rejected { background: color-mix(in oklab, var(--danger) 12%, white); color: var(--danger); padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
      .passed { color: var(--ok); }

      /* Modal */
      .modal {
        position: fixed; inset: 0; z-index: 50;
        background: color-mix(in oklab, var(--color-primary) 50%, transparent);
        display: grid; place-items: center; padding: 16px;
      }
      .modal-content {
        background: var(--paper); border-radius: var(--radius);
        max-width: 540px; width: 100%; max-height: 90vh; overflow: auto;
        box-shadow: 0 20px 60px -16px color-mix(in oklab, var(--color-primary) 50%, transparent);
        border: 1px solid var(--rule);
      }
      .modal-header {
        padding: 14px 20px;
        border-bottom: 1px solid var(--rule);
        display: flex; justify-content: space-between; align-items: center;
      }
      .modal-title {
        font-size: 15px; font-weight: 600; color: var(--color-primary); margin: 0;
      }
      .modal-body { padding: 20px; }
      .modal-actions {
        padding: 12px 20px;
        border-top: 1px solid var(--rule);
        display: flex; gap: 8px; justify-content: flex-end;
      }

      /* Spinner */
      .loading-spinner {
        display: inline-block;
        width: 18px; height: 18px;
        border: 2px solid var(--rule);
        border-top-color: var(--color-accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* Action buttons row */
      .action-buttons {
        display: flex; gap: 8px; flex-wrap: wrap;
        margin: 16px 0;
      }

      /* Conditions list (harvest, etc.) */
      .conditions-list {
        display: grid; gap: 8px;
      }
      .condition-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 14px;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--radius-sm);
        font-size: 13px;
      }

      /* History items (cupping, etc.) */
      .history-item {
        background: var(--paper); border: 1px solid var(--rule);
        border-radius: var(--radius); padding: 14px 16px;
        margin-bottom: 10px;
      }
      .history-item-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; margin-bottom: 8px;
      }
      .history-lot {
        font-size: 14px; font-weight: 600; color: var(--color-primary);
        font-family: ui-monospace, Menlo, monospace;
      }
      .history-meta { font-size: 12px; color: var(--muted); }
      .history-score {
        font-size: 18px; font-weight: 700; color: var(--color-accent);
        font-variant-numeric: tabular-nums;
      }

      /* Notes content */
      .notes-content {
        background: color-mix(in oklab, var(--color-primary) 3%, white);
        padding: 12px 14px; border-radius: var(--radius-sm);
        font-size: 13px; line-height: 1.5; color: var(--color-text);
        white-space: pre-wrap;
      }

      /* Header con badge (algunas páginas) */
      .header-badge {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 11px; font-weight: 600;
        padding: 3px 10px; border-radius: 999px;
        background: var(--active-bg); color: var(--color-primary);
      }

      /* Cover preview (etiquetas) */
      .cover-preview {
        background: var(--paper); border: 1px solid var(--rule);
        border-radius: var(--radius); padding: 12px;
        max-width: 400px;
      }

      /* mi-finca específico */
      .mf-page { padding: 24px; max-width: 1100px; margin: 0 auto; }
      .mf-header {
        display: flex; justify-content: space-between; align-items: flex-end;
        gap: 16px; flex-wrap: wrap; margin-bottom: 20px;
      }
      .mf-view-btn {
        appearance: none; border: 1px solid var(--rule);
        background: var(--paper); color: var(--color-text);
        padding: 6px 12px; border-radius: 8px; cursor: pointer;
        font-size: 12.5px; font-weight: 500;
      }
      .mf-view-btn:hover { background: var(--hover); border-color: var(--rule-2); }
      .mf-view-btn.active { background: var(--color-primary); color: white; border-color: var(--color-primary); }

      /* ===== Scrollbars sutiles ===== */
      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: color-mix(in oklab, var(--color-primary) 18%, white);
        border-radius: 999px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: color-mix(in oklab, var(--color-primary) 30%, white);
      }
    </style>
  </head>

