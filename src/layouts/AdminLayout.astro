---
import Head from "../components/Head.astro";

export interface Props {
  title?: string;
  section?: string;
}

const { title = "Admin — DobleYo Café", section = "" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <Head title={title} isAdmin={true} />
    <style is:global>
      /* ── Fiori Design System — DobleYo ERP ────────────────── */
      :root {
        --shell-h: 48px;
        --nav-w: 240px;
        --nav-w-sm: 52px;

        /* Shell */
        --shell-bg: #354a5e;
        --shell-text: rgba(255,255,255,.95);
        --shell-icon: rgba(255,255,255,.65);
        --shell-icon-hover: #fff;

        /* Nav */
        --nav-bg: #fff;
        --nav-text: #32363a;
        --nav-text-2: #6a6d70;
        --nav-hover-bg: #f5f6f7;
        --nav-active-bg: #fdf5e8;
        --nav-active-color: #7d4e10;
        --nav-active-border: #c8a96e;
        --nav-section-color: #8c9099;

        /* Content */
        --erp-bg: #f5f6f7;
        --card-bg: #fff;
        --card-shadow: 0 0 0 1px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.05);
        --border: rgba(0,0,0,.09);

        /* Text */
        --text-1: #32363a;
        --text-2: #6a6d70;
        --text-3: #a9b0b8;

        /* Semantic */
        --c-success: #107e3e;
        --c-success-bg: #f1fdf6;
        --c-success-border: #b5e8cd;
        --c-warning: #c96800;
        --c-warning-bg: #fef3e2;
        --c-warning-border: #f5c87a;
        --c-error: #aa0000;
        --c-error-bg: #ffeaea;
        --c-error-border: #f5bcbc;
        --c-info: #0064d9;
        --c-info-bg: #e8f2ff;
        --c-info-border: #91c2f5;

        /* Brand */
        --brand: #c8a96e;
        --brand-dark: #a8874a;
        --brand-green: #4a6741;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        background: var(--erp-bg);
        color: var(--text-1);
        min-height: 100vh;
        visibility: hidden;
      }

      /* ── Shell Bar ─────────────────────────────────────────── */
      .erp-shell {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--shell-h);
        background: var(--shell-bg);
        display: flex;
        align-items: center;
        z-index: 300;
        box-shadow: 0 2px 8px rgba(0,0,0,.25);
        gap: 0;
      }

      .shell-nav-toggle {
        display: grid;
        place-items: center;
        width: var(--shell-h);
        height: var(--shell-h);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--shell-icon);
        flex-shrink: 0;
        transition: color 0.15s, background 0.15s;
      }
      .shell-nav-toggle:hover { color: var(--shell-icon-hover); background: rgba(255,255,255,.08); }

      .shell-product {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 1rem 0 0.25rem;
        text-decoration: none;
        color: var(--shell-text);
        flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,.15);
        height: 100%;
      }
      .shell-product-logo {
        width: 28px;
        height: 28px;
        background: var(--brand);
        border-radius: 4px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
      }
      .shell-product-name {
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--shell-text);
        white-space: nowrap;
      }
      .shell-product-sub {
        font-size: 11px;
        color: var(--shell-icon);
        display: none;
      }
      @media (min-width: 480px) { .shell-product-sub { display: block; } }

      .shell-spacer { flex: 1; }

      .shell-actions {
        display: flex;
        align-items: center;
        height: 100%;
      }
      .shell-btn {
        display: grid;
        place-items: center;
        width: var(--shell-h);
        height: var(--shell-h);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--shell-icon);
        transition: color 0.15s, background 0.15s;
        position: relative;
        text-decoration: none;
      }
      .shell-btn:hover { color: var(--shell-icon-hover); background: rgba(255,255,255,.08); }

      .shell-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: var(--brand);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        border: 2px solid rgba(255,255,255,.3);
      }
      .shell-user-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 1rem;
        height: 100%;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--shell-text);
        font-size: 13px;
        font-family: inherit;
        transition: background 0.15s;
        position: relative;
      }
      .shell-user-btn:hover { background: rgba(255,255,255,.08); }
      .shell-user-name { display: none; }
      @media (min-width: 768px) { .shell-user-name { display: block; } }

      /* User dropdown */
      .shell-user-dropdown {
        position: absolute;
        top: calc(var(--shell-h) - 2px);
        right: 0;
        background: var(--card-bg);
        border: 1px solid var(--border);
        box-shadow: 0 8px 24px rgba(0,0,0,.15);
        border-radius: 4px;
        min-width: 200px;
        z-index: 400;
        display: none;
        overflow: hidden;
      }
      .shell-user-dropdown.open { display: block; }
      .dropdown-user-info {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--erp-bg);
      }
      .dropdown-user-name { font-weight: 600; font-size: 13px; color: var(--text-1); }
      .dropdown-user-role { font-size: 11px; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 2px; }
      .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        color: var(--text-1);
        font-size: 13px;
        text-decoration: none;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
        cursor: pointer;
        font-family: inherit;
        transition: background 0.12s;
      }
      .dropdown-item:hover { background: var(--nav-hover-bg); }
      .dropdown-item.danger { color: var(--c-error); }
      .dropdown-item svg { opacity: 0.6; flex-shrink: 0; }

      /* ── Left Navigation ───────────────────────────────────── */
      .erp-nav {
        position: fixed;
        top: var(--shell-h);
        left: 0;
        bottom: 0;
        width: var(--nav-w);
        background: var(--nav-bg);
        border-right: 1px solid var(--border);
        z-index: 200;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.25s ease, width 0.2s ease;
      }

      /* Mobile: hidden off-screen */
      @media (max-width: 1023px) {
        .erp-nav {
          transform: translateX(calc(-1 * var(--nav-w)));
          box-shadow: 4px 0 16px rgba(0,0,0,.12);
        }
        .erp-nav.open { transform: translateX(0); }
      }

      /* Desktop: collapsed icon-only */
      @media (min-width: 1024px) {
        body.nav-collapsed .erp-nav { width: var(--nav-w-sm); }
        body.nav-collapsed .nav-label,
        body.nav-collapsed .nav-section-label { display: none; }
        body.nav-collapsed .nav-item { justify-content: center; padding: 0; }
        body.nav-collapsed .nav-item svg { margin: 0; }
        body.nav-collapsed .nav-section { padding-top: 0.5rem; }
        body.nav-collapsed .nav-section + .nav-section { border-top: 1px solid var(--border); }
      }

      .nav-scroller { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 12px 0 8px; }

      .nav-section { padding-top: 12px; }
      .nav-section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--nav-section-color);
        padding: 8px 16px 6px;
        display: block;
        white-space: nowrap;
        overflow: hidden;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 16px;
        height: 40px;
        color: var(--nav-text);
        text-decoration: none;
        font-size: 13.5px;
        font-weight: 400;
        transition: background 0.12s, color 0.12s;
        position: relative;
        cursor: pointer;
        white-space: nowrap;
        overflow: hidden;
      }
      .nav-item:hover { background: var(--nav-hover-bg); }
      .nav-item.active {
        background: var(--nav-active-bg);
        color: var(--nav-active-color);
        font-weight: 600;
      }
      .nav-item.active::before {
        content: '';
        position: absolute;
        left: 0; top: 6px; bottom: 6px;
        width: 3px;
        background: var(--nav-active-border);
        border-radius: 0 2px 2px 0;
      }
      .nav-item svg { flex-shrink: 0; opacity: 0.65; }
      .nav-item:hover svg { opacity: 0.85; }
      .nav-item.active svg { opacity: 1; }
      .nav-label { flex: 1; }

      .nav-divider {
        height: 1px;
        background: var(--border);
        margin: 12px 0 0;
      }

      .nav-footer {
        padding: 12px 0;
        border-top: 1px solid var(--border);
        flex-shrink: 0;
      }

      /* ── Nav overlay (mobile) ──────────────────────────────── */
      .nav-overlay {
        display: none;
        position: fixed;
        inset: var(--shell-h) 0 0 0;
        background: rgba(0,0,0,.45);
        z-index: 199;
      }
      .nav-overlay.visible { display: block; }
      @media (min-width: 1024px) { .nav-overlay { display: none !important; } }

      /* ── Main Content ──────────────────────────────────────── */
      .erp-main {
        padding-top: var(--shell-h);
        padding-left: var(--nav-w);
        min-height: 100vh;
        transition: padding-left 0.2s ease;
      }
      @media (max-width: 1023px) {
        .erp-main { padding-left: 0; }
      }
      body.nav-collapsed .erp-main {
        padding-left: var(--nav-w-sm);
      }

      .erp-content { padding: 0; }

      /* ── Page Header (Fiori Object Page Header) ────────────── */
      .page-header {
        background: var(--card-bg);
        border-bottom: 1px solid var(--border);
        padding: 0 1.5rem;
      }
      .page-header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 52px;
        gap: 1rem;
      }
      .page-breadcrumb {
        font-size: 12px;
        color: var(--text-2);
        margin-bottom: 2px;
      }
      .page-breadcrumb a { color: var(--text-2); text-decoration: none; }
      .page-breadcrumb a:hover { color: var(--brand-dark); text-decoration: underline; }
      .page-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: -0.01em;
      }
      .page-header-actions { display: flex; gap: 8px; align-items: center; flex-shrink: 0; }

      /* ── Body padding ──────────────────────────────────────── */
      .erp-body {
        padding: 1.5rem;
      }
      @media (min-width: 768px) { .erp-body { padding: 1.75rem 2rem; } }

      /* ── Buttons (Fiori style) ─────────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0 16px;
        height: 36px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid transparent;
        transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
        white-space: nowrap;
      }
      .btn-primary {
        background: var(--brand);
        border-color: var(--brand-dark);
        color: #fff;
      }
      .btn-primary:hover { background: var(--brand-dark); }
      .btn-secondary {
        background: var(--card-bg);
        border-color: var(--border);
        color: var(--text-1);
      }
      .btn-secondary:hover { background: var(--nav-hover-bg); border-color: #bbb; }
      .btn-ghost {
        background: none;
        border-color: transparent;
        color: var(--text-1);
      }
      .btn-ghost:hover { background: var(--nav-hover-bg); }

      /* ── KPI Tile ──────────────────────────────────────────── */
      .kpi-tile {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 16px 20px;
        position: relative;
        overflow: hidden;
      }
      .kpi-tile::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
      }
      .kpi-tile.success::before { background: var(--c-success); }
      .kpi-tile.warning::before { background: var(--c-warning); }
      .kpi-tile.error::before   { background: var(--c-error); }
      .kpi-tile.info::before    { background: var(--c-info); }
      .kpi-tile.brand::before   { background: var(--brand); }

      .kpi-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-2);
        margin-bottom: 6px;
      }
      .kpi-value {
        font-size: 28px;
        font-weight: 700;
        line-height: 1;
        color: var(--text-1);
        margin-bottom: 4px;
      }
      .kpi-sub {
        font-size: 12px;
        color: var(--text-3);
      }

      /* ── Card ──────────────────────────────────────────────── */
      .card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
      }
      .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        gap: 1rem;
      }
      .card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-1);
      }
      .card-subtitle {
        font-size: 12px;
        color: var(--text-2);
        margin-top: 1px;
      }
      .card-action {
        font-size: 12px;
        color: var(--c-info);
        text-decoration: none;
        font-weight: 500;
        white-space: nowrap;
      }
      .card-action:hover { text-decoration: underline; }

      /* ── Table ─────────────────────────────────────────────── */
      .erp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
      .erp-table thead th {
        text-align: left;
        padding: 10px 16px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-2);
        background: #fafafa;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .erp-table tbody td {
        padding: 11px 16px;
        border-bottom: 1px solid rgba(0,0,0,.05);
        color: var(--text-1);
        vertical-align: middle;
      }
      .erp-table tbody tr:last-child td { border-bottom: none; }
      .erp-table tbody tr:hover td { background: var(--nav-hover-bg); }

      /* ── Badge ─────────────────────────────────────────────── */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        border: 1px solid transparent;
        white-space: nowrap;
      }
      .badge-success { background: var(--c-success-bg); color: var(--c-success); border-color: var(--c-success-border); }
      .badge-warning { background: var(--c-warning-bg); color: var(--c-warning); border-color: var(--c-warning-border); }
      .badge-error   { background: var(--c-error-bg);   color: var(--c-error);   border-color: var(--c-error-border); }
      .badge-info    { background: var(--c-info-bg);    color: var(--c-info);    border-color: var(--c-info-border); }
      .badge-neutral { background: #f0f0f0; color: #555; border-color: #ddd; }

      /* ── Skeleton ──────────────────────────────────────────── */
      .skeleton {
        display: inline-block;
        height: 1em;
        width: 70px;
        background: linear-gradient(90deg, #ebebeb 25%, #d8d8d8 50%, #ebebeb 75%);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite;
        border-radius: 3px;
      }
      @keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      /* ── Empty state ───────────────────────────────────────── */
      .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-2);
        font-size: 13px;
      }
    </style>
  </head>
  <body>

    <!-- ── Shell Bar ──────────────────────────────────────────── -->
    <header class="erp-shell">
      <button class="shell-nav-toggle" id="navToggle" aria-label="Menú de navegación">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <a href="/admin" class="shell-product">
        <div class="shell-product-logo">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/>
            <line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/>
          </svg>
        </div>
        <div>
          <div class="shell-product-name">DobleYo</div>
          <div class="shell-product-sub">ERP Café</div>
        </div>
      </a>

      <div class="shell-spacer"></div>

      <div class="shell-actions">
        <!-- Ver tienda -->
        <a href="/" target="_blank" class="shell-btn" title="Ver tienda">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>

        <!-- User -->
        <div style="position:relative">
          <button class="shell-user-btn" id="userMenuBtn" aria-label="Menú de usuario">
            <div class="shell-avatar" id="shellAvatar">—</div>
            <span class="shell-user-name" id="shellUserName">Usuario</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:.6">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="shell-user-dropdown" id="userDropdown">
            <div class="dropdown-user-info">
              <div class="dropdown-user-name" id="dropdownUserName">—</div>
              <div class="dropdown-user-role">Administrador</div>
            </div>
            <a href="/admin/perfil" class="dropdown-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              Mi Perfil
            </a>
            <div style="height:1px;background:var(--border);margin:4px 0"></div>
            <button class="dropdown-item danger" id="logoutBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
              Cerrar sesión
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- ── Nav Overlay (mobile) ───────────────────────────────── -->
    <div class="nav-overlay" id="navOverlay"></div>

    <!-- ── Left Navigation ───────────────────────────────────── -->
    <nav class="erp-nav" id="erpNav" aria-label="Navegación ERP">
      <div class="nav-scroller">

        <div class="nav-section">
          <span class="nav-section-label">Principal</span>
          <a href="/admin" class="nav-item" data-section="dashboard">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
            </svg>
            <span class="nav-label">Dashboard</span>
          </a>
          <a href="/admin/pedidos" class="nav-item" data-section="pedidos">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <span class="nav-label">Pedidos</span>
          </a>
        </div>

        <div class="nav-divider"></div>

        <div class="nav-section">
          <span class="nav-section-label">Catálogo</span>
          <a href="/admin/inventario" class="nav-item" data-section="inventario">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
            <span class="nav-label">Inventario</span>
          </a>
