---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import CookieBanner from "../components/CookieBanner.astro";
import AuthModal from "../components/AuthModal.astro";
import CartDrawer from "../components/CartDrawer.astro";
import LangSuggest from "../components/LangSuggest.astro";
import type { Lang } from "../i18n/index.ts";

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  canonical?: string;
  hreflangEs?: string;
  hreflangEn?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideWhatsApp?: boolean;
  noindex?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "product" | "article";
  articlePublishedTime?: string;
}

const {
  title,
  description,
  lang = "es",
  canonical,
  hreflangEs,
  hreflangEn,
  jsonLd,
  hideWhatsApp = false,
  noindex = false,
  ogImage,
  ogImageAlt,
  ogType,
  articlePublishedTime,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <Head
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      hreflangEs={hreflangEs}
      hreflangEn={hreflangEn}
      jsonLd={jsonLd}
      noindex={noindex}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      articlePublishedTime={articlePublishedTime}
    />
  </head>
  <body class="font-sans bg-cream text-ink">
    <a href="#main" class="skip-link">{lang === "en" ? "Skip to content" : "Saltar al contenido"}</a>

    <!-- Barra superior de anuncio -->
    <div class="topbar" id="topbar" transition:persist={`topbar-${lang}`}>
      <div class="container">
        {lang === "en" ? (
          <span>New: Free worldwide shipping on orders over $50 · Fresh harvests from Huila &amp; Nariño</span>
        ) : (
          <span>Novedad: Envíos nacionales gratis desde $120.000 · Nuevas cosechas Huila &amp; Nariño</span>
        )}
        <button class="topbar-close" aria-label={lang === "en" ? "Close" : "Cerrar"} id="topbarClose">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>

    <!-- La persistencia entre navegaciones (transition:persist) vive en el
         elemento raíz DENTRO de cada componente: Astro descarta la directiva
         si se aplica al tag del componente. -->
    <Header lang={lang} />

    <main class="container" id="main">
      <slot />
    </main>

    <Footer lang={lang} />

    {lang === "es" && <LangSuggest />}

    <!-- Banner de consentimiento de cookies (Ley 1581/2012) -->
    <CookieBanner />

    <!-- Modal de autenticación (login / registro) -->
    <AuthModal />

    <!-- Drawer lateral del carrito (feedback al agregar) -->
    <CartDrawer />

    <!-- Botón flotante WhatsApp -->
    {!hideWhatsApp && (
    <a
      href={lang === "en"
        ? "https://wa.me/573204981580?text=Hello%20DobleYo%20Café!%20I'm%20interested%20in%20learning%20more%20about%20your%20coffees."
        : "https://wa.me/573204981580?text=Hola%20Café%20DobleYo!%20Estoy%20interesado%20en%20saber%20más%20sobre%20sus%20cafés."}
      class="whatsapp-fab"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === "en" ? "Chat with us on WhatsApp" : "Escríbenos por WhatsApp"}
      transition:persist={`wa-fab-${lang}`}
    >
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      <span class="whatsapp-fab__tooltip">{lang === "en" ? "Chat with us" : "Escríbenos"}</span>
    </a>
    )}

    <!-- Scripts globales -->
    <script is:inline src="/assets/js/cart.js"></script>
    <script is:inline src="/assets/js/favorites.js"></script>
    <script is:inline src="/assets/js/auth-refresh.js"></script>

    <!-- Handlers globales del Layout (externalizados por CSP estricta sin 'unsafe-inline') -->
    <script is:inline src="/assets/js/layout.js"></script>
    <script is:inline src="/assets/js/reveal.js"></script>
  </body>
</html>
