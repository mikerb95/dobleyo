---
import Header from "../components/Header.astro";
import Head from "../components/Head.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- isAdmin=true: noindex + sin JSON-LD organizacional + fonts Inter -->
    <Head title={`${title} — DobleYo Café`} isAdmin={true} />
    <!-- Fuentes necesarias para navbar (Montserrat) y contenido (Lora, Playfair) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Playfair+Display:wght@600;700&family=Montserrat:wght@700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ── Compensar navbar fija ───────────────────────────────────────────── */
      .mobile-page-wrapper {
        padding-top: calc(var(--header-height, 96px) + var(--header-top, 0px) + 0.5rem);
        min-height: 100vh;
      }

      /* ── Contenido de la página ──────────────────────────────────────────── */
      .mobile-content {
        padding: 1.25rem 1.25rem 3rem;
        max-width: 100%;
      }

      @media (min-width: 600px) {
        .mobile-content {
          max-width: 520px;
          margin: 0 auto;
        }
      }

      /* ── Título de página ────────────────────────────────────────────────── */
      .page-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--coffee, #251a14);
        margin: 0 0 0.35rem;
        font-family: 'Playfair Display', Georgia, serif;
      }

      .page-description {
        color: var(--muted, #777);
        font-size: 0.92rem;
        margin: 0 0 1.5rem;
        line-height: 1.5;
      }

      /* ── Formularios ─────────────────────────────────────────────────────── */
      form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      label {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--dark, #1f1f1f);
      }

      label .required {
        color: #dc2626;
      }

      input,
      select,
      textarea {
        padding: 0.75rem;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 0.375rem;
        font-family: inherit;
        font-size: 1rem;
        color: var(--dark, #1f1f1f);
        background: #fff;
        width: 100%;
        box-sizing: border-box;
      }

      input:focus,
      select:focus,
      textarea:focus {
        outline: none;
        border-color: var(--accent, #c67b4e);
        box-shadow: 0 0 0 3px rgba(198, 123, 78, 0.15);
      }

      textarea {
        resize: vertical;
        min-height: 100px;
      }

      .form-hint {
        font-size: 0.82rem;
        color: var(--muted, #777);
        margin-top: 0.2rem;
      }

      /* ── Botones ─────────────────────────────────────────────────────────── */
      .btn {
        background: var(--accent, #c67b4e);
        color: #fff;
        padding: 0.875rem 1.5rem;
        border: none;
        border-radius: 0.375rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
        text-align: center;
        display: inline-block;
        text-decoration: none;
      }

      .btn:active,
      .btn:hover {
        background: #a85a3a;
      }

      .btn:disabled {
        background: var(--muted, #777);
        cursor: not-allowed;
      }

      .btn-secondary {
        background: #fff;
        color: var(--accent, #c67b4e);
        padding: 0.875rem 1.5rem;
        border: 1px solid var(--accent, #c67b4e);
        border-radius: 0.375rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
      }

      .btn-secondary:active {
        background: var(--cream, #f7f3ef);
      }

      .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }

      .form-actions button {
        flex: 1;
      }

      /* ── Alertas ─────────────────────────────────────────────────────────── */
      .alert {
        padding: 1rem;
        border-radius: 0.375rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
        line-height: 1.5;
      }

      .alert-success {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
      }

      .alert-error {
        background: #fee2e2;
        color: #7f1d1d;
        border: 1px solid #fecaca;
      }

      .alert-info {
        background: #dbeafe;
        color: #1e40af;
        border: 1px solid #93c5fd;
      }

      /* ── Cards ───────────────────────────────────────────────────────────── */
      .mobile-card {
        background: #fff;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 0.5rem;
        padding: 1.25rem;
        margin-bottom: 1rem;
      }

      .mobile-card h3 {
        margin-top: 0;
        margin-bottom: 1rem;
        font-size: 1.05rem;
        color: var(--coffee, #251a14);
      }

      /* Compatibilidad con .card usado en páginas existentes */
      .card {
        background: #fff;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 0.5rem;
        padding: 1.25rem;
        margin-bottom: 1rem;
      }

      .card h3 {
        margin-top: 0;
        margin-bottom: 1rem;
        font-size: 1.05rem;
        color: var(--coffee, #251a14);
      }

      /* ── Selecciones múltiples ───────────────────────────────────────────── */
      .checkbox-group,
      .radio-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .checkbox-item,
      .radio-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border: 1px solid var(--border, #e6e6e6);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
      }

      .checkbox-item input,
      .radio-item input {
        width: auto;
        margin: 0;
        cursor: pointer;
      }

      .checkbox-item:has(input:checked),
      .radio-item:has(input:checked) {
        background: rgba(198, 123, 78, 0.1);
        border-color: var(--accent, #c67b4e);
      }

      /* ── Info boxes ──────────────────────────────────────────────────────── */
      .info-box {
        background: rgba(198, 123, 78, 0.08);
        padding: 1rem;
        border-left: 4px solid var(--accent, #c67b4e);
        border-radius: 0.375rem;
        margin-bottom: 1rem;
      }

      .info-box strong {
        color: var(--coffee, #251a14);
      }

      /* ── Loading ─────────────────────────────────────────────────────────── */
      .loading {
        display: inline-block;
        width: 1rem;
        height: 1rem;
        border: 2px solid var(--border, #e6e6e6);
        border-top-color: var(--accent, #c67b4e);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body>
    <Header />

    <div class="mobile-page-wrapper">
      <div class="mobile-content">
        <h1 class="page-title">{title}</h1>
        {description && <p class="page-description">{description}</p>}
        <slot />
      </div>
    </div>

    <script is:inline src="/assets/js/cart.js"></script>
    <script is:inline src="/assets/js/auth-refresh.js"></script>

    <script>
      // ── Sincronizar altura de navbar fija ─────────────────────────────────
      (function syncHeaderMetrics() {
        const setMetrics = () => {
          const header = document.querySelector(".site-header");
          if (!header) return;
          const h = header.offsetHeight;
          document.documentElement.style.setProperty("--header-height", h + "px");
          document.documentElement.style.setProperty("--header-top", "0px");
        };
        setMetrics();
        window.addEventListener("resize", setMetrics);
      })();

      // ── Verificar autenticación ────────────────────────────────────────────
      (async function checkAuth() {
        const path = window.location.pathname;
        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000);
          const res = await fetch("/api/auth/me", {
            credentials: "include",
            signal: controller.signal,
          });
          clearTimeout(timeoutId);

          if (!res.ok) {
            if (res.status === 401 || res.status === 403) {
              window.location.href = "/login?redirect=" + encodeURIComponent(path);
            }
            return;
          }

          const user = await res.json();
          if (user.role !== "caficultor" && user.role !== "admin") {
            window.location.href = "/login?redirect=" + encodeURIComponent(path);
          }
        } catch (err) {
          // Timeout o error de red — dejar que las llamadas API individuales manejen el 401
          console.warn("[MobileLayout] Auth check failed:", err?.message);
        }
      })();

      // ── Haptic feedback ────────────────────────────────────────────────────
      const haptic = (pattern = 20) => {
        if (navigator.vibrate) navigator.vibrate(pattern);
      };

      document.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => haptic(15))
      );
      document
        .querySelectorAll('input[type="radio"], input[type="checkbox"]')
        .forEach((i) => i.addEventListener("change", () => haptic([10, 5, 10])));
      document
        .querySelectorAll("select")
        .forEach((s) => s.addEventListener("change", () => haptic([10, 5, 10])));
      document
        .querySelectorAll('input[type="text"], input[type="number"], input[type="email"], textarea')
        .forEach((i) => i.addEventListener("focus", () => haptic(5)));

      // ── Conservar posición de scroll ───────────────────────────────────────
      const savedPos = sessionStorage.getItem("scrollPos");
      if (savedPos !== null) {
        window.scrollTo(0, parseInt(savedPos));
        sessionStorage.removeItem("scrollPos");
      }
      document.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          if (!link.href.includes("#")) {
            sessionStorage.setItem("scrollPos", String(window.scrollY));
          }
        });
      });
    </script>
  </body>
</html>
