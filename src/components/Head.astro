---
/**
 * Reusable Head component to avoid duplication across layouts
 * Contains all common meta tags, fonts, and CSS variables
 */

import "@fontsource-variable/fraunces/wght.css";
import "@fontsource-variable/inter/wght.css";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  description?: string;
  isAdmin?: boolean;
  /** Fuerza noindex,nofollow sin aplicar el resto del modo admin (p. ej. fuentes) */
  noindex?: boolean;
  lang?: "es" | "en";
  canonical?: string;
  hreflangEs?: string;
  hreflangEn?: string;
  /** Esquema JSON-LD adicional específico de la página (Product, BreadcrumbList, etc.) */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Imagen para Open Graph / Twitter Card. URL absoluta o ruta relativa (se resuelve contra el sitio) */
  ogImage?: string;
  ogImageAlt?: string;
  /** Tipo de contenido Open Graph */
  ogType?: "website" | "product" | "article";
  /** Fecha de publicación — solo aplica cuando ogType="article" */
  articlePublishedTime?: string;
}

// Origen canónico del sitio, tomado de `site` en astro.config.mjs (fallback por si corre sin configurar)
const siteOrigin = (Astro.site ?? new URL("https://dobleyo.cafe/")).origin;

const {
  title = "DobleYo — Café de especialidad colombiano",
  description = "Tienda de café de especialidad colombiano. Tueste fresco, origen trazable, estilo sereno y acogedor.",
  isAdmin = false,
  noindex = false,
  lang = "es",
  canonical,
  hreflangEs,
  hreflangEn,
  jsonLd,
  ogImage = `${siteOrigin}/assets/img/og-default.jpg`,
  ogImageAlt = "DobleYo Café — Café de especialidad colombiano",
  ogType = "website",
  articlePublishedTime,
} = Astro.props;

const resolvedOgImage = ogImage.startsWith("http")
  ? ogImage
  : `${siteOrigin}${ogImage.startsWith("/") ? "" : "/"}${ogImage}`;

// JSON-LD de Organización — presente en todas las páginas públicas
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "DobleYo Café",
  url: siteOrigin,
  logo: `${siteOrigin}/assets/branding/logo.svg`,
  description:
    "Café de especialidad colombiano con trazabilidad completa del grano.",
  sameAs: [
    "https://www.instagram.com/dobleyo.cafe",
    "https://www.facebook.com/doblcafe",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "hola@dobleyo.cafe",
    availableLanguage: ["Spanish", "English"],
  },
};
---

{/* Robots — noindex en páginas privadas */}
<meta
  name="robots"
  content={isAdmin || noindex ? "noindex, nofollow" : "index, follow"}
/>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" href="/assets/logo.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
{!isAdmin && <link rel="manifest" href="/manifest.json" />}
{
  !isAdmin && (
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Blog DobleYo Café"
      href="https://dobleyo.cafe/rss.xml"
    />
  )
}
<meta name="theme-color" content="#251a14" />

{/* Canonical URL */}
{canonical && <link rel="canonical" href={canonical} />}

{/* hreflang — idiomas alternativos */}
{hreflangEs && <link rel="alternate" hreflang="es" href={hreflangEs} />}
{hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
{
  hreflangEs && hreflangEn && (
    <link rel="alternate" hreflang="x-default" href={hreflangEs} />
  )
}

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="DobleYo Café" />
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:locale" content={lang === "en" ? "en_US" : "es_CO"} />
{
  !isAdmin && (
    <>
      <meta property="og:image" content={resolvedOgImage} />
      <meta property="og:image:alt" content={ogImageAlt} />
      {ogType === "article" && articlePublishedTime && (
        <meta property="article:published_time" content={articlePublishedTime} />
      )}

      {/* Twitter Card */}
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content={resolvedOgImage} />
      <meta name="twitter:image:alt" content={ogImageAlt} />
    </>
  )
}

{
  isAdmin && (
    <>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600&family=Playfair+Display:wght@700&display=swap"
        rel="stylesheet"
      />
    </>
  )
}

<!-- JSON-LD: Organización (todas las páginas públicas) -->
{
  !isAdmin && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
  )
}

{/* JSON-LD adicional específico de la página */}
{
  jsonLd && !isAdmin && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
    />
  )
}

<!-- CSS Custom -->
<link rel="stylesheet" href="/assets/css/styles.css" />

{/* View Transitions — solo en el sitio público, no en el panel admin */}
{!isAdmin && <ClientRouter />}
