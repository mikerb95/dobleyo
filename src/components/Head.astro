---
/**
 * Reusable Head component to avoid duplication across layouts
 * Contains all common meta tags, fonts, and CSS variables
 */

export interface Props {
  title?: string;
  description?: string;
  isAdmin?: boolean;
  lang?: "es" | "en";
  canonical?: string;
  hreflangEs?: string;
  hreflangEn?: string;
  /** Esquema JSON-LD adicional específico de la página (Product, BreadcrumbList, etc.) */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "DobleYo — Café de especialidad colombiano",
  description = "Tienda de café de especialidad colombiano. Tueste fresco, origen trazable, estilo sereno y acogedor.",
  isAdmin = false,
  lang = "es",
  canonical,
  hreflangEs,
  hreflangEn,
  jsonLd,
} = Astro.props;

// JSON-LD de Organización — presente en todas las páginas públicas
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "DobleYo Café",
  url: "https://dobleyo.cafe",
  logo: "https://dobleyo.cafe/assets/branding/logo.svg",
  description:
    "Café de especialidad colombiano con trazabilidad completa del grano.",
  sameAs: [
    "https://www.instagram.com/dobleyo.cafe",
    "https://www.facebook.com/doblcafe",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: "hola@dobleyo.cafe",
    availableLanguage: ["Spanish", "English"],
  },
};
---

{/* Robots — noindex en páginas privadas */}
<meta name="robots" content={isAdmin ? "noindex, nofollow" : "index, follow"} />

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" href="/assets/logo.svg" type="image/svg+xml" />
<meta name="theme-color" content="#251a14" />

{/* Canonical URL */}
{canonical && <link rel="canonical" href={canonical} />}

{/* hreflang — idiomas alternativos */}
{hreflangEs && <link rel="alternate" hreflang="es" href={hreflangEs} />}
{hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
{
  hreflangEs && hreflangEn && (
    <link rel="alternate" hreflang="x-default" href={hreflangEs} />
  )
}

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="DobleYo Café" />
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:locale" content={lang === "en" ? "en_US" : "es_CO"} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

{
  !isAdmin && (
    <>
      <link
        href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
        rel="stylesheet"
      />
      <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap"
        rel="stylesheet"
      />
    </>
  )
}

{
  isAdmin && (
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  )
}

<!-- JSON-LD: Organización (todas las páginas públicas) -->
{
  !isAdmin && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
  )
}

{/* JSON-LD adicional específico de la página */}
{
  jsonLd && !isAdmin && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
    />
  )
}

<!-- CSS Custom -->
<link rel="stylesheet" href="/assets/css/styles.css" />
