---
import type { Product } from "../data/products";

interface Props {
  product: Product & { stock?: number; sca_score?: number | null };
}

const { product } = Astro.props;

const outOfStock = typeof product.stock === "number" && product.stock === 0;
const lowStock   = typeof product.stock === "number" && product.stock > 0 && product.stock <= 5;
---

<article class="card">
  <button
    class="fav-toggle"
    data-fav={product.id}
    aria-label="Agregar a favoritos"
    aria-pressed="false"
    title="Agregar a favoritos"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
      <path
        d="M12 21s-6.7-4.35-9.3-8.05C.9 10.3 1.6 6.9 4.4 5.7c2-.85 4.1-.1 5.2 1.5l.9 1.3.9-1.3c1.1-1.6 3.2-2.35 5.2-1.5 2.8 1.2 3.5 4.6 1.7 7.25C18.7 16.65 12 21 12 21z"
      ></path>
    </svg>
  </button>
  <a href={`/producto/${product.id}`} class="card-link" tabindex="-1" aria-hidden="true">
    <img
      src={product.image}
      alt={product.name}
      loading="lazy"
      transition:name={`product-image-${product.id}`}
    />
  </a>
  <div class="p">
    <div class="muted" style="font-size:.85rem">
      {product.category}{product.origin ? " · " + product.origin : ""}
    </div>
    <h3>
      <a href={`/producto/${product.id}`} class="card-name-link">{product.name}</a>
    </h3>
    <div class="muted" style="font-size:.85rem">
      {product.process || ""}{product.process && product.roast ? " · " : ""}{product.roast || ""}
    </div>
    <div class="price">${product.price.toLocaleString("es-CO")}</div>
    {product.sca_score && <span class="sca-pill">{product.sca_score} pts SCA</span>}
    {outOfStock && <span class="stock-badge out">Agotado</span>}
    {lowStock && <span class="stock-badge low">Últimas {product.stock}</span>}
  </div>
  <div class="card-actions">
    <div style="display:flex; gap:.5rem; padding: 0 1rem 1rem;">
      <button
        class="btn small"
        data-add={product.id}
        data-name={product.name}
        data-price={product.price}
        data-image={product.image}
        disabled={outOfStock || undefined}
      >
        {outOfStock ? "Agotado" : "Agregar"}
      </button>
      <a class="btn outline small" href="/cart" data-link>Ver carrito</a>
    </div>
  </div>
</article>

<style>
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-name-link {
    text-decoration: none;
    color: inherit;
  }

  .card-name-link:hover {
    color: var(--accent);
  }

  .card {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .fav-toggle {
    position: absolute;
    top: .6rem;
    right: .6rem;
    z-index: 2;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, .9);
    box-shadow: 0 1px 4px rgba(0, 0, 0, .15);
    cursor: pointer;
    color: var(--muted-fg);
    transition: color .15s, transform .15s;
  }

  .fav-toggle:hover {
    transform: scale(1.08);
    color: #dc2626;
  }

  .fav-toggle svg path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
  }

  .fav-toggle.is-fav {
    color: #dc2626;
  }

  .fav-toggle.is-fav svg path {
    fill: currentColor;
    stroke: currentColor;
  }

  .fav-toggle:disabled {
    opacity: .5;
    cursor: default;
  }

  .card-actions {
    margin-top: auto;
  }

  .stock-badge {
    display: inline-block;
    font-size: .75rem;
    font-weight: 600;
    padding: .15rem .5rem;
    border-radius: 99px;
    margin-top: .25rem;
  }

  .stock-badge.out {
    background: #fee2e2;
    color: #b91c1c;
  }

  .stock-badge.low {
    background: #fef9c3;
    color: #92400e;
  }
</style>
