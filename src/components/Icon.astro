---
/**
 * Set curado de iconos SVG en línea — reemplaza el uso de emojis en la UI.
 * Estilo: stroke 1.5, viewBox 24x24, hereda color con currentColor.
 */
export interface Props {
  name: keyof typeof icons;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className } = Astro.props;

const icons = {
  package: `<path d="M21 8.5 12 3 3 8.5v7L12 21l9-5.5v-7Z"/><path d="m3 8.5 9 5.5 9-5.5"/><path d="M12 14v7"/>`,
  "rotate-cw": `<path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 3v6h-6"/>`,
  "alert-triangle": `<path d="M10.3 3.9 2.5 18a1.6 1.6 0 0 0 1.4 2.4h16.2a1.6 1.6 0 0 0 1.4-2.4L13.7 3.9a1.6 1.6 0 0 0-3.4 0Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>`,
  phone: `<path d="M15.05 5A5 5 0 0 1 19 9m-4-8a9 9 0 0 1 8 8M4.7 8.4a15.5 15.5 0 0 0 6.9 6.9l2.1-2.1a1.6 1.6 0 0 1 1.7-.4c1 .3 2 .5 3.1.5a1.6 1.6 0 0 1 1.6 1.6V19a1.6 1.6 0 0 1-1.6 1.6A16.6 16.6 0 0 1 2.4 4.6 1.6 1.6 0 0 1 4 3h3.6A1.6 1.6 0 0 1 9.2 4.6c0 1.1.2 2.1.5 3.1a1.6 1.6 0 0 1-.4 1.7Z"/>`,
  mail: `<rect x="2.5" y="4.5" width="19" height="15" rx="2"/><path d="m3 6.5 9 6.5 9-6.5"/>`,
  whatsapp: `<path d="M17.6 14.4c-.3-.1-1.6-.8-1.9-.9-.3-.1-.5-.1-.6.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.2-1.4-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.4.1-.6l.4-.5c.1-.2.2-.3.3-.4.1-.2 0-.4 0-.5-.1-.1-.6-1.5-.8-2-.2-.5-.4-.5-.6-.5h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.3 0 1.4 1 2.7 1.1 2.9.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.6-.7 1.9-1.3.2-.6.2-1.2.2-1.3-.1-.1-.3-.2-.6-.3Z"/><path d="M12 21a9 9 0 1 0-7.8-13.5L3 21l3.6-1.2A9 9 0 0 0 12 21Z"/>`,
  "map-pin": `<path d="M20 10c0 5.5-8 12-8 12s-8-6.5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  "help-circle": `<circle cx="12" cy="12" r="9"/><path d="M9.3 9a2.7 2.7 0 0 1 5.2 1c0 1.8-2.5 2-2.5 3.5"/><path d="M12 17h.01"/>`,
  leaf: `<path d="M11 20A7 7 0 0 1 4 13c0-5 5-11 15-11 0 10-6 15-11 15Z"/><path d="M4 20c3-4 6-6.5 11-11"/>`,
  shield: `<path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z"/>`,
  truck: `<path d="M3 7h11v8H3z"/><path d="M14 11h4l3 3v2h-7z"/><circle cx="7" cy="17" r="1.8"/><circle cx="17.5" cy="17" r="1.8"/>`,
  clock: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>`,
  "chevron-down": `<path d="m6 9 6 6 6-6"/>`,
};

const path = icons[name];
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={path}
/>
