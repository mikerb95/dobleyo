---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-news">
      <div class="label">10% de descuento en tu primera compra</div>
      <div class="input" id="newsletterForm">
        <input
          id="newsletterEmail"
          type="email"
          placeholder="Tu correo electrónico"
          aria-label="Correo electrónico"
        />
        <button class="arrow" id="newsletterBtn" aria-label="Suscribirse">→</button>
      </div>
      <p id="newsletterMsg" style="font-size:0.85rem;margin-top:0.5rem;min-height:1.2em;"></p>
    </div>
    <div class="footer-main">
      <div class="footer-social">
        <img src="/assets/logo.png" alt="DobleYo Café" />
        <a href="#" aria-label="Instagram">Instagram</a>
        <a href="#" aria-label="Facebook">Facebook</a>
      </div>
      <div class="footer-columns">
        <div>
          <h4>Tienda</h4>
          <a href="/tienda" data-link>Cafés</a>
          <a href="#">Accesorios</a>
          <a href="/tienda" data-link>Ver todo</a>
        </div>
        <div>
          <h4>Aprende</h4>
          <a href="/nosotros" data-link>Sobre nosotros</a>
          <a href="/blog" data-link>Blog</a>
          <a href="#">Guías</a>
        </div>
        <div>
          <h4>Soporte</h4>
          <a href="/contacto" data-link>Contáctanos</a>
          <a href="/envios-devoluciones" data-link>Envíos y devoluciones</a>
          <a href="#">Cuenta</a>
        </div>
        <div>
          <h4>Consultas</h4>
          <a href="#">Zona de partners</a>
          <a href="#">Programa de afiliados</a>
          <a href="#">Mayoristas</a>
          <a href="/admin" data-link>Admin Panel</a>
        </div>
      </div>
    </div>

    <div class="footer-legal">
      <div>
        © <span id="year">{year}</span> DobleYo Café. Todos los derechos reservados.
      </div>
      <div style="font-size: 0.85rem; color: #999; margin-top: 0.5rem;">
        Design — <a
          href="https://github.com/mikerb95"
          target="_blank"
          rel="noopener noreferrer"
          style="color: #666; text-decoration: none; hover: color: #333;"
          >mikerb95</a
        >
      </div>
      <!-- Repository: https://github.com/mikerb95/dobleyo/ -->
      <div class="links" style="margin-top: 1rem;">
        <a href="/privacidad" data-link>Política de privacidad</a>
        <a href="/terminos" data-link>Términos y condiciones</a>
        <a href="/accesibilidad" data-link>Accesibilidad</a>
      </div>
    </div>
    <div class="footer-disclaimer">
      Las declaraciones hechas en este sitio no son evaluadas por entidades
      regulatorias. Los productos ofrecidos no están destinados a diagnosticar,
      tratar o curar enfermedades. La información provista no reemplaza una
      consulta con tu profesional de salud y no debe interpretarse como consejo
      médico individual.
    </div>
  </div>
</footer>

<script>
  (function () {
    const btn = document.getElementById('newsletterBtn');
    const input = document.getElementById('newsletterEmail');
    const msg = document.getElementById('newsletterMsg');
    if (!btn || !input || !msg) return;

    async function subscribe() {
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = 'Ingresa un correo válido.';
        msg.style.color = '#d32f2f';
        return;
      }

      btn.disabled = true;
      msg.textContent = 'Enviando...';
      msg.style.color = '#666';

      try {
        const res = await fetch('/api/emails/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });
        const data = await res.json();

        if (res.ok) {
          msg.textContent = '¡Suscrito! Revisa tu correo para el descuento.';
          msg.style.color = '#4a6741';
          input.value = '';
        } else {
          msg.textContent = data.error || 'No se pudo suscribir. Inténtalo de nuevo.';
          msg.style.color = '#d32f2f';
        }
      } catch {
        msg.textContent = 'Error de conexión. Inténtalo de nuevo.';
        msg.style.color = '#d32f2f';
      } finally {
        btn.disabled = false;
      }
    }

    btn.addEventListener('click', subscribe);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') subscribe(); });
  })();
</script>
