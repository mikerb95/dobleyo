---
import type { Lang } from "../i18n/index.ts";

interface Props { lang?: Lang; }
const { lang = "es" } = Astro.props;
const year = new Date().getFullYear();

const isEn = lang === "en";
const tx = isEn
  ? {
      promo: "10% off your first order", emailPh: "Your email address", subscribe: "Subscribe",
      shop: "Shop", learn: "Learn", support: "Support", inquiries: "Inquiries",
      coffees: "Coffees", subscription: "Subscription", accessories: "Accessories", seeAll: "See all",
      about: "About us", blog: "Blog", guides: "Guides",
      contact: "Contact us", shipping: "Shipping & returns", account: "Account",
      partners: "Partner zone", affiliates: "Affiliate program", wholesale: "Wholesale", admin: "Admin Panel",
      rights: "All rights reserved.", privacy: "Privacy Policy", terms: "Terms & Conditions", a11y: "Accessibility",
    }
  : {
      promo: "10% de descuento en tu primera compra", emailPh: "Tu correo electrónico", subscribe: "Suscribirse",
      shop: "Tienda", learn: "Aprende", support: "Soporte", inquiries: "Consultas",
      coffees: "Cafés", subscription: "Suscripción", accessories: "Accesorios", seeAll: "Ver todo",
      about: "Sobre nosotros", blog: "Blog", guides: "Guías",
      contact: "Contáctanos", shipping: "Envíos y devoluciones", account: "Cuenta",
      partners: "Zona de partners", affiliates: "Programa de afiliados", wholesale: "Mayoristas", admin: "Admin Panel",
      rights: "Todos los derechos reservados.", privacy: "Política de privacidad", terms: "Términos y condiciones", a11y: "Accesibilidad",
    };

// Rutas por idioma (en el subdominio en. se reescriben a /en/*).
const r = isEn
  ? { shop: "/shop", subscription: "/wholesale", accessories: "/shop", about: "/about", blog: "/blog", guides: "/guides",
      contact: "/contact", shipping: "/shipping", account: "/account", partners: "/partners", affiliates: "/affiliates",
      privacy: "/privacy", terms: "/terms", a11y: "/accessibility", wholesale: "/wholesale" }
  : { shop: "/tienda", subscription: "/suscripcion", accessories: "/accesorios", about: "/nosotros", blog: "/blog", guides: "/guias",
      contact: "/contacto", shipping: "/envios-devoluciones", account: "/cuenta", partners: "/partners", affiliates: "/afiliados",
      privacy: "/privacidad", terms: "/terminos", a11y: "/accesibilidad", wholesale: "/mayoristas" };
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-news">
      <div class="label">{tx.promo}</div>
      <div class="input" id="newsletterForm">
        <input
          id="newsletterEmail"
          type="email"
          placeholder={tx.emailPh}
          aria-label={tx.emailPh}
        />
        <button class="arrow" id="newsletterBtn" aria-label={tx.subscribe}>→</button>
      </div>
      <p id="newsletterMsg" style="font-size:0.85rem;margin-top:0.5rem;min-height:1.2em;"></p>
    </div>
    <div class="footer-main">
      <div class="footer-social">
        <img src="/assets/logo.png" alt="DobleYo Café" />
        <a href="#" aria-label="Instagram">Instagram</a>
        <a href="#" aria-label="Facebook">Facebook</a>
      </div>
      <div class="footer-columns">
        <div>
          <h4>{tx.shop}</h4>
          <a href={r.shop} data-link>{tx.coffees}</a>
          <a href={r.subscription} data-link>{tx.subscription}</a>
          <a href={r.accessories} data-link>{tx.accessories}</a>
          <a href={r.shop} data-link>{tx.seeAll}</a>
        </div>
        <div>
          <h4>{tx.learn}</h4>
          <a href={r.about} data-link>{tx.about}</a>
          <a href={r.blog} data-link>{tx.blog}</a>
          <a href={r.guides} data-link>{tx.guides}</a>
        </div>
        <div>
          <h4>{tx.support}</h4>
          <a href={r.contact} data-link>{tx.contact}</a>
          <a href={r.shipping} data-link>{tx.shipping}</a>
          <a href={r.account} data-link>{tx.account}</a>
        </div>
        <div>
          <h4>{tx.inquiries}</h4>
          <a href={r.partners} data-link>{tx.partners}</a>
          <a href={r.affiliates} data-link>{tx.affiliates}</a>
          <a href={r.wholesale} data-link>{tx.wholesale}</a>
          <a href="/admin" data-link>{tx.admin}</a>
        </div>
      </div>
    </div>

    <div class="footer-legal">
      <div>
        © <span id="year">{year}</span> DobleYo Café. {tx.rights}
      </div>
      <div style="font-size: 0.85rem; color: #999; margin-top: 0.5rem;">
        Design — <a
          href="https://github.com/mikerb95"
          target="_blank"
          rel="noopener noreferrer"
          style="color: #666; text-decoration: none; hover: color: #333;"
          >mikerb95</a
        >
      </div>
      <!-- Repository: https://github.com/mikerb95/dobleyo/ -->
      <div class="links" style="margin-top: 1rem;">
        <a href={r.privacy} data-link>{tx.privacy}</a>
        <a href={r.terms} data-link>{tx.terms}</a>
        <a href={r.a11y} data-link>{tx.a11y}</a>
      </div>
    </div>
    <div class="footer-disclaimer">
      {isEn
        ? "Statements made on this site have not been evaluated by regulatory agencies. The products offered are not intended to diagnose, treat or cure any disease. The information provided does not replace a consultation with your health professional and should not be interpreted as individual medical advice."
        : "Las declaraciones hechas en este sitio no son evaluadas por entidades regulatorias. Los productos ofrecidos no están destinados a diagnosticar, tratar o curar enfermedades. La información provista no reemplaza una consulta con tu profesional de salud y no debe interpretarse como consejo médico individual."}
    </div>
  </div>
</footer>

<script is:inline src="/assets/js/newsletter-footer.js"></script>
