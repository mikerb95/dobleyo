---
import { Image } from "astro:assets";
import type { Lang } from "../i18n/index.ts";
import LangToggle from "./LangToggle.astro";
import logo from "../assets/logo.png";

interface Props { lang?: Lang; }
const { lang = "es" } = Astro.props;

// Navegación por idioma. En el subdominio en. las rutas planas (/shop, /cart…)
// se reescriben a /en/* vía vercel.json, por eso van sin prefijo /en.
const NAV = {
  es: [
    { href: "/", label: "Inicio" },
    { href: "/tienda", label: "Tienda" },
    { href: "/suscripcion", label: "Suscripción" },
    { href: "/regalos", label: "Regalos" },
    { href: "/blog", label: "Blog" },
    { href: "/trazabilidad", label: "Trazabilidad" },
    { href: "/envios-devoluciones", label: "Envíos" },
  ],
  en: [
    { href: "/", label: "Home" },
    { href: "/shop", label: "Shop" },
    { href: "/wholesale", label: "Wholesale" },
    { href: "/traceability", label: "Traceability" },
    { href: "/contact", label: "Contact" },
  ],
};
const L = {
  es: { cart: "Carrito de compras", cartEmpty: "Tu carrito está vacío", profile: "Perfil",
        apps: "Panel de apps", products: "Productos", audit: "📋 Auditoría",
        logout: "Cerrar sesión", login: "Iniciar sesión", register: "Registrarse",
        account: "Mi Cuenta", menu: "Menú de usuario" },
  en: { cart: "Shopping cart", cartEmpty: "Your cart is empty", profile: "Profile",
        apps: "Apps panel", products: "Products", audit: "📋 Audit",
        logout: "Sign out", login: "Sign in", register: "Sign up",
        account: "My Account", menu: "User menu" },
};
const nav = NAV[lang] ?? NAV.es;
const tx = L[lang] ?? L.es;
const homeHref = "/";
const cartHref = "/cart";
const accountHref = lang === "en" ? "/account" : "/cuenta";
---


<header class="site-header" id="siteHeader" transition:persist={`header-${lang}`} data-lang={lang} data-cart-empty={tx.cartEmpty} data-account-href={accountHref} data-menu-label={tx.menu}>
  <div class="container">
    <div class="nav-beans" aria-hidden="true"></div>
    <a class="brand" href={homeHref}>
      <Image src={logo} alt="DobleYo" height={80} width={80} loading="eager" />
    </a>
    <nav class="nav">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="actions">
      <LangToggle lang={lang} />
      <div class="cart-preview-wrap" id="cartPreviewWrap">
        <a href={cartHref} class="icon-btn" aria-label={tx.cart}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6zm0 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M3 6h18M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="badge" id="cartCount">0</span>
        </a>
        <div class="cart-preview" id="cartPreview" role="tooltip" aria-live="polite">
          <div class="cart-preview-inner" id="cartPreviewInner">
            <p class="cart-preview-empty">{tx.cartEmpty}</p>
          </div>
        </div>
      </div>
      <div class="user-dropdown" id="userDropdown">
        <button
          class="icon-btn user-btn"
          aria-label={tx.menu}
          aria-haspopup="true"
          aria-expanded="false"
          id="userNavBtn"
        >
          <span
            id="userNameDisplay"
            style="display: none; margin-right: 0.5rem; font-size: 0.9rem; font-weight: 500;"
          ></span>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            ><path
              d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5zm0 2c-4.418 0-8 2.239-8 5v1h16v-1c0-2.761-3.582-5-8-5z"
              fill="currentColor"></path></svg
          >
        </button>
        <div class="dropdown-menu" id="userDropdownMenu">
          <!-- Opciones autenticado -->
          <div id="authenticatedMenu" style="display: none;">
            <a href={accountHref} class="dropdown-item">{tx.profile}</a>
            <a
              href="/admin"
              class="dropdown-item"
              id="appsLink"
              style="display: none;">{tx.apps}</a
            >
            <a
              href="/admin/productos"
              class="dropdown-item"
              id="productosLink"
              style="display: none;">{tx.products}</a
            >
            <a
              href="/admin/auditoria"
              class="dropdown-item"
              id="auditLink"
              style="display: none;">{tx.audit}</a
            >
            <button class="dropdown-item" id="logoutBtn">{tx.logout}</button>
          </div>
          <!-- Opciones no autenticado -->
          <div
            id="unauthenticatedMenu"
            style="display: flex; flex-direction: column;"
          >
            <button class="dropdown-item" id="openLoginModal">{tx.login}</button>
            <button class="dropdown-item" id="openRegisterModal">{tx.register}</button>
          </div>
        </div>
      </div>
      <button id="menuBtn" class="hamburger" aria-label={tx.menu} aria-expanded="false" aria-controls="mobileMenu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu" hidden>
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}

    <div class="mobile-lang" style="padding:0.75rem 0;"><LangToggle lang={lang} /></div>

    <!-- Opciones autenticado en móvil -->
    <div id="mobileAuthenticatedMenu" style="display: none;">
      <a href={accountHref} class="user-btn">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          ><path
            d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5zm0 2c-4.418 0-8 2.239-8 5v1h16v-1c0-2.761-3.582-5-8-5z"
            fill="currentColor"></path></svg
        >
        <span id="userNameMobileDisplay" style="display: none;"></span>
        <span id="userMobileLabel">{tx.account}</span>
      </a>
    </div>

    <!-- Opciones no autenticado en móvil -->
    <div
      id="mobileUnauthenticatedMenu"
      style="display: flex; flex-direction: column;"
    >
      <button class="user-btn" id="mobileOpenLoginModal">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          ><path
            d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5zm0 2c-4.418 0-8 2.239-8 5v1h16v-1c0-2.761-3.582-5-8-5z"
            fill="currentColor"></path></svg
        >
        <span>{tx.login}</span>
      </button>
      <button class="user-btn" id="mobileOpenRegisterModal">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          ><path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2m0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8m3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5m-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11m3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
            fill="currentColor"></path></svg
        >
        <span>{tx.register}</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Lógica del Header (granos, menú, auth, dropdown, cart preview).
  // El <header> se persiste entre navegaciones (transition:persist), así que
  // los bindings sobreviven. Este init es idempotente y se re-ejecuta en
  // astro:page-load para el único caso en que el header se re-renderiza:
  // el cambio de idioma ES↔EN (nombres de persistencia distintos).
  function initHeader() {
  const headerRoot = document.getElementById("siteHeader");
  if (!headerRoot || headerRoot.dataset.jsInit) return;
  headerRoot.dataset.jsInit = "1";

  (function initNavBeans() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const header = document.querySelector(".site-header");
    const layer = document.querySelector(".nav-beans");
    if (!header || !layer) return;
    const beanSrc = "/assets/branding/coffebeannav.png"; // Ruta absoluta desde public
    const beans = [];
    const COUNT = 68;
    for (let i = 0; i < COUNT; i++) {
      const img = document.createElement("img");
      img.className = "bean";
      img.src = beanSrc;
      const xPct = 4 + Math.random() * 92;
      const yPct = 8 + Math.random() * 84;
      const rot = -40 + Math.random() * 80;
      const scale = 0.8 + Math.random() * 0.6;
      const size = 16 + Math.random() * 16 + (Math.random() < 0.15 ? 8 : 0);
      img.style.left = xPct + "%";
      img.style.top = yPct + "%";
      img.style.setProperty("--rot", rot + "deg");
      img.style.setProperty("--s", scale.toString());
      img.style.setProperty("--bean-size", size + "px");
      // @ts-ignore
      img._xPct = xPct / 100;
      // @ts-ignore
      img._yPct = yPct / 100;
      // @ts-ignore
      img._rand = Math.random();
      layer.appendChild(img);
      beans.push(img);
    }

    const pointer = { x: 0, y: 0, active: false };
    let rafId = 0;
    function animate() {
      if (pointer.active) {
        const rect = layer.getBoundingClientRect();
        const cx = pointer.x - rect.left;
        const cy = pointer.y - rect.top;
        for (const b of beans) {
          // @ts-ignore
          const bx = (b._xPct || 0.5) * rect.width;
          // @ts-ignore
          const by = (b._yPct || 0.5) * rect.height;
          const dx0 = bx - cx;
          const dy0 = by - cy;
          const d = Math.hypot(dx0, dy0) || 0.0001;
          const radius = 140;
          // @ts-ignore
          const strength = 26 + (b._rand || 0) * 22;
          const falloff = Math.max(0, radius - d) / radius;
          const repel = falloff * strength;
          const nx = dx0 / d;
          const ny = dy0 / d;
          const dx = nx * repel;
          const dy = ny * repel;
          b.style.setProperty("--dx", dx.toFixed(2) + "px");
          b.style.setProperty("--dy", dy.toFixed(2) + "px");
        }
      }
      rafId = requestAnimationFrame(animate);
    }
    rafId = requestAnimationFrame(animate);

    header.addEventListener("mouseenter", () => {
      pointer.active = true;
      header.classList.add("beans-active");
    });
    header.addEventListener("mousemove", (e) => {
      pointer.x = e.clientX;
      pointer.y = e.clientY;
    });
    header.addEventListener("mouseleave", () => {
      pointer.active = false;
      header.classList.remove("beans-active");
      beans.forEach((b) => {
        b.style.setProperty("--dx", "0px");
        b.style.setProperty("--dy", "0px");
      });
    });
  })();

  // Menu movil
  const menuBtn = document.getElementById("menuBtn");
  const mobileMenu = document.getElementById("mobileMenu");

  if (menuBtn && mobileMenu) {
    // Toggle del menú
    menuBtn.addEventListener("click", () => {
      const hidden = mobileMenu.hasAttribute("hidden");
      if (hidden) {
        mobileMenu.removeAttribute("hidden");
        menuBtn.classList.add("active");
        menuBtn.setAttribute("aria-expanded", "true");
        document.body.classList.add("menu-open");
      } else {
        mobileMenu.setAttribute("hidden", "");
        menuBtn.classList.remove("active");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.classList.remove("menu-open");
      }
    });

    // Cerrar menú al hacer click en un enlace
    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.setAttribute("hidden", "");
        menuBtn.classList.remove("active");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.classList.remove("menu-open");
      });
    });

    // Cerrar menú al hacer click fuera
    document.addEventListener("click", (e) => {
      if (!menuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
        const hidden = mobileMenu.hasAttribute("hidden");
        if (!hidden) {
          mobileMenu.setAttribute("hidden", "");
          menuBtn.classList.remove("active");
          menuBtn.setAttribute("aria-expanded", "false");
          document.body.classList.remove("menu-open");
        }
      }
    });
  }

  // Verificar sesión y actualizar botón de usuario
  (async function checkAuthStatus() {
    const userBtn = document.getElementById("userNavBtn");
    const userNameDisplay = document.getElementById("userNameDisplay");
    const userMobileLabel = document.getElementById("userMobileLabel");
    const appsLink = document.getElementById("appsLink");
    const productosLink = document.getElementById("productosLink");
    const auditLink = document.getElementById("auditLink");
    const logoutBtn = document.getElementById("logoutBtn");

    // Elementos del dropdown y menú móvil
    const authenticatedMenu = document.getElementById("authenticatedMenu");
    const unauthenticatedMenu = document.getElementById("unauthenticatedMenu");
    const mobileAuthenticatedMenu = document.getElementById(
      "mobileAuthenticatedMenu"
    );
    const mobileUnauthenticatedMenu = document.getElementById(
      "mobileUnauthenticatedMenu"
    );

    try {
      const res = await fetch("/api/auth/me", {
        credentials: "include",
      });

      if (res.ok) {
        const user = await res.json();
        // Usuario logueado - mostrar menú autenticado
        const firstName = user.first_name || "Usuario";

        if (userNameDisplay) {
          userNameDisplay.textContent = firstName;
          userNameDisplay.style.display = "inline";
        }
        if (userMobileLabel) {
          userMobileLabel.textContent = firstName;
        }
        if (userBtn) {
          const header = document.getElementById("siteHeader");
          userBtn.href = header?.dataset.accountHref ?? "/cuenta";
          userBtn.setAttribute("aria-label", `${firstName}`);
          userBtn.dataset.auth = "true";
        }

        // Mostrar opciones de autenticado, ocultar no autenticado
        if (authenticatedMenu) authenticatedMenu.style.display = "block";
        if (unauthenticatedMenu) unauthenticatedMenu.style.display = "none";
        if (mobileAuthenticatedMenu)
          mobileAuthenticatedMenu.style.display = "flex";
        if (mobileUnauthenticatedMenu)
          mobileUnauthenticatedMenu.style.display = "none";

        // Mostrar opciones admin
        if (appsLink && user.role === "admin") {
          appsLink.style.display = "block";
        }
        if (productosLink && user.role === "admin") {
          productosLink.style.display = "block";
        }
        if (auditLink && user.role === "admin") {
          auditLink.style.display = "block";
        }

      } else if (res.status === 401) {
        // No autenticado - mostrar menú de login/registro

        if (authenticatedMenu) authenticatedMenu.style.display = "none";
        if (unauthenticatedMenu) unauthenticatedMenu.style.display = "flex";
        if (mobileAuthenticatedMenu)
          mobileAuthenticatedMenu.style.display = "none";
        if (mobileUnauthenticatedMenu)
          mobileUnauthenticatedMenu.style.display = "flex";

        if (userBtn) {
          const header = document.getElementById("siteHeader");
          userBtn.setAttribute("aria-label", header?.dataset.menuLabel ?? "User menu");
        }
      } else {
        // Error del servidor — mostrar menú no autenticado
        console.warn("[Header] Error del servidor en /api/auth/me:", res.status);
        if (authenticatedMenu) authenticatedMenu.style.display = "none";
        if (unauthenticatedMenu) unauthenticatedMenu.style.display = "flex";
        if (mobileAuthenticatedMenu) mobileAuthenticatedMenu.style.display = "none";
        if (mobileUnauthenticatedMenu) mobileUnauthenticatedMenu.style.display = "flex";
      }
    } catch (err) {
      console.error("[Header] Error checking auth status:", err);
      if (authenticatedMenu) authenticatedMenu.style.display = "none";
      if (unauthenticatedMenu) unauthenticatedMenu.style.display = "flex";
      if (mobileAuthenticatedMenu) mobileAuthenticatedMenu.style.display = "none";
      if (mobileUnauthenticatedMenu) mobileUnauthenticatedMenu.style.display = "flex";
    }

    // Logout
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          const response = await fetch("/api/auth/logout", {
            method: "POST",
            credentials: "include",
          });

          if (response.ok) {
            window.location.href = "/login";
          }
        } catch (err) {
          console.error("Error al cerrar sesión:", err);
        }
      });
    }
  })();

  // Botones de auth modal (desktop dropdown)
  document.getElementById('openLoginModal')?.addEventListener('click', () => {
    document.getElementById('userDropdown')?.classList.remove('active');
    window.AuthModal?.open('login');
  });
  document.getElementById('openRegisterModal')?.addEventListener('click', () => {
    document.getElementById('userDropdown')?.classList.remove('active');
    window.AuthModal?.open('register');
  });

  // Botones de auth modal (menú móvil)
  document.getElementById('mobileOpenLoginModal')?.addEventListener('click', () => {
    const mobileMenu = document.getElementById('mobileMenu');
    const menuBtn = document.getElementById('menuBtn');
    if (mobileMenu) mobileMenu.setAttribute('hidden', '');
    if (menuBtn) { menuBtn.classList.remove('active'); }
    document.body.classList.remove('menu-open');
    window.AuthModal?.open('login');
  });
  document.getElementById('mobileOpenRegisterModal')?.addEventListener('click', () => {
    const mobileMenu = document.getElementById('mobileMenu');
    const menuBtn = document.getElementById('menuBtn');
    if (mobileMenu) mobileMenu.setAttribute('hidden', '');
    if (menuBtn) { menuBtn.classList.remove('active'); }
    document.body.classList.remove('menu-open');
    window.AuthModal?.open('register');
  });

  // Dropdown menu logic
  (function initUserDropdown() {
    const userDropdown = document.getElementById("userDropdown");
    const userBtn = document.getElementById("userNavBtn");
    const dropdownMenu = document.getElementById("userDropdownMenu");
    const logoutBtn = document.getElementById("logoutBtn");

    if (!userBtn || !userDropdown || !dropdownMenu) return;

    // Función para posicionar el dropdown
    function positionDropdown() {
      const rect = userBtn.getBoundingClientRect();
      dropdownMenu.style.top = rect.bottom + 8 + "px";
      dropdownMenu.style.right = window.innerWidth - rect.right + "px";
    }

    // Toggle dropdown al hacer click en el botón
    // Si no está autenticado, abre la modal directamente
    userBtn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (userBtn.dataset.auth !== "true") {
        window.AuthModal?.open("login");
        return;
      }
      userDropdown.classList.toggle("active");
      userBtn.setAttribute(
        "aria-expanded",
        userDropdown.classList.contains("active")
      );
      if (userDropdown.classList.contains("active")) {
        positionDropdown();
      }
    });

    // Cerrar dropdown al hacer click en un item
    dropdownMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        userDropdown.classList.remove("active");
        userBtn.setAttribute("aria-expanded", "false");
      });
    });

    // Logout
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          const response = await fetch("/api/auth/logout", {
            method: "POST",
            credentials: "include",
          });

          if (response.ok) {
            window.location.href = "/login";
          }
        } catch (err) {
          console.error("Error al cerrar sesión:", err);
        }
      });
    }

    // Cerrar dropdown al hacer clic fuera
    document.addEventListener("click", (e) => {
      if (!userDropdown.contains(e.target)) {
        userDropdown.classList.remove("active");
        userBtn.setAttribute("aria-expanded", "false");
      }
    });
  })();

  // Establecer altura dinámica del header para usar en CSS
  (function setHeaderHeight() {
    const header = document.querySelector(".site-header");
    if (!header) return;

    function updateHeaderHeight() {
      const height = header.offsetHeight;
      document.documentElement.style.setProperty(
        "--header-height",
        height + "px"
      );
    }

    // Ejecutar al cargar
    updateHeaderHeight();

    // Actualizar cuando se redimensiona la ventana
    window.addEventListener("resize", updateHeaderHeight);
  })();

  // Cart preview hover
  (function initCartPreview() {
    const wrap = document.getElementById("cartPreviewWrap");
    const preview = document.getElementById("cartPreview");
    const inner = document.getElementById("cartPreviewInner");
    if (!wrap || !preview || !inner) return;

    function positionPreview() {
      const rect = wrap.getBoundingClientRect();
      preview.style.top = (rect.bottom + 8) + "px";
      preview.style.right = (window.innerWidth - rect.right) + "px";
    }

    const headerEl = document.getElementById('siteHeader');
    const lang = headerEl?.dataset.lang === 'en' ? 'en' : 'es';
    const emptyMsg = headerEl?.dataset.cartEmpty || 'Tu carrito está vacío';
    const locale = lang === 'en' ? 'en-US' : 'es-CO';
    const currency = lang === 'en' ? 'USD' : 'COP';

    function renderPreview() {
      const cart = window.Cart ? window.Cart.getCart() : [];
      if (cart.length === 0) {
        inner.innerHTML = '<p class="cart-preview-empty">' + emptyMsg + '</p>';
        return;
      }
      const fmt = (n) => new Intl.NumberFormat(locale, { style: 'currency', currency, maximumFractionDigits: 0 }).format(Number(n));
      const items = cart.slice(0, 4).map(item => `
        <div class="cart-preview-item">
          <img src="${item.image || '/assets/logo.png'}" alt="" width="20" height="20" loading="lazy" style="width:20px;height:20px;min-width:20px;flex-shrink:0">
          <span class="cart-preview-item-name">${item.name}<span class="cart-preview-item-qty"> × ${item.qty || 1}</span></span>
          <span class="cart-preview-item-price">${fmt((item.price || 0) * (item.qty || 1))}</span>
        </div>`).join('');
      const moreLbl = lang === 'en' ? 'more' : 'más';
      const extra = cart.length > 4 ? `<p class="cart-preview-empty">+${cart.length - 4} ${moreLbl}</p>` : '';
      const subtotal = window.Cart.subtotal();
      inner.innerHTML = items + extra + `
        <div style="border-top:1px solid var(--border);margin-top:0.4rem;padding-top:0.5rem;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:0.75rem;color:var(--muted-fg)">Subtotal</span>
          <span style="font-size:0.85rem;font-weight:700;color:var(--coffee)">${fmt(subtotal)}</span>
        </div>`;
    }

    wrap.addEventListener("mouseenter", () => {
      positionPreview();
      renderPreview();
    });

    window.addEventListener("resize", () => {
      if (preview.style.opacity === '1' || wrap.matches(':hover')) positionPreview();
    });
  })();
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
