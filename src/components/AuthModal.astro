---
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
---

<!-- ===== AUTH MODAL ===== -->
<div
  id="authModalOverlay"
  class="auth-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="authModalTitle"
>
  <div class="auth-modal" id="authModal" tabindex="-1">

    <!-- Botón cerrar -->
    <button class="auth-close" id="authModalClose" aria-label="Cerrar sesión modal">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Logo / branding -->
    <div class="auth-brand">
      <img src="/assets/logo.png" alt="DobleYo" height="44" />
    </div>

    <!-- Tabs -->
    <div class="auth-tabs" role="tablist">
      <button
        class="auth-tab active"
        id="tabLogin"
        role="tab"
        aria-selected="true"
        aria-controls="panelLogin"
        data-tab="login"
      >Iniciar sesión</button>
      <button
        class="auth-tab"
        id="tabRegister"
        role="tab"
        aria-selected="false"
        aria-controls="panelRegister"
        data-tab="register"
      >Crear cuenta</button>
    </div>

    <!-- ===== PANEL LOGIN ===== -->
    <div id="panelLogin" class="auth-panel" role="tabpanel" aria-labelledby="tabLogin">

      <!-- Google Sign-In (siempre visible; el JS lo activa si el SDK carga) -->
      <div id="googleBtnWrap" class="google-btn-wrap">
        <!-- Contenedor del widget oficial GSI (se inyecta cuando el SDK carga) -->
        {googleClientId && (
          <div
            id="g_id_onload"
            data-client_id={googleClientId}
            data-callback="handleGoogleCredential"
            data-auto_prompt="false"
          ></div>
        )}
        <!-- Botón personalizado de Google (fallback siempre visible) -->
        <button type="button" id="googleSignInBtn" class="google-custom-btn">
          <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          </svg>
          <span>Continuar con Google</span>
        </button>
      </div>
      <div class="auth-divider"><span>o continúa con tu correo</span></div>

      <form id="loginForm" class="auth-form" novalidate>

        <!-- Email -->
        <div class="field-group">
          <label for="loginEmail" class="field-label">Correo electrónico</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 2l-8 5-8-5h16zm0 12H4V9l8 5 8-5v9z" fill="currentColor"/>
            </svg>
            <input
              id="loginEmail"
              type="email"
              placeholder="tu@correo.com"
              autocomplete="email"
              inputmode="email"
              class="field-input"
            />
          </div>
          <span class="field-error" id="loginEmailError"></span>
        </div>

        <!-- Contraseña -->
        <div class="field-group">
          <div class="field-label-row">
            <label for="loginPass" class="field-label">Contraseña</label>
            <a href="/recuperar-contrasena" class="forgot-link" id="forgotPassLink">¿Olvidaste tu contraseña?</a>
          </div>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 1a6 6 0 00-6 6v1H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V10a2 2 0 00-2-2h-2V7a6 6 0 00-6-6zm0 2a4 4 0 014 4v1H8V7a4 4 0 014-4zm0 9a2 2 0 110 4 2 2 0 010-4z" fill="currentColor"/>
            </svg>
            <input
              id="loginPass"
              type="password"
              placeholder="••••••••"
              autocomplete="current-password"
              class="field-input has-toggle"
            />
            <button type="button" class="pass-toggle" data-target="loginPass" aria-label="Mostrar contraseña" tabindex="-1">
              <svg class="eye-icon eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
              <svg class="eye-icon eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <span class="field-error" id="loginPassError"></span>
        </div>

        <!-- Recordar sesión -->
        <label class="check-label">
          <input type="checkbox" id="loginRemember" class="check-input" />
          <span class="check-box"></span>
          <span>Recordar mi sesión</span>
        </label>

        <!-- Error general -->
        <div id="loginError" class="form-alert form-alert--error" aria-live="polite"></div>

        <button type="submit" id="loginBtn" class="auth-btn">
          <span>Entrar</span>
          <svg class="btn-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4" stroke-dashoffset="10"/>
          </svg>
        </button>

      </form>
    </div>

    <!-- ===== PANEL REGISTRO ===== -->
    <div id="panelRegister" class="auth-panel" role="tabpanel" aria-labelledby="tabRegister" hidden>
      <form id="registerForm" class="auth-form" novalidate>

        <!-- Nombre y Apellido -->
        <div class="field-row">
          <div class="field-group">
            <label for="regFirstName" class="field-label">Nombre</label>
            <div class="input-wrap">
              <input id="regFirstName" type="text" placeholder="Tu nombre" autocomplete="given-name" class="field-input" />
            </div>
            <span class="field-error" id="regFirstNameError"></span>
          </div>
          <div class="field-group">
            <label for="regLastName" class="field-label">Apellido</label>
            <div class="input-wrap">
              <input id="regLastName" type="text" placeholder="Tu apellido" autocomplete="family-name" class="field-input" />
            </div>
            <span class="field-error" id="regLastNameError"></span>
          </div>
        </div>

        <!-- Email -->
        <div class="field-group">
          <label for="regEmail" class="field-label">Correo electrónico</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 2l-8 5-8-5h16zm0 12H4V9l8 5 8-5v9z" fill="currentColor"/>
            </svg>
            <input id="regEmail" type="email" placeholder="tu@correo.com" autocomplete="email" inputmode="email" class="field-input" />
          </div>
          <span class="field-error" id="regEmailError"></span>
        </div>

        <!-- Contraseña -->
        <div class="field-group">
          <label for="regPass" class="field-label">Contraseña</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 1a6 6 0 00-6 6v1H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V10a2 2 0 00-2-2h-2V7a6 6 0 00-6-6zm0 2a4 4 0 014 4v1H8V7a4 4 0 014-4zm0 9a2 2 0 110 4 2 2 0 010-4z" fill="currentColor"/>
            </svg>
            <input id="regPass" type="password" placeholder="Mínimo 8 caracteres" autocomplete="new-password" class="field-input has-toggle" />
            <button type="button" class="pass-toggle" data-target="regPass" aria-label="Mostrar contraseña" tabindex="-1">
              <svg class="eye-icon eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
              <svg class="eye-icon eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <!-- Indicador de fortaleza -->
          <div class="pass-strength" id="passStrengthWrap" aria-live="polite">
            <div class="strength-bars">
              <span class="strength-bar" id="sb1"></span>
              <span class="strength-bar" id="sb2"></span>
              <span class="strength-bar" id="sb3"></span>
              <span class="strength-bar" id="sb4"></span>
            </div>
            <span class="strength-label" id="strengthLabel"></span>
          </div>
          <span class="field-error" id="regPassError"></span>
        </div>

        <!-- Confirmar contraseña -->
        <div class="field-group">
          <label for="regPassConfirm" class="field-label">Confirmar contraseña</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 1a6 6 0 00-6 6v1H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V10a2 2 0 00-2-2h-2V7a6 6 0 00-6-6zm0 2a4 4 0 014 4v1H8V7a4 4 0 014-4zm0 9a2 2 0 110 4 2 2 0 010-4z" fill="currentColor"/>
            </svg>
            <input id="regPassConfirm" type="password" placeholder="Repite tu contraseña" autocomplete="new-password" class="field-input has-toggle" />
            <button type="button" class="pass-toggle" data-target="regPassConfirm" aria-label="Mostrar contraseña" tabindex="-1">
              <svg class="eye-icon eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
              <svg class="eye-icon eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <span class="field-error" id="regPassConfirmError"></span>
        </div>

        <!-- Consentimiento de datos — Ley 1581/2012 -->
        <label class="check-label check-label--small">
          <input type="checkbox" id="regDataConsent" class="check-input" />
          <span class="check-box"></span>
          <span>
            He leído y acepto la
            <a href="/privacidad" target="_blank" rel="noopener" class="auth-link">Política de Privacidad</a>
            y autorizo el tratamiento de mis datos personales conforme a la <strong>Ley 1581 de 2012</strong>.
          </span>
        </label>
        <span class="field-error" id="regConsentError"></span>

        <!-- Error general -->
        <div id="regError" class="form-alert form-alert--error" aria-live="polite"></div>
        <div id="regSuccess" class="form-alert form-alert--success" aria-live="polite"></div>

        <button type="submit" id="regBtn" class="auth-btn">
          <span>Crear cuenta</span>
          <svg class="btn-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4" stroke-dashoffset="10"/>
          </svg>
        </button>

      </form>
    </div>

  </div>
</div>

{googleClientId && <script src="https://accounts.google.com/gsi/client" async defer></script>}

<script is:inline define:vars={{ googleClientId }}>
(function () {
  // ── Constantes ──────────────────────────────────────────────────────────────
  const REGEX = {
    email:    /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/,
    name:     /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s'\-]{2,}$/,
    password: /^.{8,}$/,
  };

  // ── Referencias DOM ──────────────────────────────────────────────────────────
  const overlay  = document.getElementById('authModalOverlay');
  const modal    = document.getElementById('authModal');
  const closeBtn = document.getElementById('authModalClose');
  const tabLogin    = document.getElementById('tabLogin');
  const tabRegister = document.getElementById('tabRegister');
  const panelLogin  = document.getElementById('panelLogin');
  const panelRegister = document.getElementById('panelRegister');

  if (!overlay || !modal) return;

  // ── Apertura / cierre ────────────────────────────────────────────────────────
  function openModal(tab = 'login') {
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    document.body.classList.add('modal-open');
    switchTab(tab);
    // Foco accesible
    setTimeout(() => {
      const firstInput = modal.querySelector('input');
      if (firstInput) firstInput.focus();
    }, 200);
    // Pre-rellenar email si hay uno guardado
    const saved = localStorage.getItem('dy_remember_email');
    if (saved) {
      const loginEmail = document.getElementById('loginEmail');
      const loginRemember = document.getElementById('loginRemember');
      if (loginEmail) loginEmail.value = saved;
      if (loginRemember) loginRemember.checked = true;
    }
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    document.body.classList.remove('modal-open');
    setTimeout(() => {
      overlay.setAttribute('aria-hidden', 'true');
    }, 280);
  }

  // ── Tabs ─────────────────────────────────────────────────────────────────────
  function switchTab(tab) {
    const isLogin = tab === 'login';
    tabLogin.classList.toggle('active', isLogin);
    tabRegister.classList.toggle('active', !isLogin);
    tabLogin.setAttribute('aria-selected', String(isLogin));
    tabRegister.setAttribute('aria-selected', String(!isLogin));
    if (isLogin) {
      panelLogin.removeAttribute('hidden');
      panelRegister.setAttribute('hidden', '');
    } else {
      panelRegister.removeAttribute('hidden');
      panelLogin.setAttribute('hidden', '');
    }
    clearAllErrors();
  }

  tabLogin.addEventListener('click', () => switchTab('login'));
  tabRegister.addEventListener('click', () => switchTab('register'));

  // ── Cierre ───────────────────────────────────────────────────────────────────
  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });

  // ── API pública ───────────────────────────────────────────────────────────────
  window.AuthModal = { open: openModal, close: closeModal };

  // ── Toggle contraseña ─────────────────────────────────────────────────────────
  document.querySelectorAll('.pass-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target);
      if (!target) return;
      const isPass = target.type === 'password';
      target.type = isPass ? 'text' : 'password';
      btn.querySelector('.eye-show').style.display = isPass ? 'none' : '';
      btn.querySelector('.eye-hide').style.display = isPass ? ''     : 'none';
      btn.setAttribute('aria-label', isPass ? 'Ocultar contraseña' : 'Mostrar contraseña');
    });
  });

  // ── Helpers de validación ─────────────────────────────────────────────────────
  function setError(id, msg) {
    const el = document.getElementById(id);
    if (!el) return false;
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
    const input = el.closest('.field-group')?.querySelector('.field-input');
    if (input) input.classList.toggle('is-invalid', !!msg);
    return !!msg;
  }

  function clearAllErrors() {
    document.querySelectorAll('.field-error').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });
    document.querySelectorAll('.field-input').forEach(el => el.classList.remove('is-invalid'));
    const alerts = ['loginError','regError','regSuccess'];
    alerts.forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.textContent = ''; el.style.display = 'none'; }
    });
  }

  function showAlert(id, msg, isError = true) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.style.display = msg ? 'flex' : 'none';
  }

  function setLoading(btn, spinner, loading) {
    btn.disabled = loading;
    btn.querySelector('span').style.opacity = loading ? '0' : '1';
    spinner.style.display = loading ? 'block' : 'none';
  }

  // ── Indicador de fortaleza de contraseña ──────────────────────────────────────
  const regPassInput = document.getElementById('regPass');
  if (regPassInput) {
    regPassInput.addEventListener('input', () => {
      const v = regPassInput.value;
      let score = 0;
      if (v.length >= 8)  score++;
      if (/[A-Z]/.test(v)) score++;
      if (/\d/.test(v))   score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;

      const bars = ['sb1','sb2','sb3','sb4'];
      const colors = ['','#ef4444','#f97316','#eab308','#22c55e'];
      const labels = ['','Muy débil','Débil','Buena','Fuerte'];
      bars.forEach((id, i) => {
        const bar = document.getElementById(id);
        if (bar) {
          bar.style.background = i < score ? colors[score] : 'var(--border)';
        }
      });
      const lbl = document.getElementById('strengthLabel');
      if (lbl) {
        lbl.textContent = v.length > 0 ? labels[score] : '';
        lbl.style.color = colors[score];
      }
    });
  }

  // ── Validación LOGIN ──────────────────────────────────────────────────────────
  function validateLogin() {
    const email    = (document.getElementById('loginEmail')?.value || '').trim();
    const password = document.getElementById('loginPass')?.value || '';
    let ok = true;

    if (!REGEX.email.test(email)) {
      ok = setError('loginEmailError', 'Ingresa un correo válido.') ? false : ok;
    } else {
      setError('loginEmailError', '');
    }

    if (!REGEX.password.test(password)) {
      ok = setError('loginPassError', 'Mínimo 8 caracteres.') ? false : ok;
    } else {
      setError('loginPassError', '');
    }

    return ok;
  }

  // ── Validación REGISTRO ────────────────────────────────────────────────────────
  function validateRegister() {
    const firstName   = (document.getElementById('regFirstName')?.value || '').trim();
    const lastName    = (document.getElementById('regLastName')?.value || '').trim();
    const email       = (document.getElementById('regEmail')?.value || '').trim();
    const password    = document.getElementById('regPass')?.value || '';
    const passConfirm = document.getElementById('regPassConfirm')?.value || '';
    const consent     = document.getElementById('regDataConsent')?.checked;
    let ok = true;

    if (!REGEX.name.test(firstName)) {
      if (setError('regFirstNameError', 'Nombre inválido (solo letras, mínimo 2).')) ok = false;
    } else { setError('regFirstNameError', ''); }

    if (!REGEX.name.test(lastName)) {
      if (setError('regLastNameError', 'Apellido inválido (solo letras, mínimo 2).')) ok = false;
    } else { setError('regLastNameError', ''); }

    if (!REGEX.email.test(email)) {
      if (setError('regEmailError', 'Ingresa un correo válido.')) ok = false;
    } else { setError('regEmailError', ''); }

    if (!REGEX.password.test(password)) {
      if (setError('regPassError', 'Mínimo 8 caracteres.')) ok = false;
    } else { setError('regPassError', ''); }

    if (password !== passConfirm) {
      if (setError('regPassConfirmError', 'Las contraseñas no coinciden.')) ok = false;
    } else { setError('regPassConfirmError', ''); }

    if (!consent) {
      if (setError('regConsentError', 'Debes aceptar la política de privacidad.')) ok = false;
    } else { setError('regConsentError', ''); }

    return ok;
  }

  // ── Redirect post-login ───────────────────────────────────────────────────────
  function redirectAfterLogin(role) {
    const urlParams = new URLSearchParams(window.location.search);
    const redirect = urlParams.get('redirect');
    if (redirect) {
      if (redirect.startsWith('/app')) {
        if (role === 'caficultor' || role === 'admin') {
          window.location.href = redirect;
        } else {
          showAlert('loginError', 'No tienes permisos para acceder a esa sección.');
        }
      } else if (redirect.startsWith('/admin') || redirect.includes('admin.html')) {
        if (role === 'admin') {
          window.location.href = redirect;
        } else {
          showAlert('loginError', 'Solo administradores pueden acceder a esa sección.');
        }
      } else {
        window.location.href = redirect;
      }
    } else {
      if (role === 'admin' || role === 'caficultor') {
        window.location.href = '/app';
      } else {
        window.location.href = '/cuenta';
      }
    }
  }

  // ── Google Sign-In ─────────────────────────────────────────────────────────────
  if (googleClientId) {
    window.handleGoogleCredential = async function (response) {
      showAlert('loginError', '');
      try {
        const res = await fetch('/api/auth/google', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential: response.credential }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error al iniciar sesión con Google');
        redirectAfterLogin(data.user?.role);
      } catch (e) {
        showAlert('loginError', e.message);
      }
    };
  }

  // ── Submit LOGIN ───────────────────────────────────────────────────────────────
  const loginForm = document.getElementById('loginForm');
  if (loginForm) {
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      showAlert('loginError', '');
      if (!validateLogin()) return;

      const email    = (document.getElementById('loginEmail').value || '').trim();
      const password = document.getElementById('loginPass').value || '';
      const remember = document.getElementById('loginRemember')?.checked;
      const btn     = document.getElementById('loginBtn');
      const spinner = btn.querySelector('.btn-spinner');

      setLoading(btn, spinner, true);

      // Guardar email si "recordar sesión" está activo
      if (remember) {
        localStorage.setItem('dy_remember_email', email);
      } else {
        localStorage.removeItem('dy_remember_email');
      }

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error al iniciar sesión');
        if (data.user?.devUser === true) { window.location.href = '/admin'; return; }
        redirectAfterLogin(data.user?.role);
      } catch (err) {
        showAlert('loginError', err.message);
        setLoading(btn, spinner, false);
      }
    });
  }

  // ── Submit REGISTRO ────────────────────────────────────────────────────────────
  const registerForm = document.getElementById('registerForm');
  if (registerForm) {
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      showAlert('regError', '');
      showAlert('regSuccess', '');
      if (!validateRegister()) return;

      const firstName   = (document.getElementById('regFirstName').value || '').trim();
      const lastName    = (document.getElementById('regLastName').value || '').trim();
      const email       = (document.getElementById('regEmail').value || '').trim();
      const password    = document.getElementById('regPass').value || '';
      const btn     = document.getElementById('regBtn');
      const spinner = btn.querySelector('.btn-spinner');

      setLoading(btn, spinner, true);

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ first_name: firstName, last_name: lastName, email, password }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || data.message || 'Error al registrar');
        showAlert('regSuccess', '✓ Cuenta creada. Revisa tu correo para verificar.');
        setTimeout(() => { closeModal(); }, 2500);
      } catch (err) {
        showAlert('regError', err.message);
        setLoading(btn, spinner, false);
      }
    });
  }

  // ── Validación en tiempo real (blur) ───────────────────────────────────────────
  document.getElementById('loginEmail')?.addEventListener('blur', () => {
    const v = (document.getElementById('loginEmail').value || '').trim();
    setError('loginEmailError', v && !REGEX.email.test(v) ? 'Ingresa un correo válido.' : '');
  });
  document.getElementById('loginPass')?.addEventListener('blur', () => {
    const v = document.getElementById('loginPass').value || '';
    setError('loginPassError', v && !REGEX.password.test(v) ? 'Mínimo 8 caracteres.' : '');
  });
  document.getElementById('regFirstName')?.addEventListener('blur', () => {
    const v = (document.getElementById('regFirstName').value || '').trim();
    setError('regFirstNameError', v && !REGEX.name.test(v) ? 'Nombre inválido (solo letras, mínimo 2).' : '');
  });
  document.getElementById('regLastName')?.addEventListener('blur', () => {
    const v = (document.getElementById('regLastName').value || '').trim();
    setError('regLastNameError', v && !REGEX.name.test(v) ? 'Apellido inválido (solo letras, mínimo 2).' : '');
  });
  document.getElementById('regEmail')?.addEventListener('blur', () => {
    const v = (document.getElementById('regEmail').value || '').trim();
    setError('regEmailError', v && !REGEX.email.test(v) ? 'Ingresa un correo válido.' : '');
  });
  document.getElementById('regPassConfirm')?.addEventListener('blur', () => {
    const p1 = document.getElementById('regPass')?.value || '';
    const p2 = document.getElementById('regPassConfirm')?.value || '';
    setError('regPassConfirmError', p2 && p1 !== p2 ? 'Las contraseñas no coinciden.' : '');
  });

  // ── Auto-abrir desde query param (?auth=login o ?auth=register) ───────────────
  const urlParams = new URLSearchParams(window.location.search);
  const authParam = urlParams.get('auth');
  if (authParam === 'login' || authParam === 'register') {
    openModal(authParam);
  }

})();
</script>

<style>
  /* ── Overlay ──────────────────────────────────────────────────────────────── */
