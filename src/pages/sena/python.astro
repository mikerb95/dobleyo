      color: var(--fg, #1f2937);
      line-height: 1.7;
    }
    .sena-hero {
      padding: 2rem 0 1.5rem;
      border-bottom: 2px solid var(--border, #e6e6e6);
      margin-bottom: 2rem;
    }
    .sena-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
