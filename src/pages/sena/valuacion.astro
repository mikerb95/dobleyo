---
import Layout from "../../layouts/Layout.astro";

const title = "Presupuesto de Elaboración y Marco de Negociación Tecnológica — DobleYo Café (SENA)";
const description =
  "Apéndice económico del proyecto DobleYo Café: 8 plantillas con cronograma de sprints, presupuesto por rol, costos tecnológicos, resumen financiero, negociación Turso vs Supabase, riesgos y conclusión de viabilidad.";

const formulaTalento = `Costo_rol = Σ ( horas_sprint × $80.000 )

Costo_talento = Σ Costo_rol  (todos los roles)
Total talento = 540 h × $80.000/h = $43.200.000 COP`;

const formulaContingencia = `Contingencia = 15 % × Subtotal_general_antes_contingencia

= 0.15 × $45.770.000 = $6.865.500 COP`;
---

<Layout title={title} description={description}>
  <article class="sena">

    <!-- ── Encabezado ──────────────────────────────────────────────── -->
    <header class="sena-hero">
      <span class="sena-tag">Apéndice económico · SENA · Junio 2026</span>
      <h1>Presupuesto de Elaboración y Marco de Negociación Tecnológica</h1>
      <p class="sena-lead">
        Sustentación del presupuesto del proyecto <strong>DobleYo Café</strong>:
        datos generales, cronograma de 12 sprints, distribución del costo por rol,
        costos tecnológicos con evidencia de precio, resumen financiero, negociación
        Turso vs Supabase, análisis de riesgos y conclusión de viabilidad económica.
      </p>
    </header>

    <!-- ── Índice ───────────────────────────────────────────────────── -->
    <nav class="sena-toc" aria-label="Contenido">
      <strong>Contenido</strong>
      <ol>
        <li><a href="#generales">Plantilla 1 — Datos generales del proyecto</a></li>
        <li><a href="#cronograma">Plantilla 2 — Cronograma de sprints y entregables</a></li>
        <li><a href="#talento">Plantilla 3 — Presupuesto por rol y sprint</a></li>
        <li><a href="#tecnologia">Plantilla 4 — Costos tecnológicos y licencias</a></li>
        <li><a href="#resumen">Plantilla 5 — Resumen financiero del proyecto</a></li>
        <li><a href="#negociacion">Plantilla 6 — Matriz de negociación tecnológica</a></li>
        <li><a href="#riesgos">Plantilla 7 — Riesgos económicos y contingencia</a></li>
        <li><a href="#viabilidad">Plantilla 8 — Conclusión de viabilidad económica</a></li>
        <li><a href="#evidencias">Evidencias de precios consultados</a></li>
        <li><a href="#checklist">Lista de verificación</a></li>
        <li><a href="#glosario">Glosario</a></li>
      </ol>
    </nav>

    <!-- ── Plantilla 1 — Datos generales ────────────────────────────── -->
    <section id="generales" class="sena-section">
      <h2>Plantilla 1 — Datos generales del proyecto</h2>
      <div class="sena-table-wrap">
        <table class="sena-table">
          <thead>
            <tr><th>Campo</th><th>Respuesta</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Nombre del proyecto</strong></td>
              <td>DobleYo Café</td>
            </tr>
            <tr>
              <td><strong>Problema o necesidad que atiende</strong></td>
              <td>Los productores y comercializadores de café de especialidad colombiano carecen de una plataforma digital integrada que unifique la venta directa (B2C Colombia y B2B/B2C USA), la trazabilidad completa del grano (finca → cosecha → tostión → empaque → venta mediante código QR), la gestión de producción y el control financiero en un único sistema.</td>
            </tr>
            <tr>
              <td><strong>Producto de software a construir</strong></td>
              <td>Aplicación web SSR con cinco módulos: (1) Tienda online con carrito, checkout y pasarelas de pago; (2) Pipeline de producción (cosecha, almacenamiento verde, tostión, recibo tostado, empaque, etiquetado); (3) Trazabilidad con QR en empaque; (4) Módulo financiero con contabilidad de doble partida; (5) Panel Admin/ERP con inventario, lotes, usuarios, ventas y mapa de calor.</td>
            </tr>
            <tr>
              <td><strong>Duración total del proyecto</strong></td>
              <td>24 semanas (12 sprints de 2 semanas cada uno)</td>
            </tr>
            <tr>
              <td><strong>Número de sprints</strong></td>
              <td>12</td>
            </tr>
            <tr>
              <td><strong>Duración de cada sprint</strong></td>
              <td>2 semanas</td>
            </tr>
            <tr>
              <td><strong>Moneda utilizada</strong></td>
              <td>Peso colombiano (COP). Tasa de referencia: $4.150 COP/USD</td>
            </tr>
            <tr>
              <td><strong>Supuestos principales del presupuesto</strong></td>
              <td>
                <ol class="sena-inner-list">
                  <li>Un solo desarrollador full-stack (Mike Rodríguez) asume todos los roles funcionales a $80.000/hora.</li>
                  <li>Promedio de 22,5 horas de trabajo por semana.</li>
                  <li>La inteligencia artificial (Claude Pro) se registra como herramienta tecnológica, no como rol de personal.</li>
                  <li>Los costos tecnológicos se calculan para 6 meses continuos de operación.</li>
                  <li>No se incluyen costos de oficina ni equipos de cómputo (ya disponibles).</li>
                  <li>La contingencia del 15 % cubre cambios de alcance, integraciones de pago y variaciones en precios de servicios cloud.</li>
                </ol>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

