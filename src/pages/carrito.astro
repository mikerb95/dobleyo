---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tu carrito — DobleYo Café"
  description="Revisa los productos en tu carrito y finaliza tu compra de café de especialidad colombiano."
>
  <div class="cart-page">

    <!-- Header de sección -->
    <div class="cart-header">
      <a href="/tienda" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Seguir comprando
      </a>
      <h1 class="cart-title">Tu carrito</h1>
      <span class="cart-count" id="cartCount"></span>
    </div>

    <!-- Carrito vacío -->
    <div id="cartEmpty" class="cart-empty" style="display:none;">
      <div class="empty-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="#f5f0eb"/><path d="M18 20h3l2.5 12h13l2.5-9H21" stroke="#c67b4e" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><circle cx="25" cy="35" r="1.5" fill="#c67b4e"/><circle cx="33" cy="35" r="1.5" fill="#c67b4e"/></svg>
      </div>
      <p class="empty-title">Tu carrito está vacío</p>
      <p class="empty-sub">Descubre nuestros cafés de origen único y accesorios</p>
      <a href="/tienda" class="btn-primary">Ver tienda</a>
    </div>

    <!-- Layout principal -->
    <div id="cartLayout" class="cart-layout" style="display:none;">

      <!-- Lista de productos -->
      <div class="cart-items-col">
        <div id="cartList" class="cart-list"></div>

        <!-- Cupón (UI preparada) -->
        <div class="coupon-row">
          <input type="text" class="coupon-input" placeholder="Código de descuento" aria-label="Código de descuento" />
          <button type="button" class="coupon-btn">Aplicar</button>
        </div>

        <!-- Resumen inline (solo móvil) -->
        <div class="cart-inline-summary">
          <div class="cis-inner">
            <p class="cis-heading">Resumen del pedido</p>
            <div class="cis-lines">
              <div class="cis-line"><span>Subtotal</span><span id="cisSubtotal">$0</span></div>
              <div class="cis-line" id="cisShipLine"><span>Envío</span><span id="cisShipping">—</span></div>
            </div>
            <div id="cisFreeShipProgress" class="cis-progress" style="display:none;">
              <p class="fsp-text">Te faltan <strong id="cisFspAmount"></strong> para envío gratis</p>
              <div class="fsp-bar-bg"><div class="fsp-bar-fill" id="cisFspFill"></div></div>
            </div>
            <div id="cisFreeShipBanner" class="free-ship-banner" style="display:none;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7l3.5 3.5L12 3.5" stroke="#15803d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              ¡Envío gratis en este pedido!
            </div>
            <div class="cis-total">
              <span class="cis-total-label">Total</span>
              <span id="cisTotal" class="cis-total-amount">$0</span>
            </div>
            <div class="trust-row">
              <span class="trust-item">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M6.5 1L2 3.5v3c0 2.7 1.9 5.2 4.5 5.8 2.6-.6 4.5-3.1 4.5-5.8v-3L6.5 1z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>
                Pago seguro
              </span>
              <span class="trust-item">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M2 6.5l2.5 2.5 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Devolución 5 días
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Resumen del pedido (desktop) -->
      <aside class="cart-summary-col">
        <div class="summary-card">
          <div class="summary-inner">
            <h2 class="summary-title">Resumen del pedido</h2>

            <div class="summary-lines">
              <div class="summary-line">
                <span>Subtotal</span>
                <span id="cartSubtotal">$0</span>
              </div>
              <div class="summary-line" id="shippingLine">
                <span>Envío</span>
                <span id="cartShipping">—</span>
              </div>
            </div>

            <div id="freeShipBanner" class="free-ship-banner" style="display:none;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7l3.5 3.5L12 3.5" stroke="#15803d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              ¡Envío gratis en este pedido!
            </div>

            <div id="freeShipProgress" class="free-ship-progress" style="display:none;">
              <p class="fsp-text">Te faltan <strong id="fspAmount"></strong> para envío gratis</p>
              <div class="fsp-bar-bg"><div class="fsp-bar-fill" id="fspFill"></div></div>
            </div>

            <hr class="summary-divider" />

            <div class="summary-total">
              <div>
                <span class="summary-total-label">Total</span>
                <span class="total-tax">IVA incluido</span>
              </div>
              <span id="cartTotal" class="total-amount">$0</span>
            </div>

            <button id="checkoutBtn" class="btn-checkout">
              <span>Ir a pagar</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>

            <div class="trust-row">
              <span class="trust-item">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M6.5 1L2 3.5v3c0 2.7 1.9 5.2 4.5 5.8 2.6-.6 4.5-3.1 4.5-5.8v-3L6.5 1z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>
                Pago 100% seguro
              </span>
              <span class="trust-item">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M6.5 1.5l1.2 3.7h3.9l-3.15 2.3 1.2 3.7L6.5 9 3.35 11.2l1.2-3.7L1.4 5.2h3.9z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>
                Wompi certificado
              </span>
              <span class="trust-item">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M2 6.5l2.5 2.5 6-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Devolución 5 días
              </span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- Barra inferior fija — solo móvil -->
  <div id="cartMobileBar" class="cart-mobile-bar" aria-hidden="true">
    <div class="cmb-info">
      <span class="cmb-label">Total</span>
      <span id="cmbTotal" class="cmb-amount">$0</span>
    </div>
    <button id="cmbCheckoutBtn" class="cmb-btn">
      Ir a pagar
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M5.5 3l4 4.5-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <script>
    (function () {
      const FREE_SHIP_THRESHOLD = 120000;
      const SHIP_COST = 12000;

      function fmt(n) { return '$' + Number(n || 0).toLocaleString('es-CO'); }
      function ready(fn) { if (document.readyState !== 'loading') fn(); else document.addEventListener('DOMContentLoaded', fn); }
      function whenCart(fn) { if (window.Cart) fn(); else setTimeout(() => whenCart(fn), 30); }

      ready(() => whenCart(function () {
        const listEl     = document.getElementById('cartList');
        const emptyEl    = document.getElementById('cartEmpty');
        const layoutEl   = document.getElementById('cartLayout');
        const countEl    = document.getElementById('cartCount');
        const subtotalEl = document.getElementById('cartSubtotal');
        const shippingEl = document.getElementById('cartShipping');
        const totalEl    = document.getElementById('cartTotal');
        const freeBanner = document.getElementById('freeShipBanner');
        const freeProgress = document.getElementById('freeShipProgress');
        const fspAmount  = document.getElementById('fspAmount');
        const fspFill    = document.getElementById('fspFill');
        const mobileBar  = document.getElementById('cartMobileBar');
        const cmbTotal   = document.getElementById('cmbTotal');

        function render() {
          const cart = window.Cart.getCart();
          const sub  = window.Cart.subtotal();
          const ship = sub >= FREE_SHIP_THRESHOLD ? 0 : SHIP_COST;
          const tot  = sub + ship;
          const pct  = Math.min(100, Math.round((sub / FREE_SHIP_THRESHOLD) * 100));

          // Toggle vacío / lleno
          emptyEl.style.display  = cart.length ? 'none'  : 'flex';
          layoutEl.style.display = cart.length ? 'grid' : 'none';
          if (mobileBar) { mobileBar.setAttribute('aria-hidden', cart.length ? 'false' : 'true'); mobileBar.classList.toggle('cart-mobile-bar--visible', !!cart.length); }

          // Contador
          const totalItems = cart.reduce((s, p) => s + (p.qty || 1), 0);
          countEl.textContent = totalItems ? `(${totalItems} ${totalItems === 1 ? 'producto' : 'productos'})` : '';

          // Resumen (desktop)
          subtotalEl.textContent = fmt(sub);
          shippingEl.textContent = ship === 0 ? 'Gratis' : fmt(ship);
          if (ship === 0) shippingEl.style.color = '#16a34a';
          else shippingEl.style.color = '';
          totalEl.textContent = fmt(tot);

          // Resumen inline (móvil)
          const cisSubtotal = document.getElementById('cisSubtotal');
          const cisShipping = document.getElementById('cisShipping');
          const cisTotal    = document.getElementById('cisTotal');
          const cisFreeProgress = document.getElementById('cisFreeShipProgress');
          const cisFreeBanner   = document.getElementById('cisFreeShipBanner');
          const cisFspAmount    = document.getElementById('cisFspAmount');
          const cisFspFill      = document.getElementById('cisFspFill');
          if (cisSubtotal) cisSubtotal.textContent = fmt(sub);
          if (cisShipping) { cisShipping.textContent = ship === 0 ? 'Gratis' : fmt(ship); cisShipping.style.color = ship === 0 ? '#16a34a' : ''; }
          if (cisTotal) cisTotal.textContent = fmt(tot);
          if (cisFreeProgress && cisFreeBanner) {
            if (ship === 0) { cisFreeBanner.style.display = 'flex'; cisFreeProgress.style.display = 'none'; }
            else { cisFreeBanner.style.display = 'none'; cisFreeProgress.style.display = 'block'; if (cisFspAmount) cisFspAmount.textContent = fmt(FREE_SHIP_THRESHOLD - sub); if (cisFspFill) cisFspFill.style.width = pct + '%'; }
          }
          if (cmbTotal) cmbTotal.textContent = fmt(tot);

          // Envío gratis (desktop sidebar)
          if (ship === 0) {
            freeBanner.style.display = 'flex';
            freeProgress.style.display = 'none';
          } else {
            freeBanner.style.display = 'none';
            freeProgress.style.display = 'block';
            fspAmount.textContent = fmt(FREE_SHIP_THRESHOLD - sub);
            fspFill.style.width = pct + '%';
          }

          // Items
          if (!cart.length) { listEl.innerHTML = ''; return; }
          listEl.innerHTML = cart.map((p) => `
            <div class="cart-item" data-id="${p.id}">
              <div class="item-image-wrap">
                <img src="${p.image || '/assets/img/placeholder.webp'}" alt="${(p.name || '').replace(/</g,'&lt;')}" class="item-image" loading="lazy" width="80" height="80"/>
              </div>
              <div class="item-body">
                <div class="item-top">
                  <div>
                    <p class="item-name">${p.name || ''}</p>
                    <p class="item-unit-price">${fmt(p.price || 0)} / unidad</p>
                  </div>
                  <button class="item-remove rm" data-id="${p.id}" aria-label="Eliminar ${p.name || 'producto'}">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M3 3l9 9M12 3l-9 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  </button>
                </div>
                <div class="item-bottom">
                  <div class="qty-control" role="group" aria-label="Cantidad">
                    <button type="button" class="qty-step qty-down" data-id="${p.id}" data-dir="down" aria-label="Reducir cantidad">−</button>
                    <input type="number" class="qty qty-input" value="${p.qty || 1}" min="1" max="99" data-id="${p.id}" inputmode="numeric" aria-label="Cantidad" />
                    <button type="button" class="qty-step qty-up" data-id="${p.id}" data-dir="up" aria-label="Aumentar cantidad">+</button>
                  </div>
                  <span class="item-subtotal">${fmt((p.price || 0) * (p.qty || 1))}</span>
                </div>
              </div>
            </div>
          `).join('');

          // Eventos
          listEl.onclick = (e) => {
            const rm   = e.target.closest('.rm');
            const step = e.target.closest('.qty-step');
            if (rm) { window.Cart.removeFromCart(rm.dataset.id); render(); }
            if (step) {
              const id = step.dataset.id;
              const input = listEl.querySelector(`input.qty[data-id="${id}"]`);
              if (!input) return;
              const next = Math.min(99, Math.max(1, (parseInt(input.value) || 1) + (step.dataset.dir === 'down' ? -1 : 1)));
              window.Cart.updateQty(id, next);
              render();
            }
          };
          listEl.onchange = (e) => {
            const q = e.target.closest('.qty');
            if (q) { window.Cart.updateQty(q.dataset.id, Math.min(99, Math.max(1, parseInt(q.value) || 1))); render(); }
          };
        }

        render();
        document.getElementById('checkoutBtn').addEventListener('click', () => { location.href = '/checkout'; });
        const cmbBtn = document.getElementById('cmbCheckoutBtn');
        if (cmbBtn) cmbBtn.addEventListener('click', () => { location.href = '/checkout'; });
      }));
    })();
  </script>

  <style>
    .cart-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.25rem 5rem;
    }

    /* Header */
    .cart-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: .375rem;
      color: var(--muted-fg);
      font-size: .875rem;
      text-decoration: none;
      transition: color .15s;
    }
    .back-link:hover { color: var(--coffee); }
    .cart-title {
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--coffee);
      margin: 0;
      font-family: 'Lora', Georgia, serif;
    }
    .cart-count {
      color: var(--muted-fg);
      font-size: 1rem;
      font-weight: 400;
    }

    /* Vacío */
    .cart-empty {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 5rem 1.5rem;
      gap: .875rem;
    }
    .empty-icon { margin-bottom: .5rem; }
    .empty-title { font-size: 1.25rem; font-weight: 600; color: var(--coffee); margin: 0; font-family: 'Lora', Georgia, serif; }
    .empty-sub   { color: var(--muted-fg); font-size: .95rem; margin: 0; }

    /* Layout */
    .cart-layout {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 2rem;
      align-items: start;
    }

    /* Lista de items */
    .cart-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 1rem;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 1px 4px rgba(37,26,20,.05);
    }

    .cart-item {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 1.125rem;
      padding: 1.25rem;
      border-bottom: 1px solid var(--border);
      transition: background .15s;
    }
    .cart-item:last-child { border-bottom: none; }
    .cart-item:hover { background: #fdfaf7; }

    .item-image-wrap {
      border-radius: .625rem;
      overflow: hidden;
      background: #f5f0eb;
      aspect-ratio: 1;
      flex-shrink: 0;
    }
    .item-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .item-body {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: .75rem;
      min-width: 0;
    }

    .item-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: .5rem;
    }
    .item-name {
      font-size: .975rem;
      font-weight: 600;
      color: var(--coffee);
      margin: 0;
      line-height: 1.3;
      font-family: 'Lora', Georgia, serif;
    }
    .item-unit-price {
      font-size: .78rem;
      color: var(--muted-fg);
      margin: .2rem 0 0;
      letter-spacing: .01em;
    }

    .item-remove {
      background: none;
      border: none;
      padding: .25rem;
      cursor: pointer;
      color: #c4bbb4;
      border-radius: .375rem;
      transition: color .15s, background .15s;
      flex-shrink: 0;
    }
    .item-remove:hover { color: #dc2626; background: #fee2e2; }

    .item-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .75rem;
    }

    .qty-control {
      display: flex;
      align-items: center;
      border: 1.5px solid var(--border);
      border-radius: .5rem;
      overflow: hidden;
      height: 36px;
      background: #faf8f6;
    }
    .qty-step {
      width: 36px;
      height: 36px;
      background: none;
      border: none;
      font-size: 1.1rem;
      cursor: pointer;
      color: var(--coffee);
      transition: background .15s;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .qty-step:hover { background: #f0ebe4; }
    .qty-input {
      width: 42px;
      border: none;
      border-left: 1.5px solid var(--border);
      border-right: 1.5px solid var(--border);
      text-align: center;
      font-size: .9rem;
      font-weight: 600;
      color: var(--coffee);
      height: 100%;
      outline: none;
      background: transparent;
      -moz-appearance: textfield;
    }
    .qty-input::-webkit-inner-spin-button,
    .qty-input::-webkit-outer-spin-button { -webkit-appearance: none; }

    .item-subtotal {
      font-size: 1rem;
      font-weight: 700;
      color: var(--coffee);
      white-space: nowrap;
      font-family: 'Lora', Georgia, serif;
    }

    /* Cupón */
    .coupon-row {
      display: flex;
      gap: .5rem;
      margin-top: 1rem;
    }
    .coupon-input {
      flex: 1;
      border: 1.5px solid var(--border);
      border-radius: .5rem;
      padding: .625rem 1rem;
      font-size: .875rem;
      color: var(--coffee);
      background: #fff;
      outline: none;
      transition: border-color .15s;
    }
    .coupon-input:focus { border-color: var(--accent); }
    .coupon-btn {
      padding: .625rem 1.25rem;
      border: 1.5px solid var(--border);
      border-radius: .5rem;
      background: #fff;
      font-size: .875rem;
      font-weight: 600;
      color: var(--coffee);
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
    }
    .coupon-btn:hover { border-color: var(--coffee); background: #f9f6f2; }

    /* ── Resumen del pedido ── */
    .cart-summary-col { position: sticky; top: 1.5rem; }

    .summary-card {
      background: var(--cream);
      border: 1px solid #ddd6ce;
      border-radius: 1.125rem;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(37,26,20,.07);
    }

    /* Franja de acento superior */
    .summary-card::before {
      content: '';
      display: block;
      height: 3px;
      background: linear-gradient(90deg, var(--accent) 0%, #e09a70 100%);
    }

    .summary-inner {
      padding: 1.5rem 1.75rem 1.75rem;
    }

    .summary-title {
      font-family: 'Lora', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--coffee);
      margin: 0 0 1.375rem;
      letter-spacing: -.01em;
    }

    .summary-lines {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      margin-bottom: 1.125rem;
    }
    .summary-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: .875rem;
      color: var(--muted-fg);
    }
    .summary-line span:last-child {
      font-weight: 500;
      color: var(--coffee);
    }

    .free-ship-banner {
      display: flex;
      align-items: center;
      gap: .5rem;
      background: #edfbf2;
      color: #15803d;
      font-size: .78rem;
      font-weight: 600;
      padding: .5rem .875rem;
      border-radius: .5rem;
      margin-bottom: 1rem;
      border: 1px solid #bbf7d0;
    }

    .free-ship-progress { margin-bottom: 1.125rem; }
    .fsp-text { font-size: .78rem; color: var(--muted-fg); margin: 0 0 .5rem; }
    .fsp-bar-bg {
      height: 5px;
      background: #ddd6ce;
      border-radius: 9999px;
      overflow: hidden;
    }
    .fsp-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), #e09a70);
      border-radius: 9999px;
      transition: width .4s ease;
    }

    /* Divisor decorativo */
    .summary-divider {
      border: none;
      border-top: 1px solid #ddd6ce;
      margin: 0 0 1.25rem;
    }

    .summary-total {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 1.375rem;
    }
    .summary-total-label {
      font-size: .875rem;
      font-weight: 600;
      color: var(--coffee);
    }
    .total-tax {
      display: block;
      font-size: .68rem;
      color: var(--muted-fg);
      margin-top: .15rem;
      font-weight: 400;
    }
    .total-amount {
      display: block;
      font-family: 'Lora', Georgia, serif;
      font-size: 1.625rem;
      font-weight: 700;
      color: var(--coffee);
      line-height: 1;
      text-align: right;
    }

    .btn-primary, .btn-checkout {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      width: 100%;
      padding: .9rem 1.5rem;
      background: var(--coffee);
      color: #fff;
      border: none;
      border-radius: .75rem;
      font-size: .975rem;
      font-weight: 700;
      cursor: pointer;
