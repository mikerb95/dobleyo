---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getCanonicalUrl } from "../../i18n/index.ts";
import { parseTastingNotes } from "../../../server/utils/tasting.js";

const { id } = Astro.params;

// ─── Cargar producto desde BD ──────────────────────────────────────────────
let product: any = null;
let variants: any[] = [];
let error = false;

try {
  const { query } = await import("../../../server/db.js");
  const LABEL: Record<string, string> = {
    cafe: "Cafés",
    accesorio: "Accesorios",
    merchandising: "Merchandising",
  };
  const { rows } = await query(
    `SELECT
       p.id, p.slug, p.name, p.name_en, p.category, p.origin, p.process, p.roast,
       p.tasting_notes, p.price, p.price_usd, p.rating,
       p.is_deal AS deal, p.is_bestseller AS bestseller,
       p.is_new AS new, p.is_fast AS fast,
       p.image_url AS image, p.images,
       p.stock_quantity AS stock,
       p.description,
       (SELECT MAX(l.score) FROM lots l WHERE l.product_id = p.id AND l.score IS NOT NULL) AS sca_score,
       (SELECT l.variety FROM lots l WHERE l.product_id = p.id AND l.variety IS NOT NULL ORDER BY l.created_at DESC LIMIT 1) AS variety
     FROM products p
     WHERE (p.id = ? OR p.slug = ?) AND p.is_active = 1`,
    [id, id]
  );
  if (rows.length) {
    const p = rows[0];
    const tn = parseTastingNotes(p.tasting_notes);
    product = {
      ...p,
      categoryLabel: LABEL[p.category] ?? p.category,
      notes: tn?.es ?? null,
      notesEn: tn?.en ?? null,
    };
    const vRows = await query(
      `SELECT id, size_label, grind_label, price_cop, stock_quantity, sort_order
       FROM product_variants
       WHERE product_id = ? AND is_active = 1
       ORDER BY sort_order ASC, size_label ASC`,
      [product.id]
    );
    variants = vRows.rows;
  }
} catch (_) {
  // Fallback: buscar en datos estáticos
  const { products: staticProducts } = await import("../../data/products.ts");
  const found = staticProducts.find((p) => p.id === id);
  if (found) {
    product = { ...found, image: found.image, stock: 99, categoryLabel: found.category };
  } else {
    error = true;
  }
}

if (!product && !error) {
  return Astro.redirect("/tienda", 302);
}
if (error || !product) {
  return Astro.redirect("/tienda", 302);
}

const outOfStock = typeof product.stock === "number" && product.stock === 0;
const lowStock   = typeof product.stock === "number" && product.stock > 0 && product.stock <= 5;

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: product.image,
  description:
    product.description ||
    (Array.isArray(product.notes) ? product.notes.join(", ") : ""),
  brand: { "@type": "Brand", name: "DobleYo Café" },
  offers: {
    "@type": "Offer",
    priceCurrency: "COP",
    price: product.price,
    availability: outOfStock
      ? "https://schema.org/OutOfStock"
      : "https://schema.org/InStock",
    url: `https://dobleyo.cafe/producto/${product.id}`,
  },
  aggregateRating: product.rating
    ? {
        "@type": "AggregateRating",
        ratingValue: product.rating,
        bestRating: 5,
        worstRating: 1,
        ratingCount: 1,
      }
    : undefined,
};
---

<Layout
  title={`${product.name} — DobleYo Café`}
  description={product.description ||
    (Array.isArray(product.notes)
      ? `${product.name}: ${product.notes.join(", ")}. Café de especialidad colombiano.`
      : `${product.name} — Café de especialidad colombiano DobleYo.`)}
  canonical={getCanonicalUrl(`/producto/${product.id}`, "es")}
  jsonLd={productJsonLd}
  ogImage={product.image}
  ogImageAlt={product.name}
  ogType="product"
>
  <section class="product-page">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/tienda">Tienda</a>
      <span aria-hidden="true">›</span>
      <span>{product.categoryLabel}</span>
      <span aria-hidden="true">›</span>
      <span>{product.name}</span>
    </nav>

    <div class="product-layout">
      <!-- Imagen -->
      <div class="product-image-wrap">
        <img
          src={product.image}
          alt={product.name}
          class="product-image"
          loading="eager"
          transition:name={`product-image-${product.id}`}
        />
        {product.deal && <span class="badge deal">Oferta</span>}
        {product.new && <span class="badge new-badge">Nuevo</span>}
        {product.bestseller && <span class="badge best">Más vendido</span>}
      </div>

      <!-- Detalle -->
      <div class="product-detail">
        <p class="product-meta">
          {product.categoryLabel}
          {product.origin && <span>· {product.origin}</span>}
        </p>

        <h1 class="product-title">{product.name}</h1>

        {product.rating && (
          <div class="product-rating" aria-label={`Calificación: ${product.rating} de 5`}>
            {"★".repeat(Math.round(product.rating))}{"☆".repeat(5 - Math.round(product.rating))}
            <span class="rating-num">{product.rating}</span>
          </div>
        )}

        <div class="product-price">
          <span class="price-cop">${product.price.toLocaleString("es-CO")}</span>
          {product.price_usd && (
            <span class="price-usd">≈ USD {product.price_usd}</span>
          )}
        </div>

        {outOfStock && (
          <p class="stock-badge out">Agotado temporalmente</p>
        )}
        {lowStock && (
          <p class="stock-badge low">¡Solo quedan {product.stock} unidades!</p>
        )}

        <!-- Atributos del café -->
        {(product.process || product.roast || product.variety || (product.category === "cafe" && product.sca_score)) && (
          <div class="product-attrs">
            {product.process && (
              <div class="attr">
                <span class="attr-label">Proceso</span>
                <span class="attr-val">{product.process}</span>
              </div>
            )}
            {product.variety && (
              <div class="attr">
                <span class="attr-label">Variedad</span>
                <span class="attr-val">{product.variety}</span>
              </div>
            )}
            {product.roast && (
              <div class="attr">
                <span class="attr-label">Tueste</span>
                <span class="attr-val">{product.roast}</span>
              </div>
            )}
            {product.origin && (
              <div class="attr">
                <span class="attr-label">Origen</span>
                <span class="attr-val">{product.origin}</span>
              </div>
            )}
            {product.category === "cafe" && product.sca_score && (
              <div class="attr attr-sca" title="Puntuación SCA (Specialty Coffee Association)">
                <span class="attr-label">Puntaje SCA</span>
                <span class="attr-val">{product.sca_score} pts</span>
              </div>
            )}
          </div>
        )}

        <!-- Notas de cata -->
        {Array.isArray(product.notes) && product.notes.length > 0 && (
          <div class="tasting-notes">
            <p class="tasting-title">Notas de cata</p>
            <div class="notes-list">
              {product.notes.map((note: string) => (
                <span class="note-chip">{note}</span>
              ))}
            </div>
          </div>
        )}

        {product.description && (
          <p class="product-description">{product.description}</p>
        )}

        <!-- Variantes (tamaño y molienda) -->
        {variants.length > 0 && (
          <div class="variants-wrap" id="variantsWrap" data-variants={JSON.stringify(variants)} data-base-price={product.price}>
            {[...new Set(variants.map((v: any) => v.size_label).filter(Boolean))].length > 0 && (
              <div class="variant-group">
                <p class="variant-label">Presentación</p>
                <div class="variant-options" id="variantSize">
                  {[...new Set(variants.map((v: any) => v.size_label).filter(Boolean))].map((s: any) => (
                    <button class="variant-btn" data-size={s}>{s}</button>
                  ))}
                </div>
              </div>
            )}
            {[...new Set(variants.map((v: any) => v.grind_label).filter(Boolean))].length > 0 && (
              <div class="variant-group">
                <p class="variant-label">Molienda</p>
                <div class="variant-options" id="variantGrind">
                  {[...new Set(variants.map((v: any) => v.grind_label).filter(Boolean))].map((g: any) => (
                    <button class="variant-btn" data-grind={g}>{g}</button>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        <!-- Acción -->
        <div class="product-actions" id="productActions" data-product-id={product.id} data-product-name={product.name} data-product-price={product.price} data-product-image={product.image}>
          <div class="qty-control">
            <button class="qty-btn" id="qtyDown" aria-label="Reducir cantidad">−</button>
            <input type="number" id="qtyInput" value="1" min="1" max={product.stock || 99} class="qty-input" aria-label="Cantidad" />
            <button class="qty-btn" id="qtyUp" aria-label="Aumentar cantidad">+</button>
          </div>
          <button
            class="btn add-btn"
            id="addToCartBtn"
            disabled={outOfStock || undefined}
          >
            {outOfStock ? "Agotado" : "Agregar al carrito"}
          </button>
          <a class="btn outline" href="/cart">Ver carrito</a>
          <button
            class="btn outline fav-toggle-btn"
            data-fav={product.id}
            aria-label="Agregar a favoritos"
            aria-pressed="false"
            title="Agregar a favoritos"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
              <path
                d="M12 21s-6.7-4.35-9.3-8.05C.9 10.3 1.6 6.9 4.4 5.7c2-.85 4.1-.1 5.2 1.5l.9 1.3.9-1.3c1.1-1.6 3.2-2.35 5.2-1.5 2.8 1.2 3.5 4.6 1.7 7.25C18.7 16.65 12 21 12 21z"
              ></path>
            </svg>
            <span>Favorito</span>
          </button>
        </div>

        <!-- Envío -->
        <p class="ship-note">
          🚚 Envío gratis en pedidos mayores a $120.000 COP
        </p>

        <!-- Link de trazabilidad -->
        {product.category === "cafe" && (
          <a href="/trazabilidad" class="trace-link">
            🔍 Rastrear el origen de este café
          </a>
        )}
      </div>
    </div>

    <!-- Sección de reseñas -->
    <section class="reviews-section" id="reviewsSection" data-product-id={product.id}>
      <h2 class="reviews-title">Reseñas</h2>

      <div class="reviews-summary" id="reviewsSummary">
        <span class="reviews-avg" id="reviewsAvg">—</span>
        <span class="reviews-stars" id="reviewsStars"></span>
        <span class="reviews-count" id="reviewsCount"></span>
      </div>

      <div class="reviews-list" id="reviewsList">
        <p class="reviews-empty" id="reviewsEmpty" style="display:none">Sé el primero en dejar una reseña.</p>
      </div>

      <div class="review-form-wrap">
        <h3 class="review-form-title">Dejar una reseña</h3>
        <form class="review-form" id="reviewForm" novalidate>
          <div class="review-field">
            <label class="review-label" for="revName">Tu nombre <span style="color:var(--accent)">*</span></label>
            <input id="revName" type="text" class="review-input" placeholder="Juan García" required />
          </div>
          <div class="review-field">
            <label class="review-label">Calificación <span style="color:var(--accent)">*</span></label>
            <div class="star-picker" id="starPicker" role="group" aria-label="Selecciona una calificación">
              {[1,2,3,4,5].map(n => (
                <button type="button" class="star-btn" data-val={n} aria-label={`${n} estrella${n > 1 ? 's' : ''}`}>★</button>
              ))}
            </div>
          </div>
          <div class="review-field">
            <label class="review-label" for="revComment">Comentario</label>
            <textarea id="revComment" class="review-input" rows={3} placeholder="Cuéntanos tu experiencia…"></textarea>
          </div>
          <div id="reviewMsg" class="review-msg" style="display:none"></div>
          <button type="submit" class="review-submit" id="reviewSubmit">Enviar reseña</button>
        </form>
      </div>
    </section>
  </section>

  <!-- Acciones de producto + reseñas (externalizado por CSP estricta) -->
  <script is:inline src="/assets/js/producto.js"></script>

  <style>
    .product-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.5rem 1rem 4rem;
    }

    .breadcrumb {
      display: flex;
      gap: .4rem;
      align-items: center;
      font-size: .85rem;
      color: var(--muted-fg, #888);
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .breadcrumb a {
      color: var(--accent);
      text-decoration: none;
    }

    .breadcrumb a:hover { text-decoration: underline; }

    .product-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    .product-image-wrap {
      position: relative;
      border-radius: .75rem;
      overflow: hidden;
      aspect-ratio: 1 / 1;
      background: var(--surface, #f9f6f2);
    }

    .product-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .badge {
      position: absolute;
      top: .75rem;
      left: .75rem;
      font-size: .75rem;
      font-weight: 700;
      padding: .2rem .6rem;
      border-radius: 99px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }

    .badge.deal      { background: var(--accent); color: #fff; }
    .badge.new-badge { background: #4a6741; color: #fff; }
    .badge.best      { background: #92400e; color: #fff; }

    .product-meta {
      font-size: .85rem;
      color: var(--muted-fg, #888);
      margin: 0 0 .4rem;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .product-title {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      margin: 0 0 .5rem;
      line-height: 1.2;
    }

    .product-rating {
      color: #f59e0b;
      font-size: 1.1rem;
      margin-bottom: .75rem;
    }

    .rating-num {
      color: var(--muted-fg, #888);
      font-size: .85rem;
      margin-left: .25rem;
    }

    .attr-sca {
      background: #f0f9f0;
      border: 1px solid #86efac;
    }

    .attr-sca .attr-label { color: #15803d; }

    .attr-sca .attr-val {
      color: #15803d;
      font-weight: 700;
    }

    .product-price {
      margin-bottom: .75rem;
    }

    .price-cop {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--accent);
    }

    .price-usd {
      font-size: .9rem;
      color: var(--muted-fg, #888);
      margin-left: .5rem;
    }

    .stock-badge {
      display: inline-block;
      font-size: .8rem;
      font-weight: 600;
      padding: .2rem .65rem;
      border-radius: 99px;
      margin-bottom: .75rem;
    }

    .stock-badge.out { background: #fee2e2; color: #b91c1c; }
    .stock-badge.low { background: #fef9c3; color: #92400e; }

    .product-attrs {
      display: flex;
      flex-wrap: wrap;
      gap: .65rem;
      margin: 1rem 0;
    }

    .attr {
      display: flex;
      flex-direction: column;
      background: var(--surface, #f9f6f2);
      border-radius: .5rem;
      padding: .4rem .75rem;
      min-width: 80px;
    }

    .attr-label {
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted-fg, #888);
    }

    .attr-val {
      font-size: .9rem;
      font-weight: 600;
    }

    .variants-wrap { margin: 1rem 0; display: flex; flex-direction: column; gap: .75rem; }

    .variant-group {}

    .variant-label {
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted-fg, #888);
      margin: 0 0 .35rem;
    }

    .variant-options { display: flex; flex-wrap: wrap; gap: .4rem; }

    .variant-btn {
      padding: .35rem .75rem;
      border: 1.5px solid var(--border, #e5e0d8);
      border-radius: 6px;
      background: transparent;
      font-size: .85rem;
      cursor: pointer;
      transition: border-color .15s, background .15s, color .15s;
    }

    .variant-btn:hover { border-color: var(--accent); }

    .variant-btn.active {
      border-color: var(--accent);
      background: var(--accent);
      color: #fff;
    }

    .tasting-notes { margin: 1rem 0; }

    .tasting-title {
      font-size: .8rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted-fg, #888);
      margin-bottom: .4rem;
    }

    .notes-list { display: flex; flex-wrap: wrap; gap: .4rem; }

    .note-chip {
      background: var(--accent-light, #f0e8df);
      color: var(--accent);
      font-size: .82rem;
      font-weight: 600;
      padding: .2rem .65rem;
      border-radius: 99px;
    }

    .product-description {
      font-size: .95rem;
      line-height: 1.6;
      color: var(--text, #333);
      margin: 1rem 0;
    }

    .product-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .65rem;
      align-items: center;
      margin: 1.25rem 0 .75rem;
    }

    .qty-control {
      display: flex;
      align-items: center;
      border: 1px solid var(--border, #ddd);
      border-radius: .375rem;
      overflow: hidden;
    }

    .qty-btn {
      width: 2.25rem;
      height: 2.5rem;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--accent);
      transition: background .15s;
    }

    .qty-btn:hover { background: var(--surface, #f9f6f2); }

    .qty-input {
      width: 3rem;
      height: 2.5rem;
      border: none;
      border-left: 1px solid var(--border, #ddd);
      border-right: 1px solid var(--border, #ddd);
      text-align: center;
      font-size: .95rem;
      font-weight: 600;
      -moz-appearance: textfield;
    }

    .qty-input::-webkit-inner-spin-button,
    .qty-input::-webkit-outer-spin-button { -webkit-appearance: none; }

    .add-btn {
      flex: 1;
      min-width: 160px;
      min-height: 2.5rem;
      font-size: 1rem;
    }

    .fav-toggle-btn {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      min-height: 2.5rem;
    }

    .fav-toggle-btn svg path {
      fill: none;
      stroke: currentColor;
      stroke-width: 1.8;
    }

    .fav-toggle-btn.is-fav {
      color: #dc2626;
      border-color: #dc2626;
    }

    .fav-toggle-btn.is-fav svg path { fill: currentColor; }

    .ship-note {
      font-size: .82rem;
      color: #4a6741;
      margin: .25rem 0 .75rem;
    }

    .trace-link {
      display: inline-block;
      font-size: .85rem;
      color: var(--accent);
      text-decoration: none;
      margin-top: .25rem;
    }

    .trace-link:hover { text-decoration: underline; }

    /* Reviews */
    .reviews-section {
      max-width: 780px;
      margin: 3rem auto 0;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border, #e6e6e6);
    }
    .reviews-title { font-size: 1.4rem; margin: 0 0 1rem; }
    .reviews-summary { display: flex; align-items: center; gap: .5rem; margin-bottom: 1.5rem; }
    .reviews-avg { font-size: 2rem; font-weight: 700; color: var(--accent); }
    .reviews-stars { color: #f59e0b; font-size: 1.2rem; }
    .reviews-count { color: var(--muted-fg, #888); font-size: .9rem; }
    .reviews-list { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .reviews-empty { color: var(--muted-fg, #888); font-style: italic; }
    .review-card { background: var(--surface, #f9f6f2); border-radius: .5rem; padding: 1rem 1.25rem; }
    .review-card__header { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; margin-bottom: .35rem; }
    .review-card__date { font-size: .75rem; color: var(--muted-fg, #888); margin-left: auto; }
    .review-card__comment { margin: 0; font-size: .9rem; }
    .review-form-wrap { background: var(--surface, #f9f6f2); border-radius: .75rem; padding: 1.5rem; }
    .review-form-title { margin: 0 0 1.25rem; font-size: 1.1rem; }
    .review-form { display: flex; flex-direction: column; gap: 1rem; }
    .review-field { display: flex; flex-direction: column; gap: .3rem; }
    .review-label { font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted-fg, #888); }
    .review-input { padding: .55rem .75rem; border: 1.5px solid var(--border, #e6e6e6); border-radius: 6px; font-family: inherit; font-size: .95rem; background: #fff; width: 100%; }
    .review-input:focus { outline: none; border-color: var(--accent); }
    .star-picker { display: flex; gap: .25rem; }
    .star-btn { background: none; border: none; font-size: 1.75rem; cursor: pointer; color: var(--border, #e6e6e6); transition: color .1s; padding: 0; line-height: 1; }
    .star-btn.active { color: #f59e0b; }
    .star-btn:hover { color: #f59e0b; }
    .review-submit { padding: .65rem 1.5rem; background: var(--accent); color: #fff; border: none; border-radius: 6px; font-size: .95rem; font-weight: 600; cursor: pointer; align-self: flex-start; transition: opacity .15s; }
    .review-submit:hover { opacity: .88; }
    .review-submit:disabled { opacity: .5; cursor: not-allowed; }
    .review-msg { padding: .6rem .9rem; border-radius: 6px; font-size: .9rem; }
    .review-msg.success { background: #f0fdf4; color: #15803d; }
    .review-msg.error { background: #fee2e2; color: #b91c1c; }

    @media (max-width: 768px) {
      .product-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .product-image-wrap {
        max-height: 340px;
      }
    }
  </style>
</Layout>
