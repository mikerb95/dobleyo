---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";

const origin = Astro.url.origin;
const cookie = Astro.request.headers.get("cookie") ?? "";
const opts   = { headers: { cookie } };

// ─── Fetch paralelo de APIs del pipeline ────────────────────────────────────
let harvests: any[]  = [];
let packaged: any[]  = [];
let lotsData: any[]  = [];
let fetchError       = false;

try {
  const [rH, rP, rL] = await Promise.all([
    fetch(`${origin}/api/coffee/harvests`, opts),
    fetch(`${origin}/api/coffee/packaged`,  opts),
    fetch(`${origin}/api/coffee/lots`,      opts),
  ]);

  if (rH.ok) harvests  = await rH.json();
  if (rP.ok) packaged  = await rP.json();
  if (rL.ok) lotsData  = await rL.json();

  // Normalizar: los endpoints devuelven arrays directos o {data:[]}
  if (!Array.isArray(harvests)) harvests = (harvests as any)?.data ?? [];
  if (!Array.isArray(packaged)) packaged = (packaged as any)?.data ?? [];
  if (!Array.isArray(lotsData)) lotsData = (lotsData as any)?.data ?? [];
} catch (_) {
  fetchError = true;
}

// ─── KPIs principales ────────────────────────────────────────────────────────
const totalLotes  = harvests.length;
const totalEmpacados = packaged.length;

// Calidad: score de empaquetado (escala 1–5, promedio de acidez, cuerpo, balance)
const scoresValidos = packaged.filter((p: any) => p.score > 0);
const avgScore = scoresValidos.length > 0
  ? (scoresValidos.reduce((s: number, p: any) => s + Number(p.score), 0) / scoresValidos.length).toFixed(2)
  : null;

// Precio promedio (placeholder — viene de sales cuando esté disponible)
// Por ahora calculamos kg totales de packaged (unit_count * weight por presentación)
const PACK_WEIGHTS: Record<string, number> = { "250g": 0.25, "500g": 0.5, "1kg": 1, "1000g": 1, "100g": 0.1 };
const totalKgEmpacado = packaged.reduce((s: number, p: any) => {
  const w = PACK_WEIGHTS[p.package_size ?? ""] ?? 0;
  return s + w * (Number(p.unit_count) || 0);
}, 0);

// ─── Distribución de calidad ────────────────────────────────────────────────
const qDist = [
  { label: "4.5–5 (Excepcional)", color: "#2d6a4f", count: scoresValidos.filter((p: any) => p.score >= 4.5).length },
  { label: "3.5–4.4 (Muy bueno)", color: "#8b6f47", count: scoresValidos.filter((p: any) => p.score >= 3.5 && p.score < 4.5).length },
  { label: "< 3.5 (Regular)",     color: "#d4a017", count: scoresValidos.filter((p: any) => p.score <  3.5 && p.score > 0).length },
];
const maxQDist = Math.max(1, ...qDist.map((d) => d.count));

// ─── Variedades ──────────────────────────────────────────────────────────────
const VARIETY_LABEL: Record<string, string> = {
  CAT: "Caturra", TIP: "Típica", BOB: "Bourbon",
  GER: "Geisha",  PAC: "Pacamara", CAS: "Castillo",
  PBO: "Pink Bourbon",
};

const varietyCounts: Record<string, number> = {};
for (const h of harvests) {
  // lot_id = COL-HUI-1800-CAT-NAT-01 → parts[3] = código de variedad
  const parts = (h.lot_id as string)?.split("-") ?? [];
  const code  = h.variety ?? parts[3] ?? "UNK";
  varietyCounts[code] = (varietyCounts[code] ?? 0) + 1;
}
const topVarieties = Object.entries(varietyCounts)
  .map(([code, count]) => ({
    name: VARIETY_LABEL[code] ?? code,
    count,
    pct: Math.round((count / Math.max(1, totalLotes)) * 100),
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);

// ─── Producción mensual (últimos 6 meses) ───────────────────────────────────
const now = new Date();
const last6: { label: string; key: string }[] = [];
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  last6.push({
    label: d.toLocaleDateString("es-CO", { month: "short" }),
    key:   `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`,
  });
}
const monthCounts: Record<string, number> = {};
for (const h of harvests) {
  if (!h.created_at) continue;
  const d   = new Date(h.created_at);
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  monthCounts[key] = (monthCounts[key] ?? 0) + 1;
}
const maxMonthCount = Math.max(1, ...last6.map((m) => monthCounts[m.key] ?? 0));

// ─── Estado del pipeline (desde /api/coffee/lots) ───────────────────────────
const STAGE_LABEL: Record<string, string> = {
  harvested:           "Cosecha",
  in_storage_green:    "Café Verde",
  sent_to_roasting:    "En Tueste",
  roasted:             "Tostado",
  in_storage_roasted:  "Almacén tostado",
  packaged:            "Empacado",
};
const pipelineCounts: Record<string, number> = {};
for (const lot of lotsData) {
  const stage = lot.stage ?? lot.status ?? lot.state ?? "unknown";
  pipelineCounts[stage] = (pipelineCounts[stage] ?? 0) + 1;
}
const pipelineStages = Object.entries(pipelineCounts)
  .map(([stage, count]) => ({ stage, label: STAGE_LABEL[stage] ?? stage, count }))
  .sort((a, b) => b.count - a.count);

// ─── Pronóstico de demanda (escrito por api/ml/recompute.py) ─────────────────
let forecast: any = { generated_at: null, units: [], revenue: null };
try {
  const rF = await fetch(`${origin}/api/ml/forecast`, opts);
  if (rF.ok) {
    const j = await rF.json();
    if (j?.success && j.data) forecast = j.data;
  }
} catch (_) { /* sección de demanda queda vacía */ }

const fcUnits: any[]  = forecast.units ?? [];
const fcRevenue: any  = forecast.revenue;
const fcGeneratedAt   = forecast.generated_at;
const revenueMax = fcRevenue
  ? Math.max(1, ...fcRevenue.points.map((p: any) => p.upper_bound ?? p.forecast_value))
  : 1;
const MODEL_LABEL: Record<string, string> = { holt: "Holt", moving_avg: "Media móvil" };
const fmtCOP  = (n: number) => new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n || 0);
const fmtWeek = (s: string) => new Date(s + "T00:00:00").toLocaleDateString("es-CO", { day: "2-digit", month: "short" });
---

<AdminLayout title="Estadísticas — DobleYo Admin">

  <style>
    .page-header {
      padding: 1.75rem 2rem 1.5rem;
      background: #fff;
      border-bottom: 1px solid rgba(0,0,0,.08);
    }
    .page-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: #251a14;
      margin: 0 0 0.3rem;
    }
    .page-header p { margin: 0; color: #7a6652; font-size: 0.95rem; }
    .page-body { padding: 1.75rem 2rem 2rem; }

    .stat-error {
      background: #ffeaea;
      border: 1px solid var(--c-error-border, #f5bcbc);
      color: var(--c-error, #aa0000);
      padding: 0.875rem 1.25rem;
      border-radius: 6px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: #fff;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      border-radius: 6px;
      box-shadow: var(--card-shadow, 0 0 0 1px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.05));
      padding: 1.25rem 1.5rem;
    }
    .stat-card h3 {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-2, #6a6d70);
      margin: 0 0 0.75rem;
    }
    .stat-empty { color: var(--text-3, #a9b0b8); font-size: 0.88rem; text-align: center; padding: 1.5rem 0; }

    .bar-chart {
      height: 180px;
      display: flex;
      align-items: flex-end;
      gap: 0.4rem;
      border-bottom: 2px solid var(--border, rgba(0,0,0,.09));
      padding-bottom: 0.4rem;
    }
    .bar-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      height: 100%;
      justify-content: flex-end;
    }
    .bar-count { font-size: 0.7rem; font-weight: 700; color: #7a6652; }
    .bar-fill { width: 100%; border-radius: 3px 3px 0 0; }
    .bar-label { font-size: 0.7rem; color: var(--text-2, #6a6d70); }

    .progress-row { margin-bottom: 0.75rem; }
    .progress-row__header { display: flex; justify-content: space-between; margin-bottom: 0.3rem; font-size: 0.84rem; }
    .progress-row__label { color: var(--text-1, #32363a); }
    .progress-row__value { color: var(--text-2, #6a6d70); font-weight: 600; }
    .progress-bar { background: var(--border, rgba(0,0,0,.09)); border-radius: 9999px; height: 6px; overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 9999px; }

    .pipeline-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0.75rem;
      background: #faf8f5;
      border-radius: 4px;
      margin-bottom: 0.5rem;
      font-size: 0.875rem;
    }
    .pipeline-item__count { font-weight: 700; color: #7a6652; }

    .section-divider {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin: 2.5rem 0 1.25rem;
      padding-top: 1.75rem;
      border-top: 2px solid var(--border, rgba(0,0,0,.09));
    }
    .section-divider h2 { font-size: 1.25rem; font-weight: 700; color: #251a14; margin: 0; }
    .section-divider p  { margin: .2rem 0 0; color: #7a6652; font-size: .85rem; }
    .fc-meta { font-size: .78rem; color: var(--text-3, #a9b0b8); }

    .btn-recalc {
      background: #c8a96e;
      color: #251a14;
      border: 0;
      border-radius: 6px;
      padding: .55rem 1.1rem;
      font-size: .85rem;
      font-weight: 700;
      cursor: pointer;
      transition: filter .15s;
    }
    .btn-recalc:hover:not(:disabled) { filter: brightness(.95); }
    .btn-recalc:disabled { opacity: .6; cursor: progress; }
    .fc-status { font-size: .8rem; margin-left: .75rem; color: #7a6652; }

    .badge {
      display: inline-block;
      padding: .15rem .5rem;
      border-radius: 9999px;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .02em;
    }
    .badge--warn  { background: #fbe7d2; color: #8a5a00; }
    .badge--ok    { background: #dff0e4; color: #2d6a4f; }
    .badge--muted { background: var(--border, rgba(0,0,0,.08)); color: var(--text-2, #6a6d70); }

    .fc-note {
      background: #faf8f5;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      border-left: 3px solid #c8a96e;
      border-radius: 4px;
      padding: .7rem 1rem;
      font-size: .82rem;
      color: #6a5a48;
      margin-top: 1rem;
    }
  </style>

  <header class="page-header">
    <h1>Estadísticas de Producción</h1>
    <p>Métricas de calidad y rendimiento de los lotes</p>
  </header>

  <div class="page-body">

    {fetchError && (
      <div class="stat-error">
        No se pudo conectar con la base de datos. Mostrando datos parciales.
      </div>
    )}

    <!-- KPIs -->
    <div class="kpi-grid">
      <div class="kpi-tile brand">
        <div class="kpi-label">Lotes Registrados</div>
        <div class="kpi-value">{totalLotes}</div>
        <div class="kpi-sub">cosechas en BD</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Calidad Promedio</div>
        <div class="kpi-value">{avgScore ?? "—"}</div>
        <div class="kpi-sub">puntos (escala 1–5)</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Lotes Empacados</div>
        <div class="kpi-value">{totalEmpacados}</div>
        <div class="kpi-sub">listos para venta</div>
      </div>
      <div class="kpi-tile warning">
        <div class="kpi-label">Kg Empacados</div>
        <div class="kpi-value">{totalKgEmpacado > 0 ? totalKgEmpacado.toFixed(1) : "—"}</div>
        <div class="kpi-sub">kg estimados</div>
      </div>
    </div>

    <!-- Gráficas -->
    <div class="charts-grid">
      <div class="stat-card">
        <h3>Lotes por Mes (últimos 6 meses)</h3>
        {harvests.length === 0 ? (
          <p class="stat-empty">Sin datos de cosechas aún.</p>
        ) : (
          <div class="bar-chart">
            {last6.map((m) => {
              const count = monthCounts[m.key] ?? 0;
              const pct   = Math.round((count / maxMonthCount) * 100);
              return (
                <div class="bar-col">
                  {count > 0 && <span class="bar-count">{count}</span>}
                  <div class="bar-fill" style={`background:${pct > 0 ? '#c8a96e' : 'var(--border)'}; height:${Math.max(pct, 2)}%;`}></div>
                  <span class="bar-label">{m.label}</span>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <div class="stat-card">
        <h3>Distribución de Calidad</h3>
        {scoresValidos.length === 0 ? (
          <p class="stat-empty">Sin lotes empacados con puntaje aún.</p>
        ) : (
          qDist.map((d) => (
            <div class="progress-row">
              <div class="progress-row__header">
                <span class="progress-row__label">{d.label}</span>
                <span class="progress-row__value">{d.count} ({Math.round(d.count / scoresValidos.length * 100)}%)</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`background:${d.color}; width:${Math.round(d.count / maxQDist * 100)}%;`}></div>
              </div>
            </div>
          ))
        )}
      </div>
    </div>

    <div class="charts-grid">
      <div class="stat-card">
        <h3>Variedades Cultivadas</h3>
        {topVarieties.length === 0 ? (
          <p class="stat-empty">Sin datos de cosechas aún.</p>
        ) : (
          topVarieties.map((v) => (
            <div class="progress-row">
              <div class="progress-row__header">
                <span class="progress-row__label" style="font-weight:600">{v.name}</span>
                <span class="progress-row__value">{v.count} lotes · {v.pct}%</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`background:#c8a96e; width:${v.pct}%;`}></div>
              </div>
            </div>
          ))
        )}
      </div>

      <div class="stat-card">
        <h3>Pipeline de Lotes</h3>
        {pipelineStages.length === 0 ? (
          <p class="stat-empty">Sin lotes en pipeline.</p>
        ) : (
          pipelineStages.map((s) => (
            <div class="pipeline-item">
              <span>{s.label}</span>
              <span class="pipeline-item__count">{s.count}</span>
            </div>
          ))
        )}
      </div>
    </div>

    <!-- Últimas cosechas -->
    {harvests.length > 0 && (
      <div class="table-wrap" style="background:#fff; border-radius:6px; border:1px solid var(--border,rgba(0,0,0,.09)); box-shadow:var(--card-shadow); overflow-x:auto;">
        <div style="padding:1rem 1.25rem; border-bottom:1px solid var(--border,rgba(0,0,0,.09));">
          <span style="font-size:0.85rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--text-2,#6a6d70);">Últimas Cosechas</span>
        </div>
        <table class="erp-table">
          <thead>
            <tr>
              <th>Lote</th>
              <th>Variedad</th>
              <th>Proceso</th>
              <th>Clima</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            {harvests.slice(0, 8).map((h: any) => (
              <tr>
                <td style="font-family:monospace; font-size:0.8rem;">{h.lot_id}</td>
                <td>{VARIETY_LABEL[h.variety] ?? h.variety ?? "—"}</td>
                <td>{h.process ?? "—"}</td>
                <td>{h.climate ?? "—"}</td>
                <td>
                  {h.created_at ? new Date(h.created_at).toLocaleDateString("es-CO", { day:"2-digit", month:"short", year:"numeric" }) : "—"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- ─── Pronóstico de Demanda (Python) ──────────────────────────────── -->
    <div class="section-divider">
      <div>
        <h2>Pronóstico de Demanda</h2>
        <p>Proyección de las próximas 8 semanas desde ventas de MercadoLibre · calculado con Python</p>
        {fcGeneratedAt && (
          <span class="fc-meta">
            Última actualización: {new Date(fcGeneratedAt + " UTC").toLocaleString("es-CO", { dateStyle: "medium", timeStyle: "short" })}
          </span>
        )}
      </div>
      <div>
        <button id="btn-recalc" class="btn-recalc" type="button">Recalcular ahora</button>
        <span id="fc-status" class="fc-status"></span>
      </div>
    </div>

    {(!fcRevenue && fcUnits.length === 0) && (
      <div class="stat-card">
        <p class="stat-empty">
          Aún no hay pronóstico. Pulse <strong>«Recalcular ahora»</strong> o espere a la corrida automática nocturna.
          Requiere ventas registradas en MercadoLibre.
        </p>
      </div>
    )}

    {(fcRevenue || fcUnits.length > 0) && (
      <Fragment>
        {fcRevenue && (
          <div class="kpi-grid">
            <div class="kpi-tile brand">
              <div class="kpi-label">Ingresos proyectados (4 sem)</div>
              <div class="kpi-value" style="font-size:1.4rem">{fmtCOP(fcRevenue.next_4w)}</div>
              <div class="kpi-sub">modelo: {MODEL_LABEL[fcRevenue.model_used] ?? fcRevenue.model_used}</div>
            </div>
            <div class="kpi-tile info">
              <div class="kpi-label">SKUs con demanda</div>
              <div class="kpi-value">{fcUnits.length}</div>
              <div class="kpi-sub">productos pronosticados</div>
            </div>
            <div class="kpi-tile warning">
              <div class="kpi-label">Sugerencias de reorden</div>
              <div class="kpi-value">{fcUnits.filter((u: any) => u.reorder).length}</div>
              <div class="kpi-sub">demanda 4 sem &gt; stock</div>
            </div>
            <div class="kpi-tile success">
              <div class="kpi-label">Historia usada</div>
              <div class="kpi-value">{fcRevenue.history_weeks ?? "—"}</div>
              <div class="kpi-sub">semanas de ventas</div>
            </div>
          </div>
        )}

        <div class="charts-grid">
          {fcRevenue && (
            <div class="stat-card">
              <h3>Ingresos proyectados por semana</h3>
              <div class="bar-chart">
                {fcRevenue.points.map((p: any) => {
                  const pct = Math.round(((p.forecast_value ?? 0) / revenueMax) * 100);
                  return (
                    <div class="bar-col" title={`${fmtCOP(p.lower_bound)} – ${fmtCOP(p.upper_bound)}`}>
                      <div class="bar-fill" style={`background:#c8a96e; height:${Math.max(pct, 2)}%;`}></div>
                      <span class="bar-label">{fmtWeek(p.period_start)}</span>
                    </div>
                  );
                })}
              </div>
              <p class="fc-meta" style="margin-top:.6rem">Pase el cursor sobre cada barra para ver la banda de confianza (~95%).</p>
            </div>
          )}

          <div class="stat-card">
            <h3>Demanda por producto (próximas 4 semanas)</h3>
            {fcUnits.length === 0 ? (
              <p class="stat-empty">Sin demanda por SKU en la última corrida.</p>
            ) : (
              <div style="overflow-x:auto">
                <table class="erp-table">
                  <thead>
                    <tr>
                      <th>Producto</th>
                      <th style="text-align:right">Unidades (4 sem)</th>
                      <th>Stock</th>
                      <th>Reorden</th>
                      <th>Modelo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {fcUnits.slice(0, 12).map((u: any) => (
                      <tr>
                        <td>{u.product_key}</td>
                        <td style="text-align:right; font-weight:700">{u.next_4w}</td>
                        <td>{u.stock_quantity ?? "—"}</td>
                        <td>
                          {u.reorder === true ? (
                            <span class="badge badge--warn">Reordenar</span>
                          ) : u.reorder === false ? (
                            <span class="badge badge--ok">OK</span>
                          ) : (
                            <span class="badge badge--muted">sin match</span>
                          )}
                        </td>
                        <td><span class="badge badge--muted">{MODEL_LABEL[u.model_used] ?? u.model_used}</span></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>

        <div class="fc-note">
          <strong>Nota:</strong> el pronóstico es orientativo. Con MercadoLibre como única fuente y un historial corto,
          úselo como guía de tendencia, no como cifra exacta. La señal de reorden empareja el título del producto de
          MercadoLibre con el catálogo por nombre (best-effort); «sin match» significa que no se encontró en el inventario.
        </div>
      </Fragment>
    )}

  </div>

  <script>
    const btn = document.getElementById("btn-recalc") as HTMLButtonElement | null;
    const status = document.getElementById("fc-status");
    btn?.addEventListener("click", async () => {
      if (!status) return;
      btn.disabled = true;
      status.textContent = "Calculando…";
      try {
        const r = await fetch("/api/ml/forecast/recompute", { method: "POST", credentials: "include" });
        const j = await r.json();
        if (r.ok && j.success) {
          status.textContent = `Listo: ${j.data?.rows_written ?? 0} filas. Recargando…`;
          setTimeout(() => location.reload(), 900);
        } else {
          status.textContent = j.error || "No se pudo recalcular.";
          btn.disabled = false;
        }
      } catch {
        status.textContent = "Error de red al recalcular.";
        btn.disabled = false;
      }
    });
  </script>
</AdminLayout>
