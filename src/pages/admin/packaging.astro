---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Preparar para Venta — DobleYo">
  <!-- ── Encabezado de página ──────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">Producción · Empaque</div>
        <h1 class="page-title">Preparar para Venta</h1>
        <p class="page-subtitle">
          Defina el perfil de taza del café tostado y conviértalo en unidades
          listas para empaque e inventario.
        </p>
      </div>
      <div class="page-header-actions">
        <button type="button" class="btn btn-secondary" id="refreshBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
          Actualizar
        </button>
      </div>
    </div>
  </div>

  <div class="erp-body">
    <!-- ── KPIs ──────────────────────────────────────────────────────── -->
    <div class="kpi-grid" style="margin-bottom: 22px;">
      <div class="kpi-tile brand">
        <div class="kpi-label">Cafés tostados disponibles</div>
        <div class="kpi-value" id="kpiRoasted">—</div>
        <div class="kpi-sub">Listos para empacar</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Peso disponible</div>
        <div class="kpi-value" id="kpiWeight">—</div>
        <div class="kpi-sub">Total en bodega de tostado</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Lotes preparados</div>
        <div class="kpi-value" id="kpiPackaged">—</div>
        <div class="kpi-sub">Listos para la venta</div>
      </div>
      <div class="kpi-tile warning">
        <div class="kpi-label">Unidades empacadas</div>
        <div class="kpi-value" id="kpiUnits">—</div>
        <div class="kpi-sub">Acumulado</div>
      </div>
    </div>

    <!-- ── Workbench: formulario + plan de empaque ───────────────────── -->
    <div class="pkg-grid">
      <!-- Columna izquierda: formulario -->
      <section class="card">
        <div class="card-header">
          <div>
            <h3 class="card-title">Configuración del empaque</h3>
            <div class="card-subtitle">Perfil de taza y presentación del producto</div>
          </div>
        </div>
        <div class="card-pad">
          <form id="packagingForm">
            <!-- Selección de Café Tostado -->
            <div class="form-group">
              <label for="roastedSelect">
                Café tostado disponible <span class="required">*</span>
              </label>
              <select id="roastedSelect" name="roasted" required>
                <option value="">Seleccione un café…</option>
              </select>
              <div class="form-hint">Cafés tostados listos para empacar.</div>
            </div>

            <!-- Info del Café -->
            <div class="lot-info" id="coffeeInfoCard" hidden>
              <div class="form-section"><h3>Información del café</h3></div>
              <div class="detail-grid">
                <div class="detail-item">
                  <dt>Lote ID</dt><dd id="coffeeLotId">—</dd>
                </div>
                <div class="detail-item">
                  <dt>Variedad</dt><dd id="coffeeVariety">—</dd>
                </div>
                <div class="detail-item">
                  <dt>Tueste</dt><dd id="coffeeRoastLevel">—</dd>
                </div>
                <div class="detail-item">
                  <dt>Peso disponible</dt>
                  <dd style="color: var(--color-accent);" id="coffeeAvailableWeight">—</dd>
                </div>
              </div>
              <div class="info-box" id="originInfo" hidden style="margin-top: 14px;">
                <strong>📍 Origen</strong>
                <div class="origin-grid">
                  <div><span>Finca</span><b id="originFarm">—</b></div>
                  <div><span>Región</span><b id="originRegion">—</b></div>
                  <div><span>Altura</span><b id="originAltitude">—</b></div>
                  <div><span>Aroma</span><b id="originAroma">—</b></div>
                  <div class="origin-wide"><span>Notas</span><b id="originNotes">—</b></div>
                </div>
              </div>
            </div>

            <!-- Propiedades de Cata -->
            <div class="form-section"><h3>☕ Propiedades de cata</h3></div>

            <div class="slider-field">
              <label for="acidity">
                Acidez <span class="required">*</span>
                <span class="slider-value" id="acidityValue">3/5</span>
              </label>
              <input type="range" id="acidity" name="acidity" min="1" max="5" value="3" />
              <div class="slider-scale"><span>Baja</span><span>Media</span><span>Alta</span></div>
            </div>

            <div class="slider-field">
              <label for="body">
                Cuerpo <span class="required">*</span>
                <span class="slider-value" id="bodyValue">3/5</span>
              </label>
              <input type="range" id="body" name="body" min="1" max="5" value="3" />
              <div class="slider-scale"><span>Ligero</span><span>Medio</span><span>Pesado</span></div>
            </div>

            <div class="slider-field">
              <label for="balance">
                Balance <span class="required">*</span>
                <span class="slider-value" id="balanceValue">3/5</span>
              </label>
              <input type="range" id="balance" name="balance" min="1" max="5" value="3" />
              <div class="slider-scale"><span>Desbalanceado</span><span>Equilibrado</span><span>Muy balanceado</span></div>
            </div>

            <!-- Presentación -->
            <div class="form-section"><h3>📏 Presentación</h3></div>

            <div class="form-group">
              <label>Tipo de presentación <span class="required">*</span></label>
              <div class="radio-group">
                <label class="radio-item">
                  <input type="radio" name="presentation" value="GRANO" required />
                  <span>🫘 Grano entero</span>
                </label>
                <label class="radio-item">
                  <input type="radio" name="presentation" value="MOLIDO" required />
                  <span>☕ Molido</span>
                </label>
              </div>
            </div>

            <div class="form-group" id="grindingGroup" hidden>
              <label for="grindSize">Tipo de molienda <span class="required">*</span></label>
              <select id="grindSize" name="grindSize">
                <option value="">Seleccione tipo de molienda</option>
                <option value="EXTRA-FINE">Extra fina (Espresso)</option>
                <option value="FINE">Fina (Aeropress, Moka)</option>
                <option value="MEDIUM-FINE">Media-fina (V60, Chemex)</option>
                <option value="MEDIUM">Media (Prensa francesa)</option>
                <option value="COARSE">Gruesa (Cafetera de goteo)</option>
              </select>
              <div class="form-hint">Solo aplica si seleccionó presentación molida.</div>
            </div>

            <div class="form-grid">
              <div class="form-group">
                <label for="packageQuantity">
                  Cantidad para empacar <span class="required">*</span>
                </label>
                <div class="input-row">
                  <input
                    type="number" id="packageQuantity" name="packageQuantity"
                    placeholder="Ej: 15" step="0.1" min="0" required
                  />
                  <select id="packageUnit" name="packageUnit" class="unit-select">
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                  </select>
                </div>
                <div class="form-hint" id="quantityHint">Máximo disponible: —</div>
              </div>

              <div class="form-group">
                <label for="packageSize">
                  Tamaño individual <span class="required">*</span>
                </label>
                <select id="packageSize" name="packageSize" required>
                  <option value="">Seleccione tamaño</option>
                  <option value="250g">250g · Bolsa pequeña</option>
                  <option value="500g">500g · Bolsa regular</option>
                  <option value="1kg">1kg · Bolsa grande</option>
                  <option value="100g">100g · Muestra</option>
                  <option value="bulk">A granel (kilos enteros)</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="unitCount">
                <span id="unitCountLabel">Cantidad de unidades a empacar</span>
                <span class="required">*</span>
              </label>
              <input
                type="number" id="unitCount" name="unitCount"
                placeholder="Ej: 60 unidades de 250g" step="1" min="1" required
              />
              <div class="form-hint" id="unitHint">Se calcula automáticamente.</div>
            </div>

            <div class="form-group">
              <label for="notes">Notas del empaque</label>
              <textarea
                id="notes" name="notes" rows="3" maxlength="500"
                placeholder="Observaciones del proceso, destino del lote, responsable…"
              ></textarea>
              <div class="form-hint">Opcional. Queda registrado junto al lote empacado.</div>
            </div>

            <label class="checkbox-item" style="margin-top: 8px;">
              <input type="checkbox" id="addToInventory" name="addToInventory" checked />
              <span>📦 Sumar unidades al inventario disponible</span>
            </label>
            <div class="form-hint" style="margin-top: 6px;">
              Crea un producto y registra el stock inmediatamente en inventario.
            </div>

            <div class="form-actions">
              <button type="reset" class="btn btn-secondary">Limpiar</button>
              <button type="submit" class="btn btn-save" id="submitBtn">
                Preparar para venta
              </button>
            </div>
          </form>
        </div>
      </section>

      <!-- Columna derecha: plan de empaque en vivo -->
      <aside class="pkg-side">
        <section class="card">
          <div class="card-header">
            <div>
              <h3 class="card-title">Plan de empaque</h3>
              <div class="card-subtitle">Resumen en tiempo real</div>
            </div>
            <span class="badge badge-neutral" id="planScore">—</span>
          </div>
          <div class="card-pad">
            <!-- Estado vacío -->
            <div class="plan-empty" id="planEmpty">
              <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>
              </svg>
              <p><b>Seleccione un café</b><br />Elija un café tostado para ver el plan de empaque.</p>
            </div>

            <!-- Plan -->
            <div id="planBody" hidden>
              <div class="plan-facet">
                <span class="plan-lot" id="planLot">—</span>
                <span class="badge badge-brand" id="planRoast">—</span>
              </div>
              <div class="plan-sub" id="planMeta">—</div>

              <div class="plan-profile">
                <div class="pv-row">
                  <span class="pv-k">Acidez</span>
                  <div class="pv-bars" data-bar="acidity"><i></i><i></i><i></i><i></i><i></i></div>
                </div>
                <div class="pv-row">
                  <span class="pv-k">Cuerpo</span>
                  <div class="pv-bars" data-bar="body"><i></i><i></i><i></i><i></i><i></i></div>
                </div>
                <div class="pv-row">
                  <span class="pv-k">Balance</span>
                  <div class="pv-bars" data-bar="balance"><i></i><i></i><i></i><i></i><i></i></div>
                </div>
              </div>

              <div class="plan-list">
                <div class="plan-row"><span>Presentación</span><b id="planPresentation">—</b></div>
                <div class="plan-row" id="planGrindRow" hidden><span>Molienda</span><b id="planGrind">—</b></div>
                <div class="plan-row"><span>Tamaño</span><b id="planSize">—</b></div>
                <div class="plan-row"><span>Unidades</span><b id="planUnits">—</b></div>
                <div class="plan-row"><span>Peso a usar</span><b id="planUsed">—</b></div>
                <div class="plan-row"><span>Peso restante</span><b id="planRemaining">—</b></div>
                <div class="plan-row"><span>Inventario</span><b id="planInventory">—</b></div>
              </div>
            </div>
          </div>
        </section>
      </aside>
    </div>

    <!-- ── Empaques recientes ────────────────────────────────────────── -->
    <section class="card" style="margin-top: 22px;">
      <div class="card-header">
        <div>
          <h3 class="card-title">Empaques recientes</h3>
          <div class="card-subtitle">Últimos lotes preparados para venta</div>
        </div>
      </div>
      <div class="table-wrapper">
        <table class="erp-table">
          <thead>
            <tr>
              <th>Presentación</th>
              <th>Molienda</th>
              <th>Tamaño</th>
              <th>Unidades</th>
              <th>Puntaje</th>
              <th>Notas</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody id="recentBody">
            <tr><td colspan="6" class="empty-state">Cargando…</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <!-- Toasts -->
  <div class="toast-stack" id="toastStack" aria-live="polite"></div>

  <script>
    // ── Estado / refs ───────────────────────────────────────────────
    const roastedSelect = document.getElementById("roastedSelect");
    const presentationRadios = document.querySelectorAll('input[name="presentation"]');
    const grindingGroup = document.getElementById("grindingGroup");
    const form = document.getElementById("packagingForm");
    const coffeeInfoCard = document.getElementById("coffeeInfoCard");
    const originInfo = document.getElementById("originInfo");

    const packageSizeWeights = { "250g": 0.25, "500g": 0.5, "1kg": 1, "100g": 0.1 };
    let currentRoasted = null;

    // ── Toast ───────────────────────────────────────────────────────
    function toast(message, type = "info") {
      const stack = document.getElementById("toastStack");
      const el = document.createElement("div");
      el.className = `toast toast--${type}`;
      el.textContent = message;
      stack.appendChild(el);
      requestAnimationFrame(() => el.classList.add("is-in"));
      setTimeout(() => {
        el.classList.remove("is-in");
        setTimeout(() => el.remove(), 250);
      }, 4000);
    }

    // ── Helpers ─────────────────────────────────────────────────────
    function roastLabel(level) {
      return level === "LIGHT" ? "Clara"
        : level === "MEDIUM" ? "Media"
        : level === "DARK" ? "Oscura"
        : level || "Por especificar";
    }
    function availWeight(item) {
      return Number(item?.weight_kg || item?.remaining_weight || 0);
    }
    function esc(s) {
      if (s == null) return "";
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c])
      );
    }
    function setBars(name, value) {
      const wrap = document.querySelector(`.pv-bars[data-bar="${name}"]`);
      if (!wrap) return;
      const v = parseInt(value) || 0;
      wrap.querySelectorAll("i").forEach((b, i) => b.classList.toggle("is-on", i < v));
    }

    // ── Carga de cafés tostados ─────────────────────────────────────
    async function loadRoastedLots() {
      try {
        const response = await fetch("/api/coffee/roasted-coffee", {
          credentials: "include",
          headers: { "Content-Type": "application/json" },
        });
        if (!response.ok) {
          const err = await response.json().catch(() => ({}));
          throw new Error(err.error || "Error al cargar cafés");
        }
        const roastedLots = await response.json();

        roastedSelect.innerHTML = '<option value="">Seleccione un café…</option>';
        if (roastedLots.length === 0) {
          const opt = document.createElement("option");
          opt.value = "";
          opt.textContent = "No hay cafés tostados disponibles";
          opt.disabled = true;
          roastedSelect.appendChild(opt);
          return;
        }
        roastedLots.forEach((item) => {
          const opt = document.createElement("option");
          opt.value = JSON.stringify(item);
          opt.textContent = `${item.lot_id || "Desconocido"} · ${roastLabel(item.roast_level)} (${availWeight(item)} kg)`;
          roastedSelect.appendChild(opt);
        });
      } catch (error) {
        console.error("[Packaging] Error cargando cafés:", error);
        toast("Error al cargar cafés tostados", "error");
      }
    }

    // ── KPIs ────────────────────────────────────────────────────────
    // Totales agregados en SQL: las listas están topadas a 100 filas y no
    // sirven para calcular acumulados.
    async function loadStats() {
      const setAll = (v) =>
        ["kpiRoasted", "kpiWeight", "kpiPackaged", "kpiUnits"].forEach(
          (id) => (document.getElementById(id).textContent = v)
        );
      try {
        const res = await fetch("/api/coffee/packaging-stats", { credentials: "include" });
        if (!res.ok) throw new Error("stats");
        const { data } = await res.json();
        document.getElementById("kpiRoasted").textContent = data.roastedLots;
        document.getElementById("kpiWeight").textContent = `${data.roastedKg.toFixed(1)} kg`;
        document.getElementById("kpiPackaged").textContent = data.packagedBatches;
        document.getElementById("kpiUnits").textContent = data.packagedBulkKg > 0
          ? `${data.packagedUnits} + ${data.packagedBulkKg} kg`
          : data.packagedUnits;
      } catch (error) {
        console.error("[Packaging] Error cargando estadísticas:", error);
        setAll("—");
      }
    }

    // ── Empaques recientes ──────────────────────────────────────────
    async function loadPackaged() {
      try {
        const res = await fetch("/api/coffee/packaged", { credentials: "include" });
        const rows = res.ok ? await res.json() : [];
        renderRecent(rows.slice(0, 8));
      } catch (error) {
        console.error("[Packaging] Error cargando empacados:", error);
        renderRecent([]);
      }
    }

    function renderRecent(rows) {
      const body = document.getElementById("recentBody");
      if (!rows.length) {
        body.innerHTML =
          '<tr><td colspan="6" class="empty-state">Aún no hay empaques preparados.</td></tr>';
        return;
      }
      body.innerHTML = rows
        .map((r) => {
          const pres = r.presentation === "GRANO" ? "Grano entero"
            : r.presentation === "MOLIDO" ? "Molido" : (r.presentation || "—");
          const date = r.created_at
            ? new Date(r.created_at).toLocaleDateString("es-CO", { day: "2-digit", month: "short", year: "numeric" })
            : "—";
          return `
        <tr>
          <td>${esc(pres)}</td>
          <td>${esc(r.grind_size) || "—"}</td>
          <td>${esc(r.package_size) || "—"}</td>
          <td style="font-variant-numeric: tabular-nums;">${r.unit_count ?? "—"}</td>
          <td style="font-variant-numeric: tabular-nums;">${r.score != null ? r.score + "/5" : "—"}</td>
          <td>${esc(date)}</td>
        </tr>`;
        })
        .join("");
    }

    // ── Selección de café ───────────────────────────────────────────
    roastedSelect.addEventListener("change", () => {
      if (!roastedSelect.value) {
        currentRoasted = null;
        coffeeInfoCard.hidden = true;
        updatePlan();
        return;
      }
      currentRoasted = JSON.parse(roastedSelect.value);

      document.getElementById("coffeeLotId").textContent = currentRoasted.lot_id || "—";
      document.getElementById("coffeeVariety").textContent = currentRoasted.variety || "—";
      document.getElementById("coffeeRoastLevel").textContent = roastLabel(currentRoasted.roast_level);

      const weight = availWeight(currentRoasted);
      document.getElementById("coffeeAvailableWeight").textContent = `${weight} kg`;
      syncQuantityMax();

      const farm = (currentRoasted.farm_name || currentRoasted.farm || "").trim();
      const region = (currentRoasted.region || "").trim();
      const altitude = currentRoasted.altitude || 0;
      const aroma = (currentRoasted.aroma || "").trim();
      const notes = (currentRoasted.taste_notes || currentRoasted.notes || "").trim();

      document.getElementById("originFarm").textContent = farm || "—";
      document.getElementById("originRegion").textContent = region || "—";
      document.getElementById("originAltitude").textContent = altitude > 0 ? `${altitude} m` : "—";
      document.getElementById("originAroma").textContent = aroma || "—";
      document.getElementById("originNotes").textContent = notes || "—";
      originInfo.hidden = !(farm || region || altitude || aroma || notes);

      coffeeInfoCard.hidden = false;
      updatePlan();
    });

    // ── Molienda condicional ────────────────────────────────────────
    presentationRadios.forEach((radio) => {
      radio.addEventListener("change", () => {
        grindingGroup.hidden = radio.value !== "MOLIDO";
        if (radio.value === "GRANO") document.getElementById("grindSize").value = "";
        updatePlan();
      });
    });

    // ── Sliders ─────────────────────────────────────────────────────
    ["acidity", "body", "balance"].forEach((id) => {
      document.getElementById(id).addEventListener("input", (e) => {
        document.getElementById(`${id}Value`).textContent = `${e.target.value}/5`;
        updatePlan();
      });
    });

    // ── Cálculo de unidades ─────────────────────────────────────────
    // Peso realmente consumido: el backend lo deriva de unitCount, no de
    // "Cantidad para empacar" (esta última solo sirve para autocalcular).
    function consumedKg() {
      const size = document.getElementById("packageSize").value;
      const units = parseInt(document.getElementById("unitCount").value) || 0;
      if (!size || units <= 0) return 0;
      // A granel, cada unidad equivale a 1 kg.
      const sizeInKg = size === "bulk" ? 1 : packageSizeWeights[size];
      return Math.round(units * sizeInKg * 1000) / 1000;
    }

    // El atributo max debe expresarse en la unidad seleccionada (kg o g),
    // de lo contrario la validación nativa bloquea valores válidos en gramos.
    function syncQuantityMax() {
      const maxKg = availWeight(currentRoasted);
      const unit = document.getElementById("packageUnit").value;
      const input = document.getElementById("packageQuantity");
      if (!currentRoasted) {
        input.removeAttribute("max");
        document.getElementById("quantityHint").textContent = "Máximo disponible: —";
        return;
      }
      const max = unit === "g" ? maxKg * 1000 : maxKg;
      input.max = max;
      document.getElementById("quantityHint").textContent = `Máximo disponible: ${max} ${unit}`;
    }

    function updateUnitCount() {
      const packageSize = document.getElementById("packageSize").value;
      const packageQuantity = parseFloat(document.getElementById("packageQuantity").value) || 0;
      const packageUnit = document.getElementById("packageUnit").value;
      const unitCountEl = document.getElementById("unitCount");
      const isBulk = packageSize === "bulk";

      document.getElementById("unitCountLabel").textContent = isBulk
        ? "Kilos a empacar a granel"
        : "Cantidad de unidades a empacar";
      unitCountEl.placeholder = isBulk ? "Ej: 12 kg" : "Ej: 60 unidades de 250g";

      syncQuantityMax();

      if (!packageSize || packageQuantity <= 0) {
        unitCountEl.value = "";
        document.getElementById("unitHint").textContent = "Se calcula automáticamente.";
        updatePlan();
        return;
      }

      let quantityInKg = packageUnit === "g" ? packageQuantity / 1000 : packageQuantity;
      const maxKg = availWeight(currentRoasted);
      if (currentRoasted && quantityInKg > maxKg) {
        toast(`La cantidad no puede exceder ${maxKg} kg disponibles`, "error");
        document.getElementById("packageQuantity").value =
          packageUnit === "g" ? maxKg * 1000 : maxKg;
        quantityInKg = maxKg;
      }

      // A granel el backend interpreta unitCount como kilos enteros.
      const sizeInKg = isBulk ? 1 : packageSizeWeights[packageSize];
      const units = Math.floor(quantityInKg / sizeInKg);
      unitCountEl.value = units;
      document.getElementById("unitHint").textContent = isBulk
        ? `${units} kg a granel (solo kilos enteros)`
        : `${units} unidades de ${packageSize} · ${consumedKg()} kg`;
      updatePlan();
    }
    ["packageQuantity", "packageUnit", "packageSize"].forEach((id) => {
      const el = document.getElementById(id);
      el.addEventListener(id === "packageQuantity" ? "input" : "change", updateUnitCount);
    });
    document.getElementById("unitCount").addEventListener("input", updatePlan);
    document.getElementById("grindSize").addEventListener("change", updatePlan);
    document.getElementById("addToInventory").addEventListener("change", updatePlan);

    // ── Plan de empaque en vivo ─────────────────────────────────────
    function updatePlan() {
      const empty = document.getElementById("planEmpty");
      const planBody = document.getElementById("planBody");

      if (!currentRoasted) {
        empty.hidden = false;
        planBody.hidden = true;
        document.getElementById("planScore").textContent = "—";
        return;
      }
      empty.hidden = true;
      planBody.hidden = false;

      const acidity = document.getElementById("acidity").value;
      const body = document.getElementById("body").value;
      const balance = document.getElementById("balance").value;
      const score = ((+acidity + +body + +balance) / 3).toFixed(1);

      document.getElementById("planLot").textContent = currentRoasted.lot_id || "—";
      document.getElementById("planRoast").textContent = roastLabel(currentRoasted.roast_level);
      const meta = [currentRoasted.variety, currentRoasted.region].filter(Boolean).join(" · ");
      document.getElementById("planMeta").textContent =
        `${meta || "Sin datos de origen"} · ${availWeight(currentRoasted)} kg disponibles`;
      document.getElementById("planScore").textContent = `${score}/5`;

      setBars("acidity", acidity);
      setBars("body", body);
      setBars("balance", balance);

      const presentation = document.querySelector('input[name="presentation"]:checked')?.value;
      const grind = document.getElementById("grindSize").value;
      const size = document.getElementById("packageSize").value;
      const units = document.getElementById("unitCount").value;
      const used = consumedKg();
      const availableKg = availWeight(currentRoasted);

      document.getElementById("planPresentation").textContent =
        presentation === "GRANO" ? "Grano entero"
        : presentation === "MOLIDO" ? "Molido" : "—";
      const grindRow = document.getElementById("planGrindRow");
      grindRow.hidden = presentation !== "MOLIDO";
      document.getElementById("planGrind").textContent = grind || "Por especificar";
      document.getElementById("planSize").textContent = size || "—";
      document.getElementById("planUnits").textContent = units
        ? `${units} ${size === "bulk" ? "kg" : "unidades"}`
        : "—";
      document.getElementById("planUsed").textContent = used > 0 ? `${used} kg` : "—";
      document.getElementById("planRemaining").textContent =
        used > 0 ? `${Math.round((availableKg - used) * 1000) / 1000} kg` : `${availableKg} kg`;
      document.getElementById("planInventory").textContent =
        document.getElementById("addToInventory").checked ? "Sí, sumar stock" : "No";
    }

    // ── Envío ───────────────────────────────────────────────────────
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!currentRoasted) return toast("Debe seleccionar un café", "error");

      const presentation = document.querySelector('input[name="presentation"]:checked')?.value;
      const packageSize = document.getElementById("packageSize").value;
      const unitCount = parseInt(document.getElementById("unitCount").value);

      if (!presentation || !packageSize || !(unitCount > 0))
        return toast("Debe completar todos los campos requeridos", "error");
      if (presentation === "MOLIDO" && !document.getElementById("grindSize").value)
        return toast("Debe especificar el tipo de molienda", "error");

      const acidity = parseInt(document.getElementById("acidity").value);
      const body = parseInt(document.getElementById("body").value);
      const balance = parseInt(document.getElementById("balance").value);

      const submitBtn = document.getElementById("submitBtn");
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando…";

      try {
        const response = await fetch("/api/coffee/packaging", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            roastedStorageId: currentRoasted.id,
            acidity, body, balance,
            presentation,
            grindSize: presentation === "MOLIDO" ? document.getElementById("grindSize").value : null,
            packageSize,
            unitCount,
            notes: document.getElementById("notes").value.trim() || null,
            addToInventory: document.getElementById("addToInventory").checked,
          }),
        });

        if (!response.ok) {
          const error = await response.json().catch(() => ({}));
          let msg = error.error || error.message || "Error al preparar café";
          if (error.detail?.max_units !== undefined)
            msg += ` (máximo ${error.detail.max_units} unidades de ${error.detail.package_size})`;
          throw new Error(msg);
        }

        const data = await response.json();
        const extra = data.inventoryUpdated || data.inventoryMovementCreated
          ? " · stock sumado al inventario" : "";
        const cantidad = packageSize === "bulk"
          ? `${unitCount} kg a granel`
          : `${unitCount} unidades de ${packageSize}`;
        const restante = data.lotExhausted
          ? " · lote agotado"
          : data.remainingKg != null ? ` · quedan ${data.remainingKg} kg del lote` : "";
        toast(`Café preparado: ${cantidad} · puntaje ${data.score}/5${extra}${restante}`, "success");

        form.reset();
        currentRoasted = null;
        coffeeInfoCard.hidden = true;
        grindingGroup.hidden = true;
        ["acidityValue", "bodyValue", "balanceValue"].forEach(
          (id) => (document.getElementById(id).textContent = "3/5")
        );
        updatePlan();
        loadRoastedLots();
        loadPackaged();
        loadStats();
      } catch (error) {
        console.error("Error:", error);
        toast(error.message || "Error desconocido", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });

    form.addEventListener("reset", () => {
      setTimeout(() => {
        currentRoasted = null;
        coffeeInfoCard.hidden = true;
        grindingGroup.hidden = true;
        ["acidityValue", "bodyValue", "balanceValue"].forEach(
          (id) => (document.getElementById(id).textContent = "3/5")
        );
        updateUnitCount();
        updatePlan();
      }, 0);
    });

    document.getElementById("refreshBtn").addEventListener("click", () => {
      loadRoastedLots();
      loadPackaged();
      loadStats();
      toast("Datos actualizados", "info");
    });

    // ── Init ────────────────────────────────────────────────────────
    loadRoastedLots();
    loadPackaged();
    loadStats();
    updatePlan();
  </script>
</AdminLayout>

<style>
  /* ── Layout workbench ──────────────────────────────────────────── */
  .pkg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: start;
  }
  @media (min-width: 980px) {
    .pkg-grid { grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr); }
    .pkg-side { position: sticky; top: 16px; }
  }
  .card-pad { padding: 18px; }
  .lot-info[hidden] { display: none; }

  /* ── Origen ────────────────────────────────────────────────────── */
  .origin-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
    margin-top: 10px;
  }
  .origin-grid > div { display: flex; flex-direction: column; gap: 1px; }
  .origin-grid .origin-wide { grid-column: 1 / -1; }
  .origin-grid span {
    font-size: 11px; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .origin-grid b { font-size: 13px; color: var(--color-primary); font-weight: 600; }

  /* ── Input con unidad ──────────────────────────────────────────── */
  .input-row { display: flex; gap: 8px; }
  .input-row .unit-select { width: 84px; flex-shrink: 0; }

  /* ── Sliders ───────────────────────────────────────────────────── */
  .slider-field { margin-bottom: 18px; }
  .slider-field > label {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600; color: var(--color-primary);
    text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 10px;
  }
  .slider-value {
    margin-left: auto;
    background: var(--active-bg); color: var(--color-primary);
    padding: 2px 10px; border-radius: 999px;
    font-size: 12px; letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }
  .slider-field input[type="range"] {
    width: 100%; accent-color: var(--color-accent); cursor: pointer;
  }
  .slider-scale {
    display: flex; justify-content: space-between;
    margin-top: 6px; font-size: 11px; color: var(--muted);
  }

  /* ── Plan de empaque (panel) ───────────────────────────────────── */
  .plan-empty {
    text-align: center; color: var(--muted);
    padding: 28px 12px; display: grid; gap: 10px; justify-items: center;
  }
  .plan-empty p { margin: 0; font-size: 13px; line-height: 1.5; }
  .plan-empty b { color: var(--color-primary); }

  .plan-facet {
    display: flex; align-items: center; justify-content: space-between;
    gap: 10px; margin-bottom: 4px;
  }
  .plan-lot {
    font-size: 15px; font-weight: 700; color: var(--color-primary);
    font-family: ui-monospace, Menlo, monospace;
  }
  .plan-sub { font-size: 12px; color: var(--muted); margin-bottom: 14px; }

  .plan-profile {
    display: grid; gap: 8px;
    padding: 14px; margin-bottom: 14px;
    background: color-mix(in oklab, var(--color-primary) 4%, white);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
  }
  .pv-row { display: flex; align-items: center; gap: 12px; }
  .pv-k {
    width: 56px; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted);
  }
  .pv-bars { display: flex; gap: 5px; flex: 1; }
  .pv-bars i {
    flex: 1; height: 7px; border-radius: 999px;
    background: color-mix(in oklab, var(--color-primary) 12%, white);
    transition: background 0.15s;
  }
  .pv-bars i.is-on { background: var(--color-accent); }

  .plan-list { display: grid; gap: 0; }
  .plan-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 9px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 13px;
  }
  .plan-row:last-child { border-bottom: 0; }
  .plan-row span { color: var(--muted); }
  .plan-row b { color: var(--color-primary); font-weight: 600; text-align: right; }

  /* ── Toasts ────────────────────────────────────────────────────── */
  .toast-stack {
    position: fixed; bottom: 20px; right: 20px; z-index: 60;
    display: flex; flex-direction: column; gap: 8px;
  }
  .toast {
    padding: 11px 16px; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 500; color: #fff;
    background: var(--color-primary);
    box-shadow: 0 8px 24px -8px color-mix(in oklab, var(--color-primary) 50%, transparent);
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s;
    max-width: 340px;
  }
  .toast.is-in { opacity: 1; transform: translateY(0); }
  .toast--success { background: var(--ok); }
  .toast--error { background: var(--danger); }
  .toast--info { background: var(--color-primary); }
</style>
