---
import AdminLayout from "../../layouts/AdminLayout.astro";
import InventarioApp from "../../components/InventarioApp.jsx";
---

<AdminLayout title="Inventario — DobleYo Café" section="inventario">
  <InventarioApp client:load />
</AdminLayout>

<style is:global>
  /* ================================================================
     Inventario — estilos del módulo de inventario de producción
     Prefijo: inv-  (para no colisionar con AdminLayout)
     Variables: reutiliza las de :root definidas en AdminLayout
     ================================================================ */

  .inv-shell {
    padding: 24px;
    max-width: 1240px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* ── Header ──────────────────────────────────────────────────── */
  .inv-head {
    margin-bottom: 14px;
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .inv-head__title {
    margin: 0 0 2px;
    font-size: 22px; font-weight: 600; letter-spacing: -0.01em;
    color: var(--color-primary);
  }
  .inv-head__sub { font-size: 13px; color: var(--muted); margin: 0; }

  /* ── Buttons ─────────────────────────────────────────────────── */
  .inv-btn {
    appearance: none; cursor: pointer; font: inherit;
    font-size: 13px; font-weight: 500;
    padding: 7px 13px; border-radius: 8px;
    border: 1px solid var(--rule); background: var(--paper); color: var(--color-text);
  }
  .inv-btn:hover { border-color: var(--rule-2); }
  .inv-btn--primary {
    background: var(--color-primary); color: white; border-color: var(--color-primary);
  }
  .inv-btn--primary:hover {
    background: color-mix(in oklab, var(--color-primary) 90%, black);
  }

  /* ── Tabs ────────────────────────────────────────────────────── */
  .inv-tabs {
    display: flex; gap: 4px; flex-wrap: wrap;
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: var(--radius); padding: 6px;
    margin-bottom: 16px;
    overflow-x: auto;
  }
  .inv-tab {
    appearance: none; cursor: pointer; font: inherit;
    background: transparent; border: 0; color: var(--color-text);
    padding: 8px 14px; border-radius: 7px;
    font-size: 13px; font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
    white-space: nowrap;
  }
  .inv-tab:hover { background: var(--hover); }
  .inv-tab--on { background: var(--color-primary); color: white; }
  .inv-tab--on:hover {
    background: color-mix(in oklab, var(--color-primary) 92%, black);
  }
  .inv-tab__count {
    font-family: ui-monospace, "JetBrains Mono", Menlo, monospace;
    font-size: 11px;
    padding: 1px 7px; border-radius: 999px;
    background: color-mix(in oklab, currentColor 12%, transparent);
    opacity: 0.85;
  }
  .inv-tab--on .inv-tab__count { background: rgba(255,255,255,0.16); }

  /* ── KPIs ────────────────────────────────────────────────────── */
  .inv-kpis {
    display: grid; gap: 12px;
    grid-template-columns: repeat(2, 1fr);
    margin-bottom: 16px;
  }
  @media (min-width: 760px) { .inv-kpis { grid-template-columns: repeat(4, 1fr); } }

  .inv-kpi {
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: var(--radius); padding: 14px 16px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .inv-kpi__label {
    font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted);
  }
  .inv-kpi__value {
    font-size: 22px; font-weight: 600;
    color: var(--color-primary);
    font-variant-numeric: tabular-nums; letter-spacing: -0.02em;
    margin-top: 2px;
  }
  .inv-kpi__sub {
    font-size: 12px; color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .inv-kpi__sub b { font-weight: 600; color: var(--color-text); }
  .inv-kpi--accent .inv-kpi__value { color: var(--color-accent); }
  .inv-kpi--ok     .inv-kpi__value { color: var(--ok); }
  .inv-kpi--warn   .inv-kpi__value { color: var(--warn); }

  /* ── Toolbar ─────────────────────────────────────────────────── */
  .inv-toolbar {
    display: flex; gap: 8px; flex-wrap: wrap;
    align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .inv-search {
    display: flex; align-items: center; gap: 8px;
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: 8px; padding: 6px 10px;
    font-size: 13px; min-width: 220px; flex: 1; max-width: 360px;
  }
  .inv-search input {
    appearance: none; border: 0; background: transparent;
    font: inherit; color: var(--color-text); outline: none; width: 100%;
  }
  .inv-search span { color: var(--muted); font-family: ui-monospace, Menlo, monospace; }
  .inv-filters { display: flex; gap: 6px; flex-wrap: wrap; }
  .inv-chip {
    appearance: none; cursor: pointer; font: inherit; font-size: 12px;
    padding: 5px 10px; border-radius: 999px;
    border: 1px solid var(--rule); background: var(--paper); color: var(--color-text);
    display: inline-flex; align-items: center; gap: 5px;
  }
  .inv-chip:hover { border-color: var(--rule-2); }
  .inv-chip--on { background: var(--color-primary); color: white; border-color: var(--color-primary); }

  /* ── Workspace (lista + detalle) ─────────────────────────────── */
  .inv-workspace {
    display: grid; gap: 14px;
    grid-template-columns: 1fr;
    margin-bottom: 16px;
  }
  @media (min-width: 1000px) {
    .inv-workspace { grid-template-columns: minmax(0, 1fr) 360px; }
  }

  /* ── Lista de ítems ──────────────────────────────────────────── */
  .inv-list {
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: 0 1px 0 color-mix(in oklab, var(--color-primary) 6%, transparent),
                0 8px 24px -16px color-mix(in oklab, var(--color-primary) 30%, transparent);
    overflow: hidden;
  }
  .inv-list__head,
  .inv-list__row {
    display: grid; align-items: center; gap: 10px;
    padding: 12px 16px; font-size: 13px;
  }
  .inv-list__head {
    background: var(--hover);
    border-bottom: 1px solid var(--rule);
    font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted);
  }
  .inv-list__row {
    border-top: 1px solid var(--rule); cursor: pointer;
    font-variant-numeric: tabular-nums;
  }
  .inv-list__row:first-of-type { border-top: 0; }
  .inv-list__row:hover { background: var(--hover); }
  .inv-list__row--on {
    background: color-mix(in oklab, var(--color-accent) 6%, white);
  }
  .inv-list__row--on:hover {
    background: color-mix(in oklab, var(--color-accent) 10%, white);
  }

  /* Columnas por tipo de tab */
  .inv-list--green  .inv-list__head,
  .inv-list--green  .inv-list__row,
  .inv-list--roast  .inv-list__head,
  .inv-list--roast  .inv-list__row {
    grid-template-columns: 80px 1.5fr 1.2fr 0.9fr 0.9fr 0.7fr;
  }
  .inv-list--pack   .inv-list__head,
  .inv-list--pack   .inv-list__row {
    grid-template-columns: 1fr 1fr 0.9fr 0.9fr 1.3fr;
  }
  .inv-list--labels .inv-list__head,
  .inv-list--labels .inv-list__row {
    grid-template-columns: 1.2fr 0.9fr 0.9fr 1.3fr;
  }
  @media (max-width: 700px) {
    .inv-list--green  .inv-list__head,
    .inv-list--green  .inv-list__row,
    .inv-list--roast  .inv-list__head,
    .inv-list--roast  .inv-list__row,
    .inv-list--pack   .inv-list__head,
    .inv-list--pack   .inv-list__row,
    .inv-list--labels .inv-list__head,
    .inv-list--labels .inv-list__row { grid-template-columns: 1fr auto; }
    .inv-list__row > :nth-child(n+3) { display: none; }
  }

  /* Celdas */
  .inv-cell--mono {
    font-family: ui-monospace, "JetBrains Mono", Menlo, monospace;
    font-size: 13px; color: var(--color-primary); font-weight: 600;
  }
  .inv-cell--strong { color: var(--color-primary); font-weight: 600; }
  .inv-cell--muted  { color: var(--muted); }
  .inv-cell--right  { text-align: right; }

  /* ── Stock bar ────────────────────────────────────────────────── */
  .inv-stockbar {
    height: 6px; border-radius: 999px;
    background: color-mix(in oklab, var(--color-primary) 8%, white);
    overflow: hidden; max-width: 160px;
  }
  .inv-stockbar__fill { height: 100%; transition: width 0.25s ease; }
  .inv-stockbar--ok   .inv-stockbar__fill { background: var(--ok); }
  .inv-stockbar--warn .inv-stockbar__fill { background: var(--warn); }
  .inv-stockbar--low  .inv-stockbar__fill { background: var(--danger); }

  /* ── Pills / badges ──────────────────────────────────────────── */
  .inv-pill {
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
    padding: 2px 7px; border-radius: 999px;
    text-transform: uppercase; display: inline-block;
  }
  .inv-pill--ok   { background: color-mix(in oklab, var(--ok) 14%, white);     color: var(--ok); }
  .inv-pill--warn { background: color-mix(in oklab, var(--warn) 22%, white);   color: color-mix(in oklab, var(--warn) 80%, black); }
  .inv-pill--low  { background: color-mix(in oklab, var(--danger) 14%, white); color: var(--danger); }

  /* ── Panel de detalle ────────────────────────────────────────── */
  .inv-detail {
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: 0 1px 0 color-mix(in oklab, var(--color-primary) 6%, transparent),
                0 8px 24px -16px color-mix(in oklab, var(--color-primary) 30%, transparent);
    padding: 18px;
    display: flex; flex-direction: column; gap: 14px;
    align-self: start;
    position: sticky; top: 70px;
  }
  .inv-detail__title {
    margin: 0; font-size: 13px; font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase; letter-spacing: 0.08em;
    display: flex; align-items: center; gap: 10px;
  }
  .inv-detail__title small {
    font-size: 11.5px; font-weight: 500; color: var(--muted);
    letter-spacing: 0; text-transform: none;
  }
  .inv-detail__code {
    font-family: ui-monospace, "JetBrains Mono", Menlo, monospace;
    font-size: 20px; font-weight: 600;
    color: var(--color-primary); letter-spacing: -0.02em; margin: 0;
  }
  .inv-detail__sub { font-size: 13px; color: var(--muted); margin-top: 2px; }
  .inv-detail__grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; margin: 0;
  }
  .inv-detail__field dt {
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted); margin: 0;
  }
  .inv-detail__field dd {
    margin: 2px 0 0; font-weight: 600; color: var(--color-primary);
    font-variant-numeric: tabular-nums; font-size: 14px;
  }
  .inv-detail__section {
    padding-top: 12px; border-top: 1px solid var(--rule);
  }
  .inv-detail__section h4 {
    margin: 0 0 8px; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);
  }
  .inv-detail__movs { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .inv-detail__movs li {
    display: grid; grid-template-columns: 60px 1fr auto;
    gap: 8px; font-size: 12.5px; align-items: baseline;
  }
  .inv-detail__movs time {
    color: var(--muted); font-family: ui-monospace, Menlo, monospace; font-size: 11.5px;
  }
  .inv-mov__qty { font-variant-numeric: tabular-nums; font-weight: 600; }
  .inv-mov__qty--in  { color: var(--ok); }
  .inv-mov__qty--out { color: var(--danger); }
  .inv-detail__actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .inv-detail--empty {
    align-items: center; justify-content: center;
    text-align: center; min-height: 220px;
    color: var(--muted); font-size: 13px;
  }
  .inv-detail--empty span {
    display: inline-block; padding: 12px 14px;
    border: 1px dashed var(--rule-2); border-radius: 8px;
    font-family: ui-monospace, Menlo, monospace; font-size: 12px; color: var(--muted);
  }

  /* ── Feed de movimientos ─────────────────────────────────────── */
  .inv-feed {
    background: var(--paper); border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: 0 1px 0 color-mix(in oklab, var(--color-primary) 6%, transparent),
                0 8px 24px -16px color-mix(in oklab, var(--color-primary) 30%, transparent);
    padding: 18px 20px;
  }
  .inv-feed__head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .inv-feed__head h2 {
    margin: 0; font-size: 13px; font-weight: 600;
    color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .inv-feed__head small { font-size: 12px; color: var(--muted); }
  .inv-feed__list { list-style: none; margin: 0; padding: 0; }
  .inv-feed__item {
    display: grid;
    grid-template-columns: 16px 90px 1fr 70px 96px;
    gap: 12px; padding: 10px 0;
    border-top: 1px solid var(--rule);
    font-size: 13px; align-items: center;
  }
  .inv-feed__item:first-child { border-top: 0; }
  .inv-feed__icon {
    width: 18px; height: 18px; border-radius: 999px;
    display: grid; place-items: center;
    font-size: 11px; font-weight: 700;
    font-family: ui-monospace, Menlo, monospace;
  }
  .inv-feed__icon--in  { background: color-mix(in oklab, var(--ok) 14%, white);     color: var(--ok); }
  .inv-feed__icon--out { background: color-mix(in oklab, var(--danger) 14%, white); color: var(--danger); }
  .inv-feed__icon--mv  {
    background: color-mix(in oklab, var(--color-accent) 22%, white);
    color: color-mix(in oklab, var(--color-accent) 80%, black);
  }
  .inv-feed__when {
    color: var(--muted); font-family: ui-monospace, Menlo, monospace; font-size: 12px;
  }
  .inv-feed__what { color: var(--color-text); }
  .inv-feed__qty { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }
  .inv-feed__by  { color: var(--muted); font-size: 12px; text-align: right; }
  @media (max-width: 700px) {
    .inv-feed__item { grid-template-columns: 16px 1fr auto; }
    .inv-feed__by, .inv-feed__what { grid-column: 2 / -1; }
    .inv-feed__qty { grid-column: 3; grid-row: 1; }
  }

  /* ── Error state ─────────────────────────────────────────────── */
  .inv-error {
    background: color-mix(in oklab, var(--danger) 8%, white);
    border: 1px solid color-mix(in oklab, var(--danger) 30%, white);
    color: var(--danger);
    border-radius: var(--radius); padding: 14px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    font-size: 13.5px; margin-bottom: 16px;
  }

  /* ── Skeletons ───────────────────────────────────────────────── */
  .inv-skel {
    display: block;
    background: linear-gradient(90deg,
      color-mix(in oklab, var(--color-primary) 6%,  white) 0%,
      color-mix(in oklab, var(--color-primary) 12%, white) 50%,
      color-mix(in oklab, var(--color-primary) 6%,  white) 100%);
    background-size: 200% 100%;
    animation: inv-shimmer 1.4s linear infinite;
    border-radius: 6px; height: 14px;
  }
  @keyframes inv-shimmer {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
  }
</style>
