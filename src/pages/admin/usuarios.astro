---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Usuarios — DobleYo" section="usuarios">
  <!-- ── Encabezado de página ──────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">Configuración · Usuarios</div>
        <h1 class="page-title">Gestor de usuarios</h1>
        <p class="page-subtitle">
          Administre cuentas, roles y verificación. Atienda las solicitudes de
          caficultores y mantenga el acceso bajo control.
        </p>
      </div>
      <div class="page-header-actions">
        <button type="button" class="btn btn-secondary" id="refreshBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
          Actualizar
        </button>
        <button type="button" class="btn btn-save" id="addUserBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo usuario
        </button>
      </div>
    </div>
  </div>

  <div class="erp-body">
    <!-- ── KPIs ──────────────────────────────────────────────────────── -->
    <div class="kpi-grid" style="margin-bottom: 22px;">
      <div class="kpi-tile brand">
        <div class="kpi-label">Total de usuarios</div>
        <div class="kpi-value" id="kpiTotal">—</div>
        <div class="kpi-sub" id="kpiAdminSub">—</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Verificados</div>
        <div class="kpi-value" id="kpiVerified">—</div>
        <div class="kpi-sub" id="kpiVerifiedSub">—</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Caficultores</div>
        <div class="kpi-value" id="kpiCaficultor">—</div>
        <div class="kpi-sub">Cuentas con rol caficultor</div>
      </div>
      <div class="kpi-tile warning">
        <div class="kpi-label">Solicitudes pendientes</div>
        <div class="kpi-value" id="kpiPending">—</div>
        <div class="kpi-sub">Caficultores por revisar</div>
      </div>
    </div>

    <!-- ── Usuarios ──────────────────────────────────────────────────── -->
    <section class="card">
      <div class="card-header">
        <div>
          <h3 class="card-title">Usuarios</h3>
          <div class="card-subtitle" id="resultCount">—</div>
        </div>
      </div>

      <!-- Filtros -->
      <div class="filters">
        <div class="search-field">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="search" id="searchInput" placeholder="Buscar por nombre o email…" />
        </div>
        <select id="roleFilter" class="filter-select">
          <option value="">Todos los roles</option>
          <option value="admin">Administrador</option>
          <option value="caficultor">Caficultor</option>
          <option value="client">Cliente</option>
          <option value="provider">Proveedor</option>
        </select>
        <select id="verifiedFilter" class="filter-select">
          <option value="">Verificación</option>
          <option value="true">Verificado</option>
          <option value="false">No verificado</option>
        </select>
        <select id="caficultorFilter" class="filter-select">
          <option value="">Estado caficultor</option>
          <option value="none">Sin solicitud</option>
          <option value="pending">Pendiente</option>
          <option value="approved">Aprobado</option>
          <option value="rejected">Rechazado</option>
        </select>
      </div>

      <div class="table-wrapper">
        <table class="erp-table users-table">
          <thead>
            <tr>
              <th>Usuario</th>
              <th>Rol</th>
              <th>Verificado</th>
              <th>Caficultor</th>
              <th>Último ingreso</th>
              <th style="text-align: right;">Acciones</th>
            </tr>
          </thead>
          <tbody id="usersTableBody">
            <tr><td colspan="6" class="empty-state">Cargando usuarios…</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <!-- ── Modal Crear/Editar ──────────────────────────────────────────── -->
  <div class="modal" id="userModal" hidden>
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title" id="modalTitle">Nuevo usuario</h2>
        <button type="button" class="modal-close" id="userModalX" aria-label="Cerrar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <form id="userForm" novalidate>
          <div class="form-section"><h3>Cuenta</h3></div>
          <div class="form-grid">
            <div class="form-group form-group--wide">
              <label for="emailInput">Correo electrónico <span class="required">*</span></label>
              <input id="emailInput" type="email" placeholder="usuario@correo.com" required />
              <div class="form-hint" id="emailHint">No editable después de crear la cuenta.</div>
            </div>
            <div class="form-group">
              <label for="firstNameInput">Nombre <span class="required">*</span></label>
              <input id="firstNameInput" type="text" placeholder="Juan" required />
            </div>
            <div class="form-group">
              <label for="lastNameInput">Apellido</label>
              <input id="lastNameInput" type="text" placeholder="Pérez" />
            </div>
            <div class="form-group">
              <label for="roleInput">Rol <span class="required">*</span></label>
              <select id="roleInput" required>
                <option value="client">Cliente</option>
                <option value="caficultor">Caficultor</option>
                <option value="admin">Administrador</option>
                <option value="provider">Proveedor</option>
              </select>
            </div>
            <div class="form-group">
              <label for="taxIdInput">NIT / Cédula</label>
              <input id="taxIdInput" type="text" placeholder="900123456-7" />
            </div>
          </div>

          <div class="form-section"><h3>Contacto</h3></div>
          <div class="form-grid">
            <div class="form-group">
              <label for="mobilePhoneInput">Celular</label>
              <input id="mobilePhoneInput" type="tel" placeholder="+57 300 123 4567" />
            </div>
            <div class="form-group">
              <label for="landlinePhoneInput">Teléfono fijo</label>
              <input id="landlinePhoneInput" type="tel" placeholder="+57 1 234 5678" />
            </div>
            <div class="form-group">
              <label for="cityInput">Ciudad</label>
              <input id="cityInput" type="text" placeholder="Bogotá" />
            </div>
            <div class="form-group">
              <label for="stateProvinceInput">Departamento</label>
              <input id="stateProvinceInput" type="text" placeholder="Cundinamarca" />
            </div>
            <div class="form-group">
              <label for="countryInput">País</label>
              <input id="countryInput" type="text" placeholder="Colombia" />
            </div>
            <div class="form-group form-group--wide">
              <label for="addressInput">Dirección</label>
              <textarea id="addressInput" rows="2" placeholder="Calle 123 # 45-67, Apto 8"></textarea>
            </div>
          </div>

          <label class="checkbox-item" style="margin-top: 8px;">
            <input id="verifiedInput" type="checkbox" />
            <span>✓ Cuenta verificada</span>
          </label>
        </form>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" id="cancelBtn">Cancelar</button>
        <button type="submit" form="userForm" class="btn btn-save" id="saveUserBtn">Guardar</button>
      </div>
    </div>
  </div>

  <!-- ── Modal Credenciales (tras crear) ─────────────────────────────── -->
  <div class="modal" id="credModal" hidden>
    <div class="modal-content" style="max-width: 440px;">
      <div class="modal-header">
        <h2 class="modal-title">Usuario creado</h2>
      </div>
      <div class="modal-body">
        <p style="margin: 0 0 14px; color: var(--muted); font-size: 14px;">
          Comparta esta contraseña temporal con el usuario. Deberá cambiarla en
          su primer ingreso. <strong>No se volverá a mostrar.</strong>
        </p>
        <div class="cred-row">
          <span>Correo</span>
          <b id="credEmail">—</b>
        </div>
        <div class="cred-row">
          <span>Contraseña temporal</span>
          <code id="credPassword">—</code>
        </div>
        <button type="button" class="btn btn-secondary" id="copyCredBtn" style="margin-top: 14px; width: 100%;">
          Copiar contraseña
        </button>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-save" id="credCloseBtn">Entendido</button>
      </div>
    </div>
  </div>

  <!-- ── Modal Eliminar ──────────────────────────────────────────────── -->
  <div class="modal" id="deleteModal" hidden>
    <div class="modal-content" style="max-width: 420px;">
      <div class="modal-header">
        <h2 class="modal-title" style="color: var(--danger);">Eliminar usuario</h2>
      </div>
      <div class="modal-body">
        <p style="margin: 0 0 12px; color: var(--muted); font-size: 14px;">
          Esta acción no se puede deshacer.
        </p>
        <div class="error-box">
          Usuario: <strong id="deleteUserName"></strong>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" id="deleteCancel">Cancelar</button>
        <button type="button" class="btn btn-danger" id="deleteConfirm">Eliminar</button>
      </div>
    </div>
  </div>

  <!-- Toasts -->
  <div class="toast-stack" id="toastStack" aria-live="polite"></div>

  <script>
    let allUsers: any[] = [];
    let currentEditId: number | null = null;
    let currentDeleteId: number | null = null;

    // ── Toast ───────────────────────────────────────────────────────
    function toast(message: string, type = "info") {
      const stack = document.getElementById("toastStack")!;
      const el = document.createElement("div");
      el.className = `toast toast--${type}`;
      el.textContent = message;
      stack.appendChild(el);
      requestAnimationFrame(() => el.classList.add("is-in"));
      setTimeout(() => {
        el.classList.remove("is-in");
        setTimeout(() => el.remove(), 250);
      }, 4000);
    }

    // ── Helpers ─────────────────────────────────────────────────────
    function esc(s: any) {
      if (s == null) return "";
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!)
      );
    }
    const fmtDate = (d: string) =>
      d ? new Date(d).toLocaleDateString("es-CO", { day: "2-digit", month: "short", year: "numeric" }) : "Nunca";
    const setVal = (id: string, v: any) => {
      const el = document.getElementById(id) as HTMLInputElement;
      if (el) el.value = v ?? "";
    };
    const getVal = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value?.trim() ?? "";

    const ROLE = {
      admin: { label: "Administrador", cls: "badge-warning" },
      caficultor: { label: "Caficultor", cls: "badge-success" },
      client: { label: "Cliente", cls: "badge-info" },
      provider: { label: "Proveedor", cls: "badge-brand" },
    } as Record<string, { label: string; cls: string }>;

    const CAFICULTOR = {
      none: { label: "Sin solicitud", cls: "badge-neutral" },
      pending: { label: "Pendiente", cls: "badge-warning" },
      approved: { label: "Aprobado", cls: "badge-success" },
      rejected: { label: "Rechazado", cls: "badge-error" },
    } as Record<string, { label: string; cls: string }>;

    // ── Carga ───────────────────────────────────────────────────────
    async function loadUsers() {
      const tbody = document.getElementById("usersTableBody")!;
      try {
        const response = await fetch("/api/users", { credentials: "include" });
        if (!response.ok) throw new Error("Error al cargar usuarios");
        const data = await response.json();
        const list = data.data ?? data.users ?? [];
        allUsers = list.map((u: any) => ({ ...u, is_verified: !!u.is_verified }));
        updateStats(allUsers);
        applyFilters();
      } catch (err: any) {
        console.error("Error:", err);
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No se pudieron cargar los usuarios.</td></tr>';
        toast("Error al cargar usuarios", "error");
      }
    }

    function updateStats(users: any[]) {
      const total = users.length;
      const admins = users.filter((u) => u.role === "admin").length;
      const verified = users.filter((u) => u.is_verified).length;
      const caficultores = users.filter((u) => u.role === "caficultor").length;
      const pending = users.filter((u) => u.caficultor_status === "pending").length;

      document.getElementById("kpiTotal")!.textContent = String(total);
      document.getElementById("kpiAdminSub")!.textContent = `${admins} administrador${admins === 1 ? "" : "es"}`;
      document.getElementById("kpiVerified")!.textContent = String(verified);
      document.getElementById("kpiVerifiedSub")!.textContent = `${total - verified} sin verificar`;
      document.getElementById("kpiCaficultor")!.textContent = String(caficultores);
      document.getElementById("kpiPending")!.textContent = String(pending);
    }

    // ── Render ──────────────────────────────────────────────────────
    function displayUsers(users: any[]) {
      const tbody = document.getElementById("usersTableBody")!;
      document.getElementById("resultCount")!.textContent =
        `${users.length} de ${allUsers.length} usuario${allUsers.length === 1 ? "" : "s"}`;

      if (!users.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No se encontraron usuarios con los filtros aplicados.</td></tr>';
        return;
      }

      tbody.innerHTML = users.map((u) => {
        const fullName = [u.first_name, u.last_name].filter(Boolean).join(" ") || u.name || "Sin nombre";
        const initials = fullName.split(" ").slice(0, 2).map((w: string) => w[0]).join("").toUpperCase();
        const role = ROLE[u.role] || { label: u.role || "—", cls: "badge-neutral" };
        const caf = CAFICULTOR[u.caficultor_status] || { label: "—", cls: "badge-neutral" };
        const verified = u.is_verified
          ? '<span class="badge badge-success">Verificado</span>'
          : '<span class="badge badge-error">Sin verificar</span>';
        const cafCell = u.caficultor_status && u.caficultor_status !== "none"
          ? `<span class="badge ${caf.cls}">${esc(caf.label)}</span>`
          : '<span style="color: var(--muted-2);">—</span>';

        return `
        <tr>
          <td>
            <div class="user-cell">
              <div class="user-avatar">${esc(initials || "?")}</div>
              <div class="user-meta">
                <span class="user-name">${esc(fullName)}</span>
                <span class="user-email">${esc(u.email)}</span>
              </div>
            </div>
          </td>
          <td><span class="badge ${role.cls}">${esc(role.label)}</span></td>
          <td>${verified}</td>
          <td>${cafCell}</td>
          <td style="color: var(--muted); white-space: nowrap;">${esc(fmtDate(u.last_login_at))}</td>
          <td style="text-align: right; white-space: nowrap;">
            <button class="icon-btn" data-action="edit-user" data-user-id="${u.id}" title="Editar" aria-label="Editar">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            </button>
            <button class="icon-btn icon-btn--danger" data-action="delete-user" data-user-id="${u.id}" data-user-email="${esc(u.email)}" title="Eliminar" aria-label="Eliminar">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </td>
        </tr>`;
      }).join("");
    }

    // ── Filtros ─────────────────────────────────────────────────────
    function applyFilters() {
      const role = (document.getElementById("roleFilter") as HTMLSelectElement).value;
      const verified = (document.getElementById("verifiedFilter") as HTMLSelectElement).value;
      const caficultor = (document.getElementById("caficultorFilter") as HTMLSelectElement).value;
      const search = getVal("searchInput").toLowerCase();

      const filtered = allUsers.filter((u) => {
        const matchRole = !role || u.role === role;
        const matchVerified = verified === "" || String(u.is_verified) === verified;
        const matchCaficultor = !caficultor || (u.caficultor_status || "none") === caficultor;
        const fullName = [u.first_name, u.last_name].filter(Boolean).join(" ") || u.name || "";
        const matchSearch = !search ||
          (u.email || "").toLowerCase().includes(search) ||
          fullName.toLowerCase().includes(search);
        return matchRole && matchVerified && matchCaficultor && matchSearch;
      });

      displayUsers(filtered);
    }

    // ── Modal usuario ───────────────────────────────────────────────
    function openCreateModal() {
      currentEditId = null;
      (document.getElementById("userForm") as HTMLFormElement).reset();
      document.getElementById("modalTitle")!.textContent = "Nuevo usuario";
      const email = document.getElementById("emailInput") as HTMLInputElement;
      email.readOnly = false;
      document.getElementById("emailHint")!.textContent = "No editable después de crear la cuenta.";
      setVal("countryInput", "Colombia");
      document.getElementById("userModal")!.hidden = false;
    }

    function openEditModal(userId: number) {
      const user = allUsers.find((u) => u.id === userId);
      if (!user) return;
      currentEditId = userId;
      document.getElementById("modalTitle")!.textContent = "Editar usuario";
      setVal("emailInput", user.email);
      setVal("firstNameInput", user.first_name);
      setVal("lastNameInput", user.last_name);
      setVal("mobilePhoneInput", user.mobile_phone);
      setVal("landlinePhoneInput", user.landline_phone);
      setVal("taxIdInput", user.tax_id);
      (document.getElementById("roleInput") as HTMLSelectElement).value = user.role;
      setVal("cityInput", user.city);
      setVal("stateProvinceInput", user.state_province);
      setVal("countryInput", user.country);
      setVal("addressInput", user.address);
      (document.getElementById("verifiedInput") as HTMLInputElement).checked = !!user.is_verified;
      const email = document.getElementById("emailInput") as HTMLInputElement;
      email.readOnly = true;
      document.getElementById("emailHint")!.textContent = "El correo no se puede modificar.";
      document.getElementById("userModal")!.hidden = false;
    }

    function closeUserModal() {
      document.getElementById("userModal")!.hidden = true;
      currentEditId = null;
      (document.getElementById("emailInput") as HTMLInputElement).readOnly = false;
      (document.getElementById("userForm") as HTMLFormElement).reset();
    }

    function openDeleteModal(userId: number, userEmail: string) {
      currentDeleteId = userId;
      document.getElementById("deleteUserName")!.textContent = userEmail;
      document.getElementById("deleteModal")!.hidden = false;
    }
    function closeDeleteModal() {
      document.getElementById("deleteModal")!.hidden = true;
      currentDeleteId = null;
    }

    // ── Guardar ─────────────────────────────────────────────────────
    document.getElementById("userForm")!.addEventListener("submit", async (e) => {
      e.preventDefault();

      const first_name = getVal("firstNameInput");
      const last_name = getVal("lastNameInput");
      if (!getVal("emailInput") || !first_name) {
        toast("Correo y nombre son obligatorios", "error");
        return;
      }

      const userData: Record<string, any> = {
        email: getVal("emailInput"),
        first_name, last_name,
        name: [first_name, last_name].filter(Boolean).join(" "),
        mobile_phone: getVal("mobilePhoneInput"),
        landline_phone: getVal("landlinePhoneInput"),
        tax_id: getVal("taxIdInput"),
        role: (document.getElementById("roleInput") as HTMLSelectElement).value,
        city: getVal("cityInput"),
        state_province: getVal("stateProvinceInput"),
        country: getVal("countryInput"),
        address: getVal("addressInput"),
        is_verified: (document.getElementById("verifiedInput") as HTMLInputElement).checked,
      };

      const saveBtn = document.getElementById("saveUserBtn") as HTMLButtonElement;
      const originalText = saveBtn.textContent;
      saveBtn.disabled = true;
      saveBtn.textContent = "Guardando…";

      try {
        let endpoint: string, method: string;
        if (currentEditId) {
          delete userData.email;
          endpoint = `/api/users/${currentEditId}`;
          method = "PUT";
        } else {
          endpoint = "/api/users";
          method = "POST";
        }

        const response = await fetch(endpoint, {
          method,
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(userData),
        });
        if (!response.ok) {
          const error = await response.json().catch(() => ({}));
          throw new Error(error.error || "Error al guardar usuario");
        }
        const result = await response.json();

        const email = userData.email;
        closeUserModal();
        await loadUsers();

        if (method === "POST") {
          toast("Usuario creado correctamente", "success");
          document.getElementById("credEmail")!.textContent = email;
          document.getElementById("credPassword")!.textContent = result.tempPassword || "—";
          document.getElementById("credModal")!.hidden = false;
        } else {
          toast("Usuario actualizado correctamente", "success");
        }
      } catch (err: any) {
        toast(err.message || "Error al guardar usuario", "error");
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });

    // ── Eliminar ────────────────────────────────────────────────────
    document.getElementById("deleteConfirm")!.addEventListener("click", async () => {
      if (!currentDeleteId) return;
      try {
        const response = await fetch(`/api/users/${currentDeleteId}`, {
          method: "DELETE", credentials: "include",
        });
        if (!response.ok) {
          const error = await response.json().catch(() => ({}));
          throw new Error(error.error || "Error al eliminar usuario");
        }
        closeDeleteModal();
        await loadUsers();
        toast("Usuario eliminado correctamente", "success");
      } catch (err: any) {
        toast(err.message || "Error al eliminar usuario", "error");
      }
    });

    // ── Credenciales: copiar ────────────────────────────────────────
    document.getElementById("copyCredBtn")!.addEventListener("click", async () => {
      const pwd = document.getElementById("credPassword")!.textContent || "";
      try {
        await navigator.clipboard.writeText(pwd);
        toast("Contraseña copiada al portapapeles", "success");
      } catch {
        toast("No se pudo copiar automáticamente", "error");
      }
    });
    document.getElementById("credCloseBtn")!.addEventListener("click", () => {
      document.getElementById("credModal")!.hidden = true;
    });

    // ── Eventos ─────────────────────────────────────────────────────
    document.getElementById("addUserBtn")!.addEventListener("click", openCreateModal);
    document.getElementById("refreshBtn")!.addEventListener("click", () => { loadUsers(); toast("Datos actualizados", "info"); });
    document.getElementById("cancelBtn")!.addEventListener("click", closeUserModal);
    document.getElementById("userModalX")!.addEventListener("click", closeUserModal);
    document.getElementById("deleteCancel")!.addEventListener("click", closeDeleteModal);

    document.getElementById("roleFilter")!.addEventListener("change", applyFilters);
    document.getElementById("verifiedFilter")!.addEventListener("change", applyFilters);
    document.getElementById("caficultorFilter")!.addEventListener("change", applyFilters);
    document.getElementById("searchInput")!.addEventListener("input", applyFilters);

    document.getElementById("userModal")!.addEventListener("click", (e) => {
      if (e.target === document.getElementById("userModal")) closeUserModal();
    });
    document.getElementById("deleteModal")!.addEventListener("click", (e) => {
      if (e.target === document.getElementById("deleteModal")) closeDeleteModal();
    });

    document.getElementById("usersTableBody")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-action]") as HTMLElement | null;
      if (!btn) return;
      const id = parseInt(btn.dataset.userId!);
      if (btn.dataset.action === "edit-user") openEditModal(id);
      if (btn.dataset.action === "delete-user") openDeleteModal(id, btn.dataset.userEmail!);
    });

    // ── Init ────────────────────────────────────────────────────────
    loadUsers();
  </script>
</AdminLayout>

