    gap: 0.25rem;
    text-align: right;
    font-size: 0.875rem;
    color: #374151;
  }
  .adm-total-box__grand {
    font-size: 1rem;
    font-weight: 700;
    color: #2d6a4f;
    border-top: 1px solid #e5e7eb;
