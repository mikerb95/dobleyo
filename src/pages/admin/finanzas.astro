</style>

<script>
// ================================================================
// Pestañas
// ================================================================
document.querySelectorAll('.adm-tab').forEach(tab => {
  tab.addEventListener('click', () => switchTab(tab.dataset.tab));
});
document.querySelectorAll('[data-switch-tab]').forEach(link => {
  link.addEventListener('click', (e) => { e.preventDefault(); switchTab(link.dataset.switchTab); });
});

let loadedTabs = new Set(['overview']);

function switchTab(name) {
  document.querySelectorAll('.adm-tab').forEach(t => t.classList.toggle('adm-tab--active', t.dataset.tab === name));
  document.querySelectorAll('.adm-panel').forEach(p => p.classList.add('adm-panel--hidden'));
  const panel = document.getElementById(`panel-${name}`);
  if (panel) panel.classList.remove('adm-panel--hidden');
  if (!loadedTabs.has(name)) { loadedTabs.add(name); loadPanelData(name); }
}

// ================================================================
// Formateo
// ================================================================
const fmtCOP = v => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(Number(v ?? 0));
const fmtDate = d => d ? new Date(d + 'T00:00:00').toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';
const BADGES = {
  borrador:       ['#f3f4f6','#374151','Borrador'],
  confirmada:     ['#fef3c7','#92400e','Confirmada'],
  confirmado:     ['#fef3c7','#92400e','Confirmado'],
  pagada_parcial: ['#dbeafe','#1e40af','Pago parcial'],
  pagada:         ['#d1fae5','#065f46','Pagada'],
  pagado:         ['#d1fae5','#065f46','Pagado'],
  cancelada:      ['#fee2e2','#991b1b','Cancelada'],
  aprobado:       ['#d1fae5','#065f46','Aprobado'],
  rechazado:      ['#fee2e2','#991b1b','Rechazado'],
  conciliado:     ['#d1fae5','#065f46','Conciliado'],
};
function badge(state) {
  const [bg, color, text] = BADGES[state] ?? ['#f3f4f6','#374151', state];
  return `<span class="adm-badge" style="background:${bg};color:${color}">${text}</span>`;
}

// ================================================================
// Listas de soporte (cacheadas)
// ================================================================
let _caficultores = null, _clients = null, _allUsers = null, _payMethods = null;

async function getCaficultores() {
  if (_caficultores) return _caficultores;
  const r = await fetch('/api/finance/users-list?role=caficultor', { credentials: 'include' });
  const json = await r.json();
  _caficultores = json.success ? json.data : [];
  return _caficultores;
}

async function getClients() {
  if (_clients) return _clients;
  const r = await fetch('/api/finance/users-list?role=client', { credentials: 'include' });
  const json = await r.json();
  _clients = json.success ? json.data : [];
  return _clients;
}

async function getAllUsers() {
  if (_allUsers) return _allUsers;
  const r = await fetch('/api/finance/users-list', { credentials: 'include' });
  const json = await r.json();
  _allUsers = json.success ? json.data : [];
  return _allUsers;
}

async function getPaymentMethods() {
  if (_payMethods) return _payMethods;
  const r = await fetch('/api/finance/payment-methods', { credentials: 'include' });
  const json = await r.json();
  _payMethods = json.success ? json.data : [];
  return _payMethods;
}

function fillSelect(selectEl, items, valueKey, labelFn, emptyLabel) {
  selectEl.innerHTML = `<option value="">${emptyLabel}</option>` +
    items.map(i => `<option value="${i[valueKey]}">${labelFn(i)}</option>`).join('');
}

// ================================================================
// Paneles — carga lazy
// ================================================================
async function loadPanelData(name) {
  const loaders = {
    'purchase-invoices': loadPurchaseInvoices,
    'sales-invoices':    loadSalesInvoices,
    'expenses':          loadExpenses,
    'payments':          loadPayments,
  };
  if (loaders[name]) await loaders[name]();
}

async function loadPurchaseInvoices() {
  const el = document.getElementById('purchaseInvoicesTable');
  try {
    const r = await fetch('/api/finance/purchase-invoices?limit=50', { credentials: 'include' });
    const json = await r.json();
    if (!json.success) { el.innerHTML = `<p class="adm-empty">Error: ${json.error}</p>`; return; }
    if (!json.data.length) { el.innerHTML = '<p class="adm-empty">Sin facturas de compra</p>'; return; }
    el.innerHTML = `<div style="overflow-x:auto"><table class="adm-table">
      <thead><tr><th>Número</th><th>Caficultor</th><th>Fecha</th><th>Vence</th><th>Total</th><th>Por pagar</th><th>Estado</th><th></th></tr></thead>
      <tbody>${json.data.map(inv => `<tr>
        <td class="adm-table__mono">${inv.invoice_number}</td>
        <td>${inv.caficultor_name ?? '—'}</td>
        <td>${fmtDate(inv.invoice_date)}</td>
        <td>${fmtDate(inv.due_date)}</td>
        <td class="adm-table__amount">${fmtCOP(inv.total_amount)}</td>
        <td class="adm-table__amount">${fmtCOP(inv.amount_due)}</td>
        <td>${badge(inv.state)}</td>
        <td>${inv.state !== 'pagada' && inv.state !== 'cancelada'
          ? `<button class="adm-btn adm-btn--sm adm-btn--primary" data-action="mark-paid" data-inv-id="${inv.id}">Marcar pagada</button>`
          : ''}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
  } catch { el.innerHTML = '<p class="adm-empty">Error al cargar</p>'; }
}

async function loadSalesInvoices() {
  const el = document.getElementById('salesInvoicesTable');
  try {
    const r = await fetch('/api/finance/sales-invoices?limit=50', { credentials: 'include' });
    const json = await r.json();
    if (!json.success) { el.innerHTML = `<p class="adm-empty">Error: ${json.error}</p>`; return; }
    if (!json.data.length) { el.innerHTML = '<p class="adm-empty">Sin facturas de venta</p>'; return; }
    el.innerHTML = `<div style="overflow-x:auto"><table class="adm-table">
      <thead><tr><th>Número</th><th>Cliente</th><th>Fecha</th><th>Total</th><th>Por cobrar</th><th>Estado</th></tr></thead>
      <tbody>${json.data.map(inv => `<tr>
        <td class="adm-table__mono">${inv.invoice_number}</td>
        <td>${inv.customer_name ?? '—'}</td>
        <td>${fmtDate(inv.invoice_date)}</td>
        <td class="adm-table__amount">${fmtCOP(inv.total_amount)}</td>
        <td class="adm-table__amount">${fmtCOP(inv.amount_due)}</td>
        <td>${badge(inv.state)}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
  } catch { el.innerHTML = '<p class="adm-empty">Error al cargar</p>'; }
}

async function loadExpenses() {
  const el = document.getElementById('expensesTable');
  try {
    const r = await fetch('/api/finance/expenses?limit=50', { credentials: 'include' });
    const json = await r.json();
    if (!json.success) { el.innerHTML = `<p class="adm-empty">Error: ${json.error}</p>`; return; }
    if (!json.data.length) { el.innerHTML = '<p class="adm-empty">Sin gastos registrados</p>'; return; }
    el.innerHTML = `<div style="overflow-x:auto"><table class="adm-table">
      <thead><tr><th>Número</th><th>Fecha</th><th>Categoría</th><th>Descripción</th><th>Monto</th><th>Estado</th><th></th></tr></thead>
      <tbody>${json.data.map(exp => `<tr>
        <td class="adm-table__mono">${exp.expense_number}</td>
        <td>${fmtDate(exp.expense_date)}</td>
        <td class="adm-table__cat">${exp.category}</td>
        <td>${exp.description}</td>
        <td class="adm-table__amount">${fmtCOP(exp.amount)}</td>
        <td>${badge(exp.state)}</td>
        <td>${exp.state === 'borrador'
          ? `<button class="adm-btn adm-btn--sm adm-btn--outline" data-action="approve-expense" data-exp-id="${exp.id}">Aprobar</button>`
          : ''}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
  } catch { el.innerHTML = '<p class="adm-empty">Error al cargar</p>'; }
}

async function loadPayments() {
  const el = document.getElementById('paymentsTable');
  try {
    const r = await fetch('/api/finance/payments?limit=50', { credentials: 'include' });
    const json = await r.json();
    if (!json.success) { el.innerHTML = `<p class="adm-empty">Error: ${json.error}</p>`; return; }
    if (!json.data.length) { el.innerHTML = '<p class="adm-empty">Sin pagos registrados</p>'; return; }
    el.innerHTML = `<div style="overflow-x:auto"><table class="adm-table">
      <thead><tr><th>Número</th><th>Tipo</th><th>Fecha</th><th>Socio</th><th>Monto</th><th>Referencia</th><th>Estado</th></tr></thead>
      <tbody>${json.data.map(p => `<tr>
        <td class="adm-table__mono">${p.payment_number}</td>
        <td>${p.payment_type === 'recibido' ? '📥 Cobro' : '📤 Pago'}</td>
        <td>${fmtDate(p.payment_date)}</td>
        <td>${p.partner_name ?? '—'}</td>
        <td class="adm-table__amount">${fmtCOP(p.amount)}</td>
        <td class="adm-table__mono">${p.reference ?? '—'}</td>
        <td>${badge(p.state)}</td>
      </tr>`).join('')}</tbody>
    </table></div>`;
  } catch { el.innerHTML = '<p class="adm-empty">Error al cargar</p>'; }
}

// ================================================================
// Acciones rápidas
// ================================================================
async function markInvoicePaid(id) {
  if (!confirm('¿Marcar esta factura como pagada?')) return;
  const r = await fetch(`/api/finance/purchase-invoices/${id}/state`, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
    body: JSON.stringify({ state: 'pagada' }),
  });
  const json = await r.json();
  if (json.success) { loadedTabs.delete('purchase-invoices'); await loadPurchaseInvoices(); }
  else alert('Error: ' + json.error);
}

async function approveExpense(id) {
  if (!confirm('¿Aprobar este gasto?')) return;
  const r = await fetch(`/api/finance/expenses/${id}/state`, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
    body: JSON.stringify({ state: 'aprobado' }),
  });
  const json = await r.json();
  if (json.success) { loadedTabs.delete('expenses'); await loadExpenses(); }
  else alert('Error: ' + json.error);
}

// ================================================================
// Modales — abrir / cerrar
// ================================================================
function openModal(id) { document.getElementById(id)?.showModal(); }
function closeModal(id) { document.getElementById(id)?.close(); }

// Gasto
['btnNewExpense', 'btnNewExpense2'].forEach(id => {
  document.getElementById(id)?.addEventListener('click', () => openModal('modalExpense'));
});
document.getElementById('closeModalExpense').addEventListener('click', () => closeModal('modalExpense'));

// Factura de compra — cargar caficultores al abrir
async function openPurchaseInvoice() {
  const sel = document.getElementById('selectCaficultor');
  const list = await getCaficultores();
  fillSelect(sel, list, 'id', u => `${u.name} (${u.email})`, '— Sin asignar —');
  openModal('modalPurchaseInvoice');
}
['btnNewPurchaseInvoice', 'btnNewPurchaseInvoice2'].forEach(id => {
  document.getElementById(id)?.addEventListener('click', openPurchaseInvoice);
});
document.getElementById('closeModalPurchaseInvoice').addEventListener('click', () => closeModal('modalPurchaseInvoice'));

// Factura de venta — cargar clientes al abrir
async function openSalesInvoice() {
  const sel = document.getElementById('selectClient');
  const list = await getClients();
  fillSelect(sel, list, 'id', u => `${u.name} (${u.email})`, '— Seleccionar cliente —');
  const today = new Date().toISOString().slice(0, 10);
  document.querySelector('#formSalesInvoice [name="invoice_date"]').value = today;
  document.querySelector('#formSalesInvoice [name="due_date"]').value = today;
  recalcSaleTotal();
  openModal('modalSalesInvoice');
}
['btnNewSalesInvoice', 'btnNewSalesInvoice2'].forEach(id => {
  document.getElementById(id)?.addEventListener('click', openSalesInvoice);
});
document.getElementById('closeModalSalesInvoice').addEventListener('click', () => closeModal('modalSalesInvoice'));

// Pago — cargar usuarios y métodos al abrir
document.getElementById('btnNewPayment').addEventListener('click', async () => {
  const [users, methods] = await Promise.all([getAllUsers(), getPaymentMethods()]);
  fillSelect(document.getElementById('selectPartner'), users, 'id',
    u => `${u.name} — ${u.role} (${u.email})`, '— Seleccionar persona —');
  fillSelect(document.getElementById('selectPaymentMethod'), methods, 'id',
    m => `${m.name} (${m.method_type})`, '— Seleccionar método —');
  const today = new Date().toISOString().slice(0, 10);
  document.querySelector('#formPayment [name="payment_date"]').value = today;
  openModal('modalPayment');
});
document.getElementById('closeModalPayment').addEventListener('click', () => closeModal('modalPayment'));

// ================================================================
// Formulario: Gasto
// ================================================================
document.getElementById('formExpense').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msgEl = document.getElementById('expenseMsg');
  const data = Object.fromEntries(new FormData(e.target));
  msgEl.style.color = '#374151'; msgEl.textContent = 'Guardando…';
  try {
    const r = await fetch('/api/finance/expenses', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
      body: JSON.stringify({ ...data, amount: parseFloat(data.amount) }),
    });
    const json = await r.json();
    if (json.success) {
      msgEl.style.color = '#065f46';
      msgEl.textContent = `✅ Gasto ${json.data.expense_number} registrado`;
      e.target.reset();
      setTimeout(() => { closeModal('modalExpense'); msgEl.textContent = ''; loadedTabs.delete('expenses'); }, 1800);
    } else {
      msgEl.style.color = '#991b1b';
      msgEl.textContent = 'Error: ' + (json.errors?.[0]?.msg ?? json.error);
    }
  } catch { msgEl.style.color = '#991b1b'; msgEl.textContent = 'Error de conexión'; }
});

// ================================================================
// Formulario: Factura de compra
// ================================================================
let purchaseLineCount = 1;

document.getElementById('addPurchaseLine').addEventListener('click', () => {
  const n = purchaseLineCount++;
  const row = document.createElement('div');
  row.className = 'adm-line-row';
  row.innerHTML = `
    <input type="text" name="lines[${n}][description]" placeholder="Descripción" required />
    <input type="text" name="lines[${n}][lot_reference]" placeholder="Ref. lote" />
    <input type="number" name="lines[${n}][quantity]" placeholder="Kg" min="0.01" step="0.01" required />
    <input type="number" name="lines[${n}][unit_price]" placeholder="$/kg" min="0" step="1" required />
    <span class="adm-line-remove" data-action="remove-purchase-line">✕</span>
  `;
  document.getElementById('purchaseLines').appendChild(row);
});

document.getElementById('formPurchaseInvoice').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msgEl = document.getElementById('purchaseInvoiceMsg');
  const rawData = Object.fromEntries(new FormData(e.target));

  const linesMap = {};
  for (const [key, val] of Object.entries(rawData)) {
    const m = key.match(/^lines\[(\d+)\]\[(\w+)\]$/);
    if (m) {
      const [, idx, field] = m;
      if (!linesMap[idx]) linesMap[idx] = {};
      linesMap[idx][field] = (field === 'quantity' || field === 'unit_price') ? parseFloat(val) : val;
      delete rawData[key];
    }
  }
  rawData.lines = Object.values(linesMap).filter(l => l.description && l.quantity > 0);
  if (rawData.caficultor_id) rawData.caficultor_id = parseInt(rawData.caficultor_id, 10);

  msgEl.style.color = '#374151'; msgEl.textContent = 'Creando factura…';
  try {
    const r = await fetch('/api/finance/purchase-invoices', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
      body: JSON.stringify(rawData),
    });
    const json = await r.json();
    if (json.success) {
      msgEl.style.color = '#065f46';
      msgEl.textContent = `✅ Factura ${json.data.invoice_number} creada`;
      e.target.reset();
      document.getElementById('purchaseLines').innerHTML = purchaseLineTemplate(0);
      purchaseLineCount = 1;
      setTimeout(() => { closeModal('modalPurchaseInvoice'); msgEl.textContent = ''; loadedTabs.delete('purchase-invoices'); }, 1800);
    } else {
      msgEl.style.color = '#991b1b';
      msgEl.textContent = 'Error: ' + (json.errors?.[0]?.msg ?? json.error);
    }
  } catch { msgEl.style.color = '#991b1b'; msgEl.textContent = 'Error de conexión'; }
});

function purchaseLineTemplate(n) {
  return `<div class="adm-line-row">
    <input type="text" name="lines[${n}][description]" placeholder="Descripción (ej: Café verde Huila)" required />
    <input type="text" name="lines[${n}][lot_reference]" placeholder="Ref. lote" />
    <input type="number" name="lines[${n}][quantity]" placeholder="Kg" min="0.01" step="0.01" required />
    <input type="number" name="lines[${n}][unit_price]" placeholder="$/kg" min="0" step="1" required />
    <span class="adm-line-remove" data-action="remove-purchase-line">✕</span>
  </div>`;
}

// ================================================================
// Formulario: Factura de venta — con cálculo automático
// ================================================================
let saleLineCount = 1;

function removeSaleLine(btn) {
  btn.closest('.adm-line-row--sale').remove();
  recalcSaleTotal();
}

function recalcSaleTotal() {
  let subtotal = 0, tax = 0;
  document.querySelectorAll('#salesLines .adm-line-row--sale').forEach(row => {
    const qty  = parseFloat(row.querySelector('[name$="[quantity]"]')?.value) || 0;
    const price = parseFloat(row.querySelector('[name$="[unit_price]"]')?.value) || 0;
    const disc  = parseFloat(row.querySelector('[name$="[discount_percent]"]')?.value) || 0;
    const iva   = parseFloat(row.querySelector('[name$="[tax_rate]"]')?.value) || 0;
    const base  = qty * price * (1 - disc / 100);
    const lineTax = base * (iva / 100);
    const lineTotal = base + lineTax;
    subtotal += base;
    tax += lineTax;
    const totalEl = row.querySelector('.adm-line-total');
    if (totalEl) totalEl.textContent = fmtCOP(lineTotal);
  });
  const ship = parseFloat(document.querySelector('#formSalesInvoice [name="shipping_cost"]')?.value) || 0;
  document.getElementById('saleSub').textContent  = fmtCOP(subtotal);
  document.getElementById('saleTax').textContent  = fmtCOP(tax);
  document.getElementById('saleShip').textContent = fmtCOP(ship);
  document.getElementById('saleTotal').textContent = fmtCOP(subtotal + tax + ship);
}

document.getElementById('salesLines').addEventListener('input', recalcSaleTotal);
document.querySelector('#formSalesInvoice [name="shipping_cost"]')
  ?.addEventListener('input', recalcSaleTotal);

document.getElementById('addSaleLine').addEventListener('click', () => {
  const n = saleLineCount++;
  const row = document.createElement('div');
  row.className = 'adm-line-row adm-line-row--sale';
  row.innerHTML = `
    <input type="text" name="sl[${n}][description]" placeholder="Descripción del producto" required />
    <input type="number" name="sl[${n}][quantity]" placeholder="1" min="0.01" step="0.01" value="1" required class="adm-line-calc" />
    <input type="number" name="sl[${n}][unit_price]" placeholder="0" min="0" step="1" required class="adm-line-calc" />
    <input type="number" name="sl[${n}][discount_percent]" placeholder="0" min="0" max="100" step="0.1" value="0" class="adm-line-calc" />
    <input type="number" name="sl[${n}][tax_rate]" placeholder="19" min="0" max="100" step="0.1" value="19" class="adm-line-calc" />
    <span class="adm-line-total">$ 0</span>
    <span class="adm-line-remove" data-action="remove-sale-line">✕</span>
  `;
  document.getElementById('salesLines').appendChild(row);
});

document.getElementById('formSalesInvoice').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msgEl = document.getElementById('salesInvoiceMsg');
  const rawData = Object.fromEntries(new FormData(e.target));

  const linesMap = {};
  for (const [key, val] of Object.entries(rawData)) {
    const m = key.match(/^sl\[(\d+)\]\[(\w+)\]$/);
    if (m) {
      const [, idx, field] = m;
      if (!linesMap[idx]) linesMap[idx] = {};
      const numFields = ['quantity','unit_price','discount_percent','tax_rate'];
      linesMap[idx][field] = numFields.includes(field) ? parseFloat(val) : val;
      delete rawData[key];
    }
  }
  rawData.lines = Object.values(linesMap).filter(l => l.description && l.quantity > 0);
  rawData.customer_id = parseInt(rawData.customer_id, 10);
  rawData.shipping_cost = parseFloat(rawData.shipping_cost) || 0;

  msgEl.style.color = '#374151'; msgEl.textContent = 'Creando factura…';
  try {
    const r = await fetch('/api/finance/sales-invoices', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
      body: JSON.stringify(rawData),
    });
    const json = await r.json();
    if (json.success) {
      msgEl.style.color = '#065f46';
      msgEl.textContent = `✅ Factura ${json.data.invoice_number} creada — Total: ${fmtCOP(json.data.total_amount)}`;
      e.target.reset();
      document.getElementById('salesLines').innerHTML = saleLineTemplate(0);
      saleLineCount = 1;
      recalcSaleTotal();
      setTimeout(() => { closeModal('modalSalesInvoice'); msgEl.textContent = ''; loadedTabs.delete('sales-invoices'); }, 2200);
    } else {
      msgEl.style.color = '#991b1b';
      msgEl.textContent = 'Error: ' + (json.errors?.[0]?.msg ?? json.error);
    }
  } catch { msgEl.style.color = '#991b1b'; msgEl.textContent = 'Error de conexión'; }
});

function saleLineTemplate(n) {
  return `<div class="adm-line-row adm-line-row--sale">
    <input type="text" name="sl[${n}][description]" placeholder="Descripción del producto" required />
    <input type="number" name="sl[${n}][quantity]" placeholder="1" min="0.01" step="0.01" value="1" required class="adm-line-calc" />
    <input type="number" name="sl[${n}][unit_price]" placeholder="0" min="0" step="1" required class="adm-line-calc" />
    <input type="number" name="sl[${n}][discount_percent]" placeholder="0" min="0" max="100" step="0.1" value="0" class="adm-line-calc" />
    <input type="number" name="sl[${n}][tax_rate]" placeholder="19" min="0" max="100" step="0.1" value="19" class="adm-line-calc" />
    <span class="adm-line-total">$ 0</span>
    <span class="adm-line-remove" data-action="remove-sale-line">✕</span>
  </div>`;
}

// ================================================================
// Formulario: Pago
// ================================================================
document.getElementById('formPayment').addEventListener('submit', async (e) => {
  e.preventDefault();
  const msgEl = document.getElementById('paymentMsg');
  const rawData = Object.fromEntries(new FormData(e.target));
  rawData.partner_id = parseInt(rawData.partner_id, 10);
  rawData.payment_method_id = parseInt(rawData.payment_method_id, 10);
  rawData.amount = parseFloat(rawData.amount);

  msgEl.style.color = '#374151'; msgEl.textContent = 'Registrando pago…';
  try {
    const r = await fetch('/api/finance/payments', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
      body: JSON.stringify(rawData),
    });
    const json = await r.json();
    if (json.success) {
      const tipo = rawData.payment_type === 'recibido' ? 'cobro' : 'pago';
      msgEl.style.color = '#065f46';
      msgEl.textContent = `✅ ${tipo.charAt(0).toUpperCase() + tipo.slice(1)} ${json.data.payment_number} registrado — ${fmtCOP(json.data.amount)}`;
      e.target.reset();
      setTimeout(() => { closeModal('modalPayment'); msgEl.textContent = ''; loadedTabs.delete('payments'); }, 2000);
    } else {
      msgEl.style.color = '#991b1b';
      msgEl.textContent = 'Error: ' + (json.errors?.[0]?.msg ?? json.error);
    }
  } catch { msgEl.style.color = '#991b1b'; msgEl.textContent = 'Error de conexión'; }
});

// ── Event delegation — reemplaza todos los onclick= inline ─────────────────
document.getElementById('salesLines')?.addEventListener('click', (e) => {
  if (e.target.closest('[data-action="remove-sale-line"]')) removeSaleLine(e.target.closest('[data-action="remove-sale-line"]'));
});
document.getElementById('purchaseLines')?.addEventListener('click', (e) => {
  if (e.target.closest('[data-action="remove-purchase-line"]')) e.target.closest('.adm-line-row').remove();
});
document.getElementById('purchaseInvoicesTable')?.addEventListener('click', (e) => {
  const btn = e.target.closest('[data-action="mark-paid"]');
  if (btn) markInvoicePaid(parseInt(btn.dataset.invId));
});
document.getElementById('expensesTable')?.addEventListener('click', (e) => {
  const btn = e.target.closest('[data-action="approve-expense"]');
  if (btn) approveExpense(parseInt(btn.dataset.expId));
});
</script>
