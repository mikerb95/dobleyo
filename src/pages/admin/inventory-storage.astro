---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="Almacenar en Inventario"
  description="Registra el café verde en el inventario físico con peso y ubicación"
>
  <div class="inventory-storage">
    <header class="is-head">
      <h1>Almacenar en inventario</h1>
      <p>
        Registre el café verde en el inventario físico indicando peso y
        ubicación en bodega.
      </p>
    </header>

    <!-- Estado actual del inventario verde -->
    <div class="kpi-grid is-stats">
      <div class="kpi-tile info">
        <div class="kpi-label">Lotes en bodega</div>
        <div class="kpi-value" id="statLots">—</div>
        <div class="kpi-sub">café verde almacenado</div>
      </div>
      <div class="kpi-tile brand">
        <div class="kpi-label">Peso total almacenado</div>
        <div class="kpi-value" id="statWeight">—</div>
        <div class="kpi-sub">kilogramos</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Ubicaciones en uso</div>
        <div class="kpi-value" id="statLocations">—</div>
        <div class="kpi-sub">posiciones de bodega</div>
      </div>
    </div>

    <form id="inventoryForm">
      <!-- Selección de Lote -->
      <div class="form-group">
        <label for="lotSelect"
          >Lote de café <span class="required">*</span></label
        >
        <select id="lotSelect" name="lot" required>
          <option value="">Seleccione un lote…</option>
        </select>
        <div class="form-hint">Lotes disponibles sin almacenar</div>
      </div>

      <!-- Info del Lote Seleccionado -->
      <div class="card lot-info" id="lotInfoCard" style="display: none;">
        <div class="card-header">
          <h3 class="card-title">Información del lote</h3>
        </div>
        <div class="card-body">
          <dl class="detail-grid">
            <div class="detail-item">
              <dt>Variedad</dt>
              <dd id="lotVariety">—</dd>
            </div>
            <div class="detail-item">
              <dt>Proceso</dt>
              <dd id="lotProcess">—</dd>
            </div>
            <div class="detail-item">
              <dt>Finca</dt>
              <dd id="lotFarm">—</dd>
            </div>
            <div class="detail-item">
              <dt>Recolectado</dt>
              <dd id="lotDate">—</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Peso Neto -->
      <div class="form-group">
        <label for="weight"
          >Peso neto de café verde <span class="required">*</span></label
        >
        <div class="input-suffix">
          <input
            type="number"
            id="weight"
            name="weight"
            placeholder="Ej: 45.5"
            step="0.1"
            min="0"
            required
          />
          <select class="suffix-select" id="weightUnit" name="weightUnit">
            <option value="kg">kg</option>
            <option value="lb">lb</option>
          </select>
        </div>
        <div class="form-hint">Peso total del café verde para este lote</div>
      </div>

      <!-- Ubicación de Almacenamiento -->
      <div class="form-group">
        <label for="location"
          >Ubicación en bodega <span class="required">*</span></label
        >
        <select id="location" name="location" required>
          <option value="">Seleccione una ubicación</option>
          <option value="A-01">Sección A · Estante 01</option>
          <option value="A-02">Sección A · Estante 02</option>
          <option value="B-01">Sección B · Estante 01</option>
          <option value="B-02">Sección B · Estante 02</option>
          <option value="C-01"
            >Sección C · Estante 01 (temperatura controlada)</option
          >
          <option value="C-02"
            >Sección C · Estante 02 (temperatura controlada)</option
          >
        </select>
        <div class="form-hint">
          Elija la ubicación física de almacenamiento
        </div>
      </div>

      <!-- Fecha de Almacenamiento -->
      <div class="form-group">
        <label for="storageDate">Fecha de almacenamiento</label>
        <input type="date" id="storageDate" name="storageDate" disabled />
        <div class="form-hint">
          Se registra automáticamente con la fecha actual
        </div>
      </div>

      <!-- Notas Adicionales -->
      <div class="form-group">
        <label for="notes">Notas (opcional)</label>
        <textarea
          id="notes"
          name="notes"
          placeholder="Ej: empaques en buen estado, sin daño aparente…"
        ></textarea>
      </div>

      <!-- Resumen -->
      <div class="info-box summary-box" id="summaryBox" style="display: none;">
        <strong>Resumen del almacenamiento</strong>
        <dl class="summary-list">
          <div><dt>📦 Lote</dt><dd id="summaryLot">—</dd></div>
          <div><dt>⚖️ Peso</dt><dd id="summaryWeight">—</dd></div>
          <div><dt>📍 Ubicación</dt><dd id="summaryLocation">—</dd></div>
          <div><dt>📅 Fecha</dt><dd id="summaryDate">—</dd></div>
        </dl>
      </div>

      <!-- Botones de Acción -->
      <div class="form-actions">
        <button type="reset" class="btn-secondary">Limpiar</button>
        <button type="submit" class="btn-primary">Almacenar lote</button>
      </div>
    </form>

    <!-- Modal de Confirmación -->
    <div class="modal" id="successModal" style="display: none;">
      <div class="modal-content modal-success">
        <div class="modal-body success-body">
          <div class="success-icon" aria-hidden="true">✅</div>
          <h2 class="modal-title success-title">¡Lote almacenado!</h2>
          <p>
            El lote <strong id="successLotId"></strong> ha sido almacenado
            correctamente.
          </p>
          <p class="success-sub">Ahora está en el inventario de café verde.</p>

          <dl class="summary-list success-details">
            <div><dt>Peso</dt><dd id="detailWeight">—</dd></div>
            <div><dt>Ubicación</dt><dd id="detailLocation">—</dd></div>
            <div><dt>Fecha</dt><dd id="detailDate">—</dd></div>
          </dl>
        </div>
        <div class="modal-actions">
          <button id="closeInventorySuccessBtn" class="btn btn-secondary">
            Cerrar
          </button>
          <button id="goToLotesFromInventoryBtn" class="btn btn-primary">
            Ver lotes de café verde
          </button>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* ── Encabezado de página ─────────────────────────────────────────────── */
    .is-head {
      margin-bottom: 20px;
    }
    .is-head p {
      font-size: 13px;
      color: var(--muted);
      margin: 4px 0 0;
      max-width: 60ch;
    }

    /* ── Tira de métricas del inventario ──────────────────────────────────── */
    .is-stats {
      margin-bottom: 24px;
    }

    /* ── Tarjeta de información del lote ──────────────────────────────────── */
    .lot-info {
      margin-bottom: 16px;
    }
    .lot-info .card-body {
      padding: 16px 18px;
    }

    /* ── Input con sufijo (selector de unidad kg / lb) ────────────────────── */
    .input-suffix {
      display: flex;
    }
    .input-suffix > input {
      flex: 1;
      width: auto;
      border-top-right-radius: 0;
      border-bottom-right-radius: 0;
    }
    .input-suffix > .suffix-select {
      width: auto;
      min-width: 74px;
      border-top-left-radius: 0;
      border-bottom-left-radius: 0;
      margin-left: -1px;
    }

    /* ── Resumen del envío y detalles del modal ───────────────────────────── */
    .summary-list {
      display: grid;
      gap: 8px;
      margin: 12px 0 0;
    }
    .summary-list > div {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
    }
    .summary-list dt {
      font-size: 13px;
      color: var(--muted);
    }
    .summary-list dd {
      margin: 0;
      font-size: 13px;
      font-weight: 600;
      color: var(--color-primary);
      font-variant-numeric: tabular-nums;
      text-align: right;
    }

    /* ── Modal de éxito ───────────────────────────────────────────────────── */
    .modal-success {
      max-width: 440px;
    }
    .success-body {
      text-align: center;
    }
    .success-icon {
      font-size: 44px;
      line-height: 1;
      margin-bottom: 8px;
    }
    .success-title {
      text-align: center;
      font-size: 18px;
      margin: 0 0 6px;
    }
    .success-body > p {
      font-size: 13.5px;
      color: var(--color-text);
      margin: 4px 0;
    }
    .success-sub {
      color: var(--muted) !important;
      font-size: 12.5px !important;
    }
    .success-details {
      margin-top: 16px;
      text-align: left;
      background: color-mix(in oklab, var(--color-primary) 3%, white);
      border: 1px solid var(--rule);
      border-radius: var(--radius-sm);
      padding: 12px 14px;
    }
  </style>

  <script>
    const lotSelect = document.getElementById("lotSelect");
    const storageDate = document.getElementById("storageDate");
    const form = document.getElementById("inventoryForm");
    const summaryBox = document.getElementById("summaryBox");
    const lotInfoCard = document.getElementById("lotInfoCard");

    const numberFmt = new Intl.NumberFormat("es-CO", {
      maximumFractionDigits: 1,
    });

    // Actualizar la tira de métricas con el inventario verde actual
    function updateInventoryStats(inventory) {
      const totalWeight = inventory.reduce(
        (sum, item) => sum + Number(item.weight_kg || 0),
        0
      );
      const locations = new Set(
        inventory.map((item) => item.location).filter(Boolean)
      );
      const set = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
      };
      set("statLots", String(inventory.length));
      set("statWeight", numberFmt.format(totalWeight));
      set("statLocations", String(locations.size));
    }

    // Cargar lotes disponibles desde API
    async function loadAvailableLots() {
      try {
        const response = await fetch("/api/coffee/harvests");
        if (!response.ok) throw new Error("Error al cargar lotes");

        const harvests = await response.json();

        // También obtener inventario para filtrar y para las métricas
        const inventoryResponse = await fetch("/api/coffee/green-inventory");
        const inventory = inventoryResponse.ok
          ? await inventoryResponse.json()
          : [];
        updateInventoryStats(inventory);

        const storedLotIds = inventory.map((item) => item.lot_id);

        const available = harvests.filter(
          (h) => !storedLotIds.includes(h.lot_id)
        );

        lotSelect.innerHTML = '<option value="">Seleccione un lote…</option>';
        available.forEach((harvest) => {
          const option = document.createElement("option");
          option.value = JSON.stringify(harvest);
          option.textContent = `${harvest.lot_id} (${harvest.variety})`;
          lotSelect.appendChild(option);
        });
      } catch (error) {
        console.error("Error cargando lotes:", error);
        alert("Error al cargar lotes disponibles");
      }
    }

    // Establecer fecha actual
    const today = new Date().toISOString().split("T")[0];
    storageDate.value = today;

    // Actualizar información del lote seleccionado
    lotSelect.addEventListener("change", () => {
      if (!lotSelect.value) {
        lotInfoCard.style.display = "none";
        summaryBox.style.display = "none";
        return;
      }

      const harvest = JSON.parse(lotSelect.value);
      document.getElementById("lotVariety").textContent = harvest.variety;
      document.getElementById("lotProcess").textContent = harvest.process;
      document.getElementById("lotFarm").textContent = harvest.farm;
      document.getElementById("lotDate").textContent = new Date(
        harvest.created_at
      ).toLocaleDateString("es-CO");
      lotInfoCard.style.display = "block";
      updateSummary();
    });

    // Actualizar resumen
    function updateSummary() {
      const weight = document.getElementById("weight").value;
      const unit = document.getElementById("weightUnit").value;
      const location = document.getElementById("location").value;

      if (weight && location && lotSelect.value) {
        const harvest = JSON.parse(lotSelect.value);
        document.getElementById("summaryLot").textContent = harvest.lot_id;
        document.getElementById("summaryWeight").textContent =
          `${weight} ${unit}`;
        document.getElementById("summaryLocation").textContent = location;
        document.getElementById("summaryDate").textContent = new Date(
          storageDate.value
        ).toLocaleDateString("es-CO");
        summaryBox.style.display = "block";
      } else {
        summaryBox.style.display = "none";
      }
    }

    document.getElementById("weight").addEventListener("input", updateSummary);
    document
      .getElementById("weightUnit")
      .addEventListener("change", updateSummary);
    document
      .getElementById("location")
      .addEventListener("change", updateSummary);

    // Enviar formulario a la API
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!lotSelect.value) {
        alert("⚠️ Debe seleccionar un lote");
        return;
      }

      const harvest = JSON.parse(lotSelect.value);
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando…";

      try {
        const response = await fetch("/api/coffee/inventory-storage", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            lotId: harvest.lot_id,
            weight: parseFloat(document.getElementById("weight").value),
            weightUnit: document.getElementById("weightUnit").value,
            location: document.getElementById("location").value,
            storageDate: storageDate.value,
            notes: document.getElementById("notes").value,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.message || "Error al almacenar lote");
        }

        // Llenar datos del modal
        document.getElementById("successLotId").textContent = harvest.lot_id;
        document.getElementById("detailWeight").textContent =
          `${document.getElementById("weight").value} ${document.getElementById("weightUnit").value}`;
        document.getElementById("detailLocation").textContent =
          document.getElementById("location").value;
        document.getElementById("detailDate").textContent = new Date(
          storageDate.value
        ).toLocaleDateString("es-CO");

        // Mostrar modal de éxito
        document.getElementById("successModal").style.display = "grid";
      } catch (error) {
        console.error("Error:", error);
        alert(`❌ Error: ${error.message || "Error desconocido"}`);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });

    // Cargar lotes al iniciar
    loadAvailableLots();

    document
      .getElementById("closeInventorySuccessBtn")
      ?.addEventListener("click", () => {
        document.getElementById("successModal").style.display = "none";
        document.getElementById("inventoryForm").reset();
        document.getElementById("lotInfoCard").style.display = "none";
        document.getElementById("summaryBox").style.display = "none";
        loadAvailableLots();
      });
    document
      .getElementById("goToLotesFromInventoryBtn")
      ?.addEventListener("click", () => {
        window.location.href = "/admin/lotes";
      });
  </script>
</AdminLayout>
