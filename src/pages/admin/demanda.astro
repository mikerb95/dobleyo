---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Gestión de Demanda — DobleYo Admin" section="demanda">
  <header class="page-header">
    <h1>Gestión de Demanda</h1>
    <p>Cree, consulte, actualice y elimine registros de demanda por categoría.</p>
  </header>

  <div class="page-body">
    <div class="info-box" style="margin-top:0">
      <strong>Módulo 100% Python.</strong> Este CRUD se sirve por la función
      <code>api/ml/demand.py</code> sobre Turso. En desarrollo local con Express
      la función no corre (solo en el deploy de Vercel o con <code>vercel dev</code>).
    </div>

    <div id="alert" class="alert" style="display:none"></div>

    <!-- ── Formulario de creación ─────────────────────────────────── -->
    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-header">
        <div>
          <h2 class="card-title">Nuevo registro de demanda</h2>
          <p class="card-subtitle">Los campos marcados con * son obligatorios.</p>
        </div>
      </div>
      <div style="padding:18px">
        <form id="create-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="c-category">Categoría <span class="required">*</span></label>
              <input type="text" id="c-category" name="category" placeholder="p. ej. cafe-grano" required />
            </div>
            <div class="form-group">
              <label for="c-product">Producto (opcional)</label>
              <input type="text" id="c-product" name="product_key" placeholder="p. ej. Huila Caturra 500g" />
            </div>
            <div class="form-group">
              <label for="c-period">Período (opcional)</label>
              <input type="text" id="c-period" name="period" placeholder="p. ej. 2026-W24 o 2026-06" />
            </div>
            <div class="form-group">
              <label for="c-value">Demanda <span class="required">*</span></label>
              <input type="number" id="c-value" name="demand_value" min="0" step="0.01" placeholder="0" required />
            </div>
            <div class="form-group">
              <label for="c-unit">Unidad</label>
              <input type="text" id="c-unit" name="unit" value="units" placeholder="units" />
            </div>
            <div class="form-group form-group--wide">
              <label for="c-notes">Notas (opcional)</label>
              <textarea id="c-notes" name="notes" placeholder="Observaciones…"></textarea>
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-save">Crear registro</button>
            <button type="reset" class="btn btn-secondary">Limpiar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Listado ────────────────────────────────────────────────── -->
    <div class="card">
      <div class="card-header">
        <div>
          <h2 class="card-title">Registros de demanda</h2>
          <p class="card-subtitle" id="count-label">—</p>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <input type="text" id="filter-category" placeholder="Filtrar por categoría…" style="max-width:220px" />
          <button class="btn btn-secondary" id="btn-refresh" type="button">Actualizar</button>
          <button class="btn btn-export" id="btn-export" type="button">⬇ Exportar Excel</button>
        </div>
      </div>
      <div style="overflow-x:auto">
        <table class="erp-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Categoría</th>
              <th>Producto</th>
              <th>Período</th>
              <th style="text-align:right">Demanda</th>
              <th>Unidad</th>
              <th>Actualizado</th>
              <th style="text-align:right">Acciones</th>
            </tr>
          </thead>
          <tbody id="rows">
            <tr><td colspan="8" class="empty-state">Cargando…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── Modal de edición ─────────────────────────────────────────── -->
  <div class="modal" id="edit-modal" style="display:none">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Editar registro</h3>
        <button class="btn btn-secondary" id="edit-close" type="button" aria-label="Cerrar">✕</button>
      </div>
      <form id="edit-form">
        <div class="modal-body">
          <input type="hidden" id="e-id" />
          <div class="form-grid">
            <div class="form-group">
              <label for="e-category">Categoría <span class="required">*</span></label>
              <input type="text" id="e-category" required />
            </div>
            <div class="form-group">
              <label for="e-product">Producto</label>
              <input type="text" id="e-product" />
            </div>
            <div class="form-group">
              <label for="e-period">Período</label>
              <input type="text" id="e-period" />
            </div>
            <div class="form-group">
              <label for="e-value">Demanda <span class="required">*</span></label>
              <input type="number" id="e-value" min="0" step="0.01" required />
            </div>
            <div class="form-group">
              <label for="e-unit">Unidad</label>
              <input type="text" id="e-unit" />
            </div>
            <div class="form-group form-group--wide">
              <label for="e-notes">Notas</label>
              <textarea id="e-notes"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" id="edit-cancel">Cancelar</button>
          <button type="submit" class="btn btn-save">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .page-header {
      padding: 1.75rem 2rem 1.25rem;
      background: var(--paper);
      border-bottom: 1px solid var(--rule);
    }
    .page-header h1 { font-size: 1.6rem; font-weight: 700; color: var(--color-primary); margin: 0 0 .25rem; }
    .page-header p  { margin: 0; color: var(--muted); font-size: .92rem; }
    .page-body { padding: 1.5rem 2rem 2rem; }
    @media (max-width: 640px) {
      .page-header { padding: 1.25rem 1rem 1rem; }
      .page-body { padding: 1rem; }
    }
    .row-actions { display: flex; gap: 6px; justify-content: flex-end; }
    code { background: var(--hover); padding: 1px 5px; border-radius: 4px; font-size: .85em; }
    .btn-export {
      background: #2e7d5b;
      color: #fff;
      border-color: #2e7d5b;
    }
    .btn-export:hover { background: #256649; border-color: #256649; }
    .btn-export:disabled { opacity: .6; cursor: not-allowed; }
  </style>

  <script>
    const API = "/api/ml/demand";
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const rowsEl = $("rows") as HTMLTableSectionElement;
    const alertEl = $("alert");
    const countEl = $("count-label");

    let cache: any[] = [];

    function showAlert(msg: string, kind: "error" | "success" = "error") {
      alertEl.className = "alert alert--" + (kind === "success" ? "success" : "error");
      alertEl.textContent = msg;
      alertEl.style.display = "block";
      if (kind === "success") setTimeout(() => (alertEl.style.display = "none"), 3000);
    }

    function esc(s: any): string {
      return String(s ?? "").replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
    }

    function fmtDate(s: string): string {
      if (!s) return "—";
      const d = new Date(s.replace(" ", "T") + "Z");
      return isNaN(+d) ? s : d.toLocaleString("es-CO", { dateStyle: "short", timeStyle: "short" });
    }

    async function api(method: string, body?: any, qs = ""): Promise<any> {
      const res = await fetch(API + qs, {
        method,
        credentials: "include",
        headers: body ? { "Content-Type": "application/json" } : undefined,
        body: body ? JSON.stringify(body) : undefined,
      });
      let json: any = null;
      try { json = await res.json(); } catch { /* respuesta no-JSON */ }
      if (!res.ok || !json?.success) {
        const err = json?.error || (json?.errors ? json.errors.join(", ") : `Error ${res.status}`);
        throw new Error(err);
      }
      return json;
    }

    function render(records: any[]) {
      cache = records;
      countEl.textContent = `${records.length} registro(s)`;
      if (!records.length) {
        rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">Sin registros. Cree el primero arriba.</td></tr>`;
        return;
      }
      rowsEl.innerHTML = records.map((r) => `
        <tr>
          <td>${r.id}</td>
          <td><span class="badge badge-neutral">${esc(r.category)}</span></td>
          <td>${esc(r.product_key) || "—"}</td>
          <td>${esc(r.period) || "—"}</td>
          <td style="text-align:right;font-weight:700;font-variant-numeric:tabular-nums">${esc(r.demand_value)}</td>
          <td>${esc(r.unit)}</td>
          <td style="white-space:nowrap">${fmtDate(r.updated_at)}</td>
          <td>
            <div class="row-actions">
              <button class="btn btn-secondary" data-edit="${r.id}" type="button">Editar</button>
              <button class="btn btn-danger" data-del="${r.id}" type="button">Borrar</button>
            </div>
          </td>
        </tr>`).join("");
    }

    async function load() {
      const cat = ($("filter-category") as HTMLInputElement).value.trim();
      rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">Cargando…</td></tr>`;
      try {
        const json = await api("GET", undefined, cat ? `?category=${encodeURIComponent(cat)}` : "");
        render(json.data || []);
      } catch (e: any) {
        rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">No se pudo cargar: ${esc(e.message)}</td></tr>`;
      }
    }

    // ── Crear ──
    ($("create-form") as HTMLFormElement).addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const f = ev.target as HTMLFormElement;
      const payload = {
        category: (f.elements.namedItem("category") as HTMLInputElement).value,
        product_key: (f.elements.namedItem("product_key") as HTMLInputElement).value,
        period: (f.elements.namedItem("period") as HTMLInputElement).value,
        demand_value: (f.elements.namedItem("demand_value") as HTMLInputElement).value,
        unit: (f.elements.namedItem("unit") as HTMLInputElement).value,
        notes: (f.elements.namedItem("notes") as HTMLTextAreaElement).value,
      };
      try {
        await api("POST", payload);
        f.reset();
        (f.elements.namedItem("unit") as HTMLInputElement).value = "units";
        showAlert("Registro creado correctamente.", "success");
        load();
      } catch (e: any) { showAlert(e.message); }
    });

    // ── Editar / Borrar (delegación) ──
    rowsEl.addEventListener("click", async (ev) => {
      const t = ev.target as HTMLElement;
      const editId = t.getAttribute("data-edit");
      const delId = t.getAttribute("data-del");
      if (editId) openEdit(Number(editId));
      if (delId) {
        if (!confirm("¿Eliminar este registro de demanda? Esta acción no se puede deshacer.")) return;
        try {
          await api("DELETE", undefined, `?id=${delId}`);
          showAlert("Registro eliminado.", "success");
          load();
        } catch (e: any) { showAlert(e.message); }
      }
    });

    function openEdit(id: number) {
      const r = cache.find((x) => x.id === id);
      if (!r) return;
      ($("e-id") as HTMLInputElement).value = String(r.id);
      ($("e-category") as HTMLInputElement).value = r.category ?? "";
      ($("e-product") as HTMLInputElement).value = r.product_key ?? "";
      ($("e-period") as HTMLInputElement).value = r.period ?? "";
      ($("e-value") as HTMLInputElement).value = r.demand_value ?? "";
      ($("e-unit") as HTMLInputElement).value = r.unit ?? "";
      ($("e-notes") as HTMLTextAreaElement).value = r.notes ?? "";
      $("edit-modal").style.display = "grid";
    }
    function closeEdit() { $("edit-modal").style.display = "none"; }
    $("edit-close").addEventListener("click", closeEdit);
    $("edit-cancel").addEventListener("click", closeEdit);

    ($("edit-form") as HTMLFormElement).addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const id = ($("e-id") as HTMLInputElement).value;
      const payload = {
        category: ($("e-category") as HTMLInputElement).value,
        product_key: ($("e-product") as HTMLInputElement).value,
        period: ($("e-period") as HTMLInputElement).value,
        demand_value: ($("e-value") as HTMLInputElement).value,
        unit: ($("e-unit") as HTMLInputElement).value,
        notes: ($("e-notes") as HTMLTextAreaElement).value,
      };
      try {
        await api("PUT", payload, `?id=${id}`);
        closeEdit();
        showAlert("Registro actualizado.", "success");
        load();
      } catch (e: any) { showAlert(e.message); }
    });

    $("btn-refresh").addEventListener("click", load);
    let filterTimer: any;
    ($("filter-category") as HTMLInputElement).addEventListener("input", () => {
      clearTimeout(filterTimer);
      filterTimer = setTimeout(load, 350);
    });

    load();
  </script>
</AdminLayout>
