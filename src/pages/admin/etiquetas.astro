  }
  .lbl-brand {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .lbl-brand span { color: var(--color-accent); margin-left: 4px; }
  .lbl-origin {
    font-size: 11px;
    text-transform: uppercase;
