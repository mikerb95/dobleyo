---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Generación de Etiquetas — DobleYo">
  <!-- ── Encabezado de página ──────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">Producción · Trazabilidad</div>
        <h1 class="page-title">Generación de Etiquetas</h1>
        <p class="page-subtitle">
          Cree etiquetas con código QR de trazabilidad desde un lote preparado o
          a partir de un perfil de café personalizado.
        </p>
      </div>
      <div class="page-header-actions">
        <button type="button" class="btn btn-secondary" id="refreshBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
          Actualizar
        </button>
      </div>
    </div>
  </div>

  <div class="erp-body">
    <!-- ── KPIs ──────────────────────────────────────────────────────── -->
    <div class="kpi-grid" style="margin-bottom: 22px;">
      <div class="kpi-tile brand">
        <div class="kpi-label">Etiquetas generadas</div>
        <div class="kpi-value" id="kpiTotal">—</div>
        <div class="kpi-sub">Histórico acumulado</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Desde lotes</div>
        <div class="kpi-value" id="kpiFromLots">—</div>
        <div class="kpi-sub">Con trazabilidad completa</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Personalizadas</div>
        <div class="kpi-value" id="kpiCustom">—</div>
        <div class="kpi-sub">Perfil creado a mano</div>
      </div>
      <div class="kpi-tile warning">
        <div class="kpi-label">Lotes disponibles</div>
        <div class="kpi-value" id="kpiAvailable">—</div>
        <div class="kpi-sub">Listos para etiquetar</div>
      </div>
    </div>

    <!-- ── Workbench: formulario + vista previa ──────────────────────── -->
    <div class="labels-grid">
      <!-- Columna izquierda: formulario -->
      <section class="card">
        <div class="card-header">
          <div>
            <h3 class="card-title">Datos de la etiqueta</h3>
            <div class="card-subtitle">Elija el origen de los datos del café</div>
          </div>
        </div>
        <div class="card-pad">
          <!-- Segmented control -->
          <div class="seg" role="tablist">
            <button type="button" class="seg-btn is-active" id="tabLotes" role="tab">
              📦 Desde lote preparado
            </button>
            <button type="button" class="seg-btn" id="tabCero" role="tab">
              ✏️ Crear desde cero
            </button>
          </div>

          <!-- TAB 1: Desde Lotes Preparados -->
          <div id="tabLotesContent">
            <form id="labelsFromLotsForm">
              <div class="form-group">
                <label for="preparedLotSelect">
                  Lote preparado para venta <span class="required">*</span>
                </label>
                <select id="preparedLotSelect" name="preparedLot" required>
                  <option value="">Seleccione un lote preparado…</option>
                </select>
                <div class="form-hint">
                  Cafés ya procesados con perfil de taza definido.
                </div>
              </div>

              <!-- Información del Lote -->
              <div class="lot-info" id="lotInfoCard" hidden>
                <div class="form-section"><h3>Información del café</h3></div>
                <div class="detail-grid">
                  <div class="detail-item">
                    <dt>Lote ID</dt><dd id="lotIdDisplay">—</dd>
                  </div>
                  <div class="detail-item">
                    <dt>Origen</dt><dd id="lotOriginDisplay">—</dd>
                  </div>
                  <div class="detail-item">
                    <dt>Variedad</dt><dd id="lotVarietyDisplay">—</dd>
                  </div>
                  <div class="detail-item">
                    <dt>Tueste</dt><dd id="lotRoastDisplay">—</dd>
                  </div>
                  <div class="detail-item">
                    <dt>Presentación</dt><dd id="lotPresentationDisplay">—</dd>
                  </div>
                  <div class="detail-item">
                    <dt>Peso disponible</dt>
                    <dd style="color: var(--color-accent);" id="lotWeightDisplay">—</dd>
                  </div>
                </div>

                <div class="info-box" style="margin-top: 16px;">
                  <strong>☕ Perfil de taza</strong>
                  <div class="detail-grid" style="margin-top: 12px;">
                    <div class="detail-item">
                      <dt>Acidez</dt><dd id="lotAcidityDisplay">—</dd>
                    </div>
                    <div class="detail-item">
                      <dt>Cuerpo</dt><dd id="lotBodyDisplay">—</dd>
                    </div>
                    <div class="detail-item">
                      <dt>Balance</dt><dd id="lotBalanceDisplay">—</dd>
                    </div>
                    <div class="detail-item">
                      <dt>Puntuación</dt>
                      <dd style="color: var(--color-accent);" id="lotScoreDisplay">—</dd>
                    </div>
                  </div>
                </div>
              </div>

              <div class="form-group" style="margin-top: 16px;">
                <label for="quantityLots">
                  Cantidad de etiquetas a generar <span class="required">*</span>
                </label>
                <input
                  type="number" id="quantityLots" name="quantityLots"
                  placeholder="Ej: 25" min="1" max="1000" required
                />
                <div class="form-hint">¿Cuántas etiquetas desea imprimir?</div>
              </div>

              <label class="checkbox-item" style="margin-bottom: 8px;">
                <input type="checkbox" id="includeQRLots" name="includeQR" checked />
                <span>Incluir código QR de trazabilidad</span>
              </label>
              <div class="form-hint" style="margin-bottom: 8px;">
                Permite a los clientes escanear la información del café.
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-save" id="submitLots">
                  Generar etiquetas
                </button>
              </div>
            </form>
          </div>

          <!-- TAB 2: Crear de Cero -->
          <div id="tabCeroContent" hidden>
            <form id="labelFromScratchForm">
              <div class="form-grid">
                <div class="form-group form-group--wide">
                  <label for="customCoffeeOrigin">
                    Origen del café <span class="required">*</span>
                  </label>
                  <input
                    type="text" id="customCoffeeOrigin" name="origin"
                    placeholder="Ej: Sierra Nevada, Huila" required
                  />
                </div>

                <div class="form-group form-group--wide">
                  <label for="customCoffeeFarm">Finca (opcional)</label>
                  <input
                    type="text" id="customCoffeeFarm" name="farm"
                    placeholder="Ej: Finca La Aurora"
                  />
                </div>

                <div class="form-group">
                  <label for="customVariety">
                    Variedad <span class="required">*</span>
                  </label>
                  <input
                    type="text" id="customVariety" name="variety"
                    placeholder="Ej: Caturra, Bourbon" required
                  />
                </div>
                <div class="form-group">
                  <label for="customRoast">
                    Nivel de tueste <span class="required">*</span>
                  </label>
                  <select id="customRoast" name="roast" required>
                    <option value="">Seleccione…</option>
                    <option value="Claro">Claro (Light)</option>
                    <option value="Medio">Medio (Medium)</option>
                    <option value="Oscuro">Oscuro (Dark)</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="customProcess">Proceso (opcional)</label>
                  <select id="customProcess" name="process">
                    <option value="">Sin especificar</option>
                    <option value="Lavado">Lavado</option>
                    <option value="Natural">Natural</option>
                    <option value="Honey">Honey</option>
                    <option value="Anaeróbico">Anaeróbico</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="customAltitude">Altitud (opcional)</label>
                  <input
                    type="text" id="customAltitude" name="altitude"
                    placeholder="Ej: 1800 m"
                  />
                </div>
              </div>

              <!-- Perfil de Taza -->
              <div class="form-section"><h3>☕ Perfil de taza</h3></div>

              <div class="slider-field">
                <label for="customAcidity">
                  Acidez <span class="required">*</span>
                  <span class="slider-value" id="customAcidityValue">3/5</span>
                </label>
                <input type="range" id="customAcidity" name="acidity" min="1" max="5" value="3" />
                <div class="slider-scale">
                  <span>Baja</span><span>Media</span><span>Alta</span>
                </div>
              </div>

              <div class="slider-field">
                <label for="customBody">
                  Cuerpo <span class="required">*</span>
                  <span class="slider-value" id="customBodyValue">3/5</span>
                </label>
                <input type="range" id="customBody" name="body" min="1" max="5" value="3" />
                <div class="slider-scale">
                  <span>Ligero</span><span>Medio</span><span>Pesado</span>
                </div>
              </div>

              <div class="slider-field">
                <label for="customBalance">
                  Balance <span class="required">*</span>
                  <span class="slider-value" id="customBalanceValue">3/5</span>
                </label>
                <input type="range" id="customBalance" name="balance" min="1" max="5" value="3" />
                <div class="slider-scale">
                  <span>Desbalanceado</span><span>Balanceado</span><span>Muy balanceado</span>
                </div>
              </div>

              <div class="form-group" style="margin-top: 16px;">
                <label for="customFlavorNotes">Notas de sabor (opcional)</label>
                <textarea
                  id="customFlavorNotes" name="flavorNotes"
                  placeholder="Ej: Chocolate, nueces, caramelo, frutas tropicales"
                ></textarea>
                <div class="form-hint">Describa los sabores principales del café.</div>
              </div>

              <div class="form-grid">
                <div class="form-group">
                  <label for="customRoastDate">Fecha de tostión (opcional)</label>
                  <input type="date" id="customRoastDate" name="roastDate" />
                </div>
                <div class="form-group">
                  <label for="customRegion">Región (opcional)</label>
                  <select id="customRegion" name="region">
                    <option value="">Seleccione…</option>
                    <option value="Huila">Huila</option>
                    <option value="Nariño">Nariño</option>
                    <option value="Cauca">Cauca</option>
                    <option value="Tolima">Tolima</option>
                    <option value="Cundinamarca">Cundinamarca</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="customClimate">Clima (opcional)</label>
                  <select id="customClimate" name="climate">
                    <option value="">Seleccione…</option>
                    <option value="Seco">Seco</option>
                    <option value="Lluvioso">Lluvioso</option>
                    <option value="Templado">Templado</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="quantityCero">
                    Cantidad de etiquetas <span class="required">*</span>
                  </label>
                  <input
                    type="number" id="quantityCero" name="quantityCero"
                    placeholder="Ej: 25" min="1" max="1000" required
                  />
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-save" id="submitCero">
                  Generar etiquetas
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>

      <!-- Columna derecha: vista previa -->
      <aside class="labels-side">
        <section class="card">
          <div class="card-header">
            <div>
              <h3 class="card-title">Vista previa</h3>
              <div class="card-subtitle">Así se verá la etiqueta impresa</div>
            </div>
            <span class="badge badge-neutral" id="previewCount">0 etiquetas</span>
          </div>
          <div class="card-pad">
            <div class="preview-actions">
              <button type="button" class="btn btn-secondary btn-sm" id="printPreviewBtn">
                🖨️ Imprimir prueba
              </button>
              <button type="button" class="btn btn-save btn-sm" id="printBatchBtn" hidden>
                🖨️ Imprimir lote generado
              </button>
            </div>
            <!-- Etiqueta -->
            <div class="lbl" id="labelPreview">
              <div class="lbl-head">
                <div class="lbl-brand">DobleYo<span>Café</span></div>
                <div class="lbl-origin" id="pvOrigin">Origen del café</div>
              </div>

              <div class="lbl-variety" id="pvVariety">Variedad</div>

              <div class="lbl-tags">
                <span class="lbl-tag" id="pvRoast" hidden></span>
                <span class="lbl-tag" id="pvProcess" hidden></span>
                <span class="lbl-tag" id="pvFarm" hidden></span>
              </div>

              <div class="lbl-profile">
                <div class="pv-row">
                  <span class="pv-k">Acidez</span>
                  <div class="pv-bars" data-bar="acidity">
                    <i></i><i></i><i></i><i></i><i></i>
                  </div>
                </div>
                <div class="pv-row">
                  <span class="pv-k">Cuerpo</span>
                  <div class="pv-bars" data-bar="body">
                    <i></i><i></i><i></i><i></i><i></i>
                  </div>
                </div>
                <div class="pv-row">
                  <span class="pv-k">Balance</span>
                  <div class="pv-bars" data-bar="balance">
                    <i></i><i></i><i></i><i></i><i></i>
                  </div>
                </div>
              </div>

              <div class="lbl-notes" id="pvNotes">Notas de sabor del café…</div>

              <div class="lbl-foot">
                <div class="lbl-qr" id="pvQr" aria-hidden="true">
                  <svg viewBox="0 0 29 29" width="56" height="56">
                    <rect width="29" height="29" fill="#fff"></rect>
                    <path fill="currentColor" d="M0 0h7v7H0zM2 2v3h3V2zM22 0h7v7h-7zM24 2v3h3V2zM0 22h7v7H0zM2 24v3h3v-3zM9 0h2v2H9zM13 2h2v3h-2zM9 9h2v2h2v2h-2v2H9v-2H7v-2h2zM16 9h2v2h-2zM20 9h2v2h-2zM24 9h3v2h-2v2h-2v-2h1zM16 13h3v2h-3zM22 13h2v4h-2zM9 16h2v2h-2zM13 16h2v2h-2zM18 16h2v2h-2zM26 16h3v2h-3zM16 18h2v2h-2zM20 18h2v3h-2zM24 18h2v2h-2zM9 20h3v2h-3zM13 22h2v2h-2zM17 22h2v2h-2zM22 23h2v2h-2zM26 22h3v3h-3zM13 26h4v3h-4zM20 26h2v3h-2zM24 26h2v2h-2z"></path>
                  </svg>
                </div>
                <div class="lbl-meta">
                  <div class="lbl-code" id="pvCode">LBL-—-0001</div>
                  <div class="lbl-score">Puntaje: <strong id="pvScore">—</strong></div>
                  <div class="lbl-tagline">Café de especialidad colombiano</div>
                </div>
              </div>
            </div>

            <!-- Resumen -->
            <div class="info-box" id="summaryBox" hidden style="margin-top: 16px;">
              <strong>Resumen</strong>
              <div id="summaryBody" style="margin-top: 8px; font-size: 13px; line-height: 1.7;"></div>
            </div>
          </div>
        </section>
      </aside>
    </div>

    <!-- ── Etiquetas recientes ───────────────────────────────────────── -->
    <section class="card" style="margin-top: 22px;">
      <div class="card-header">
        <div>
          <h3 class="card-title">Etiquetas recientes</h3>
          <div class="card-subtitle">Últimas generaciones registradas</div>
        </div>
      </div>
      <div class="table-wrapper">
        <table class="erp-table">
          <thead>
            <tr>
              <th>Código</th>
              <th>Lote</th>
              <th>Origen</th>
              <th>Variedad</th>
              <th>Tueste</th>
              <th>Puntaje</th>
              <th>Estado</th>
              <th style="text-align: right;">Acción</th>
            </tr>
          </thead>
          <tbody id="recentBody">
            <tr><td colspan="8" class="empty-state">Cargando…</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <!-- Toasts -->
  <div class="toast-stack" id="toastStack" aria-live="polite"></div>

  <!-- Scripts -->
  <script>
    // ── Estado ──────────────────────────────────────────────────────
    let activeTab = "lotes";
    let selectedLot = null;
    let availableCount = 0;

    // ── Toast ───────────────────────────────────────────────────────
    function toast(message, type = "info") {
      const stack = document.getElementById("toastStack");
      const el = document.createElement("div");
      el.className = `toast toast--${type}`;
      el.textContent = message;
      stack.appendChild(el);
      requestAnimationFrame(() => el.classList.add("is-in"));
      setTimeout(() => {
        el.classList.remove("is-in");
        setTimeout(() => el.remove(), 250);
      }, 3500);
    }

    // ── Tabs ────────────────────────────────────────────────────────
    function switchTab(tab) {
      activeTab = tab;
      const isLotes = tab === "lotes";
      document.getElementById("tabLotesContent").hidden = !isLotes;
      document.getElementById("tabCeroContent").hidden = isLotes;
      document.getElementById("tabLotes").classList.toggle("is-active", isLotes);
      document.getElementById("tabCero").classList.toggle("is-active", !isLotes);
      updatePreview();
    }

    // ── Vista previa en vivo ────────────────────────────────────────
    function setBars(name, value) {
      const wrap = document.querySelector(`.pv-bars[data-bar="${name}"]`);
      if (!wrap) return;
      const v = parseInt(value) || 0;
      wrap.querySelectorAll("i").forEach((bar, idx) => {
        bar.classList.toggle("is-on", idx < v);
      });
    }

    function setTag(id, text) {
      const el = document.getElementById(id);
      if (!el) return;
      if (text) {
        el.textContent = text;
        el.hidden = false;
      } else {
        el.hidden = true;
      }
    }

    function updatePreview() {
      let data = {};
      let qty = 0;
      let code = "LBL-—-0001";

      if (activeTab === "lotes" && selectedLot) {
        data = {
          origin: selectedLot.origin,
          variety: selectedLot.variety,
          roast: selectedLot.roast,
          process: selectedLot.process,
          farm: selectedLot.farm,
          notes: selectedLot.flavorNotes,
          acidity: selectedLot.acidity,
          body: selectedLot.body,
          balance: selectedLot.balance,
          score: selectedLot.score,
        };
        qty = parseInt(document.getElementById("quantityLots").value) || 0;
        code = `LBL-${selectedLot.code}-0001`;
        document.getElementById("pvQr").style.display =
          document.getElementById("includeQRLots").checked ? "" : "none";
      } else if (activeTab === "cero") {
        const acidity = document.getElementById("customAcidity").value;
        const body = document.getElementById("customBody").value;
        const balance = document.getElementById("customBalance").value;
        data = {
          origin: document.getElementById("customCoffeeOrigin").value,
          variety: document.getElementById("customVariety").value,
          roast: document.getElementById("customRoast").value,
          process: document.getElementById("customProcess").value,
          farm: document.getElementById("customCoffeeFarm").value,
          notes: document.getElementById("customFlavorNotes").value,
          acidity, body, balance,
          score: ((+acidity + +body + +balance) / 3).toFixed(1),
        };
        qty = parseInt(document.getElementById("quantityCero").value) || 0;
        const o = (data.origin || "XXX").substring(0, 3).toUpperCase();
        const v = (data.variety || "XXX").substring(0, 3).toUpperCase();
        // El backend agrega un timestamp único al código real (LBL-TMP-ORI-VAR-<ts>-0001);
        // aquí solo se muestra un adelanto aproximado.
        code = `LBL-TMP-${o}-${v}-•••-0001`;
        document.getElementById("pvQr").style.display = "";
      }

      document.getElementById("pvOrigin").textContent = data.origin || "Origen del café";
      document.getElementById("pvVariety").textContent = data.variety || "Variedad";
      setTag("pvRoast", data.roast ? `Tueste ${data.roast}` : "");
      setTag("pvProcess", data.process || "");
      setTag("pvFarm", data.farm || "");
      document.getElementById("pvNotes").textContent =
        data.notes || "Notas de sabor del café…";
      document.getElementById("pvCode").textContent = code;
      document.getElementById("pvScore").textContent = data.score || "—";
      setBars("acidity", data.acidity);
      setBars("body", data.body);
      setBars("balance", data.balance);

      document.getElementById("previewCount").textContent =
        `${qty || 0} ${qty === 1 ? "etiqueta" : "etiquetas"}`;

      updateSummary(data, qty, code);
    }

    function updateSummary(data, qty, code) {
      const box = document.getElementById("summaryBox");
      if (!qty || !data.variety) {
        box.hidden = true;
        return;
      }
      box.hidden = false;
      document.getElementById("summaryBody").innerHTML = `
        <div>☕ Café: <strong>${esc(data.origin) || "—"} · ${esc(data.variety)}</strong></div>
        <div>🔥 Tueste: <strong>${esc(data.roast) || "—"}</strong></div>
        <div>🏷️ Cantidad: <strong>${qty}</strong></div>
        <div>🔖 Primer código: <strong>${esc(code)}</strong></div>`;
    }

    // ── Cargar lotes preparados ─────────────────────────────────────
    async function loadPreparedLots() {
      try {
        const response = await fetch("/api/labels/prepared-lots");
        if (!response.ok) throw new Error("Error al cargar lotes");
        const lots = await response.json();
        availableCount = lots.length;
        document.getElementById("kpiAvailable").textContent = lots.length;

        const select = document.getElementById("preparedLotSelect");
        select.innerHTML = '<option value="">Seleccione un lote preparado…</option>';
        lots.forEach((lot) => {
          const option = document.createElement("option");
          option.value = JSON.stringify(lot);
          option.textContent = `${lot.code} · ${lot.variety} (${lot.weight}kg)`;
          select.appendChild(option);
        });
      } catch (error) {
        console.error("Error cargando lotes:", error);
        document.getElementById("kpiAvailable").textContent = "0";
      }
    }

    // ── Estadísticas (KPIs) + recientes ─────────────────────────────
    async function loadStats() {
      try {
        const [statsRes, recentRes] = await Promise.all([
          fetch("/api/labels/stats"),
          fetch("/api/labels/list?limit=8"),
        ]);
        const stats = await statsRes.json();
        const recent = await recentRes.json();

        document.getElementById("kpiTotal").textContent = stats.data?.total ?? 0;
        document.getElementById("kpiFromLots").textContent = stats.data?.fromLots ?? 0;
        document.getElementById("kpiCustom").textContent = stats.data?.custom ?? 0;

        renderRecent(recent.data || []);
      } catch (error) {
        console.error("Error cargando estadísticas:", error);
        renderRecent([]);
      }
    }

    function renderRecent(labels) {
      const body = document.getElementById("recentBody");
      if (!labels.length) {
        body.innerHTML =
          '<tr><td colspan="8" class="empty-state">Aún no hay etiquetas generadas.</td></tr>';
        return;
      }
      body.innerHTML = labels
        .map((l) => {
          const isPrinted = !!l.printed;
          return `
        <tr>
          <td style="font-family: ui-monospace, monospace; font-size: 12px;">${esc(l.label_code)}</td>
          <td>${esc(l.lot_code) || "—"}</td>
          <td>${esc(l.origin) || "—"}</td>
          <td>${esc(l.variety) || "—"}</td>
          <td>${esc(l.roast) || "—"}</td>
          <td style="font-variant-numeric: tabular-nums;">${l.score ?? "—"}</td>
          <td>
            <span class="badge ${isPrinted ? "badge-success" : "badge-neutral"}">
              ${isPrinted ? "Impresa" : "Pendiente"}
            </span>
          </td>
          <td style="text-align: right; white-space: nowrap;">
            <button
              class="btn btn-secondary btn-sm"
              data-toggle-print="${esc(l.label_code)}"
              data-printed="${isPrinted ? "1" : "0"}"
            >${isPrinted ? "Marcar pendiente" : "Marcar impresa"}</button>
            <button class="btn btn-danger btn-sm" data-del="${esc(l.label_code)}">Eliminar</button>
          </td>
        </tr>`;
        })
        .join("");
    }

    function esc(s) {
      if (s == null) return "";
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c])
      );
    }

    async function deleteLabel(code) {
      if (!confirm(`¿Eliminar la etiqueta ${code}?`)) return;
      try {
        const res = await fetch(`/api/labels/${encodeURIComponent(code)}`, {
          method: "DELETE",
        });
        if (!res.ok) throw new Error("No se pudo eliminar");
        toast("Etiqueta eliminada", "success");
        loadStats();
      } catch (error) {
        toast(error.message, "error");
      }
    }

    async function togglePrint(code, currentlyPrinted) {
      try {
        const res = await fetch(`/api/labels/${encodeURIComponent(code)}/print`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ printed: !currentlyPrinted }),
        });
        const result = await res.json();
        if (!res.ok || result.success === false)
          throw new Error(result.error || "No se pudo actualizar el estado");
        toast(
          currentlyPrinted ? "Etiqueta marcada como pendiente" : "Etiqueta marcada como impresa",
          "success"
        );
        loadStats();
      } catch (error) {
        toast(error.message, "error");
      }
    }

    // ── Listeners ───────────────────────────────────────────────────
    document.getElementById("preparedLotSelect")?.addEventListener("change", (e) => {
      if (!e.target.value) {
        selectedLot = null;
        document.getElementById("lotInfoCard").hidden = true;
        updatePreview();
        return;
      }
      const lot = JSON.parse(e.target.value);
      selectedLot = lot;
      document.getElementById("lotIdDisplay").textContent = lot.code;
      document.getElementById("lotOriginDisplay").textContent = lot.origin || "—";
      document.getElementById("lotVarietyDisplay").textContent = lot.variety || "—";
      document.getElementById("lotRoastDisplay").textContent = lot.roast || "—";
      document.getElementById("lotPresentationDisplay").textContent = lot.presentation || "—";
      document.getElementById("lotWeightDisplay").textContent = `${lot.weight} kg`;
      document.getElementById("lotAcidityDisplay").textContent = `${lot.acidity || "—"}/5`;
      document.getElementById("lotBodyDisplay").textContent = `${lot.body || "—"}/5`;
      document.getElementById("lotBalanceDisplay").textContent = `${lot.balance || "—"}/5`;
      document.getElementById("lotScoreDisplay").textContent = lot.score
        ? Number(lot.score).toFixed(1)
        : "—";
      document.getElementById("lotInfoCard").hidden = false;
      updatePreview();
    });

    document.getElementById("quantityLots")?.addEventListener("input", updatePreview);
    document.getElementById("includeQRLots")?.addEventListener("change", updatePreview);

    ["customAcidity", "customBody", "customBalance"].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", (e) => {
        document.getElementById(`${id}Value`).textContent = `${e.target.value}/5`;
        updatePreview();
      });
    });
    [
      "customCoffeeOrigin", "customCoffeeFarm", "customVariety", "customRoast",
      "customProcess", "customFlavorNotes", "quantityCero",
    ].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", updatePreview);
    });

    // ── Envío Tab 1 ─────────────────────────────────────────────────
    document.getElementById("labelsFromLotsForm")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!selectedLot) return toast("Seleccione un lote preparado", "error");

      const quantity = parseInt(document.getElementById("quantityLots").value);
      const includeQR = document.getElementById("includeQRLots").checked;
      const btn = document.getElementById("submitLots");
      btn.disabled = true;
      const prev = btn.textContent;
      btn.textContent = "Generando…";

      try {
        const response = await fetch("/api/labels/generate-from-lot", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ lotId: selectedLot.id, quantity, includeQR }),
        });
        const result = await response.json();
        if (!response.ok || result.success === false)
          throw new Error(result.error || "Error al generar etiquetas");

        toast(`${quantity} etiquetas generadas exitosamente`, "success");
        e.target.reset();
        selectedLot = null;
        document.getElementById("lotInfoCard").hidden = true;
        updatePreview();
        loadStats();
      } catch (error) {
        toast(error.message, "error");
      } finally {
        btn.disabled = false;
        btn.textContent = prev;
      }
    });

    // ── Envío Tab 2 ─────────────────────────────────────────────────
    document.getElementById("labelFromScratchForm")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = {
        origin: document.getElementById("customCoffeeOrigin").value,
        farm: document.getElementById("customCoffeeFarm").value,
        variety: document.getElementById("customVariety").value,
        roast: document.getElementById("customRoast").value,
        roastDate: document.getElementById("customRoastDate").value,
        region: document.getElementById("customRegion").value,
        climate: document.getElementById("customClimate").value,
        process: document.getElementById("customProcess").value,
        altitude: document.getElementById("customAltitude").value,
        acidity: parseInt(document.getElementById("customAcidity").value),
        body: parseInt(document.getElementById("customBody").value),
        balance: parseInt(document.getElementById("customBalance").value),
        flavorNotes: document.getElementById("customFlavorNotes").value,
        quantity: parseInt(document.getElementById("quantityCero").value),
      };

      const btn = document.getElementById("submitCero");
      btn.disabled = true;
      const prev = btn.textContent;
      btn.textContent = "Generando…";

      try {
        const response = await fetch("/api/labels/generate-from-scratch", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(formData),
        });
        const result = await response.json();
        if (!response.ok || result.success === false)
          throw new Error(result.error || "Error al generar etiquetas");

        toast(`${formData.quantity} etiquetas generadas exitosamente`, "success");
        e.target.reset();
        ["customAcidityValue", "customBodyValue", "customBalanceValue"].forEach(
          (id) => (document.getElementById(id).textContent = "3/5")
        );
        updatePreview();
        loadStats();
      } catch (error) {
        toast(error.message, "error");
      } finally {
        btn.disabled = false;
        btn.textContent = prev;
      }
    });

    // Delegación: eliminar / marcar impresa etiqueta reciente
    document.getElementById("recentBody")?.addEventListener("click", (e) => {
      const delBtn = e.target.closest("[data-del]");
      if (delBtn) return deleteLabel(delBtn.dataset.del);

      const printBtn = e.target.closest("[data-toggle-print]");
      if (printBtn)
        return togglePrint(printBtn.dataset.togglePrint, printBtn.dataset.printed === "1");
    });

    document.getElementById("tabLotes")?.addEventListener("click", () => switchTab("lotes"));
    document.getElementById("tabCero")?.addEventListener("click", () => switchTab("cero"));
    document.getElementById("refreshBtn")?.addEventListener("click", () => {
      loadPreparedLots();
      loadStats();
      toast("Datos actualizados", "info");
    });

    // ── Init ────────────────────────────────────────────────────────
    document.addEventListener("DOMContentLoaded", () => {
      loadPreparedLots();
      loadStats();
      updatePreview();
    });
  </script>
</AdminLayout>

<style>
  /* ── Layout workbench ──────────────────────────────────────────── */
  .labels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: start;
  }
  @media (min-width: 980px) {
    .labels-grid { grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr); }
    .labels-side { position: sticky; top: 16px; }
  }

  .card-pad { padding: 18px; }

  /* ── Segmented control (tabs) ──────────────────────────────────── */
  .seg {
    display: flex;
    gap: 4px;
    padding: 4px;
    background: color-mix(in oklab, var(--color-primary) 5%, white);
