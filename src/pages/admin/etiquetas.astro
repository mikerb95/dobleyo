    color: color-mix(in oklab, #f3e9dd 75%, transparent);
    text-align: right;
  }
  .lbl-variety {
    font-size: 22px;
    font-weight: 700;
    margin: 14px 0 10px;
    color: #fff;
    line-height: 1.15;
  }
  .lbl-tags { display: flex; flex-wrap: wrap; gap: 6px; min-height: 4px; }
  .lbl-tag {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-accent) 28%, transparent);
