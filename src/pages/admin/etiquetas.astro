    color: color-mix(in oklab, #f3e9dd 70%, transparent);
    word-break: break-all;
  }
  .lbl-score { margin: 3px 0; }
  .lbl-score strong { color: var(--color-accent); }
  .lbl-tagline {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, #f3e9dd 55%, transparent);
  }

  /* ── Botón pequeño ─────────────────────────────────────────────── */
  .btn-sm { padding: 4px 10px; font-size: 12px; }

  /* ── Toasts ────────────────────────────────────────────────────── */
  .toast-stack {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .toast {
    padding: 11px 16px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    background: var(--color-primary);
    box-shadow: 0 8px 24px -8px color-mix(in oklab, var(--color-primary) 50%, transparent);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s;
    max-width: 320px;
  }
  .toast.is-in { opacity: 1; transform: translateY(0); }
  .toast--success { background: var(--ok); }
  .toast--error { background: var(--danger); }
  .toast--info { background: var(--color-primary); }
</style>
