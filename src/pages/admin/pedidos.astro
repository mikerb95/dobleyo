---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Pedidos — DobleYo Admin" section="pedidos">
  <style>
    .page-header { margin-bottom: 1.75rem; }
    .page-header h1 { font-size: 1.75rem; font-weight: 700; color: #251a14; margin: 0 0 0.25rem; }
    .page-header p { margin: 0; color: #7a6652; font-size: 0.95rem; }

    /* ── Filters ──────────────────────────────────── */
    .filters-bar {
      background: #fff;
      border-radius: 10px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(37,26,20,0.08);
      margin-bottom: 1.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: flex-end;
    }
    .filter-group { display: flex; flex-direction: column; gap: 0.3rem; min-width: 140px; }
    .filter-group label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #7a6652; }
    .filter-group select,
    .filter-group input {
      padding: 0.55rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.88rem;
      color: #251a14;
      background: #faf8f5;
      outline: none;
    }
    .filter-group select:focus, .filter-group input:focus { border-color: #c8a96e; }
    .btn-filter {
      padding: 0.55rem 1.25rem;
      background: #4a6741;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: auto;
    }
    .btn-filter:hover { background: #3a5331; }
    .btn-reset {
      padding: 0.55rem 1rem;
      background: transparent;
      color: #7a6652;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.88rem;
      cursor: pointer;
      margin-top: auto;
    }
    .btn-reset:hover { border-color: #bbb; color: #251a14; }

    /* ── Summary row ──────────────────────────────── */
    .summary-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
      font-size: 0.88rem;
      color: #7a6652;
    }
    .summary-bar strong { color: #251a14; }

    /* ── Table ────────────────────────────────────── */
    .table-wrap {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(37,26,20,0.08);
      overflow-x: auto;
      margin-bottom: 1.5rem;
    }
    table { width: 100%; border-collapse: collapse; font-size: 0.87rem; }
    thead th {
      text-align: left;
      padding: 0.75rem 1rem;
      font-size: 0.71rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #7a6652;
      border-bottom: 1px solid #ede8e2;
      white-space: nowrap;
    }
    tbody td {
      padding: 0.7rem 1rem;
      border-bottom: 1px solid #f5f2ee;
      color: #3d2e22;
      vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf8f5; }

    /* ── Badge ────────────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 50px;
      font-size: 0.71rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .badge-paid       { background: #d4edda; color: #155724; }
    .badge-pending    { background: #fff3cd; color: #856404; }
    .badge-processing { background: #cce5ff; color: #004085; }
    .badge-shipped    { background: #d1ecf1; color: #0c5460; }
    .badge-delivered  { background: #d4edda; color: #155724; }
    .badge-cancelled  { background: #f8d7da; color: #721c24; }
    .badge-refunded   { background: #e2e3e5; color: #383d41; }
    .badge-default    { background: #e9ecef; color: #495057; }

    /* ── Pagination ───────────────────────────────── */
    .pagination {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }
    .page-btn {
      padding: 0.4rem 0.8rem;
      border: 1px solid #ddd;
      background: #fff;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
      color: #251a14;
      transition: background 0.15s, border-color 0.15s;
    }
    .page-btn:hover { background: #f7f3ef; border-color: #c8a96e; }
    .page-btn.active { background: #4a6741; color: #fff; border-color: #4a6741; }
    .page-btn:disabled { opacity: 0.4; cursor: default; }

    /* ── Empty / loading ──────────────────────────── */
    .empty { text-align: center; padding: 2.5rem; color: #7a6652; font-style: italic; }

    /* ── Modal ────────────────────────────────────── */
    .modal-back {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 300;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .modal-back.open { display: flex; }
    .modal {
      background: #fff;
      border-radius: 12px;
      width: 100%;
      max-width: 560px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 8px 32px rgba(37,26,20,0.22);
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid #ede8e2;
    }
    .modal-header h2 { margin: 0; font-size: 1.1rem; color: #251a14; }
    .modal-close {
      background: none; border: none; cursor: pointer;
      color: #7a6652; font-size: 1.4rem; line-height: 1; padding: 0.2rem;
    }
    .modal-body { padding: 1.5rem; }
    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 0.45rem 0;
      border-bottom: 1px solid #f5f2ee;
      font-size: 0.88rem;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: #7a6652; font-weight: 600; }
    .detail-value { color: #251a14; text-align: right; max-width: 60%; word-break: break-word; }
    .modal-section { margin-top: 1.25rem; }
    .modal-section-title {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7a6652;
      margin-bottom: 0.75rem;
    }
    .status-form { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end; margin-top: 1rem; }
    .status-form select {
      flex: 1;
      min-width: 160px;
      padding: 0.6rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.88rem;
      background: #faf8f5;
    }
    .btn-save {
      padding: 0.6rem 1.25rem;
      background: #4a6741;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-save:hover { background: #3a5331; }
    .btn-save:disabled { opacity: 0.5; cursor: default; }
    .save-msg { font-size: 0.82rem; margin-top: 0.5rem; }

    /* Action button in table */
    .btn-action {
      padding: 0.3rem 0.7rem;
      font-size: 0.78rem;
      font-weight: 600;
      border: 1px solid #ddd;
      border-radius: 5px;
      background: #fff;
      cursor: pointer;
      color: #251a14;
      transition: background 0.15s;
    }
    .btn-action:hover { background: #f7f3ef; border-color: #c8a96e; }
  </style>

  <header class="page-header">
    <h1>Pedidos</h1>
    <p>Gestión y seguimiento de órdenes de la tienda</p>
  </header>

  <!-- Filters -->
  <div class="filters-bar">
    <div class="filter-group">
      <label for="fStatus">Estado</label>
      <select id="fStatus">
        <option value="">Todos</option>
        <option value="pending_payment">Pendiente pago</option>
        <option value="paid">Pagado</option>
        <option value="processing">En proceso</option>
        <option value="shipped">Enviado</option>
        <option value="delivered">Entregado</option>
        <option value="cancelled">Cancelado</option>
        <option value="refunded">Reembolsado</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="fSearch">Buscar (ref / cliente)</label>
      <input type="text" id="fSearch" placeholder="REF-xxxx o nombre..." />
    </div>
    <button class="btn-filter" id="btnSearch">Buscar</button>
    <button class="btn-reset" id="btnReset">Limpiar</button>
  </div>

  <!-- Summary -->
  <div class="summary-bar">
    <span id="summaryText">Cargando...</span>
  </div>

  <!-- Table -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Referencia</th>
          <th>Cliente</th>
          <th>Email</th>
          <th>Ciudad</th>
          <th>Total</th>
          <th>Pago</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="ordersBody">
        <tr><td colspan="9" class="empty">Cargando pedidos...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="pagination" id="pagination"></div>

  <!-- Detail / status modal -->
  <div class="modal-back" id="modalBack">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-header">
        <h2 id="modalTitle">Pedido</h2>
        <button class="modal-close" id="modalClose" aria-label="Cerrar">&times;</button>
      </div>
      <div class="modal-body">
        <div id="modalDetails"></div>

        <div class="modal-section">
          <div class="modal-section-title">Actualizar estado</div>
          <div class="status-form">
            <select id="newStatus">
              <option value="pending_payment">Pendiente pago</option>
              <option value="paid">Pagado</option>
              <option value="processing">En proceso</option>
              <option value="shipped">Enviado</option>
              <option value="delivered">Entregado</option>
              <option value="cancelled">Cancelado</option>
              <option value="refunded">Reembolsado</option>
            </select>
            <button class="btn-save" id="btnSaveStatus">Guardar</button>
          </div>
          <div class="save-msg" id="saveMsg"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Config ────────────────────────────────────────────────
    const PAGE_SIZE = 20;

    const STATUS_LABELS: Record<string, string> = {
      pending_payment: "Pendiente pago",
      paid: "Pagado",
      processing: "En proceso",
      shipped: "Enviado",
      delivered: "Entregado",
      cancelled: "Cancelado",
      refunded: "Reembolsado",
    };
    const STATUS_CLASS: Record<string, string> = {
      pending_payment: "badge-pending",
      paid: "badge-paid",
      processing: "badge-processing",
      shipped: "badge-shipped",
      delivered: "badge-delivered",
      cancelled: "badge-cancelled",
      refunded: "badge-refunded",
    };

    const fmtCOP = (n: number) =>
      new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n);
    const fmtDate = (s: string) =>
      s ? new Date(s).toLocaleDateString("es-CO", { day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" }) : "—";
    const badge = (st: string) => {
      const cls = STATUS_CLASS[st] ?? "badge-default";
      return `<span class="badge ${cls}">${STATUS_LABELS[st] ?? st}</span>`;
    };

    // ── State ─────────────────────────────────────────────────
    let currentPage = 0;
    let totalOrders = 0;
    let currentRef = "";

    const getFilters = () => ({
      status: (document.getElementById("fStatus") as HTMLSelectElement).value,
      search: (document.getElementById("fSearch") as HTMLInputElement).value.trim(),
    });

    // ── Load orders ───────────────────────────────────────────
    async function loadOrders(page = 0) {
      currentPage = page;
      const { status, search } = getFilters();
      const offset = page * PAGE_SIZE;
      const params = new URLSearchParams({ limit: String(PAGE_SIZE), offset: String(offset) });
      if (status) params.set("status", status);

      const tbody = document.getElementById("ordersBody")!;
      tbody.innerHTML = `<tr><td colspan="9" class="empty">Cargando...</td></tr>`;
      document.getElementById("summaryText")!.textContent = "Cargando...";

      try {
        const res = await fetch(`/api/orders?${params}`, { credentials: "include" });
        if (!res.ok) throw new Error("Error al cargar");
        const data = await res.json();
        let rows: any[] = data.data ?? [];
        totalOrders = data.total ?? rows.length;

        // Client-side search filter
        if (search) {
          const q = search.toLowerCase();
          rows = rows.filter(
            (o) =>
              o.reference?.toLowerCase().includes(q) ||
              o.customer_name?.toLowerCase().includes(q) ||
              o.customer_email?.toLowerCase().includes(q)
          );
        }

        document.getElementById("summaryText")!.innerHTML =
          `Mostrando <strong>${rows.length}</strong> de <strong>${totalOrders}</strong> pedidos`;

        if (rows.length === 0) {
          tbody.innerHTML = `<tr><td colspan="9" class="empty">No se encontraron pedidos.</td></tr>`;
        } else {
          tbody.innerHTML = rows
            .map(
              (o) => `
            <tr>
              <td><strong>${o.reference ?? "—"}</strong></td>
              <td>${o.customer_name ?? "—"}</td>
              <td style="color:#7a6652;font-size:0.82rem">${o.customer_email ?? "—"}</td>
              <td>${o.shipping_city ?? "—"}</td>
              <td style="font-weight:600">${fmtCOP(Number(o.total_cop) || 0)}</td>
              <td style="font-size:0.8rem;color:#7a6652">${o.payment_method ?? "—"}</td>
              <td>${badge(o.status)}</td>
              <td style="color:#7a6652;font-size:0.82rem">${fmtDate(o.created_at)}</td>
              <td>
                <button class="btn-action" data-ref="${o.reference}" data-status="${o.status}">
                  Gestionar
                </button>
              </td>
            </tr>
          `
            )
            .join("");

          // Attach row click handlers
          tbody.querySelectorAll(".btn-action").forEach((btn) => {
            btn.addEventListener("click", () => {
              const ref = (btn as HTMLElement).dataset.ref!;
              const st = (btn as HTMLElement).dataset.status!;
              openModal(ref, st, rows.find(o => o.reference === ref));
            });
          });
        }

        renderPagination();
      } catch {
        tbody.innerHTML = `<tr><td colspan="9" class="empty">Error al cargar pedidos. Verifica tu sesión.</td></tr>`;
      }
    }

    // ── Pagination ─────────────────────────────────────────────
    function renderPagination() {
      const total = Math.ceil(totalOrders / PAGE_SIZE);
      const pag = document.getElementById("pagination")!;
      if (total <= 1) { pag.innerHTML = ""; return; }

      const pages = [];
      pages.push(`<button class="page-btn" id="prevBtn" ${currentPage === 0 ? "disabled" : ""}>← Anterior</button>`);
      const start = Math.max(0, currentPage - 2);
      const end = Math.min(total - 1, currentPage + 2);
      for (let i = start; i <= end; i++) {
        pages.push(`<button class="page-btn ${i === currentPage ? "active" : ""}" data-page="${i}">${i + 1}</button>`);
      }
      pages.push(`<button class="page-btn" id="nextBtn" ${currentPage >= total - 1 ? "disabled" : ""}>Siguiente →</button>`);
      pag.innerHTML = pages.join("");

      pag.querySelector("#prevBtn")?.addEventListener("click", () => loadOrders(currentPage - 1));
      pag.querySelector("#nextBtn")?.addEventListener("click", () => loadOrders(currentPage + 1));
      pag.querySelectorAll("[data-page]").forEach((btn) => {
        btn.addEventListener("click", () => loadOrders(Number((btn as HTMLElement).dataset.page)));
      });
    }

    // ── Modal ─────────────────────────────────────────────────
    function openModal(ref: string, status: string, order: any) {
      currentRef = ref;
      document.getElementById("modalTitle")!.textContent = `Pedido ${ref}`;
      (document.getElementById("newStatus") as HTMLSelectElement).value = status;
      document.getElementById("saveMsg")!.textContent = "";

      const fields: [string, string][] = [
        ["Referencia", order?.reference ?? ref],
        ["Cliente", order?.customer_name ?? "—"],
        ["Email", order?.customer_email ?? "—"],
        ["Estado", STATUS_LABELS[order?.status] ?? order?.status ?? "—"],
        ["Total", fmtCOP(Number(order?.total_cop) || 0)],
        ["Método de pago", order?.payment_method ?? "—"],
        ["Ciudad", order?.shipping_city ?? "—"],
        ["Fecha", fmtDate(order?.created_at)],
      ];

      document.getElementById("modalDetails")!.innerHTML = fields
        .map(([l, v]) => `<div class="detail-row"><span class="detail-label">${l}</span><span class="detail-value">${v}</span></div>`)
        .join("");

      document.getElementById("modalBack")!.classList.add("open");
    }

    // Close modal
    document.getElementById("modalClose")?.addEventListener("click", () => {
      document.getElementById("modalBack")!.classList.remove("open");
    });
    document.getElementById("modalBack")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) document.getElementById("modalBack")!.classList.remove("open");
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") document.getElementById("modalBack")!.classList.remove("open");
    });

    // Save status
    document.getElementById("btnSaveStatus")?.addEventListener("click", async () => {
      if (!currentRef) return;
      const status = (document.getElementById("newStatus") as HTMLSelectElement).value;
      const btn = document.getElementById("btnSaveStatus") as HTMLButtonElement;
      const msg = document.getElementById("saveMsg")!;
      btn.disabled = true;
      btn.textContent = "Guardando...";
      msg.textContent = "";
      msg.style.color = "";

      try {
        const res = await fetch(`/api/orders/${currentRef}/status`, {
          method: "PATCH",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error ?? "Error");
        msg.textContent = "✅ Estado actualizado correctamente.";
        msg.style.color = "#155724";
        // Refresh table
        await loadOrders(currentPage);
      } catch (err: any) {
        msg.textContent = `❌ Error: ${err.message}`;
        msg.style.color = "#721c24";
      } finally {
        btn.disabled = false;
        btn.textContent = "Guardar";
      }
    });

    // Filters
    document.getElementById("btnSearch")?.addEventListener("click", () => loadOrders(0));
    document.getElementById("btnReset")?.addEventListener("click", () => {
      (document.getElementById("fStatus") as HTMLSelectElement).value = "";
      (document.getElementById("fSearch") as HTMLInputElement).value = "";
      loadOrders(0);
    });
    document.getElementById("fSearch")?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") loadOrders(0);
    });

    // ── Init ──────────────────────────────────────────────────
    // Check for ?ref= in URL
    const urlRef = new URLSearchParams(window.location.search).get("ref");
    if (urlRef) {
      (document.getElementById("fSearch") as HTMLInputElement).value = urlRef;
    }
    loadOrders(0);
  </script>
</AdminLayout>
