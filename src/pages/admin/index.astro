---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard — DobleYo Admin" section="dashboard">
  <style>
    /* ── Page header ──────────────────────────────── */
    .page-header {
      margin-bottom: 2rem;
    }
    .page-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: #251a14;
      margin: 0 0 0.25rem;
    }
    .page-header p { margin: 0; color: #7a6652; font-size: 0.95rem; }

    /* ── KPI grid ─────────────────────────────────── */
    .kpi-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(2, 1fr);
      margin-bottom: 2rem;
    }
    @media (min-width: 1024px) { .kpi-grid { grid-template-columns: repeat(4, 1fr); } }

    .kpi-card {
      background: #fff;
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(37,26,20,0.08);
      border-left: 4px solid transparent;
    }
    .kpi-card.green  { border-color: #4a6741; }
    .kpi-card.amber  { border-color: #c8a96e; }
    .kpi-card.red    { border-color: #c0392b; }
    .kpi-card.blue   { border-color: #3b7fc4; }

    .kpi-label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #7a6652;
      margin-bottom: 0.5rem;
    }
    .kpi-value {
      font-size: 1.9rem;
      font-weight: 700;
      color: #251a14;
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .kpi-sub { font-size: 0.8rem; color: #7a6652; }

    /* ── Section ──────────────────────────────────── */
    .section-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #251a14;
      margin: 0 0 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-title a {
      font-size: 0.82rem;
      font-weight: 500;
      color: #4a6741;
      text-decoration: none;
    }
    .section-title a:hover { text-decoration: underline; }

    /* ── Table ────────────────────────────────────── */
    .table-wrap {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(37,26,20,0.08);
      overflow-x: auto;
      margin-bottom: 2rem;
    }
    table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    thead th {
      text-align: left;
      padding: 0.75rem 1rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #7a6652;
      border-bottom: 1px solid #ede8e2;
      white-space: nowrap;
    }
    tbody td {
      padding: 0.7rem 1rem;
      border-bottom: 1px solid #f5f2ee;
      color: #3d2e22;
      vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf8f5; }

    /* ── Status badge ─────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .badge-paid       { background: #d4edda; color: #155724; }
    .badge-pending    { background: #fff3cd; color: #856404; }
    .badge-processing { background: #cce5ff; color: #004085; }
    .badge-shipped    { background: #d1ecf1; color: #0c5460; }
    .badge-delivered  { background: #d4edda; color: #155724; }
    .badge-cancelled  { background: #f8d7da; color: #721c24; }
    .badge-refunded   { background: #e2e3e5; color: #383d41; }
    .badge-default    { background: #e9ecef; color: #495057; }

    /* ── Two-col layout ───────────────────────────── */
    .two-col {
      display: grid;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    @media (min-width: 1024px) { .two-col { grid-template-columns: 1fr 1fr; } }

    /* ── Alert card ───────────────────────────────── */
    .alert-card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(37,26,20,0.08);
      overflow: hidden;
    }
    .alert-card-header {
      padding: 0.9rem 1.25rem;
      border-bottom: 1px solid #ede8e2;
    }
    .alert-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.65rem 1.25rem;
      border-bottom: 1px solid #f5f2ee;
      font-size: 0.88rem;
    }
    .alert-item:last-child { border-bottom: none; }
    .alert-item-name { color: #251a14; font-weight: 500; }
    .alert-item-stock { font-weight: 700; color: #c0392b; }

    /* ── Quick actions ────────────────────────────── */
    .quick-actions {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(2, 1fr);
      padding: 1.25rem;
    }
    @media (min-width: 768px) { .quick-actions { grid-template-columns: repeat(3, 1fr); } }

    .action-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      padding: 1rem 0.75rem;
      background: #f7f3ef;
      border: 1px solid #ede8e2;
      border-radius: 8px;
      text-decoration: none;
      color: #251a14;
      font-size: 0.8rem;
      font-weight: 600;
      text-align: center;
      transition: background 0.15s, border-color 0.15s;
    }
    .action-btn:hover { background: #ede8e2; border-color: #c8a96e; color: #4a1c00; }
    .action-btn svg { opacity: 0.7; }

    /* ── Empty state ──────────────────────────────── */
    .empty { text-align: center; padding: 2rem; color: #7a6652; font-style: italic; }

    /* ── Loading skeleton ─────────────────────────── */
    .skeleton {
      background: linear-gradient(90deg, #f0ebe5 25%, #e8e2db 50%, #f0ebe5 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 4px;
      display: inline-block;
      height: 1.5em;
      width: 80px;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  </style>

  <header class="page-header">
    <h1>Dashboard</h1>
    <p id="dashDate">Cargando...</p>
  </header>

  <!-- KPI cards -->
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card green">
      <div class="kpi-label">Pedidos totales</div>
      <div class="kpi-value" id="kpiOrders"><span class="skeleton"></span></div>
      <div class="kpi-sub" id="kpiOrdersSub"></div>
    </div>
    <div class="kpi-card amber">
      <div class="kpi-label">Ingresos (30 días)</div>
      <div class="kpi-value" id="kpiRevenue"><span class="skeleton"></span></div>
      <div class="kpi-sub" id="kpiRevenueSub">en COP</div>
    </div>
    <div class="kpi-card blue">
      <div class="kpi-label">Usuarios registrados</div>
      <div class="kpi-value" id="kpiUsers"><span class="skeleton"></span></div>
      <div class="kpi-sub" id="kpiUsersSub"></div>
    </div>
    <div class="kpi-card red">
      <div class="kpi-label">Stock bajo</div>
      <div class="kpi-value" id="kpiLowStock"><span class="skeleton"></span></div>
      <div class="kpi-sub">productos</div>
    </div>
  </div>

  <!-- Recent orders -->
  <div class="section-title">
    <span>Pedidos recientes</span>
    <a href="/admin/pedidos">Ver todos →</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Referencia</th>
          <th>Cliente</th>
          <th>Ciudad</th>
          <th>Total</th>
          <th>Estado</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody id="ordersBody">
        <tr><td colspan="6" class="empty">Cargando pedidos...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Two-col: low stock + quick actions -->
  <div class="two-col">
    <!-- Low stock -->
    <div>
      <div class="section-title">
        <span>Alertas de inventario</span>
        <a href="/admin/inventario">Ver inventario →</a>
      </div>
      <div class="alert-card">
        <div class="alert-card-header section-title" style="margin:0">
          <span style="font-size:0.85rem;color:#7a6652">Productos con stock bajo o agotado</span>
        </div>
        <div id="lowStockList"><div class="empty">Cargando...</div></div>
      </div>
    </div>

    <!-- Quick actions -->
    <div>
      <div class="section-title"><span>Acciones rápidas</span></div>
      <div class="alert-card">
        <div class="quick-actions">
          <a href="/admin/pedidos" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Gestionar pedidos
          </a>
          <a href="/admin/inventario" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
            Inventario
          </a>
          <a href="/admin/lotes" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
              <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
            </svg>
            Lotes
          </a>
          <a href="/admin/usuarios" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
            Usuarios
          </a>
          <a href="/admin/sales-map" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
              <line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
            </svg>
            Mapa ventas
          </a>
          <a href="/app/harvest" class="action-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Nueva cosecha
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Helpers ──────────────────────────────────────────────
    const fmtCOP = (n: number) =>
      new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n);

    const fmtDate = (s: string) => {
      if (!s) return "—";
      const d = new Date(s);
      return d.toLocaleDateString("es-CO", { day: "2-digit", month: "short", year: "numeric" });
    };

    const STATUS_LABELS: Record<string, string> = {
      pending_payment: "Pendiente pago",
      paid: "Pagado",
      processing: "En proceso",
      shipped: "Enviado",
      delivered: "Entregado",
      cancelled: "Cancelado",
      refunded: "Reembolsado",
    };
    const STATUS_CLASS: Record<string, string> = {
      pending_payment: "badge-pending",
      paid: "badge-paid",
      processing: "badge-processing",
      shipped: "badge-shipped",
      delivered: "badge-delivered",
      cancelled: "badge-cancelled",
      refunded: "badge-refunded",
    };

    function badge(status: string) {
      const cls = STATUS_CLASS[status] ?? "badge-default";
      const label = STATUS_LABELS[status] ?? status;
      return `<span class="badge ${cls}">${label}</span>`;
    }

    // ── Date header ──────────────────────────────────────────
    const dateEl = document.getElementById("dashDate");
    if (dateEl)
      dateEl.textContent = new Date().toLocaleDateString("es-CO", {
        weekday: "long", year: "numeric", month: "long", day: "numeric",
      });

    // ── Fetch all data in parallel ───────────────────────────
    (async () => {
      const [ordersRes, usersRes, invStatsRes, lowStockRes] = await Promise.allSettled([
        fetch("/api/orders?limit=10", { credentials: "include" }),
        fetch("/api/users", { credentials: "include" }),
        fetch("/api/inventory/stats/dashboard", { credentials: "include" }),
        fetch("/api/inventory/alerts/low-stock", { credentials: "include" }),
      ]);

      // ── Orders ──────────────────────────────────────────────
      if (ordersRes.status === "fulfilled" && ordersRes.value.ok) {
        const data = await ordersRes.value.json();
        const orders: any[] = data.data ?? [];
        const total: number = data.total ?? 0;

        // KPI
        const kpiOrders = document.getElementById("kpiOrders");
        if (kpiOrders) kpiOrders.textContent = String(total);
        const kpiOrdersSub = document.getElementById("kpiOrdersSub");
        if (kpiOrdersSub) kpiOrdersSub.textContent = `${orders.filter(o => o.status === "paid" || o.status === "delivered").length} pagados`;

        // Revenue: sum of paid/delivered orders in the response (best-effort from first page)
        const revenue = orders
          .filter(o => ["paid", "delivered", "shipped", "processing"].includes(o.status))
          .reduce((s: number, o: any) => s + (Number(o.total_cop) || 0), 0);
        const kpiRevenue = document.getElementById("kpiRevenue");
        if (kpiRevenue) kpiRevenue.textContent = fmtCOP(revenue);
        const kpiRevenueSub = document.getElementById("kpiRevenueSub");
        if (kpiRevenueSub) kpiRevenueSub.textContent = "últimos 10 pedidos";

        // Table
        const tbody = document.getElementById("ordersBody");
        if (tbody) {
          if (orders.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="empty">No hay pedidos aún.</td></tr>`;
          } else {
            tbody.innerHTML = orders.map(o => `
              <tr>
                <td><a href="/admin/pedidos?ref=${o.reference}" style="color:#4a6741;font-weight:600;text-decoration:none">${o.reference}</a></td>
                <td>${o.customer_name ?? "—"}</td>
                <td>${o.shipping_city ?? "—"}</td>
                <td style="font-weight:600">${fmtCOP(Number(o.total_cop) || 0)}</td>
                <td>${badge(o.status)}</td>
                <td style="color:#7a6652">${fmtDate(o.created_at)}</td>
              </tr>
            `).join("");
          }
        }
      } else {
        const tbody = document.getElementById("ordersBody");
        if (tbody) tbody.innerHTML = `<tr><td colspan="6" class="empty">Error al cargar pedidos.</td></tr>`;
      }

      // ── Users ───────────────────────────────────────────────
      if (usersRes.status === "fulfilled" && usersRes.value.ok) {
        const data = await usersRes.value.json();
        const users: any[] = data.users ?? [];
        const kpiUsers = document.getElementById("kpiUsers");
        if (kpiUsers) kpiUsers.textContent = String(users.length);
        const kpiUsersSub = document.getElementById("kpiUsersSub");
        if (kpiUsersSub) {
          const admins = users.filter(u => u.role === "admin").length;
          const caficultores = users.filter(u => u.role === "caficultor").length;
          kpiUsersSub.textContent = `${admins} admin · ${caficultores} caficultores`;
        }
      }

      // ── Inventory stats ─────────────────────────────────────
      if (invStatsRes.status === "fulfilled" && invStatsRes.value.ok) {
        const data = await invStatsRes.value.json();
        const stats = data.stats ?? data ?? {};
        const lowCount = stats.lowStockCount ?? stats.low_stock_count ?? "?";
        const kpiLowStock = document.getElementById("kpiLowStock");
        if (kpiLowStock) kpiLowStock.textContent = String(lowCount);
      }

      // ── Low stock list ──────────────────────────────────────
      const listEl = document.getElementById("lowStockList");
      if (lowStockRes.status === "fulfilled" && lowStockRes.value.ok) {
        const data = await lowStockRes.value.json();
        const items: any[] = data.products ?? data.alerts ?? data ?? [];
        if (listEl) {
          if (items.length === 0) {
            listEl.innerHTML = `<div class="empty" style="color:#4a6741">✅ Sin alertas de stock</div>`;
          } else {
            listEl.innerHTML = items.slice(0, 8).map(p => `
              <div class="alert-item">
                <span class="alert-item-name">${p.name ?? p.product_name ?? "—"}</span>
                <span class="alert-item-stock">${p.stock ?? p.quantity ?? 0} uds.</span>
              </div>
            `).join("");
          }
        }
      } else {
        if (listEl) listEl.innerHTML = `<div class="empty">Error al cargar alertas.</div>`;
      }
    })();
  </script>
</AdminLayout>
