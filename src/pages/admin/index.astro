---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard — DobleYo ERP" section="dashboard">
  <style>
    /* ── Dashboard layout ──────────────────────────────────── */
    .dash-page-header {
      background: var(--card-bg);
      border-bottom: 1px solid var(--border);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .dash-title-group {}
    .dash-breadcrumb {
      font-size: 11px;
      color: var(--text-3);
      margin-bottom: 3px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .dash-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-1);
      letter-spacing: -0.01em;
    }
    .dash-subtitle {
      font-size: 12px;
      color: var(--text-2);
      margin-top: 2px;
    }

    /* ── Body ──────────────────────────────────────────────── */
    .dash-body {
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* ── KPI Row ───────────────────────────────────────────── */
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (min-width: 768px)  { .kpi-row { grid-template-columns: repeat(4, 1fr); } }

    .kpi-tile {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 16px 20px;
      position: relative;
      overflow: hidden;
    }
    .kpi-tile::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .kpi-tile.t-success::after { background: var(--c-success); }
    .kpi-tile.t-warning::after { background: var(--brand); }
    .kpi-tile.t-info::after    { background: var(--c-info); }
    .kpi-tile.t-error::after   { background: var(--c-error); }

    .kpi-icon {
      width: 32px;
      height: 32px;
      border-radius: 6px;
      display: grid;
      place-items: center;
      margin-bottom: 10px;
    }
    .kpi-icon.success { background: var(--c-success-bg); color: var(--c-success); }
    .kpi-icon.warning { background: var(--c-warning-bg); color: var(--c-warning); }
    .kpi-icon.info    { background: var(--c-info-bg);    color: var(--c-info); }
    .kpi-icon.error   { background: var(--c-error-bg);   color: var(--c-error); }

    .kpi-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-2);
      margin-bottom: 4px;
    }
    .kpi-value {
      font-size: 26px;
      font-weight: 700;
      line-height: 1;
      color: var(--text-1);
      margin-bottom: 3px;
    }
    .kpi-sub { font-size: 11px; color: var(--text-3); }

    /* ── Two-col grid ──────────────────────────────────────── */
    .two-col {
      display: grid;
      gap: 20px;
    }
    @media (min-width: 1024px) { .two-col { grid-template-columns: 1fr 360px; } }

    /* ── App tiles (Fiori launchpad) ───────────────────────── */
    .tile-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 16px;
    }
    @media (min-width: 480px) { .tile-grid { grid-template-columns: repeat(3, 1fr); } }

    .app-tile {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 16px 14px;
      background: var(--erp-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      color: var(--text-1);
      font-size: 12.5px;
      font-weight: 600;
      transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
      cursor: pointer;
    }
    .app-tile:hover {
      background: var(--card-bg);
      border-color: var(--brand);
      box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }
    .app-tile-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: grid;
      place-items: center;
    }
    .app-tile-icon.amber  { background: #fef3e2; color: var(--c-warning); }
    .app-tile-icon.green  { background: var(--c-success-bg); color: var(--c-success); }
    .app-tile-icon.blue   { background: var(--c-info-bg); color: var(--c-info); }
    .app-tile-icon.brown  { background: #fdf5e8; color: var(--brand-dark); }
    .app-tile-icon.red    { background: var(--c-error-bg); color: var(--c-error); }
    .app-tile-icon.purple { background: #f3ebff; color: #7730c8; }

    /* ── Alert list ────────────────────────────────────────── */
    .alert-list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 11px 20px;
      border-bottom: 1px solid rgba(0,0,0,.05);
      font-size: 13px;
    }
    .alert-list-item:last-child { border-bottom: none; }
    .alert-item-name { color: var(--text-1); font-weight: 500; }
    .alert-item-stock { font-weight: 700; color: var(--c-error); font-size: 13px; }

    /* ── Table link ────────────────────────────────────────── */
    .tbl-link { color: var(--c-info); font-weight: 600; text-decoration: none; font-size: 13px; }
    .tbl-link:hover { text-decoration: underline; }
  </style>

  <!-- Page header -->
  <div class="dash-page-header">
    <div class="dash-title-group">
      <div class="dash-breadcrumb">ERP · Admin</div>
      <div class="dash-title">Dashboard</div>
      <div class="dash-subtitle" id="dashDate">—</div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-secondary" onclick="location.reload()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
        Actualizar
      </button>
    </div>
  </div>

  <div class="dash-body">

    <!-- KPI tiles -->
    <div class="kpi-row">
      <div class="kpi-tile t-success">
        <div class="kpi-icon success">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </div>
        <div class="kpi-label">Pedidos totales</div>
        <div class="kpi-value" id="kpiOrders"><span class="skeleton" style="width:50px;height:1em"></span></div>
        <div class="kpi-sub" id="kpiOrdersSub">&nbsp;</div>
      </div>

      <div class="kpi-tile t-warning">
        <div class="kpi-icon warning">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <div class="kpi-label">Ingresos (30 días)</div>
        <div class="kpi-value" id="kpiRevenue"><span class="skeleton" style="width:80px;height:1em"></span></div>
        <div class="kpi-sub" id="kpiRevenueSub">COP</div>
      </div>

      <div class="kpi-tile t-info">
        <div class="kpi-icon info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="kpi-label">Usuarios</div>
        <div class="kpi-value" id="kpiUsers"><span class="skeleton" style="width:40px;height:1em"></span></div>
        <div class="kpi-sub" id="kpiUsersSub">&nbsp;</div>
      </div>

      <div class="kpi-tile t-error">
        <div class="kpi-icon error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <div class="kpi-label">Stock bajo</div>
        <div class="kpi-value" id="kpiLowStock"><span class="skeleton" style="width:35px;height:1em"></span></div>
        <div class="kpi-sub">productos con alerta</div>
      </div>
    </div>

    <!-- Recent orders + quick actions -->
    <div class="two-col">

      <!-- Recent orders table -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Pedidos recientes</div>
            <div class="card-subtitle">Últimas transacciones del sistema</div>
          </div>
          <a href="/admin/pedidos" class="card-action">Ver todos →</a>
        </div>
        <div style="overflow-x:auto">
          <table class="erp-table">
            <thead>
              <tr>
                <th>Referencia</th>
                <th>Cliente</th>
                <th>Ciudad</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody id="ordersBody">
              <tr><td colspan="6" class="empty-state">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Right column -->
      <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Low stock alerts -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Alertas de inventario</div>
              <div class="card-subtitle">Stock bajo o agotado</div>
            </div>
            <a href="/admin/inventario" class="card-action">Ver →</a>
          </div>
          <div id="lowStockList">
            <div class="empty-state">Cargando...</div>
          </div>
        </div>

        <!-- Quick actions (Fiori tiles) -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">Acciones rápidas</div>
          </div>
          <div class="tile-grid">
            <a href="/admin/pedidos" class="app-tile">
              <div class="app-tile-icon amber">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
              </div>
              Pedidos
            </a>
            <a href="/admin/inventario" class="app-tile">
              <div class="app-tile-icon blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                </svg>
              </div>
              Inventario
            </a>
            <a href="/admin/lotes" class="app-tile">
              <div class="app-tile-icon brown">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                  <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                </svg>
              </div>
              Lotes
            </a>
            <a href="/admin/usuarios" class="app-tile">
              <div class="app-tile-icon purple">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
              </div>
              Usuarios
            </a>
            <a href="/admin/sales-map" class="app-tile">
              <div class="app-tile-icon green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
                </svg>
              </div>
              Mapa ventas
            </a>
            <a href="/app/harvest" class="app-tile">
              <div class="app-tile-icon green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              Cosecha
            </a>
          </div>
        </div>

      </div>
    </div>

  </div><!-- /dash-body -->

  <script>
    const fmtCOP = (n: number) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n);
    const fmtDate = (s: string) => s ? new Date(s).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';

    const STATUS_LABEL: Record<string, string> = {
      pending_payment: 'Pdte. pago', paid: 'Pagado', processing: 'En proceso',
      shipped: 'Enviado', delivered: 'Entregado', cancelled: 'Cancelado', refunded: 'Reembolsado',
    };
    const STATUS_CLS: Record<string, string> = {
      pending_payment: 'badge-warning', paid: 'badge-success', processing: 'badge-info',
      shipped: 'badge-info', delivered: 'badge-success', cancelled: 'badge-error', refunded: 'badge-neutral',
    };
    const badge = (s: string) => `<span class="badge ${STATUS_CLS[s] ?? 'badge-neutral'}">${STATUS_LABEL[s] ?? s}</span>`;

    // Date header
    const dateEl = document.getElementById('dashDate');
    if (dateEl) dateEl.textContent = new Date().toLocaleDateString('es-CO', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

    (async () => {
      const [ordersRes, usersRes, invStatsRes, lowStockRes] = await Promise.allSettled([
        fetch('/api/orders?limit=10', { credentials: 'include' }),
        fetch('/api/users', { credentials: 'include' }),
        fetch('/api/inventory/stats/dashboard', { credentials: 'include' }),
        fetch('/api/inventory/alerts/low-stock', { credentials: 'include' }),
      ]);

      // Orders
      if (ordersRes.status === 'fulfilled' && ordersRes.value.ok) {
        const data = await ordersRes.value.json();
        const orders: any[] = data.data ?? [];
        const total: number = data.total ?? 0;

        const kpiOrders = document.getElementById('kpiOrders');
        if (kpiOrders) kpiOrders.textContent = String(total);
        const kpiOrdersSub = document.getElementById('kpiOrdersSub');
        if (kpiOrdersSub) kpiOrdersSub.textContent = `${orders.filter(o => ['paid','delivered'].includes(o.status)).length} pagados`;

        const revenue = orders.filter(o => ['paid','delivered','shipped','processing'].includes(o.status))
          .reduce((s: number, o: any) => s + (Number(o.total_cop) || 0), 0);
        const kpiRevenue = document.getElementById('kpiRevenue');
        if (kpiRevenue) kpiRevenue.textContent = fmtCOP(revenue);
        const kpiRevenueSub = document.getElementById('kpiRevenueSub');
        if (kpiRevenueSub) kpiRevenueSub.textContent = 'últimos 10 pedidos';

        const tbody = document.getElementById('ordersBody');
        if (tbody) {
          tbody.innerHTML = orders.length === 0
            ? `<tr><td colspan="6" class="empty-state">No hay pedidos aún.</td></tr>`
            : orders.map(o => `
              <tr>
                <td><a class="tbl-link" href="/admin/pedidos?ref=${o.reference}">${o.reference}</a></td>
                <td>${o.customer_name ?? '—'}</td>
                <td>${o.shipping_city ?? '—'}</td>
                <td style="font-weight:600">${fmtCOP(Number(o.total_cop) || 0)}</td>
                <td>${badge(o.status)}</td>
                <td style="color:var(--text-2)">${fmtDate(o.created_at)}</td>
              </tr>`).join('');
        }
      } else {
        const tbody = document.getElementById('ordersBody');
        if (tbody) tbody.innerHTML = `<tr><td colspan="6" class="empty-state">Error al cargar pedidos.</td></tr>`;
      }

      // Users
      if (usersRes.status === 'fulfilled' && usersRes.value.ok) {
        const data = await usersRes.value.json();
        const users: any[] = data.users ?? [];
        const kpiUsers = document.getElementById('kpiUsers');
        if (kpiUsers) kpiUsers.textContent = String(users.length);
        const kpiUsersSub = document.getElementById('kpiUsersSub');
        if (kpiUsersSub) {
          const admins = users.filter(u => u.role === 'admin').length;
          const caficultores = users.filter(u => u.role === 'caficultor').length;
          kpiUsersSub.textContent = `${admins} admin · ${caficultores} caficultores`;
        }
      }

      // Inventory stats
      if (invStatsRes.status === 'fulfilled' && invStatsRes.value.ok) {
        const data = await invStatsRes.value.json();
        const stats = data.stats ?? data ?? {};
        const kpiLowStock = document.getElementById('kpiLowStock');
        if (kpiLowStock) kpiLowStock.textContent = String(stats.lowStockCount ?? stats.low_stock_count ?? '—');
      }

      // Low stock list
      const listEl = document.getElementById('lowStockList');
      if (lowStockRes.status === 'fulfilled' && lowStockRes.value.ok) {
        const data = await lowStockRes.value.json();
        const items: any[] = data.products ?? data.alerts ?? data ?? [];
        if (listEl) {
          listEl.innerHTML = items.length === 0
            ? `<div class="empty-state" style="color:var(--c-success)">Sin alertas de stock</div>`
            : items.slice(0, 7).map(p => `
              <div class="alert-list-item">
                <span class="alert-item-name">${p.name ?? p.product_name ?? '—'}</span>
                <span class="alert-item-stock">${p.stock ?? p.quantity ?? 0} uds.</span>
              </div>`).join('');
        }
      } else {
        if (listEl) listEl.innerHTML = `<div class="empty-state">Error al cargar alertas.</div>`;
      }
    })();
  </script>
</AdminLayout>
