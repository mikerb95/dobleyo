---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="Enviar a Tostión"
  description="Seleccione café verde del inventario para llevar a proceso de tostión"
>
  <form id="roastingForm" class="send-roasting">
    <header class="sr-head">
      <h1>Enviar a Tostión</h1>
      <p>
        Seleccione café verde del inventario para llevarlo a proceso de tostión.
      </p>
    </header>

    <!-- Selección de Lote -->
    <div class="form-group">
      <label for="lotSelect"
        >Lote de café verde <span class="required">*</span></label
      >
      <select id="lotSelect" name="lot" required>
        <option value="">Seleccione un lote…</option>
      </select>
      <div class="form-hint">Solo se muestran lotes sin procesar</div>
    </div>

    <!-- Info del Lote Seleccionado -->
    <div class="card lot-info" id="lotInfoCard" style="display: none;">
      <div class="card-header">
        <h3 class="card-title">Información del lote</h3>
      </div>
      <div class="card-body">
        <dl class="detail-grid">
          <div class="detail-item">
            <dt>Lote ID</dt>
            <dd id="lotId">—</dd>
          </div>
          <div class="detail-item">
            <dt>Variedad</dt>
            <dd id="lotVariety">—</dd>
          </div>
          <div class="detail-item">
            <dt>Peso disponible</dt>
            <dd class="detail-value--accent" id="lotAvailableWeight">—</dd>
          </div>
          <div class="detail-item">
            <dt>Ubicación actual</dt>
            <dd id="lotLocation">—</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Selección de Cantidad -->
    <div class="form-group">
      <label for="quantity"
        >Cantidad para tostión <span class="required">*</span></label
      >
      <div class="input-suffix">
        <input
          type="number"
          id="quantity"
          name="quantity"
          placeholder="Ej: 25"
          step="0.1"
          min="0"
          required
        />
        <span class="suffix" id="unit">kg</span>
      </div>
      <div class="form-hint" id="quantityHint">Máximo disponible: —</div>
    </div>

    <!-- Opción: Parcial o Todo -->
    <div class="info-box">
      <strong>💡 Nota:</strong> Puede enviar solo una parte del lote y el resto permanecerá
      en inventario. Si envía todo, el lote se marcará como procesado.
    </div>

    <!-- Fecha de Envío -->
    <div class="form-group">
      <label for="roastingDate">Fecha de envío a tostión</label>
      <input type="date" id="roastingDate" name="roastingDate" disabled />
      <div class="form-hint">
        Se registra automáticamente con la fecha actual
      </div>
    </div>

    <!-- Temperatura Target -->
    <div class="form-group">
      <label for="targetTemp">Temperatura objetivo (opcional)</label>
      <div class="input-suffix">
        <input
          type="number"
          id="targetTemp"
          name="targetTemp"
          placeholder="Ej: 210"
          step="1"
          min="180"
          max="230"
        />
        <span class="suffix">°C</span>
      </div>
      <div class="form-hint">
        Temperatura sugerida para el desarrollo del tueste
      </div>
    </div>

    <!-- Notas -->
    <div class="form-group">
      <label for="notes">Notas (opcional)</label>
      <textarea
        id="notes"
        name="notes"
        placeholder="Ej: tueste medio, desarrollo lento, buscar notas de chocolate…"
      ></textarea>
    </div>

    <!-- Resumen -->
    <div class="info-box summary-box" id="summaryBox" style="display: none;">
      <strong>Resumen del envío a tostión</strong>
      <dl class="summary-list">
        <div><dt>📦 Lote</dt><dd id="summaryLot">—</dd></div>
        <div><dt>⚖️ Cantidad</dt><dd id="summaryQuantity">—</dd></div>
        <div><dt>🌡️ Temperatura</dt><dd id="summaryTemp">—</dd></div>
        <div><dt>📅 Fecha</dt><dd id="summaryDate">—</dd></div>
      </dl>
    </div>

    <!-- Botones de Acción -->
    <div class="form-actions">
      <button type="reset" class="btn-secondary">Limpiar</button>
      <button type="submit" class="btn-primary">Enviar a tostión</button>
    </div>
  </form>

  <style>
    /* ── Encabezado de página ─────────────────────────────────────────────── */
    .sr-head {
      margin-bottom: 24px;
    }
    .sr-head p {
      font-size: 13px;
      color: var(--muted);
      margin: 4px 0 0;
      max-width: 60ch;
    }

    /* ── Tarjeta de información del lote ──────────────────────────────────── */
    .lot-info {
      margin-bottom: 16px;
    }
    .lot-info .card-body {
      padding: 16px 18px;
    }
    .detail-value--accent {
      color: var(--color-accent);
    }

    /* ── Input con sufijo de unidad (kg / °C) ─────────────────────────────── */
    .input-suffix {
      display: flex;
    }
    .input-suffix input {
      flex: 1;
      width: auto;
      border-top-right-radius: 0;
      border-bottom-right-radius: 0;
    }
    .input-suffix .suffix {
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 56px;
      padding: 0 14px;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      background: color-mix(in oklab, var(--color-primary) 4%, white);
      border: 1px solid var(--rule);
      border-left: 0;
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }

    /* ── Resumen del envío ────────────────────────────────────────────────── */
    .summary-list {
      display: grid;
      gap: 8px;
      margin: 12px 0 0;
    }
    .summary-list > div {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
    }
    .summary-list dt {
      font-size: 13px;
      color: var(--muted);
    }
    .summary-list dd {
      margin: 0;
      font-size: 13px;
      font-weight: 600;
      color: var(--color-primary);
      font-variant-numeric: tabular-nums;
      text-align: right;
    }
  </style>

  <script>
    const lotSelect = document.getElementById("lotSelect");
    const roastingDate = document.getElementById("roastingDate");
    const form = document.getElementById("roastingForm");
    const summaryBox = document.getElementById("summaryBox");
    const lotInfoCard = document.getElementById("lotInfoCard");
    const quantityInput = document.getElementById("quantity");

    // Cargar lotes disponibles desde API
    async function loadAvailableLots() {
      try {
        const response = await fetch("/api/coffee/green-inventory");
        if (!response.ok) throw new Error("Error al cargar inventario");

        const inventory = await response.json();

        lotSelect.innerHTML = '<option value="">Selecciona un lote...</option>';
        inventory.forEach((item) => {
          const option = document.createElement("option");
          option.value = JSON.stringify(item);
          option.textContent = `${item.lot_id} (${item.weight_kg} kg disponible)`;
          lotSelect.appendChild(option);
        });
      } catch (error) {
        console.error("Error cargando inventario:", error);
        alert("Error al cargar inventario disponible");
      }
    }

    // Establecer fecha actual
    const today = new Date().toISOString().split("T")[0];
    roastingDate.value = today;

    // Actualizar información del lote
    lotSelect.addEventListener("change", () => {
      if (!lotSelect.value) {
        lotInfoCard.style.display = "none";
        summaryBox.style.display = "none";
        return;
      }

      const item = JSON.parse(lotSelect.value);
      document.getElementById("lotId").textContent = item.lot_id;
      document.getElementById("lotVariety").textContent = item.variety || "—";
      document.getElementById("lotLocation").textContent = item.location;
      document.getElementById("lotAvailableWeight").textContent =
        `${item.weight_kg} kg`;
      document.getElementById("quantityHint").textContent =
        `Máximo disponible: ${item.weight_kg} kg`;

      quantityInput.max = item.weight_kg;
      lotInfoCard.style.display = "block";
      updateSummary();
    });

    // Actualizar resumen
    function updateSummary() {
      const quantity = parseFloat(quantityInput.value) || 0;
      const temp = document.getElementById("targetTemp").value || "—";
      const lotItem = lotSelect.value ? JSON.parse(lotSelect.value) : null;

      if (quantity > 0 && lotItem) {
        document.getElementById("summaryLot").textContent = lotItem.lot_id;
        document.getElementById("summaryQuantity").textContent =
          `${quantity} kg`;
        document.getElementById("summaryTemp").textContent =
          temp !== "—" ? `${temp}°C` : "No especificada";
        document.getElementById("summaryDate").textContent = new Date(
          roastingDate.value
        ).toLocaleDateString("es-CO");
        summaryBox.style.display = "block";
      } else {
        summaryBox.style.display = "none";
      }
    }

    quantityInput.addEventListener("input", updateSummary);
    document
      .getElementById("targetTemp")
      .addEventListener("input", updateSummary);

    // Enviar formulario a la API
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!lotSelect.value) {
        alert("⚠️ Debes seleccionar un lote");
        return;
      }

      const item = JSON.parse(lotSelect.value);
      const quantity = parseFloat(quantityInput.value);

      if (quantity <= 0) {
        alert("⚠️ La cantidad debe ser mayor a 0");
        return;
      }

      if (quantity > item.weight_kg) {
        alert("⚠️ La cantidad excede el peso disponible");
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando...";

      try {
        const response = await fetch("/api/coffee/send-roasting", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            lotId: item.lot_id,
            quantitySent: quantity,
            targetTemp: document.getElementById("targetTemp").value || null,
            notes: document.getElementById("notes").value,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          const msg = error.error || error.message || "Error al enviar a tostión";
          const detail = error.detail ? `\nDisponible: ${error.detail.available_kg} kg` : "";
          throw new Error(msg + detail);
        }

        alert(
          `✅ Lote ${item.lot_id} enviado a tostión correctamente\n${quantity} kg en proceso`
        );

        form.reset();
        roastingDate.value = today;
        lotInfoCard.style.display = "none";
        summaryBox.style.display = "none";
        loadAvailableLots();
      } catch (error) {
        console.error("Error:", error);
        alert(`❌ Error: ${error.message || "Error desconocido"}`);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });

    // Cargar lotes al iniciar
    loadAvailableLots();
  </script>
</AdminLayout>
