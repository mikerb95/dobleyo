          tipo: 'historia', dias: 3, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['blog', 'admin'],
        },
        {
          id: 'DY-197',
          titulo: 'Como visitante, quiero leer entradas de blog en el sitio para conocer más sobre el café de DobleYo',
          tipo: 'historia', dias: 2, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['blog', 'ui'],
        },
        {
          id: 'DY-199',
          titulo: 'Como editor, quiero guardar borradores de blog para publicarlos cuando estén listos',
          tipo: 'historia', dias: 2, valor: 'medio',
          col: 'aceptada', par: 'DC',
          tags: ['blog'],
        },
        {
          id: 'DY-201',
          titulo: 'Migrar datos de blog de localStorage a la base de datos Turso',
          tipo: 'tarea', dias: 2, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['bd', 'migración'],
        },
        {
          id: 'DY-203',
          titulo: 'Bug: markdown no renderiza en la vista de detalle del artículo',
          tipo: 'bug', dias: 1, valor: 'alto',
          col: 'aceptada', par: 'DC',
          tags: ['blog'],
        },
        {
          id: 'DY-205',
          titulo: 'Agregar endpoint GET /api/admin/posts para listar todos los artículos incluyendo borradores',
          tipo: 'tarea', dias: 1, valor: 'medio',
          col: 'aceptada', par: 'MR',
          tags: ['api'],
        },
      ],
    },
    {
      id: 'i10',
      nombre: 'Iteración 10 · Migración a Turso',
      rango: '12 may – 23 may 2026',
      dias: 10,
      comprometido: 10,
      burndown: [10, 10, 9, 7, 6, 5, 4, 2, 1, 0, 0],
      historias: [
        {
          id: 'DY-170',
          titulo: 'Migrar el driver de base de datos de PostgreSQL a @libsql/client (Turso)',
          tipo: 'tarea', dias: 3, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['bd', 'turso'],
        },
        {
          id: 'DY-173',
          titulo: 'Adaptar todas las queries a sintaxis SQLite: parámetros ?, datetime("now"), sin type casts',
          tipo: 'tarea', dias: 3, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['bd'],
        },
        {
          id: 'DY-176',
          titulo: 'Reescribir migraciones incrementales para libSQL',
          tipo: 'tarea', dias: 2, valor: 'medio',
          col: 'aceptada', par: 'MR',
          tags: ['bd'],
        },
        {
          id: 'DY-179',
          titulo: '[Spike] Evaluar Turso vs PlanetScale para el stack Colombia+USA — límite: 1 día ideal',
          tipo: 'spike', dias: 1, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['research'],
        },
        {
          id: 'DY-181',
          titulo: 'Configurar variables TURSO_DATABASE_URL y TURSO_AUTH_TOKEN en Vercel',
          tipo: 'tarea', dias: 1, valor: 'alto',
          col: 'aceptada', par: 'MR',
          tags: ['infra', 'vercel'],
        },
      ],
    },
  ];

  const VELOCIDAD = [
    { iter: 'I8',  plan: 8,  done: 7  },
    { iter: 'I9',  plan: 10, done: 9  },
    { iter: 'I10', plan: 10, done: 10 },
    { iter: 'I11', plan: 11, done: 11 },
    { iter: 'I12', plan: 14, done: 6  },
  ];

  // ── Helpers ───────────────────────────────────────────────
  const NS = 'http://www.w3.org/2000/svg';
  const SVG_TAGS = new Set(['svg','g','path','line','rect','circle','polyline','text']);
  const el = (tag, attrs = {}, ...kids) => {
    const node = SVG_TAGS.has(tag)
      ? document.createElementNS(NS, tag)
      : document.createElement(tag);
    for (const [k, v] of Object.entries(attrs)) node.setAttribute(k, v);
    kids.forEach(k => node.appendChild(typeof k === 'string' ? document.createTextNode(k) : k));
    return node;
  };

  let iterActual = ITERACIONES[0];

  // Selector
  const sel = document.getElementById('iterSelect');
  ITERACIONES.forEach(it => {
    const o = document.createElement('option');
    o.value = it.id;
    o.textContent = it.nombre;
    sel.appendChild(o);
  });
  sel.addEventListener('change', () => {
    iterActual = ITERACIONES.find(i => i.id === sel.value) || ITERACIONES[0];
    render();
  });

  // Toggle vista
  document.getElementById('iterViewToggle').addEventListener('click', (e) => {
    const btn = e.target.closest('.dt-view-btn');
    if (!btn) return;
    document.querySelectorAll('.dt-view-btn').forEach(b => b.classList.toggle('dt-view-btn--on', b === btn));
    const charts = btn.dataset.view === 'charts';
    document.getElementById('iterBoard').hidden = charts;
    document.getElementById('iterProgressCard').hidden = charts;
    document.getElementById('iterCharts').hidden = !charts;
    if (charts) renderCharts();
  });

  // ── Render principal ───────────────────────────────────────
  function render() {
    const h = iterActual.historias;
    const total      = h.reduce((a, s) => a + s.dias, 0);
    const aceptadas  = h.filter(s => s.col === 'aceptada').reduce((a, s) => a + s.dias, 0);
    const enAcept    = h.filter(s => s.col === 'aceptacion').reduce((a, s) => a + s.dias, 0);
    const enDesarr   = h.filter(s => s.col === 'desarrollo').reduce((a, s) => a + s.dias, 0);
    const pct        = total ? Math.round((aceptadas / total) * 100) : 0;
    const dayIdx     = iterActual.burndown.filter(v => v !== null).length - 1;

    // KPIs
    const summary = document.getElementById('iterSummary');
    summary.innerHTML = '';
    [
      { label: 'Historias',      value: h.length,                                          sub: `${h.filter(s => s.col === 'aceptada').length} aceptadas`,    tone: '' },
      { label: 'Días ideales',   value: `${aceptadas}/${total}`,                           sub: `${total - aceptadas} restantes`,                              tone: 'info' },
      { label: 'Completado',     value: `${pct}%`,                                         sub: `${enDesarr} días en desarrollo`,                              tone: 'success' },
      { label: 'Día de iteración', value: `${Math.min(dayIdx + 1, iterActual.dias)}/${iterActual.dias}`, sub: iterActual.rango, tone: 'warning' },
    ].forEach(k => {
      const tile = document.createElement('div');
      tile.className = `kpi-tile${k.tone ? ' ' + k.tone : ''}`;
      tile.innerHTML = `<div class="kpi-label">${k.label}</div><div class="kpi-value">${k.value}</div><div class="kpi-sub">${k.sub}</div>`;
      summary.appendChild(tile);
    });

    // Progreso
    document.getElementById('iterProgressTitle').textContent = iterActual.nombre;
    document.getElementById('iterProgressMeta').textContent =
      `${aceptadas} de ${total} días ideales · ${iterActual.rango}`;
    document.getElementById('iterProgressPct').textContent = pct + '%';

    const bar = document.getElementById('iterBar');
    bar.innerHTML = '';
    [
      { cls: 'done',       v: aceptadas },
      { cls: 'aceptacion', v: enAcept   },
      { cls: 'desarrollo', v: enDesarr  },
    ].forEach(s => {
      if (s.v <= 0) return;
      const d = document.createElement('div');
      d.className = `iter-bar__seg iter-bar__seg--${s.cls}`;
      d.style.width = (s.v / total * 100) + '%';
      bar.appendChild(d);
    });
    const cola = total - aceptadas - enAcept - enDesarr;
    document.getElementById('iterBarLegend').innerHTML =
      `<span><i style="background:var(--ok)"></i>Aceptadas ${aceptadas}d</span>` +
      `<span><i style="background:var(--color-accent)"></i>En aceptación ${enAcept}d</span>` +
      `<span><i style="background:var(--info)"></i>En desarrollo ${enDesarr}d</span>` +
      `<span><i style="background:color-mix(in oklab,var(--color-primary) 8%,white)"></i>Cola ${cola}d</span>`;

    // Tablero
    const board = document.getElementById('iterBoard');
    board.innerHTML = '';
    COLUMNAS.forEach(col => {
      const items = h.filter(s => s.col === col.id);
      const dias  = items.reduce((a, s) => a + s.dias, 0);
      const colEl = document.createElement('div');
      colEl.className = 'iter-col';
      const head = document.createElement('div');
      head.className = 'iter-col__head';
      head.appendChild(el('span', { class: 'iter-col__dot', style: `background:${col.color}` }));
      head.appendChild(el('span', { class: 'iter-col__name' }, col.nombre));
      head.appendChild(el('span', { class: 'iter-col__count' }, `${items.length} · ${dias}d`));
      colEl.appendChild(head);
      const body = document.createElement('div');
      body.className = 'iter-col__body';
      if (!items.length) {
        body.appendChild(el('div', { class: 'iter-col__empty' }, 'Sin historias'));
      } else {
        items.forEach(s => body.appendChild(historiaCard(s)));
      }
      colEl.appendChild(body);
      board.appendChild(colEl);
    });
  }

  function historiaCard(s) {
    const par = PARES[s.par] || { nombre: s.par, color: '#888' };
    const tipoLabel = { historia: 'Historia', bug: 'Bug', tarea: 'Tarea', spike: 'Spike' };
    const valorLabel = { alto: 'Valor alto', medio: 'Valor medio', bajo: 'Valor bajo' };

    const card = document.createElement('div');
    card.className = 'iter-card';

    const top = document.createElement('div');
    top.className = 'iter-card__top';
    top.appendChild(el('span', { class: 'iter-card__id' }, s.id));
    top.appendChild(el('span', { class: `iter-card__type iter-card__type--${s.tipo}` }, tipoLabel[s.tipo] || s.tipo));
    top.appendChild(el('span', { class: 'iter-card__pts' }, `${s.dias}d`));
    card.appendChild(top);

    const title = document.createElement('p');
    title.className = 'iter-card__title';
    title.textContent = s.titulo;
    card.appendChild(title);

    if (s.tags && s.tags.length) {
      const tags = document.createElement('div');
      tags.className = 'iter-card__tags';
      s.tags.forEach(t => {
        const span = document.createElement('span');
        span.className = 'iter-tag';
        span.textContent = '#' + t;
        tags.appendChild(span);
      });
      card.appendChild(tags);
    }

    const foot = document.createElement('div');
    foot.className = 'iter-card__foot';

    const valor = document.createElement('span');
    valor.className = `iter-card__valor iter-card__valor--${s.valor}`;
    const dot = document.createElement('i');
    valor.appendChild(dot);
    valor.appendChild(document.createTextNode(valorLabel[s.valor] || s.valor));

    const pair = document.createElement('span');
    pair.className = 'iter-card__pair';
    pair.title = par.nombre;
    const avatar = document.createElement('span');
    avatar.className = 'iter-avatar';
    avatar.style.background = par.color;
    avatar.textContent = s.par;
    pair.appendChild(avatar);

    foot.appendChild(valor);
    foot.appendChild(pair);
    card.appendChild(foot);
    return card;
  }

  // ── Gráficos SVG ──────────────────────────────────────────
  function renderCharts() { renderBurndown(); renderVelocity(); }

  function renderBurndown() {
    const W = 520, H = 260, pad = { t: 16, r: 16, b: 30, l: 40 };
    const cw = W - pad.l - pad.r, ch = H - pad.t - pad.b;
    const data = iterActual.burndown;
    const n = data.length - 1;
    const maxY = iterActual.comprometido;
    const x = i => pad.l + (i / n) * cw;
    const y = v => pad.t + (1 - v / maxY) * ch;

    const svg = el('svg', { viewBox: `0 0 ${W} ${H}`, role: 'img', 'aria-label': 'Burndown' });
    for (let i = 0; i <= 4; i++) {
      const v = (maxY / 4) * i, yy = y(v);
      svg.appendChild(el('line', { x1: pad.l, y1: yy, x2: W - pad.r, y2: yy, stroke: '#e5e1da', 'stroke-width': '1' }));
      svg.appendChild(el('text', { x: pad.l - 8, y: yy + 4, 'text-anchor': 'end', 'font-size': '10', fill: '#a09080' }, String(Math.round(v))));
    }
    for (let i = 0; i <= n; i += Math.ceil(n / 5)) {
      svg.appendChild(el('text', { x: x(i), y: H - 10, 'text-anchor': 'middle', 'font-size': '10', fill: '#a09080' }, 'D' + i));
    }
    svg.appendChild(el('line', { x1: x(0), y1: y(maxY), x2: x(n), y2: y(0), stroke: '#c5bdb5', 'stroke-width': '1.5', 'stroke-dasharray': '5 4' }));
    const reales = data.map((v, i) => ({ v, i })).filter(p => p.v !== null);
    svg.appendChild(el('polyline', {
      points: reales.map(p => `${x(p.i)},${y(p.v)}`).join(' '),
      fill: 'none', stroke: '#c9893d', 'stroke-width': '2.5',
      'stroke-linejoin': 'round', 'stroke-linecap': 'round',
    }));
    reales.forEach(p => svg.appendChild(el('circle', { cx: x(p.i), cy: y(p.v), r: '3', fill: '#c9893d' })));
    const box = document.getElementById('iterBurndown');
    box.innerHTML = ''; box.appendChild(svg);
  }

  function renderVelocity() {
    const W = 520, H = 260, pad = { t: 16, r: 16, b: 34, l: 40 };
    const cw = W - pad.l - pad.r, ch = H - pad.t - pad.b;
    const maxY = Math.max(...VELOCIDAD.map(d => Math.max(d.plan, d.done))) * 1.1;
    const y = v => pad.t + (1 - v / maxY) * ch;
    const band = cw / VELOCIDAD.length, bw = Math.min(24, band / 3);

    const svg = el('svg', { viewBox: `0 0 ${W} ${H}`, role: 'img', 'aria-label': 'Velocidad' });
    for (let i = 0; i <= 4; i++) {
      const v = (maxY / 4) * i, yy = y(v);
      svg.appendChild(el('line', { x1: pad.l, y1: yy, x2: W - pad.r, y2: yy, stroke: '#e5e1da', 'stroke-width': '1' }));
      svg.appendChild(el('text', { x: pad.l - 8, y: yy + 4, 'text-anchor': 'end', 'font-size': '10', fill: '#a09080' }, String(Math.round(v))));
    }
    VELOCIDAD.forEach((d, i) => {
      const cx = pad.l + band * i + band / 2, x1 = cx - bw - 2, x2 = cx + 2;
      svg.appendChild(el('rect', { x: x1, y: y(d.plan), width: bw, height: pad.t + ch - y(d.plan), rx: '3', fill: '#d4c9be' }));
      svg.appendChild(el('rect', { x: x2, y: y(d.done), width: bw, height: pad.t + ch - y(d.done), rx: '3', fill: '#c9893d' }));
      svg.appendChild(el('text', { x: cx, y: H - 12, 'text-anchor': 'middle', 'font-size': '10', fill: '#a09080' }, d.iter));
    });
    const box = document.getElementById('iterVelocity');
    box.innerHTML = ''; box.appendChild(svg);
    const cerradas = VELOCIDAD.filter(d => d.done > 0);
    const avg = cerradas.length ? Math.round(cerradas.reduce((a, d) => a + d.done, 0) / cerradas.length) : 0;
    document.getElementById('iterVelocityAvg').innerHTML =
      `Velocidad promedio: <b>${avg} días ideales</b> por iteración (últimas ${cerradas.length}).`;
  }

  render();
})();
</script>
