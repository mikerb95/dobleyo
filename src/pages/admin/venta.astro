---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Registrar Venta Externa — DobleYo Admin" section="ventas">
  <div class="ext-sales-page">

    <!-- Header -->
    <section class="ios-page-header">
      <div class="ios-header-inner">
        <div>
          <h1 class="ios-page-title">Ventas Externas</h1>
          <p class="ios-page-sub">Instagram, WhatsApp, referidos y canales no integrados</p>
        </div>
        <button id="btnNewSale" class="ios-btn ios-btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          Nueva Venta
        </button>
      </div>
    </section>

    <!-- KPIs -->
    <section class="ios-kpi-section">
      <div class="ios-kpi-grid">
        <div class="ios-kpi-card ios-kpi-brand">
          <div class="ios-kpi-label">Total Ventas</div>
          <div class="ios-kpi-value" id="statTotal">—</div>
          <div class="ios-kpi-icon">🧾</div>
        </div>
        <div class="ios-kpi-card ios-kpi-success">
          <div class="ios-kpi-label">Ingresos</div>
          <div class="ios-kpi-value" id="statRevenue">—</div>
          <div class="ios-kpi-icon">💰</div>
        </div>
        <div class="ios-kpi-card ios-kpi-info">
          <div class="ios-kpi-label">Este Mes</div>
          <div class="ios-kpi-value" id="statMonth">—</div>
          <div class="ios-kpi-icon">📅</div>
        </div>
        <div class="ios-kpi-card ios-kpi-warning">
          <div class="ios-kpi-label">Canal Top</div>
          <div class="ios-kpi-value" id="statTopChannel">—</div>
          <div class="ios-kpi-icon">📣</div>
        </div>
      </div>
    </section>

    <!-- Filtros -->
    <section class="ios-filters-section">
      <div class="ios-search-bar">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="ios-search-icon">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="filterSearch" placeholder="Buscar por #, cliente, ciudad…" class="ios-search-input" />
      </div>
      <div class="ios-filter-chips">
        <select id="filterChannel" class="ios-filter-select">
          <option value="">Todos los canales</option>
          <option value="instagram">Instagram</option>
          <option value="whatsapp">WhatsApp</option>
          <option value="referido">Referido</option>
          <option value="tienda_fisica">Tienda Física</option>
          <option value="telefono">Teléfono</option>
          <option value="otro">Otro</option>
        </select>
        <select id="filterStatus" class="ios-filter-select">
          <option value="">Todos los estados</option>
          <option value="completada">Completada</option>
          <option value="pendiente">Pendiente</option>
          <option value="cancelada">Cancelada</option>
        </select>
        <input type="date" id="filterFrom" class="ios-filter-select" title="Desde" />
        <input type="date" id="filterTo" class="ios-filter-select" title="Hasta" />
        <button id="btnApplyFilters" class="ios-btn ios-btn-secondary ios-btn-sm">Filtrar</button>
        <button id="btnClearFilters" class="ios-btn ios-btn-ghost ios-btn-sm">Limpiar</button>
      </div>
    </section>

    <!-- Tabla -->
    <section class="ios-table-section">
      <div class="ios-table-card">
        <table class="ios-table" id="salesTable">
          <thead>
            <tr>
              <th># Venta</th>
              <th>Fecha</th>
              <th>Canal</th>
              <th>Cliente</th>
              <th>Ciudad</th>
              <th>Detalle</th>
              <th class="text-right">Total</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="salesBody">
            <tr><td colspan="9" class="ios-empty-row">Cargando ventas…</td></tr>
          </tbody>
        </table>
      </div>
      <div class="ios-pagination" id="pagination"></div>
    </section>

  </div>

  <!-- ── Modal: Registrar venta ────────────────────────── -->
  <div id="modalNewSale" class="ios-modal-overlay" hidden>
    <div class="ios-modal ios-modal-lg">
      <div class="ios-modal-handle"></div>
      <div class="ios-modal-header">
        <h2>Registrar Venta Externa</h2>
        <button class="ios-modal-close" id="btnCloseModal" aria-label="Cerrar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <form id="formNewSale" novalidate>
        <div class="ios-modal-body">

          <div class="ios-form-row">
            <div class="ios-form-group">
              <label for="fChannel">Canal de venta *</label>
              <select id="fChannel" name="channel" required>
                <option value="">Seleccionar…</option>
                <option value="instagram">Instagram</option>
                <option value="whatsapp">WhatsApp</option>
                <option value="referido">Referido</option>
                <option value="tienda_fisica">Tienda Física</option>
                <option value="telefono">Teléfono</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="ios-form-group">
              <label for="fChannelDetail">Detalle del canal</label>
              <input type="text" id="fChannelDetail" name="channel_detail" placeholder="ej. @usuario, referidor…" />
            </div>
            <div class="ios-form-group">
              <label for="fSaleDate">Fecha de venta *</label>
              <input type="date" id="fSaleDate" name="sale_date" required />
            </div>
          </div>

          <div class="ios-form-row">
            <div class="ios-form-group">
              <label for="fCustomerName">Nombre del cliente</label>
              <input type="text" id="fCustomerName" name="customer_name" placeholder="Nombre completo" />
            </div>
            <div class="ios-form-group">
              <label for="fCustomerContact">Contacto</label>
              <input type="text" id="fCustomerContact" name="customer_contact" placeholder="Teléfono o email" />
            </div>
            <div class="ios-form-group">
              <label for="fCustomerCity">Ciudad</label>
              <input type="text" id="fCustomerCity" name="customer_city" placeholder="Ciudad" />
            </div>
          </div>

          <div class="ios-form-section-title">
            <span>Productos vendidos</span>
            <button type="button" id="btnAddItem" class="ios-btn ios-btn-ghost ios-btn-sm">+ Agregar</button>
          </div>

          <div id="itemsContainer" class="ios-items-container"></div>

          <div class="ios-totals-box">
            <div class="ios-total-line">
              <span>Subtotal</span>
              <span id="tSubtotal">$ 0</span>
            </div>
            <div class="ios-total-line">
              <span class="ios-discount-label">
                Descuento
                <input type="number" id="fDiscount" name="discount" min="0" value="0" class="ios-discount-input" />
                <span class="ios-discount-unit">COP</span>
              </span>
              <span id="tDiscount">−$ 0</span>
            </div>
            <div class="ios-total-line ios-total-bold">
              <span>Total</span>
              <span id="tTotal">$ 0</span>
            </div>
          </div>

          <div class="ios-form-row">
            <div class="ios-form-group">
              <label for="fStatus">Estado</label>
              <select id="fStatus" name="status">
                <option value="completada">Completada (ajusta inventario)</option>
                <option value="pendiente">Pendiente (no ajusta inventario)</option>
              </select>
            </div>
            <div class="ios-form-group ios-form-group--wide">
              <label for="fNotes">Notas internas</label>
              <input type="text" id="fNotes" name="notes" placeholder="Observaciones opcionales" />
            </div>
          </div>

        </div>

        <div class="ios-modal-footer">
          <div id="formError" class="ios-form-error" hidden></div>
          <button type="button" id="btnCancelForm" class="ios-btn ios-btn-secondary">Cancelar</button>
          <button type="submit" id="btnSubmit" class="ios-btn ios-btn-primary">
            <span id="btnSubmitText">Registrar Venta</span>
            <span id="btnSubmitSpinner" class="ios-spinner" hidden></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal: Detalle de venta ───────────────────────── -->
  <div id="modalDetail" class="ios-modal-overlay" hidden>
    <div class="ios-modal">
      <div class="ios-modal-handle"></div>
      <div class="ios-modal-header">
        <h2 id="detailTitle">Detalle de Venta</h2>
        <button class="ios-modal-close" id="btnCloseDetail" aria-label="Cerrar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="ios-modal-body" id="detailBody">
        <div class="ios-empty-row">Cargando…</div>
      </div>
      <div class="ios-modal-footer">
        <button id="btnCancelSale" class="ios-btn ios-btn-danger" hidden>Cancelar Venta</button>
        <button id="btnCloseDetail2" class="ios-btn ios-btn-secondary">Cerrar</button>
      </div>
    </div>
  </div>

<style>
  /* ── Layout ─────────────────────────────────────────────── */
  .ext-sales-page { padding-bottom: 3rem; }

  /* ── Page header ────────────────────────────────────────── */
  .ios-page-header { padding: 1.5rem 1.5rem 0; }
  .ios-header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .ios-page-title { font-size: 1.5rem; font-weight: 700; color: var(--text-1); letter-spacing: -.02em; margin: 0 0 .2rem; }
  .ios-page-sub { font-size: .8rem; color: var(--text-2); margin: 0; }

  /* ── KPI cards ──────────────────────────────────────────── */
  .ios-kpi-section { padding: 1.25rem 1.5rem 0; }
  .ios-kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: .875rem; }

  .ios-kpi-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 1.1rem 1.25rem;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.06);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }
  .ios-kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    border-radius: 16px 16px 0 0;
  }
  .ios-kpi-brand::before   { background: linear-gradient(90deg, #c8a96e, #a8874a); }
  .ios-kpi-success::before { background: linear-gradient(90deg, #34c759, #248a3d); }
  .ios-kpi-info::before    { background: linear-gradient(90deg, #007aff, #0051a8); }
  .ios-kpi-warning::before { background: linear-gradient(90deg, #ff9500, #c96800); }

  .ios-kpi-icon {
    position: absolute;
    right: 1rem; top: 50%;
    transform: translateY(-50%);
    font-size: 2rem;
    opacity: .12;
    pointer-events: none;
  }
  .ios-kpi-label { font-size: .7rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; color: var(--text-2); }
  .ios-kpi-value { font-size: 1.5rem; font-weight: 700; color: var(--text-1); line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* ── Filters ────────────────────────────────────────────── */
  .ios-filters-section { padding: 1rem 1.5rem 0; display: flex; flex-direction: column; gap: .6rem; }

  .ios-search-bar {
    display: flex;
    align-items: center;
    gap: .6rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0 .875rem;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
    transition: border-color .15s, box-shadow .15s;
  }
  .ios-search-bar:focus-within {
    border-color: var(--nav-active-border);
    box-shadow: 0 0 0 3px rgba(200,169,110,.15);
  }
  .ios-search-icon { color: var(--text-3); flex-shrink: 0; }
  .ios-search-input {
    border: none; outline: none; background: transparent;
    padding: .625rem 0; font-size: .875rem; width: 100%;
    color: var(--text-1); font-family: inherit;
  }

  .ios-filter-chips { display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; }
  .ios-filter-select {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: .45rem .75rem;
    font-size: .8rem;
    background: var(--card-bg);
    color: var(--text-1);
    font-family: inherit;
    outline: none;
    transition: border-color .15s;
    cursor: pointer;
  }
  .ios-filter-select:focus { border-color: var(--nav-active-border); }

  /* ── Table ──────────────────────────────────────────────── */
  .ios-table-section { padding: 1rem 1.5rem 0; }
  .ios-table-card {
    background: var(--card-bg);
    border-radius: 16px;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.06);
    overflow: hidden;
    overflow-x: auto;
  }
  .ios-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
  .ios-table thead th {
    padding: .75rem 1rem;
    text-align: left;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--text-2);
    background: #fafafa;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .ios-table tbody td {
    padding: .8rem 1rem;
    border-bottom: 1px solid rgba(0,0,0,.04);
    color: var(--text-1);
    vertical-align: middle;
  }
  .ios-table tbody tr:last-child td { border-bottom: none; }
  .ios-table tbody tr { transition: background .1s; }
  .ios-table tbody tr:hover td { background: var(--nav-hover-bg); }
  .text-right { text-align: right !important; }
  .ios-empty-row { text-align: center; padding: 2.5rem 1rem !important; color: var(--text-2); font-size: .875rem; }

  /* ── Badges ─────────────────────────────────────────────── */
  .badge { display: inline-flex; align-items: center; padding: .22rem .65rem; border-radius: 999px; font-size: .7rem; font-weight: 700; letter-spacing: .03em; white-space: nowrap; }
  .badge-channel-instagram  { background: #fce4ec; color: #ad1457; }
  .badge-channel-whatsapp   { background: #e8f5e9; color: #2e7d32; }
  .badge-channel-referido   { background: #e3f2fd; color: #1565c0; }
  .badge-channel-tienda_fisica { background: #fff8e1; color: #f57f17; }
  .badge-channel-telefono   { background: #ede7f6; color: #4527a0; }
  .badge-channel-otro       { background: #f5f5f5; color: #424242; }
  .badge-completada { background: var(--c-success-bg); color: var(--c-success); border: 1px solid var(--c-success-border); }
  .badge-pendiente  { background: var(--c-warning-bg); color: var(--c-warning); border: 1px solid var(--c-warning-border); }
  .badge-cancelada  { background: var(--c-error-bg);   color: var(--c-error);   border: 1px solid var(--c-error-border); }

  /* ── Row action button ──────────────────────────────────── */
  .action-btn {
    padding: .3rem .7rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    cursor: pointer;
    font-size: .78rem;
    font-weight: 500;
    color: var(--text-2);
    font-family: inherit;
    transition: background .12s, transform .1s;
  }
  .action-btn:hover  { background: var(--nav-hover-bg); color: var(--text-1); }
  .action-btn:active { transform: scale(.95); }

  /* ── Pagination ─────────────────────────────────────────── */
  .ios-pagination { padding: .75rem 1rem; display: flex; align-items: center; gap: .5rem; justify-content: flex-end; font-size: .8rem; color: var(--text-2); }

  /* ── Buttons ────────────────────────────────────────────── */
  .ios-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .55rem 1.1rem;
    border-radius: 10px;
    font-size: .875rem;
    font-weight: 600;
    font-family: inherit;
    border: none;
    cursor: pointer;
    transition: filter .12s, transform .1s, background .12s;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }
  .ios-btn:active { transform: scale(.96); }
  .ios-btn-primary   { background: var(--brand); color: #fff; }
  .ios-btn-primary:hover { filter: brightness(1.08); }
  .ios-btn-secondary { background: var(--card-bg); border: 1px solid var(--border); color: var(--text-1); }
  .ios-btn-secondary:hover { background: var(--nav-hover-bg); }
  .ios-btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text-2); }
  .ios-btn-ghost:hover { background: var(--nav-hover-bg); color: var(--text-1); }
  .ios-btn-danger { background: var(--c-error-bg); color: var(--c-error); border: 1px solid var(--c-error-border); }
  .ios-btn-danger:hover { filter: brightness(.96); }
  .ios-btn-sm { padding: .32rem .7rem !important; font-size: .78rem !important; border-radius: 8px !important; }

  /* ── Modal ──────────────────────────────────────────────── */
  .ios-modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .ios-modal-overlay[hidden] { display: none; }

  .ios-modal {
    background: var(--card-bg);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,.22), 0 4px 16px rgba(0,0,0,.1);
    width: 100%;
    max-width: 640px;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ios-modal-lg { max-width: 860px; }

  .ios-modal-handle {
    width: 40px; height: 5px;
    background: var(--border);
    border-radius: 999px;
    margin: 10px auto 0;
    flex-shrink: 0;
  }

  .ios-modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: .875rem 1.5rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .ios-modal-header h2 { font-size: 1rem; font-weight: 700; margin: 0; color: var(--text-1); letter-spacing: -.01em; }
  .ios-modal-close {
    background: #f0f0f0;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: background .12s;
  }
  .ios-modal-close:hover { background: #e0e0e0; color: var(--text-1); }

  .ios-modal-body { padding: 1.25rem 1.5rem; overflow-y: auto; flex: 1; }
  .ios-modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: flex-end; gap: .625rem;
    flex-shrink: 0;
    background: #fafafa;
    border-radius: 0 0 20px 20px;
  }

  /* ── Form ───────────────────────────────────────────────── */
  .ios-form-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin-bottom: .75rem; }
  .ios-form-group { display: flex; flex-direction: column; gap: .3rem; }
  .ios-form-group--wide { grid-column: span 2; }
  .ios-form-group label { font-size: .75rem; font-weight: 600; color: var(--text-2); }
  .ios-form-group input,
  .ios-form-group select {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: .55rem .875rem;
    font-size: .875rem;
    color: var(--text-1);
    background: var(--card-bg);
    outline: none;
    font-family: inherit;
    transition: border-color .15s, box-shadow .15s;
  }
  .ios-form-group input:focus,
  .ios-form-group select:focus {
    border-color: var(--nav-active-border);
    box-shadow: 0 0 0 3px rgba(200,169,110,.15);
  }

  .ios-form-section-title {
    display: flex; align-items: center; justify-content: space-between;
    margin: 1rem 0 .5rem;
    font-size: .75rem; font-weight: 700; color: var(--text-2);
    text-transform: uppercase; letter-spacing: .07em;
    border-bottom: 1px solid var(--border);
    padding-bottom: .4rem;
  }

  /* Items */
  .ios-items-container { display: flex; flex-direction: column; gap: .5rem; margin-bottom: .75rem; }
  .item-row { display: grid; grid-template-columns: 1fr .6fr .85fr auto; gap: .5rem; align-items: center; }
  .item-row select, .item-row input {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: .45rem .65rem;
    font-size: .85rem;
    color: var(--text-1);
    background: var(--card-bg);
    font-family: inherit;
    outline: none;
  }
  .item-row input[type="number"] { text-align: right; }
  .btn-remove-item {
    background: none; border: none; cursor: pointer;
    color: var(--c-error);
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; line-height: 1;
    transition: background .12s;
  }
  .btn-remove-item:hover { background: var(--c-error-bg); }

  /* Totals */
  .ios-totals-box {
    background: var(--erp-bg);
    border-radius: 12px;
    padding: .875rem 1.1rem;
    margin-bottom: .75rem;
    display: flex; flex-direction: column; gap: .4rem;
  }
  .ios-total-line { display: flex; justify-content: space-between; align-items: center; font-size: .875rem; color: var(--text-2); }
  .ios-total-bold { font-weight: 700; font-size: 1rem; color: var(--text-1); border-top: 1px solid var(--border); padding-top: .5rem; margin-top: .1rem; }
  .ios-discount-label { display: flex; align-items: center; gap: .4rem; }
  .ios-discount-input { width: 90px; border: 1px solid var(--border); border-radius: 7px; padding: .28rem .5rem; font-size: .82rem; background: var(--card-bg); font-family: inherit; outline: none; }
  .ios-discount-unit { font-size: .72rem; color: var(--text-3); }

  .ios-form-error { color: var(--c-error); font-size: .82rem; margin-right: auto; }

  .ios-spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4); border-top-color: #fff; border-radius: 50%; animation: ios-spin .6s linear infinite; }
  @keyframes ios-spin { to { transform: rotate(360deg); } }

  /* Detail content */
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem .75rem; margin-bottom: 1rem; }
  .detail-item { display: flex; flex-direction: column; gap: .15rem; }
  .detail-item .dl { font-size: .7rem; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: .06em; }
  .detail-item .dv { font-size: .9rem; color: var(--text-1); font-weight: 500; }
  .detail-items-table { width: 100%; border-collapse: collapse; font-size: .85rem; margin-top: .5rem; border-radius: 10px; overflow: hidden; }
  .detail-items-table th, .detail-items-table td { padding: .55rem .75rem; border-bottom: 1px solid rgba(0,0,0,.05); text-align: left; }
  .detail-items-table th { color: var(--text-2); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; background: #fafafa; }

  /* ── Mobile bottom sheet ────────────────────────────────── */
  @media (max-width: 640px) {
    .ios-modal-overlay { align-items: flex-end; padding: 0; }
    .ios-modal, .ios-modal.ios-modal-lg {
      max-width: 100%;
      border-radius: 20px 20px 0 0;
      max-height: 95vh;
    }
    .ios-modal-footer { border-radius: 0; }
    .ios-kpi-grid { grid-template-columns: 1fr 1fr; }
    .ios-form-row { grid-template-columns: 1fr; }
    .ios-form-group--wide { grid-column: 1; }
    .item-row { grid-template-columns: 1fr 1fr; }
    .ios-header-inner { flex-direction: column; align-items: flex-start; }
    .ios-kpi-value { font-size: 1.2rem; }
  }
  @media (max-width: 480px) {
    .ios-kpi-grid { grid-template-columns: 1fr 1fr; gap: .6rem; }
    .ios-filter-chips { gap: .4rem; }
    .ios-filter-select { font-size: .75rem; padding: .4rem .6rem; }
  }
</style>

<script>
  // ── Estado ─────────────────────────────────────────────────
  let allProducts = [];
  let currentPage = 0;
  const PAGE_SIZE = 20;
  let currentFilters = {};
  let currentDetailId = null;

  const fmt = (n) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n);
  const fmtDate = (d) => d ? new Date(d + 'T12:00:00').toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';

  const CHANNEL_LABELS = {
    instagram: 'Instagram', whatsapp: 'WhatsApp', referido: 'Referido',
    tienda_fisica: 'Tienda Física', telefono: 'Teléfono', otro: 'Otro',
  };
  const STATUS_LABELS = { completada: 'Completada', pendiente: 'Pendiente', cancelada: 'Cancelada' };

  // ── Cargar productos para el selector ──────────────────────
  async function loadProducts() {
    try {
      const r = await fetch('/api/inventory/products?active=true', { credentials: 'include' });
      const data = await r.json();
      if (data.success) allProducts = data.products;
    } catch (_) {}
  }

  // ── Cargar y renderizar ventas ─────────────────────────────
  async function loadSales(page = 0) {
    currentPage = page;
    const params = new URLSearchParams({ limit: PAGE_SIZE, offset: page * PAGE_SIZE, ...currentFilters });
    try {
      const r = await fetch(`/api/external-sales?${params}`, { credentials: 'include' });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);

      renderStats(data.stats);
      renderTable(data.sales);
      renderPagination(data.total, page);
    } catch (err) {
      document.getElementById('salesBody').innerHTML =
        `<tr><td colspan="9" class="ios-empty-row">Error al cargar ventas: ${err.message}</td></tr>`;
    }
  }

  function renderStats(stats) {
    const totalSales = stats.reduce((s, r) => s + Number(r.total_sales), 0);
    const totalRevenue = stats.reduce((s, r) => s + Number(r.total_revenue), 0);
    const topChannel = stats[0];

    document.getElementById('statTotal').textContent = totalSales;
    document.getElementById('statRevenue').textContent = fmt(totalRevenue);

    // Ventas de este mes
    const now = new Date();
    const y = now.getFullYear(), m = String(now.getMonth() + 1).padStart(2, '0');
    fetch(`/api/external-sales?limit=1&from=${y}-${m}-01&to=${y}-${m}-31`, { credentials: 'include' })
      .then(r => r.json())
      .then(d => { document.getElementById('statMonth').textContent = d.total ?? '—'; });

    document.getElementById('statTopChannel').textContent = topChannel
      ? `${CHANNEL_LABELS[topChannel.channel] || topChannel.channel} (${topChannel.total_sales})`
      : '—';
  }

  function renderTable(sales) {
    const tbody = document.getElementById('salesBody');
    if (!sales.length) {
      tbody.innerHTML = '<tr><td colspan="9" class="ios-empty-row">No hay ventas registradas.</td></tr>';
      return;
    }
    tbody.innerHTML = sales.map(s => `
      <tr>
        <td><strong>${s.sale_number}</strong></td>
        <td>${fmtDate(s.sale_date)}</td>
        <td><span class="badge badge-channel-${s.channel}">${CHANNEL_LABELS[s.channel] || s.channel}</span></td>
        <td>${s.customer_name || '—'}</td>
        <td>${s.customer_city || '—'}</td>
        <td style="color:var(--text-2); font-size:.8rem;">${s.channel_detail || '—'}</td>
        <td class="text-right"><strong>${fmt(s.total)}</strong></td>
        <td><span class="badge badge-${s.status}">${STATUS_LABELS[s.status] || s.status}</span></td>
        <td>
          <button class="action-btn" onclick="openDetail(${s.id})">Ver</button>
        </td>
      </tr>
    `).join('');
  }

  function renderPagination(total, page) {
    const pages = Math.ceil(total / PAGE_SIZE);
    const el = document.getElementById('pagination');
    if (pages <= 1) { el.innerHTML = `<span>${total} registros</span>`; return; }
    el.innerHTML = `
      <span>${total} registros</span>
      <button class="ios-btn ios-btn-ghost ios-btn-sm" onclick="loadSales(${page - 1})" ${page === 0 ? 'disabled' : ''}>‹ Anterior</button>
      <span>Pág. ${page + 1} / ${pages}</span>
      <button class="ios-btn ios-btn-ghost ios-btn-sm" onclick="loadSales(${page + 1})" ${page >= pages - 1 ? 'disabled' : ''}>Siguiente ›</button>
    `;
  }

  // ── Items dinámicos en el formulario ──────────────────────
  function buildProductOptions(selectedId = '') {
    return `<option value="">Seleccionar producto…</option>` +
      allProducts.map(p => `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>
        ${p.name} (Stock: ${p.stock_quantity ?? 0})
      </option>`).join('');
  }

  function addItemRow() {
    const container = document.getElementById('itemsContainer');
    const idx = container.children.length;
    const row = document.createElement('div');
    row.className = 'item-row';
    row.dataset.idx = idx;
    row.innerHTML = `
      <select class="item-product" onchange="recalcTotals()">${buildProductOptions()}</select>
      <input type="number" class="item-qty" min="1" value="1" placeholder="Cant." onchange="recalcTotals()" oninput="recalcTotals()" />
      <input type="number" class="item-price" min="0" value="0" placeholder="Precio unit. COP" onchange="recalcTotals()" oninput="recalcTotals()" />
      <button type="button" class="btn-remove-item" onclick="removeItemRow(this)" title="Quitar">×</button>
    `;
    container.appendChild(row);
    recalcTotals();
  }

  window.removeItemRow = (btn) => {
    btn.closest('.item-row').remove();
    recalcTotals();
  };

  function recalcTotals() {
    const rows = document.querySelectorAll('.item-row');
    let subtotal = 0;
    rows.forEach(row => {
      const qty = Number(row.querySelector('.item-qty')?.value || 0);
      const price = Number(row.querySelector('.item-price')?.value || 0);
      subtotal += qty * price;
    });
    const discount = Number(document.getElementById('fDiscount')?.value || 0);
    const total = Math.max(0, subtotal - discount);
    document.getElementById('tSubtotal').textContent = fmt(subtotal);
    document.getElementById('tDiscount').textContent = `−${fmt(discount)}`;
    document.getElementById('tTotal').textContent = fmt(total);
  }

  // ── Abrir / cerrar modal de nueva venta ───────────────────
  function openNewSaleModal() {
    const modal = document.getElementById('modalNewSale');
    document.getElementById('formNewSale').reset();
    document.getElementById('itemsContainer').innerHTML = '';
    document.getElementById('fSaleDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('formError').hidden = true;
    addItemRow();
    recalcTotals();
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeNewSaleModal() {
    document.getElementById('modalNewSale').hidden = true;
    document.body.style.overflow = '';
  }

  // ── Enviar formulario ──────────────────────────────────────
  document.getElementById('formNewSale').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = document.getElementById('formError');
    errEl.hidden = true;

    const rows = document.querySelectorAll('.item-row');
    const items = [];
    for (const row of rows) {
      const product_id = row.querySelector('.item-product').value;
      const quantity = Number(row.querySelector('.item-qty').value);
      const unit_price = Number(row.querySelector('.item-price').value);
      if (!product_id || quantity < 1) {
        errEl.textContent = 'Completa todos los campos de productos (producto y cantidad).';
        errEl.hidden = false;
        return;
      }
      items.push({ product_id, quantity, unit_price });
    }

    if (!items.length) {
      errEl.textContent = 'Agrega al menos un producto.';
      errEl.hidden = false;
      return;
    }

    const payload = {
      channel: document.getElementById('fChannel').value,
      channel_detail: document.getElementById('fChannelDetail').value,
      customer_name: document.getElementById('fCustomerName').value,
      customer_contact: document.getElementById('fCustomerContact').value,
      customer_city: document.getElementById('fCustomerCity').value,
      sale_date: document.getElementById('fSaleDate').value,
      discount: Number(document.getElementById('fDiscount').value || 0),
      notes: document.getElementById('fNotes').value,
      status: document.getElementById('fStatus').value,
      items,
    };

    const btnText = document.getElementById('btnSubmitText');
    const btnSpinner = document.getElementById('btnSubmitSpinner');
    const btnSubmit = document.getElementById('btnSubmit');
    btnText.hidden = true;
    btnSpinner.hidden = false;
    btnSubmit.disabled = true;

    try {
      const r = await fetch('/api/external-sales', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
      const data = await r.json();

      if (!data.success) {
        const msg = data.errors ? data.errors.map(e => e.msg).join(', ') : (data.error || 'Error desconocido');
        errEl.textContent = msg;
        errEl.hidden = false;
        return;
      }

      closeNewSaleModal();
      loadSales(0);
    } catch (err) {
      errEl.textContent = 'Error de conexión. Intenta de nuevo.';
      errEl.hidden = false;
    } finally {
      btnText.hidden = false;
      btnSpinner.hidden = true;
      btnSubmit.disabled = false;
    }
  });

  // ── Detalle de venta ───────────────────────────────────────
  window.openDetail = async (id) => {
    currentDetailId = id;
    const modal = document.getElementById('modalDetail');
    const body = document.getElementById('detailBody');
    const btnCancel = document.getElementById('btnCancelSale');
    body.innerHTML = '<div class="ios-empty-row">Cargando…</div>';
    btnCancel.hidden = true;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';

    try {
      const r = await fetch(`/api/external-sales/${id}`, { credentials: 'include' });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);

      const { sale, items } = data;
      document.getElementById('detailTitle').textContent = `Venta ${sale.sale_number}`;

      body.innerHTML = `
        <div class="detail-grid">
          <div class="detail-item"><span class="dl">Número</span><span class="dv">${sale.sale_number}</span></div>
          <div class="detail-item"><span class="dl">Fecha</span><span class="dv">${fmtDate(sale.sale_date)}</span></div>
          <div class="detail-item"><span class="dl">Canal</span><span class="dv">${CHANNEL_LABELS[sale.channel] || sale.channel}${sale.channel_detail ? ` — ${sale.channel_detail}` : ''}</span></div>
          <div class="detail-item"><span class="dl">Estado</span><span class="dv"><span class="badge badge-${sale.status}">${STATUS_LABELS[sale.status]}</span></span></div>
          <div class="detail-item"><span class="dl">Cliente</span><span class="dv">${sale.customer_name || '—'}</span></div>
          <div class="detail-item"><span class="dl">Contacto</span><span class="dv">${sale.customer_contact || '—'}</span></div>
          <div class="detail-item"><span class="dl">Ciudad</span><span class="dv">${sale.customer_city || '—'}</span></div>
          <div class="detail-item"><span class="dl">Registrado por</span><span class="dv">${sale.registered_by_name || '—'}</span></div>
          ${sale.notes ? `<div class="detail-item" style="grid-column:span 2"><span class="dl">Notas</span><span class="dv">${sale.notes}</span></div>` : ''}
        </div>
        <table class="detail-items-table">
          <thead><tr><th>Producto</th><th>SKU</th><th>Lote</th><th style="text-align:right">Cant.</th><th style="text-align:right">Precio unit.</th><th style="text-align:right">Subtotal</th></tr></thead>
          <tbody>
            ${items.map(it => `
              <tr>
                <td>${it.product_name}</td>
                <td style="color:var(--text-2)">${it.sku || '—'}</td>
                <td style="color:var(--text-2)">${it.lot_code || '—'}</td>
                <td style="text-align:right">${it.quantity}</td>
                <td style="text-align:right">${fmt(it.unit_price)}</td>
                <td style="text-align:right"><strong>${fmt(it.subtotal)}</strong></td>
              </tr>
            `).join('')}
          </tbody>
          <tfoot>
            <tr><td colspan="5" style="text-align:right;font-weight:600;padding:.6rem .75rem;">Descuento</td><td style="text-align:right;padding:.6rem .75rem">−${fmt(sale.discount)}</td></tr>
            <tr><td colspan="5" style="text-align:right;font-weight:700;font-size:1rem;padding:.6rem .75rem;">Total</td><td style="text-align:right;font-weight:700;font-size:1rem;padding:.6rem .75rem">${fmt(sale.total)}</td></tr>
          </tfoot>
        </table>
      `;

      if (sale.status !== 'cancelada') {
        btnCancel.hidden = false;
      }
    } catch (err) {
      body.innerHTML = `<div class="ios-empty-row">Error: ${err.message}</div>`;
    }
  };

  document.getElementById('btnCancelSale').addEventListener('click', async () => {
    if (!currentDetailId) return;
    if (!confirm('¿Confirmas cancelar esta venta? Se revertirá el ajuste de inventario.')) return;

    try {
      const r = await fetch(`/api/external-sales/${currentDetailId}/cancel`, {
        method: 'PUT',
        credentials: 'include',
      });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);
      document.getElementById('modalDetail').hidden = true;
      document.body.style.overflow = '';
      loadSales(currentPage);
    } catch (err) {
      alert('Error al cancelar: ' + err.message);
    }
  });

  // ── Filtros ────────────────────────────────────────────────
  document.getElementById('btnApplyFilters').addEventListener('click', () => {
    currentFilters = {};
    const search = document.getElementById('filterSearch').value.trim();
    const channel = document.getElementById('filterChannel').value;
    const status = document.getElementById('filterStatus').value;
    const from = document.getElementById('filterFrom').value;
    const to = document.getElementById('filterTo').value;
    if (search)  currentFilters.search = search;
    if (channel) currentFilters.channel = channel;
    if (status)  currentFilters.status = status;
    if (from)    currentFilters.from = from;
    if (to)      currentFilters.to = to;
    loadSales(0);
  });

  document.getElementById('btnClearFilters').addEventListener('click', () => {
    document.getElementById('filterSearch').value = '';
    document.getElementById('filterChannel').value = '';
    document.getElementById('filterStatus').value = '';
    document.getElementById('filterFrom').value = '';
    document.getElementById('filterTo').value = '';
    currentFilters = {};
    loadSales(0);
  });

  // ── Eventos de UI ──────────────────────────────────────────
  document.getElementById('btnNewSale').addEventListener('click', openNewSaleModal);
  document.getElementById('btnCloseModal').addEventListener('click', closeNewSaleModal);
  document.getElementById('btnCancelForm').addEventListener('click', closeNewSaleModal);
  document.getElementById('btnCloseDetail').addEventListener('click', () => {
    document.getElementById('modalDetail').hidden = true;
    document.body.style.overflow = '';
  });
  document.getElementById('btnCloseDetail2').addEventListener('click', () => {
    document.getElementById('modalDetail').hidden = true;
    document.body.style.overflow = '';
  });
  document.getElementById('btnAddItem').addEventListener('click', addItemRow);
  document.getElementById('fDiscount').addEventListener('input', recalcTotals);

  // Cerrar modales al hacer click fuera
  document.getElementById('modalNewSale').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeNewSaleModal();
  });
  document.getElementById('modalDetail').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      e.currentTarget.hidden = true;
      document.body.style.overflow = '';
    }
  });

  // ── Init ───────────────────────────────────────────────────
  (async () => {
    await loadProducts();
    await loadSales(0);
  })();
</script>
</AdminLayout>
