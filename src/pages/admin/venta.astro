---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Registrar Venta Externa — DobleYo Admin" section="ventas">
  <div class="ext-sales-page">

    <!-- Header -->
    <section class="page-header">
      <div class="header-inner">
        <div>
          <h1>Ventas Externas</h1>
          <p class="subtitle">Registra ventas realizadas por canales no integrados (revendedores, Instagram, WhatsApp, etc.)</p>
        </div>
        <button id="btnNewSale" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          Nueva Venta
        </button>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-section">
      <div class="stats-grid" id="statsGrid">
        <div class="stat-card">
          <div class="stat-label">Total Ventas</div>
          <div class="stat-value" id="statTotal">—</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Ingresos Totales</div>
          <div class="stat-value" id="statRevenue">—</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Este Mes</div>
          <div class="stat-value" id="statMonth">—</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Canal Principal</div>
          <div class="stat-value" id="statTopChannel">—</div>
        </div>
      </div>
    </section>

    <!-- Filtros -->
    <section class="filters-section">
      <div class="filters-row">
        <div class="search-box">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="filterSearch" placeholder="Buscar por #, cliente, ciudad…" />
        </div>
        <select id="filterChannel" class="filter-select">
          <option value="">Todos los canales</option>
          <option value="instagram">Instagram</option>
          <option value="whatsapp">WhatsApp</option>
          <option value="referido">Referido</option>
          <option value="tienda_fisica">Tienda Física</option>
          <option value="telefono">Teléfono</option>
          <option value="otro">Otro</option>
        </select>
        <select id="filterStatus" class="filter-select">
          <option value="">Todos los estados</option>
          <option value="completada">Completada</option>
          <option value="pendiente">Pendiente</option>
          <option value="cancelada">Cancelada</option>
        </select>
        <input type="date" id="filterFrom" class="filter-date" title="Desde" />
        <input type="date" id="filterTo" class="filter-date" title="Hasta" />
        <button id="btnApplyFilters" class="btn-secondary btn-sm">Filtrar</button>
        <button id="btnClearFilters" class="btn-ghost btn-sm">Limpiar</button>
      </div>
    </section>

    <!-- Tabla de ventas -->
    <section class="table-section">
      <div class="table-wrapper">
        <table class="sales-table" id="salesTable">
          <thead>
            <tr>
              <th># Venta</th>
              <th>Fecha</th>
              <th>Canal</th>
              <th>Cliente</th>
              <th>Ciudad</th>
              <th>Productos</th>
              <th class="text-right">Total</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="salesBody">
            <tr><td colspan="9" class="loading-row">Cargando ventas…</td></tr>
          </tbody>
        </table>
      </div>
      <div class="pagination" id="pagination"></div>
    </section>
  </div>

  <!-- ── Modal: Registrar venta ────────────────────────────── -->
  <div id="modalNewSale" class="modal-overlay" hidden>
    <div class="modal-box modal-lg">
      <div class="modal-header">
        <h2>Registrar Venta Externa</h2>
        <button class="modal-close" id="btnCloseModal" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <form id="formNewSale" novalidate>
        <div class="modal-body">

          <!-- Fila 1: canal + fecha -->
          <div class="form-row">
            <div class="form-group">
              <label for="fChannel">Canal de venta *</label>
              <select id="fChannel" name="channel" required>
                <option value="">Seleccionar…</option>
                <option value="instagram">Instagram</option>
                <option value="whatsapp">WhatsApp</option>
                <option value="referido">Referido</option>
                <option value="tienda_fisica">Tienda Física</option>
                <option value="telefono">Teléfono</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="fChannelDetail">Detalle del canal</label>
              <input type="text" id="fChannelDetail" name="channel_detail" placeholder="ej. @usuario, nombre referidor…" />
            </div>
            <div class="form-group">
              <label for="fSaleDate">Fecha de venta *</label>
              <input type="date" id="fSaleDate" name="sale_date" required />
            </div>
          </div>

          <!-- Fila 2: cliente -->
          <div class="form-row">
            <div class="form-group">
              <label for="fCustomerName">Nombre del cliente</label>
              <input type="text" id="fCustomerName" name="customer_name" placeholder="Nombre completo" />
            </div>
            <div class="form-group">
              <label for="fCustomerContact">Contacto</label>
              <input type="text" id="fCustomerContact" name="customer_contact" placeholder="Teléfono o email" />
            </div>
            <div class="form-group">
              <label for="fCustomerCity">Ciudad</label>
              <input type="text" id="fCustomerCity" name="customer_city" placeholder="Ciudad" />
            </div>
          </div>

          <!-- Productos -->
          <div class="form-section-title">
            <span>Productos vendidos</span>
            <button type="button" id="btnAddItem" class="btn-ghost btn-sm">+ Agregar producto</button>
          </div>

          <div id="itemsContainer" class="items-container">
            <!-- Se agregan dinámicamente -->
          </div>

          <div class="totals-row">
            <div class="total-line">
              <span>Subtotal</span>
              <span id="tSubtotal">$ 0</span>
            </div>
            <div class="total-line">
              <span>
                <label for="fDiscount">Descuento (COP)</label>
                <input type="number" id="fDiscount" name="discount" min="0" value="0" class="discount-input" />
              </span>
              <span id="tDiscount">−$ 0</span>
            </div>
            <div class="total-line total-line--bold">
              <span>Total</span>
              <span id="tTotal">$ 0</span>
            </div>
          </div>

          <!-- Fila final: estado + notas -->
          <div class="form-row">
            <div class="form-group">
              <label for="fStatus">Estado</label>
              <select id="fStatus" name="status">
                <option value="completada">Completada (ajusta inventario)</option>
                <option value="pendiente">Pendiente (no ajusta inventario)</option>
              </select>
            </div>
            <div class="form-group form-group--wide">
              <label for="fNotes">Notas internas</label>
              <input type="text" id="fNotes" name="notes" placeholder="Observaciones opcionales" />
            </div>
          </div>

        </div>

        <div class="modal-footer">
          <div id="formError" class="form-error" hidden></div>
          <button type="button" id="btnCancelForm" class="btn-secondary">Cancelar</button>
          <button type="submit" id="btnSubmit" class="btn-primary">
            <span id="btnSubmitText">Registrar Venta</span>
            <span id="btnSubmitSpinner" class="spinner" hidden></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal: Detalle de venta ───────────────────────────── -->
  <div id="modalDetail" class="modal-overlay" hidden>
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="detailTitle">Detalle de Venta</h2>
        <button class="modal-close" id="btnCloseDetail" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="modal-body" id="detailBody">
        <div class="loading-row">Cargando…</div>
      </div>
      <div class="modal-footer">
        <button id="btnCancelSale" class="btn-danger" hidden>Cancelar Venta</button>
        <button id="btnCloseDetail2" class="btn-secondary">Cerrar</button>
      </div>
    </div>
  </div>

<style>
  .ext-sales-page { padding-bottom: 3rem; }

  /* Header */
  .page-header { padding: 1.5rem 1.5rem 0; }
  .header-inner { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
  .header-inner h1 { font-size: 1.5rem; font-weight: 600; color: var(--text-1); margin: 0 0 .25rem; }
  .subtitle { color: var(--text-2); font-size: .875rem; margin: 0; }

  /* Stats */
  .stats-section { padding: 1.25rem 1.5rem 0; }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: .75rem; }
  .stat-card { background: var(--card-bg); border-radius: 8px; padding: 1rem 1.25rem; box-shadow: var(--card-shadow); }
  .stat-label { font-size: .75rem; color: var(--text-2); text-transform: uppercase; letter-spacing: .05em; margin-bottom: .3rem; }
  .stat-value { font-size: 1.375rem; font-weight: 700; color: var(--text-1); }

  /* Filters */
  .filters-section { padding: 1rem 1.5rem 0; }
  .filters-row { display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; }
  .search-box { display: flex; align-items: center; gap: .5rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 6px; padding: 0 .75rem; flex: 1; min-width: 200px; }
  .search-box input { border: none; outline: none; background: transparent; padding: .5rem 0; font-size: .875rem; width: 100%; }
  .filter-select, .filter-date { border: 1px solid var(--border); border-radius: 6px; padding: .5rem .75rem; font-size: .875rem; background: var(--card-bg); color: var(--text-1); }

  /* Table */
  .table-section { padding: 1rem 1.5rem 0; }
  .table-wrapper { background: var(--card-bg); border-radius: 8px; box-shadow: var(--card-shadow); overflow-x: auto; }
  .sales-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
  .sales-table th { padding: .75rem 1rem; text-align: left; font-size: .75rem; font-weight: 600; color: var(--text-2); text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid var(--border); white-space: nowrap; }
  .sales-table td { padding: .75rem 1rem; border-bottom: 1px solid var(--border); color: var(--text-1); vertical-align: middle; }
  .sales-table tbody tr:last-child td { border-bottom: none; }
  .sales-table tbody tr:hover { background: var(--nav-hover-bg); }
  .text-right { text-align: right !important; }
  .loading-row { text-align: center; padding: 2rem !important; color: var(--text-2); }

  .badge { display: inline-flex; align-items: center; padding: .2rem .55rem; border-radius: 999px; font-size: .72rem; font-weight: 600; white-space: nowrap; }
  .badge-channel-instagram { background: #fce4ec; color: #ad1457; }
  .badge-channel-whatsapp  { background: #e8f5e9; color: #2e7d32; }
  .badge-channel-referido  { background: #e3f2fd; color: #1565c0; }
  .badge-channel-tienda_fisica { background: #fff8e1; color: #f57f17; }
  .badge-channel-telefono  { background: #ede7f6; color: #4527a0; }
  .badge-channel-otro      { background: #f5f5f5; color: #424242; }

  .badge-completada { background: var(--c-success-bg); color: var(--c-success); border: 1px solid var(--c-success-border); }
  .badge-pendiente  { background: var(--c-warning-bg); color: var(--c-warning); border: 1px solid var(--c-warning-border); }
  .badge-cancelada  { background: var(--c-error-bg);   color: var(--c-error);   border: 1px solid var(--c-error-border); }

  .action-btn { padding: .3rem .6rem; border: 1px solid var(--border); border-radius: 5px; background: var(--card-bg); cursor: pointer; font-size: .8rem; color: var(--text-2); transition: background .15s; }
  .action-btn:hover { background: var(--nav-hover-bg); color: var(--text-1); }

  .pagination { padding: .75rem 1rem; display: flex; align-items: center; gap: .5rem; justify-content: flex-end; font-size: .875rem; color: var(--text-2); }

  /* Buttons */
  .btn-primary  { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; border: none; cursor: pointer; background: var(--nav-active-border); color: #fff; transition: filter .15s; }
  .btn-primary:hover  { filter: brightness(1.1); }
  .btn-secondary { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; cursor: pointer; background: var(--card-bg); border: 1px solid var(--border); color: var(--text-1); transition: background .15s; }
  .btn-secondary:hover { background: var(--nav-hover-bg); }
  .btn-ghost  { background: transparent; border: 1px solid var(--border); border-radius: 6px; padding: .35rem .75rem; font-size: .8rem; cursor: pointer; color: var(--text-2); transition: background .15s; }
  .btn-ghost:hover { background: var(--nav-hover-bg); }
  .btn-danger { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; border: none; cursor: pointer; background: var(--c-error-bg); color: var(--c-error); border: 1px solid var(--c-error-border); }
  .btn-sm { padding: .3rem .65rem !important; font-size: .8rem !important; }

  /* Modal */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .modal-overlay[hidden] { display: none; }
  .modal-box { background: var(--card-bg); border-radius: 10px; box-shadow: 0 8px 40px rgba(0,0,0,.18); width: 100%; max-width: 620px; max-height: 90vh; display: flex; flex-direction: column; }
  .modal-lg { max-width: 820px; }
  .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); }
  .modal-header h2 { font-size: 1.1rem; font-weight: 600; margin: 0; color: var(--text-1); }
  .modal-close { background: none; border: none; cursor: pointer; color: var(--text-2); padding: .25rem; border-radius: 4px; }
  .modal-close:hover { background: var(--nav-hover-bg); color: var(--text-1); }
  .modal-body { padding: 1.25rem 1.5rem; overflow-y: auto; flex: 1; }
  .modal-footer { padding: 1rem 1.5rem; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: flex-end; gap: .75rem; }

  /* Form */
  .form-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin-bottom: .75rem; }
  .form-group { display: flex; flex-direction: column; gap: .35rem; }
  .form-group--wide { grid-column: span 2; }
  .form-group label { font-size: .8rem; font-weight: 500; color: var(--text-2); }
  .form-group input, .form-group select { border: 1px solid var(--border); border-radius: 6px; padding: .5rem .75rem; font-size: .875rem; color: var(--text-1); background: var(--card-bg); outline: none; transition: border-color .15s; }
  .form-group input:focus, .form-group select:focus { border-color: var(--nav-active-border); }

  .form-section-title { display: flex; align-items: center; justify-content: space-between; margin: 1rem 0 .5rem; font-size: .85rem; font-weight: 600; color: var(--text-1); border-bottom: 1px solid var(--border); padding-bottom: .4rem; }

  /* Items */
  .items-container { display: flex; flex-direction: column; gap: .5rem; margin-bottom: .75rem; }
  .item-row { display: grid; grid-template-columns: 1fr .6fr .85fr auto; gap: .5rem; align-items: center; }
  .item-row select, .item-row input { border: 1px solid var(--border); border-radius: 6px; padding: .45rem .65rem; font-size: .85rem; color: var(--text-1); background: var(--card-bg); }
  .item-row input[type="number"] { text-align: right; }
  .btn-remove-item { background: none; border: none; cursor: pointer; color: var(--c-error); padding: .25rem .4rem; border-radius: 4px; font-size: 1.1rem; line-height: 1; }
  .btn-remove-item:hover { background: var(--c-error-bg); }

  /* Totals */
  .totals-row { background: var(--erp-bg); border-radius: 8px; padding: .75rem 1rem; margin-bottom: .75rem; }
  .total-line { display: flex; justify-content: space-between; align-items: center; padding: .25rem 0; font-size: .875rem; color: var(--text-2); }
  .total-line--bold { font-weight: 700; font-size: 1rem; color: var(--text-1); border-top: 1px solid var(--border); margin-top: .25rem; padding-top: .5rem; }
  .discount-input { width: 100px; border: 1px solid var(--border); border-radius: 5px; padding: .3rem .5rem; font-size: .85rem; background: var(--card-bg); }

  .form-error { color: var(--c-error); font-size: .85rem; margin-right: auto; }

  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4); border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Detail modal */
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem .75rem; margin-bottom: 1rem; }
  .detail-item { display: flex; flex-direction: column; gap: .15rem; }
  .detail-item .dl { font-size: .75rem; color: var(--text-2); }
  .detail-item .dv { font-size: .9rem; color: var(--text-1); font-weight: 500; }
  .detail-items-table { width: 100%; border-collapse: collapse; font-size: .85rem; margin-top: .5rem; }
  .detail-items-table th, .detail-items-table td { padding: .5rem .75rem; border-bottom: 1px solid var(--border); text-align: left; }
  .detail-items-table th { color: var(--text-2); font-size: .75rem; text-transform: uppercase; }

  /* Responsive */
  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .form-group--wide { grid-column: 1; }
    .item-row { grid-template-columns: 1fr 1fr; }
    .header-inner { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
    .filters-row { flex-direction: column; }
    .search-box { min-width: 0; width: 100%; }
  }
</style>

<script>
  // ── Estado ─────────────────────────────────────────────────
  let allProducts = [];
  let currentPage = 0;
  const PAGE_SIZE = 20;
  let currentFilters = {};
  let currentDetailId = null;

  const fmt = (n) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n);
  const fmtDate = (d) => d ? new Date(d + 'T12:00:00').toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';

  const CHANNEL_LABELS = {
    instagram: 'Instagram', whatsapp: 'WhatsApp', referido: 'Referido',
    tienda_fisica: 'Tienda Física', telefono: 'Teléfono', otro: 'Otro',
  };
  const STATUS_LABELS = { completada: 'Completada', pendiente: 'Pendiente', cancelada: 'Cancelada' };

  // ── Cargar productos para el selector ──────────────────────
  async function loadProducts() {
    try {
      const r = await fetch('/api/inventory/products?active=true', { credentials: 'include' });
      const data = await r.json();
      if (data.success) allProducts = data.products;
    } catch (_) {}
  }

  // ── Cargar y renderizar ventas ─────────────────────────────
  async function loadSales(page = 0) {
    currentPage = page;
    const params = new URLSearchParams({ limit: PAGE_SIZE, offset: page * PAGE_SIZE, ...currentFilters });
    try {
      const r = await fetch(`/api/external-sales?${params}`, { credentials: 'include' });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);

      renderStats(data.stats);
      renderTable(data.sales);
      renderPagination(data.total, page);
    } catch (err) {
      document.getElementById('salesBody').innerHTML =
        `<tr><td colspan="9" class="loading-row">Error al cargar ventas: ${err.message}</td></tr>`;
    }
  }

  function renderStats(stats) {
    const totalSales = stats.reduce((s, r) => s + Number(r.total_sales), 0);
    const totalRevenue = stats.reduce((s, r) => s + Number(r.total_revenue), 0);
    const topChannel = stats[0];

    document.getElementById('statTotal').textContent = totalSales;
    document.getElementById('statRevenue').textContent = fmt(totalRevenue);

    // Ventas de este mes
    const now = new Date();
    const y = now.getFullYear(), m = String(now.getMonth() + 1).padStart(2, '0');
    fetch(`/api/external-sales?limit=1&from=${y}-${m}-01&to=${y}-${m}-31`, { credentials: 'include' })
      .then(r => r.json())
      .then(d => { document.getElementById('statMonth').textContent = d.total ?? '—'; });

    document.getElementById('statTopChannel').textContent = topChannel
      ? `${CHANNEL_LABELS[topChannel.channel] || topChannel.channel} (${topChannel.total_sales})`
      : '—';
  }

  function renderTable(sales) {
    const tbody = document.getElementById('salesBody');
    if (!sales.length) {
      tbody.innerHTML = '<tr><td colspan="9" class="loading-row">No hay ventas registradas.</td></tr>';
      return;
    }
    tbody.innerHTML = sales.map(s => `
      <tr>
        <td><strong>${s.sale_number}</strong></td>
        <td>${fmtDate(s.sale_date)}</td>
        <td><span class="badge badge-channel-${s.channel}">${CHANNEL_LABELS[s.channel] || s.channel}</span></td>
        <td>${s.customer_name || '—'}</td>
        <td>${s.customer_city || '—'}</td>
        <td style="color:var(--text-2); font-size:.8rem;">${s.channel_detail || '—'}</td>
        <td class="text-right"><strong>${fmt(s.total)}</strong></td>
        <td><span class="badge badge-${s.status}">${STATUS_LABELS[s.status] || s.status}</span></td>
        <td>
          <button class="action-btn" onclick="openDetail(${s.id})">Ver</button>
        </td>
      </tr>
    `).join('');
  }

  function renderPagination(total, page) {
    const pages = Math.ceil(total / PAGE_SIZE);
    const el = document.getElementById('pagination');
    if (pages <= 1) { el.innerHTML = `<span>${total} registros</span>`; return; }
    el.innerHTML = `
      <span>${total} registros</span>
      <button class="btn-ghost btn-sm" onclick="loadSales(${page - 1})" ${page === 0 ? 'disabled' : ''}>‹ Anterior</button>
      <span>Pág. ${page + 1} / ${pages}</span>
      <button class="btn-ghost btn-sm" onclick="loadSales(${page + 1})" ${page >= pages - 1 ? 'disabled' : ''}>Siguiente ›</button>
    `;
  }

  // ── Items dinámicos en el formulario ──────────────────────
  function buildProductOptions(selectedId = '') {
    return `<option value="">Seleccionar producto…</option>` +
      allProducts.map(p => `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>
        ${p.name} (Stock: ${p.stock_quantity ?? 0})
      </option>`).join('');
  }

  function addItemRow() {
    const container = document.getElementById('itemsContainer');
    const idx = container.children.length;
    const row = document.createElement('div');
    row.className = 'item-row';
    row.dataset.idx = idx;
    row.innerHTML = `
      <select class="item-product" onchange="recalcTotals()">${buildProductOptions()}</select>
      <input type="number" class="item-qty" min="1" value="1" placeholder="Cant." onchange="recalcTotals()" oninput="recalcTotals()" />
      <input type="number" class="item-price" min="0" value="0" placeholder="Precio unit. COP" onchange="recalcTotals()" oninput="recalcTotals()" />
      <button type="button" class="btn-remove-item" onclick="removeItemRow(this)" title="Quitar">×</button>
    `;
    container.appendChild(row);
    recalcTotals();
  }

  window.removeItemRow = (btn) => {
    btn.closest('.item-row').remove();
    recalcTotals();
  };

  function recalcTotals() {
    const rows = document.querySelectorAll('.item-row');
    let subtotal = 0;
    rows.forEach(row => {
      const qty = Number(row.querySelector('.item-qty')?.value || 0);
      const price = Number(row.querySelector('.item-price')?.value || 0);
      subtotal += qty * price;
    });
    const discount = Number(document.getElementById('fDiscount')?.value || 0);
    const total = Math.max(0, subtotal - discount);
    document.getElementById('tSubtotal').textContent = fmt(subtotal);
    document.getElementById('tDiscount').textContent = `−${fmt(discount)}`;
    document.getElementById('tTotal').textContent = fmt(total);
  }

  // ── Abrir / cerrar modal de nueva venta ───────────────────
  function openNewSaleModal() {
    const modal = document.getElementById('modalNewSale');
    document.getElementById('formNewSale').reset();
    document.getElementById('itemsContainer').innerHTML = '';
    document.getElementById('fSaleDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('formError').hidden = true;
    addItemRow();
    recalcTotals();
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeNewSaleModal() {
    document.getElementById('modalNewSale').hidden = true;
    document.body.style.overflow = '';
  }

  // ── Enviar formulario ──────────────────────────────────────
  document.getElementById('formNewSale').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = document.getElementById('formError');
    errEl.hidden = true;

    const rows = document.querySelectorAll('.item-row');
    const items = [];
    for (const row of rows) {
      const product_id = row.querySelector('.item-product').value;
      const quantity = Number(row.querySelector('.item-qty').value);
      const unit_price = Number(row.querySelector('.item-price').value);
      if (!product_id || quantity < 1) {
        errEl.textContent = 'Completa todos los campos de productos (producto y cantidad).';
        errEl.hidden = false;
        return;
      }
      items.push({ product_id, quantity, unit_price });
    }

    if (!items.length) {
      errEl.textContent = 'Agrega al menos un producto.';
      errEl.hidden = false;
      return;
    }

    const payload = {
      channel: document.getElementById('fChannel').value,
      channel_detail: document.getElementById('fChannelDetail').value,
      customer_name: document.getElementById('fCustomerName').value,
      customer_contact: document.getElementById('fCustomerContact').value,
      customer_city: document.getElementById('fCustomerCity').value,
      sale_date: document.getElementById('fSaleDate').value,
      discount: Number(document.getElementById('fDiscount').value || 0),
      notes: document.getElementById('fNotes').value,
      status: document.getElementById('fStatus').value,
      items,
    };

    const btnText = document.getElementById('btnSubmitText');
    const btnSpinner = document.getElementById('btnSubmitSpinner');
    const btnSubmit = document.getElementById('btnSubmit');
    btnText.hidden = true;
    btnSpinner.hidden = false;
    btnSubmit.disabled = true;

    try {
      const r = await fetch('/api/external-sales', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
      const data = await r.json();

      if (!data.success) {
        const msg = data.errors ? data.errors.map(e => e.msg).join(', ') : (data.error || 'Error desconocido');
        errEl.textContent = msg;
        errEl.hidden = false;
        return;
      }

      closeNewSaleModal();
      loadSales(0);
    } catch (err) {
      errEl.textContent = 'Error de conexión. Intenta de nuevo.';
      errEl.hidden = false;
    } finally {
      btnText.hidden = false;
      btnSpinner.hidden = true;
      btnSubmit.disabled = false;
    }
  });

  // ── Detalle de venta ───────────────────────────────────────
  window.openDetail = async (id) => {
    currentDetailId = id;
    const modal = document.getElementById('modalDetail');
    const body = document.getElementById('detailBody');
    const btnCancel = document.getElementById('btnCancelSale');
    body.innerHTML = '<div class="loading-row">Cargando…</div>';
    btnCancel.hidden = true;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';

    try {
      const r = await fetch(`/api/external-sales/${id}`, { credentials: 'include' });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);

      const { sale, items } = data;
      document.getElementById('detailTitle').textContent = `Venta ${sale.sale_number}`;

      body.innerHTML = `
        <div class="detail-grid">
          <div class="detail-item"><span class="dl">Número</span><span class="dv">${sale.sale_number}</span></div>
          <div class="detail-item"><span class="dl">Fecha</span><span class="dv">${fmtDate(sale.sale_date)}</span></div>
          <div class="detail-item"><span class="dl">Canal</span><span class="dv">${CHANNEL_LABELS[sale.channel] || sale.channel}${sale.channel_detail ? ` — ${sale.channel_detail}` : ''}</span></div>
          <div class="detail-item"><span class="dl">Estado</span><span class="dv"><span class="badge badge-${sale.status}">${STATUS_LABELS[sale.status]}</span></span></div>
          <div class="detail-item"><span class="dl">Cliente</span><span class="dv">${sale.customer_name || '—'}</span></div>
          <div class="detail-item"><span class="dl">Contacto</span><span class="dv">${sale.customer_contact || '—'}</span></div>
          <div class="detail-item"><span class="dl">Ciudad</span><span class="dv">${sale.customer_city || '—'}</span></div>
          <div class="detail-item"><span class="dl">Registrado por</span><span class="dv">${sale.registered_by_name || '—'}</span></div>
          ${sale.notes ? `<div class="detail-item" style="grid-column:span 2"><span class="dl">Notas</span><span class="dv">${sale.notes}</span></div>` : ''}
        </div>
        <table class="detail-items-table">
          <thead><tr><th>Producto</th><th>SKU</th><th>Lote</th><th style="text-align:right">Cant.</th><th style="text-align:right">Precio unit.</th><th style="text-align:right">Subtotal</th></tr></thead>
          <tbody>
            ${items.map(it => `
              <tr>
                <td>${it.product_name}</td>
                <td style="color:var(--text-2)">${it.sku || '—'}</td>
                <td style="color:var(--text-2)">${it.lot_code || '—'}</td>
                <td style="text-align:right">${it.quantity}</td>
                <td style="text-align:right">${fmt(it.unit_price)}</td>
                <td style="text-align:right"><strong>${fmt(it.subtotal)}</strong></td>
              </tr>
            `).join('')}
          </tbody>
          <tfoot>
            <tr><td colspan="5" style="text-align:right;font-weight:600;padding:.6rem .75rem;">Descuento</td><td style="text-align:right;padding:.6rem .75rem">−${fmt(sale.discount)}</td></tr>
            <tr><td colspan="5" style="text-align:right;font-weight:700;font-size:1rem;padding:.6rem .75rem;">Total</td><td style="text-align:right;font-weight:700;font-size:1rem;padding:.6rem .75rem">${fmt(sale.total)}</td></tr>
          </tfoot>
        </table>
      `;

      if (sale.status !== 'cancelada') {
        btnCancel.hidden = false;
      }
    } catch (err) {
      body.innerHTML = `<div class="loading-row">Error: ${err.message}</div>`;
    }
  };

  document.getElementById('btnCancelSale').addEventListener('click', async () => {
    if (!currentDetailId) return;
    if (!confirm('¿Confirmas cancelar esta venta? Se revertirá el ajuste de inventario.')) return;

    try {
      const r = await fetch(`/api/external-sales/${currentDetailId}/cancel`, {
        method: 'PUT',
        credentials: 'include',
      });
      const data = await r.json();
      if (!data.success) throw new Error(data.error);
      document.getElementById('modalDetail').hidden = true;
      document.body.style.overflow = '';
      loadSales(currentPage);
    } catch (err) {
      alert('Error al cancelar: ' + err.message);
    }
  });

  // ── Filtros ────────────────────────────────────────────────
  document.getElementById('btnApplyFilters').addEventListener('click', () => {
    currentFilters = {};
    const search = document.getElementById('filterSearch').value.trim();
    const channel = document.getElementById('filterChannel').value;
    const status = document.getElementById('filterStatus').value;
    const from = document.getElementById('filterFrom').value;
    const to = document.getElementById('filterTo').value;
    if (search)  currentFilters.search = search;
    if (channel) currentFilters.channel = channel;
    if (status)  currentFilters.status = status;
    if (from)    currentFilters.from = from;
    if (to)      currentFilters.to = to;
    loadSales(0);
  });

  document.getElementById('btnClearFilters').addEventListener('click', () => {
    document.getElementById('filterSearch').value = '';
    document.getElementById('filterChannel').value = '';
    document.getElementById('filterStatus').value = '';
    document.getElementById('filterFrom').value = '';
    document.getElementById('filterTo').value = '';
    currentFilters = {};
    loadSales(0);
  });

  // ── Eventos de UI ──────────────────────────────────────────
  document.getElementById('btnNewSale').addEventListener('click', openNewSaleModal);
  document.getElementById('btnCloseModal').addEventListener('click', closeNewSaleModal);
  document.getElementById('btnCancelForm').addEventListener('click', closeNewSaleModal);
  document.getElementById('btnCloseDetail').addEventListener('click', () => {
    document.getElementById('modalDetail').hidden = true;
    document.body.style.overflow = '';
  });
  document.getElementById('btnCloseDetail2').addEventListener('click', () => {
    document.getElementById('modalDetail').hidden = true;
    document.body.style.overflow = '';
  });
  document.getElementById('btnAddItem').addEventListener('click', addItemRow);
  document.getElementById('fDiscount').addEventListener('input', recalcTotals);

  // Cerrar modales al hacer click fuera
  document.getElementById('modalNewSale').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeNewSaleModal();
  });
  document.getElementById('modalDetail').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      e.currentTarget.hidden = true;
      document.body.style.overflow = '';
    }
  });

  // ── Init ───────────────────────────────────────────────────
  (async () => {
    await loadProducts();
    await loadSales(0);
  })();
</script>
</AdminLayout>
