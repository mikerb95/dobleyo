---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Almacén de Café Tostado — DobleYo">
  <!-- ── Encabezado de página ──────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">Producción · Logística de bodega</div>
        <h1 class="page-title">Almacén de Café Tostado</h1>
        <p class="page-subtitle">
          Colocación en stock, ubicaciones y existencias del café tostado listo para empacar.
        </p>
      </div>
      <div class="page-header-actions">
        <button type="button" class="btn btn-secondary" id="refreshBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          Actualizar
        </button>
      </div>
    </div>
  </div>

  <div class="erp-body rs-page">

    <!-- ── KPIs ───────────────────────────────────────────────────────── -->
    <div class="kpi-grid" id="rsKpis" style="margin-bottom: 22px;">
      <div class="kpi-tile warning">
        <div class="kpi-label">Pendiente por ubicar</div>
        <div class="kpi-value" id="kpiPending">—</div>
        <div class="kpi-sub" id="kpiPendingKg">—</div>
      </div>
      <div class="kpi-tile brand">
        <div class="kpi-label">Lotes en bodega</div>
        <div class="kpi-value" id="kpiStock">—</div>
        <div class="kpi-sub" id="kpiStockLoc">—</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Peso almacenado</div>
        <div class="kpi-value" id="kpiWeight">—</div>
        <div class="kpi-sub">Café tostado en stock</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Ubicaciones ocupadas</div>
        <div class="kpi-value" id="kpiLocations">—</div>
        <div class="kpi-sub">De 6 disponibles</div>
      </div>
    </div>

    <!-- ── Workbench: worklist + formulario de entrada ─────────────────── -->
    <div class="rs-workbench">

      <!-- Worklist: pendiente de ubicación -->
      <section class="card rs-worklist">
        <div class="card-header">
          <div>
            <h3 class="card-title">Pendiente de ubicación</h3>
            <div class="card-subtitle">Mercancía tostada por colocar</div>
          </div>
          <span class="rs-count-badge" id="worklistCount">0</span>
        </div>
        <div class="rs-search">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="search" id="worklistSearch" placeholder="Buscar por lote o variedad…" />
        </div>
        <div class="rs-worklist-body" id="worklistBody">
          <div class="rs-skeleton-list">
            <div class="rs-skel-row"></div><div class="rs-skel-row"></div><div class="rs-skel-row"></div>
          </div>
        </div>
      </section>

      <!-- Panel de entrada (put-away) -->
      <section class="card rs-putaway">
        <div class="card-header">
          <div>
            <h3 class="card-title">Registro de entrada a bodega</h3>
            <div class="card-subtitle">Colocación del lote seleccionado en stock</div>
          </div>
          <span class="rs-step-flag" id="putawayFlag" hidden>
            <span class="rs-dot"></span> En curso
          </span>
        </div>

        <!-- Estado vacío -->
        <div class="rs-empty-panel" id="putawayEmpty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
          <p><b>Seleccione un lote</b><br/>Elija una entrada de la lista «Pendiente de ubicación» para iniciar la colocación en stock.</p>
        </div>

        <!-- Formulario -->
        <form id="roastedStorageForm" hidden>
          <!-- Facet: mercancía seleccionada -->
          <div class="rs-facet">
            <div class="rs-facet-head">
              <span class="rs-facet-lot" id="facetLot">—</span>
              <span class="rs-roast-badge" id="facetRoast">—</span>
            </div>
            <div class="rs-facet-grid">
              <div><span class="rs-k">Variedad</span><span class="rs-v" id="facetVariety">—</span></div>
              <div><span class="rs-k">Origen</span><span class="rs-v" id="facetRegion">—</span></div>
              <div><span class="rs-k">Peso tostado</span><span class="rs-v rs-accent" id="facetWeight">—</span></div>
              <div><span class="rs-k">Pérdida de tueste</span><span class="rs-v" id="facetLoss">—</span></div>
              <div><span class="rs-k">Temp. final</span><span class="rs-v" id="facetTemp">—</span></div>
              <div><span class="rs-k">Tiempo</span><span class="rs-v" id="facetTime">—</span></div>
            </div>
          </div>

          <!-- Sección: ubicación -->
          <div class="rs-section">
            <div class="rs-section-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Ubicación de destino
            </div>
            <div class="form-grid">
              <div class="form-group" style="margin-bottom:0;">
                <label for="location">Ubicación en bodega <span class="required">*</span></label>
                <select id="location" name="location" required>
                  <option value="">Seleccione una ubicación…</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom:0;">
                <label for="storageDate">Fecha de entrada</label>
                <input type="date" id="storageDate" name="storageDate" disabled />
                <div class="form-hint">Se registra con la fecha actual.</div>
              </div>
            </div>
          </div>

          <!-- Sección: empaque y distribución -->
          <div class="rs-section">
            <div class="rs-section-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              Empaque y distribución
            </div>
            <div class="form-grid">
              <div class="form-group" style="margin-bottom:0;">
                <label for="container">Tipo de contenedor <span class="required">*</span></label>
                <select id="container" name="container" required>
                  <option value="">Seleccione un contenedor…</option>
                  <option value="BAG-1KG">Bolsa 1 kg (para empaque)</option>
                  <option value="BAG-5KG">Bolsa 5 kg (almacenamiento)</option>
                  <option value="BUCKET-25">Cubeta 25 kg</option>
                  <option value="SACK-60">Saco 60 kg</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom:0;">
                <label for="containerCount">Cantidad de contenedores <span class="required">*</span></label>
                <div class="cup-stepper">
                  <button type="button" class="cup-stepper-btn" data-step="-1" data-target="containerCount" aria-label="Restar">−</button>
                  <input type="number" id="containerCount" name="containerCount" min="1" max="999" step="1" placeholder="0" />
                  <button type="button" class="cup-stepper-btn" data-step="1" data-target="containerCount" aria-label="Sumar">+</button>
                </div>
              </div>
            </div>

            <!-- Distribución y capacidad -->
            <div class="rs-capacity" id="capacityBox" hidden>
              <div class="rs-capacity-head">
                <span>Ocupación de capacidad</span>
                <span class="rs-capacity-pct" id="capacityPct">—</span>
              </div>
              <div class="rs-capacity-bar"><span class="rs-capacity-fill" id="capacityFill"></span></div>
              <div class="rs-capacity-meta">
                <span>Carga: <b id="capLoad">— kg</b></span>
                <span>Capacidad: <b id="capTotal">— kg</b></span>
                <span>Por contenedor: <b id="capPer">— kg</b></span>
              </div>
              <div class="rs-capacity-warn" id="capacityWarn" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                La capacidad seleccionada no alcanza para el peso del lote.
              </div>
            </div>
          </div>

          <!-- Sección: condiciones -->
          <div class="rs-section">
            <div class="rs-section-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Condiciones de almacenamiento
            </div>
            <div class="checkbox-group">
              <label class="checkbox-item">
                <input type="checkbox" name="conditions" value="sealed" />
                <span>Sellado hermético</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="conditions" value="cool" />
                <span>Lugar fresco y seco</span>
              </label>
              <label class="checkbox-item">
                <input type="checkbox" name="conditions" value="dark" />
                <span>Protegido de luz directa</span>
              </label>
            </div>
          </div>

          <!-- Sección: notas -->
          <div class="rs-section">
            <div class="form-group" style="margin-bottom:0;">
              <label for="notes">Notas (opcional)</label>
              <textarea id="notes" name="notes" rows="2" placeholder="Ej.: lotes separados por variedad, clima controlado…"></textarea>
            </div>
          </div>

          <!-- Footer: resumen + acciones -->
          <div class="rs-form-footer">
            <div class="rs-summary" id="summaryBox">
              <span class="rs-summary-k">Resumen</span>
              <span class="rs-summary-line" id="summaryLine">Complete la ubicación y el empaque para confirmar.</span>
            </div>
            <div class="rs-actions">
              <button type="button" class="btn btn-secondary" id="clearBtn">Cancelar</button>
              <button type="submit" class="btn btn-save" id="submitBtn" disabled>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                Confirmar entrada
              </button>
            </div>
          </div>
        </form>
      </section>
    </div>

    <!-- ── Mapa de ocupación de ubicaciones ───────────────────────────── -->
    <section class="card" style="margin-top: 24px;">
      <div class="card-header">
        <div>
          <h3 class="card-title">Ocupación de ubicaciones</h3>
          <div class="card-subtitle">Existencias por sección de bodega</div>
        </div>
      </div>
      <div class="rs-bins" id="binsGrid"></div>
    </section>

    <!-- ── Existencias en bodega ──────────────────────────────────────── -->
    <section class="card" style="margin-top: 24px;">
      <div class="card-header">
        <div>
          <h3 class="card-title">Existencias en bodega</h3>
          <div class="card-subtitle">Café tostado almacenado, listo para empaque</div>
        </div>
        <span class="rs-count-badge" id="stockCount">0</span>
      </div>
      <div class="table-wrapper">
        <table class="erp-table rs-stock-table">
          <thead>
            <tr>
              <th>Ubicación</th>
              <th>Lote</th>
              <th>Variedad</th>
              <th>Tueste</th>
              <th>Empaque</th>
              <th style="text-align:right;">Peso</th>
              <th>Estado</th>
              <th style="text-align:right;">Acciones</th>
            </tr>
          </thead>
          <tbody id="stockBody">
            <tr><td colspan="8" class="empty-state">Cargando existencias…</td></tr>
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <!-- Toast -->
  <div class="rs-toast" id="rsToast" role="status" aria-live="polite"></div>

  <style is:global>
    /* =================================================================
       Almacén de Café Tostado — workbench logístico (Claude Design)
       ============================================================== */
    .rs-page { max-width: 1320px; }

    /* Stepper (compartido con cupping) */
    .cup-stepper {
      display: inline-flex; align-items: stretch;
      border: 1px solid var(--rule); border-radius: var(--radius-sm);
      overflow: hidden; width: 100%; max-width: 200px;
    }
    .cup-stepper-btn {
      appearance: none; border: 0; background: var(--paper);
      width: 42px; font-size: 18px; font-weight: 600; line-height: 1;
      color: var(--color-primary); cursor: pointer;
    }
    .cup-stepper-btn:hover { background: var(--hover); }
    .cup-stepper input {
      border: 0 !important; border-radius: 0 !important;
      text-align: center; flex: 1; min-width: 0; -moz-appearance: textfield;
    }
    .cup-stepper input::-webkit-outer-spin-button,
    .cup-stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .cup-stepper input:focus { box-shadow: none !important; }

    /* ===== Workbench ===== */
    .rs-workbench {
      display: grid;
      grid-template-columns: 380px minmax(0, 1fr);
      gap: 22px;
      align-items: start;
    }
    @media (max-width: 1080px) {
      .rs-workbench { grid-template-columns: 1fr; }
    }

    .rs-count-badge {
      font-size: 12px; font-weight: 700;
      color: var(--color-primary); background: var(--active-bg);
      border-radius: 999px; padding: 3px 11px;
      font-variant-numeric: tabular-nums;
    }

    /* ===== Worklist ===== */
    .rs-worklist { position: sticky; top: calc(var(--shell-h) + 18px); }
    @media (max-width: 1080px) { .rs-worklist { position: static; } }

    .rs-search {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 14px; border-bottom: 1px solid var(--rule);
      color: var(--muted);
    }
    .rs-search input {
      border: 0 !important; padding: 2px 0 !important; background: transparent !important;
      font-size: 13px; flex: 1; box-shadow: none !important;
    }
    .rs-worklist-body { max-height: 520px; overflow-y: auto; padding: 8px; }

    .rs-wl-item {
      display: grid; grid-template-columns: 1fr auto; gap: 4px 10px;
      padding: 11px 12px; border-radius: var(--radius-sm);
      border: 1px solid transparent; cursor: pointer;
      transition: background .12s, border-color .12s;
    }
    .rs-wl-item:hover { background: var(--hover); }
    .rs-wl-item.active {
      background: var(--active-bg); border-color: var(--color-accent);
    }
    .rs-wl-item.active::before { display: none; }
    .rs-wl-lot {
      font-family: ui-monospace, Menlo, monospace; font-weight: 600;
      font-size: 13px; color: var(--color-primary);
    }
    .rs-wl-weight {
      font-size: 13px; font-weight: 700; color: var(--color-accent);
      font-variant-numeric: tabular-nums; text-align: right;
    }
    .rs-wl-sub { font-size: 11.5px; color: var(--muted); }
    .rs-wl-meta { display: flex; align-items: center; gap: 6px; justify-self: end; }

    .rs-roast-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
    .rs-roast-light  { background: #d9a441; }
    .rs-roast-medium { background: #a9683b; }
    .rs-roast-dark   { background: #5a3420; }

    /* Skeleton */
    .rs-skeleton-list { display: grid; gap: 8px; padding: 4px; }
    .rs-skel-row {
      height: 52px; border-radius: var(--radius-sm);
      background: linear-gradient(90deg,
        color-mix(in oklab, var(--color-primary) 5%, white) 0%,
        color-mix(in oklab, var(--color-primary) 11%, white) 50%,
        color-mix(in oklab, var(--color-primary) 5%, white) 100%);
      background-size: 200% 100%; animation: shimmer 1.4s linear infinite;
    }

    /* ===== Panel de entrada ===== */
    .rs-step-flag {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 11.5px; font-weight: 600; color: var(--color-accent);
      background: var(--active-bg); padding: 4px 11px; border-radius: 999px;
    }
    .rs-step-flag .rs-dot {
      width: 7px; height: 7px; border-radius: 50%; background: var(--color-accent);
      animation: rs-pulse 1.6s ease-in-out infinite;
    }
    @keyframes rs-pulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }

    .rs-empty-panel {
      display: grid; justify-items: center; gap: 14px; text-align: center;
      padding: 56px 24px; color: var(--muted);
    }
    .rs-empty-panel svg { color: var(--rule-2); }
    .rs-empty-panel b { color: var(--color-primary); }
    .rs-empty-panel p { font-size: 13.5px; line-height: 1.6; margin: 0; max-width: 320px; }

    #roastedStorageForm { padding: 18px; }

    /* Facet de mercancía */
    .rs-facet {
      background: color-mix(in oklab, var(--color-primary) 3.5%, white);
      border: 1px solid var(--rule); border-radius: var(--radius);
      padding: 14px 16px; margin-bottom: 18px;
    }
    .rs-facet-head {
      display: flex; align-items: center; justify-content: space-between;
      gap: 10px; padding-bottom: 12px; margin-bottom: 12px;
      border-bottom: 1px dashed var(--rule);
    }
    .rs-facet-lot {
      font-family: ui-monospace, Menlo, monospace; font-weight: 700;
      font-size: 16px; color: var(--color-primary);
    }
    .rs-roast-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11.5px; font-weight: 600; padding: 4px 11px;
      border-radius: 999px; background: var(--paper); border: 1px solid var(--rule);
      color: var(--color-primary);
    }
    .rs-facet-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px 16px;
    }
    @media (max-width: 540px) { .rs-facet-grid { grid-template-columns: repeat(2, 1fr); } }
    .rs-facet-grid > div { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    .rs-k {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted-2);
    }
    .rs-v {
      font-size: 13.5px; font-weight: 600; color: var(--color-primary);
      font-variant-numeric: tabular-nums;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .rs-accent { color: var(--color-accent); }

    /* Secciones de formulario */
    .rs-section {
      padding: 16px 0; border-top: 1px solid var(--rule);
    }
    .rs-section:first-of-type { border-top: 0; padding-top: 0; }
    .rs-section-title {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; font-weight: 700; color: var(--color-primary);
      text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px;
    }
    .rs-section-title svg { color: var(--color-accent); }

    /* Capacidad */
    .rs-capacity {
      margin-top: 16px; padding: 14px 16px;
      background: color-mix(in oklab, var(--color-primary) 3%, white);
      border: 1px solid var(--rule); border-radius: var(--radius-sm);
    }
    .rs-capacity-head {
      display: flex; justify-content: space-between; align-items: baseline;
      font-size: 12px; font-weight: 600; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;
    }
    .rs-capacity-pct { font-size: 15px; font-weight: 700; color: var(--color-primary); }
    .rs-capacity-bar {
      height: 9px; border-radius: 999px; background: var(--rule); overflow: hidden;
    }
    .rs-capacity-fill {
      display: block; height: 100%; border-radius: 999px;
      background: var(--color-accent); width: 0%; transition: width .3s, background .3s;
    }
    .rs-capacity.over .rs-capacity-fill { background: var(--danger); }
    .rs-capacity-meta {
      display: flex; flex-wrap: wrap; gap: 4px 18px; margin-top: 10px;
      font-size: 12px; color: var(--muted);
    }
    .rs-capacity-meta b { color: var(--color-primary); font-variant-numeric: tabular-nums; }
    .rs-capacity-warn {
      display: flex; align-items: center; gap: 8px; margin-top: 10px;
      font-size: 12.5px; font-weight: 500; color: var(--danger);
    }

    /* Footer */
    .rs-form-footer {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap; margin-top: 18px; padding-top: 16px;
      border-top: 1px solid var(--rule);
    }
    .rs-summary { display: grid; gap: 2px; min-width: 0; flex: 1; }
    .rs-summary-k {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--muted-2);
    }
    .rs-summary-line { font-size: 13px; color: var(--color-primary); font-weight: 500; }
    .rs-actions { display: flex; gap: 8px; }
    #submitBtn:disabled { opacity: .5; cursor: not-allowed; }

    /* ===== Bins ===== */
    .rs-bins {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 14px; padding: 18px;
    }
    .rs-bin {
      border: 1px solid var(--rule); border-radius: var(--radius);
      padding: 14px; background: var(--paper);
      display: grid; gap: 10px;
    }
    .rs-bin.filled { border-color: color-mix(in oklab, var(--color-accent) 40%, white); }
    .rs-bin-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .rs-bin-zone { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .rs-bin-code {
      font-family: ui-monospace, Menlo, monospace; font-weight: 700;
      font-size: 13px; color: var(--color-primary);
    }
    .rs-bin-icon {
      width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
      display: grid; place-items: center;
      background: var(--hover); color: var(--muted);
    }
    .rs-bin.filled .rs-bin-icon { background: var(--active-bg); color: var(--color-accent); }
    .rs-bin-stat { display: flex; align-items: baseline; gap: 6px; }
    .rs-bin-kg {
      font-size: 22px; font-weight: 700; color: var(--color-primary);
      font-variant-numeric: tabular-nums; line-height: 1;
    }
    .rs-bin-unit { font-size: 12px; color: var(--muted); }
    .rs-bin-lots { font-size: 11.5px; color: var(--muted); }
    .rs-bin-bar { height: 5px; border-radius: 999px; background: var(--rule); overflow: hidden; }
    .rs-bin-bar > span { display: block; height: 100%; background: var(--color-accent); border-radius: 999px; }

    /* ===== Stock table ===== */
    .rs-stock-table td { vertical-align: middle; }
    .rs-stock-loc {
      font-family: ui-monospace, Menlo, monospace; font-weight: 600;
      font-size: 12px; color: var(--color-primary);
    }
    .rs-stock-weight {
      font-weight: 700; color: var(--color-accent); text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .rs-row-btn {
      appearance: none; border: 1px solid var(--rule); background: var(--paper);
      width: 30px; height: 30px; border-radius: 8px; cursor: pointer;
      display: inline-grid; place-items: center; color: var(--muted);
    }
    .rs-row-btn:hover { background: var(--hover); color: var(--color-primary); }
    .rs-row-btn.danger:hover { color: var(--danger); border-color: color-mix(in oklab, var(--danger) 40%, white); }

    /* ===== Toast ===== */
    .rs-toast {
      position: fixed; bottom: 24px; left: 50%; transform: translate(-50%, 20px);
      background: var(--color-primary); color: #fff;
      padding: 12px 20px; border-radius: 999px;
      font-size: 13.5px; font-weight: 500;
      box-shadow: 0 12px 32px -8px color-mix(in oklab, var(--color-primary) 60%, transparent);
      opacity: 0; visibility: hidden; transition: all .25s ease; z-index: 60;
      display: flex; align-items: center; gap: 9px;
    }
    .rs-toast.show { opacity: 1; visibility: visible; transform: translate(-50%, 0); }
    .rs-toast.ok { background: var(--ok); }
    .rs-toast.err { background: var(--danger); }
  </style>

  <script>
    // ── Configuración ───────────────────────────────────────────────────────────
    const CONTAINER_SIZE = { 'BAG-1KG': 1, 'BAG-5KG': 5, 'BUCKET-25': 25, 'SACK-60': 60 };
    // Las ubicaciones vienen del maestro (/admin/ubicaciones), no de una lista
    // fija: la ocupación y la capacidad las calcula el servidor.
    let LOCATIONS = [];
    let LOC_BY_CODE = {};

    async function loadLocations() {
      try {
        const res = await fetch('/api/storage/locations?state=roasted&include_blocked=0', { credentials: 'include' });
        const json = await res.json();
        if (!res.ok || !json.success) throw new Error(json.error || 'Error');
        LOCATIONS = json.data.map((l) => ({
          code: l.code, zone: l.zone_name, label: l.name,
          capacityKg: l.capacity_kg, occupiedKg: l.occupied_kg,
          fillPct: l.fill_pct, lotCount: l.lot_count,
        }));
      } catch (e) {
        LOCATIONS = [];
        toast('No se pudieron cargar las ubicaciones de bodega.', 'err');
      }
      LOC_BY_CODE = Object.fromEntries(LOCATIONS.map((l) => [l.code, l]));
      renderLocationSelect();
    }

    function renderLocationSelect() {
      const sel = $('location');
      const prev = sel.value;
      sel.innerHTML = '<option value="">Seleccione una ubicación</option>';
      const zones = [...new Set(LOCATIONS.map((l) => l.zone))];
      zones.forEach((z) => {
        const og = document.createElement('optgroup');
        og.label = z;
        LOCATIONS.filter((l) => l.zone === z).forEach((l) => {
          const o = document.createElement('option');
          o.value = l.code;
          const libre = l.capacityKg != null
            ? ` — ${kg(Math.max(0, l.capacityKg - l.occupiedKg))} libres`
            : '';
          o.textContent = `${l.label} (${l.code})${libre}`;
          og.appendChild(o);
        });
        sel.appendChild(og);
      });
      if (prev && LOC_BY_CODE[prev]) sel.value = prev;
    }

    const roastLabel = (r) => ({ LIGHT: 'Clara', MEDIUM: 'Media', DARK: 'Oscura' }[r] || r || '—');
    const roastDotClass = (r) => ({ LIGHT: 'rs-roast-light', MEDIUM: 'rs-roast-medium', DARK: 'rs-roast-dark' }[r] || 'rs-roast-medium');
    const kg = (n) => (Number(n) || 0).toLocaleString('es-CO', { maximumFractionDigits: 2 }) + ' kg';

    // ── Estado ───────────────────────────────────────────────────────────────────
    let pending = [];     // mercancía por ubicar
    let stock = [];       // existencias en bodega
    let current = null;   // lote seleccionado

    // ── Elementos ──────────────────────────────────────────────────────────────────
    const $ = (id) => document.getElementById(id);
    const form = $('roastedStorageForm');
    const today = new Date().toISOString().split('T')[0];
    $('storageDate').value = today;

    // ── Toast ───────────────────────────────────────────────────────────────────────
    let toastTimer;
    function toast(msg, type = '') {
      const t = $('rsToast');
      t.textContent = msg;
      t.className = 'rs-toast show ' + type;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { t.className = 'rs-toast ' + type; }, 3200);
    }

    // ── Carga de datos ────────────────────────────────────────────────────────────
    async function loadAll() {
      try {
        const [pRes, sRes] = await Promise.all([
          fetch('/api/coffee/roasted-for-storage', { credentials: 'include' }),
          fetch('/api/coffee/roasted-coffee', { credentials: 'include' }),
        ]);
        pending = pRes.ok ? await pRes.json() : [];
        stock = sRes.ok ? await sRes.json() : [];
      } catch (e) {
        pending = []; stock = [];
        toast('No se pudieron cargar los datos de bodega.', 'err');
      }
      if (!Array.isArray(pending)) pending = [];
      if (!Array.isArray(stock)) stock = [];
      renderKpis();
      renderWorklist();
      renderBins();
      renderStock();
    }

    // ── KPIs ───────────────────────────────────────────────────────────────────────
    function renderKpis() {
      const pendKg = pending.reduce((a, r) => a + (Number(r.weight_kg) || 0), 0);
      const stockKg = stock.reduce((a, r) => a + (Number(r.weight_kg) || 0), 0);
      const usedLocs = new Set(stock.map((r) => r.location).filter(Boolean));
      $('kpiPending').textContent = pending.length;
      $('kpiPendingKg').textContent = pending.length ? kg(pendKg) + ' por ubicar' : 'Todo ubicado';
      $('kpiStock').textContent = stock.length;
      $('kpiStockLoc').textContent = `En ${usedLocs.size} ubicación${usedLocs.size === 1 ? '' : 'es'}`;
      $('kpiWeight').textContent = kg(stockKg);
      $('kpiLocations').textContent = usedLocs.size;
    }

    // ── Worklist ─────────────────────────────────────────────────────────────────────
    function renderWorklist() {
      const q = ($('worklistSearch').value || '').toLowerCase().trim();
      const list = pending.filter((r) =>
        !q || (r.lot_id || '').toLowerCase().includes(q) || (r.variety || '').toLowerCase().includes(q)
      );
      $('worklistCount').textContent = list.length;
      const body = $('worklistBody');
      if (!list.length) {
        body.innerHTML = `<div class="empty-state">${pending.length ? 'Sin coincidencias.' : 'No hay mercancía pendiente de ubicar.'}</div>`;
        return;
      }
      body.innerHTML = list.map((r) => `
        <div class="rs-wl-item ${current && current.id === r.id ? 'active' : ''}" data-id="${r.id}">
          <span class="rs-wl-lot">${r.lot_id || 'Lote'}</span>
          <span class="rs-wl-weight">${kg(r.weight_kg)}</span>
          <span class="rs-wl-sub">${r.variety || 'Sin variedad'}${r.region ? ' · ' + r.region : ''}</span>
          <span class="rs-wl-meta">
            <span class="rs-roast-dot ${roastDotClass(r.roast_level)}"></span>
            <span class="rs-wl-sub">${roastLabel(r.roast_level)}</span>
          </span>
        </div>`).join('');
      body.querySelectorAll('.rs-wl-item').forEach((el) => {
        el.addEventListener('click', () => selectLot(parseInt(el.dataset.id)));
      });
    }
    $('worklistSearch').addEventListener('input', renderWorklist);

    // ── Selección de lote ────────────────────────────────────────────────────────────
    function selectLot(id) {
      current = pending.find((r) => r.id === id) || null;
      if (!current) return;
      $('putawayEmpty').hidden = true;
      form.hidden = false;
      $('putawayFlag').hidden = false;

      $('facetLot').textContent = current.lot_id || 'Lote';
      $('facetRoast').innerHTML = `<span class="rs-roast-dot ${roastDotClass(current.roast_level)}"></span> Tueste ${roastLabel(current.roast_level)}`;
      $('facetVariety').textContent = current.variety || '—';
      $('facetRegion').textContent = current.region || current.farm || '—';
      $('facetWeight').textContent = kg(current.weight_kg);
      $('facetLoss').textContent = current.weight_loss_percent != null ? Number(current.weight_loss_percent).toFixed(1) + ' %' : '—';
      $('facetTemp').textContent = current.actual_temp != null ? current.actual_temp + ' °C' : '—';
      $('facetTime').textContent = current.roast_time_minutes != null ? current.roast_time_minutes + ' min' : '—';

      renderWorklist();
      updateDistribution();
      form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Distribución y capacidad ──────────────────────────────────────────────────────
    function updateDistribution() {
      const box = $('capacityBox');
      const container = $('container').value;
      const count = parseInt($('containerCount').value);
      if (!current || !container || !count || count < 1) {
        box.hidden = true;
        updateSummary(false);
        return;
      }
      const size = CONTAINER_SIZE[container];
      const capacity = size * count;
      const load = Number(current.weight_kg) || 0;
      const pct = capacity > 0 ? Math.min(100, load / capacity * 100) : 0;
      const over = capacity < load;

      box.hidden = false;
      box.classList.toggle('over', over);
      $('capacityPct').textContent = Math.round(pct) + ' %';
      $('capacityFill').style.width = pct + '%';
      $('capLoad').textContent = kg(load);
      $('capTotal').textContent = kg(capacity);
      $('capPer').textContent = kg(load / count);
      $('capacityWarn').hidden = !over;

      updateSummary(!over);
    }
    $('container').addEventListener('change', updateDistribution);
    $('containerCount').addEventListener('input', updateDistribution);

    // Steppers
    document.querySelectorAll('.cup-stepper-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = $(btn.dataset.target);
        const step = parseInt(btn.dataset.step);
        const min = input.min !== '' ? parseInt(input.min) : -Infinity;
        const max = input.max !== '' ? parseInt(input.max) : Infinity;
        input.value = Math.max(min, Math.min(max, (parseInt(input.value) || 0) + step));
        input.dispatchEvent(new Event('input'));
      });
    });

    $('location').addEventListener('change', () => updateSummary());

    // ── Resumen + validez ────────────────────────────────────────────────────────────
    function updateSummary(capacityOk = null) {
      const location = $('location').value;
      const container = $('container').value;
      const count = parseInt($('containerCount').value);
      const hasAll = current && location && container && count >= 1;

      // capacidad
      let capOk = capacityOk;
      if (capOk === null && hasAll) {
        capOk = CONTAINER_SIZE[container] * count >= (Number(current.weight_kg) || 0);
      }
      const valid = hasAll && capOk !== false;
      $('submitBtn').disabled = !valid;

      const line = $('summaryLine');
      if (!hasAll) {
        line.textContent = 'Complete la ubicación y el empaque para confirmar.';
      } else if (capOk === false) {
        line.textContent = 'Ajuste el empaque: la capacidad no alcanza para el lote.';
      } else {
        const loc = LOC_BY_CODE[location];
        line.innerHTML = `<b>${current.lot_id}</b> · ${kg(current.weight_kg)} → ${loc ? loc.zone + ' / ' + loc.label : location} · ${count} × ${CONTAINER_SIZE[container]} kg`;
      }
    }

    // ── Mapa de bins ────────────────────────────────────────────────────────────────
    function renderBins() {
      if (!LOCATIONS.length) {
        $('binsGrid').innerHTML = '<div class="empty-state">No hay ubicaciones configuradas. Configúrelas en Administración → Ubicaciones.</div>';
        return;
      }
      // La ocupación y el porcentaje de llenado vienen del servidor (quants),
      // no de sumar las filas visibles: la tabla está paginada y limitada.
      $('binsGrid').innerHTML = LOCATIONS.map((l) => {
        const d = { kg: l.occupiedKg || 0, lots: l.lotCount || 0 };
        const filled = d.kg > 0;
        // Si hay capacidad definida el porcentaje es real; si no, es relativo
        // a la ubicación más cargada, solo como referencia visual.
        const maxKg = Math.max(1, ...LOCATIONS.map((x) => x.occupiedKg || 0));
        const pct = l.fillPct != null ? l.fillPct : Math.round((d.kg / maxKg) * 100);
        const level = pct >= 90 ? 'danger' : pct >= 70 ? 'warning' : '';
        return `
          <div class="rs-bin ${filled ? 'filled' : ''} ${level}">
            <div class="rs-bin-top">
              <div>
                <div class="rs-bin-zone">${l.zone}</div>
                <div class="rs-bin-code">${l.code}</div>
              </div>
              <div class="rs-bin-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8V21H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
              </div>
            </div>
            <div class="rs-bin-stat">
              <span class="rs-bin-kg">${(d.kg).toLocaleString('es-CO', { maximumFractionDigits: 1 })}</span>
              <span class="rs-bin-unit">kg</span>
            </div>
            <div class="rs-bin-bar"><span style="width:${filled ? pct : 0}%"></span></div>
            <div class="rs-bin-lots">${d.lots} lote${d.lots === 1 ? '' : 's'} almacenado${d.lots === 1 ? '' : 's'}</div>
          </div>`;
      }).join('');
    }

    // ── Tabla de existencias ───────────────────────────────────────────────────────────
    function renderStock() {
      $('stockCount').textContent = stock.length;
      const body = $('stockBody');
      if (!stock.length) {
        body.innerHTML = '<tr><td colspan="8" class="empty-state">No hay café tostado almacenado.</td></tr>';
        return;
      }
      const CONT_LABEL = { 'BAG-1KG': 'Bolsa 1 kg', 'BAG-5KG': 'Bolsa 5 kg', 'BUCKET-25': 'Cubeta 25 kg', 'SACK-60': 'Saco 60 kg' };
      body.innerHTML = stock.map((r) => {
        const loc = LOC_BY_CODE[r.location];
        const cont = r.container_type ? `${CONT_LABEL[r.container_type] || r.container_type}${r.container_count ? ' × ' + r.container_count : ''}` : '—';
        return `
          <tr>
            <td><span class="rs-stock-loc">${r.location || '—'}</span>${loc ? `<div class="rs-wl-sub">${loc.zone}</div>` : ''}</td>
            <td style="font-family:ui-monospace,Menlo,monospace;font-weight:600;">${r.lot_id || '—'}</td>
            <td>${r.variety || '—'}</td>
            <td><span class="rs-roast-dot ${roastDotClass(r.roast_level)}"></span> ${roastLabel(r.roast_level)}</td>
            <td>${cont}</td>
            <td class="rs-stock-weight">${kg(r.weight_kg)}</td>
            <td><span class="badge badge-success">Listo para empaque</span></td>
            <td style="text-align:right;">
              <button type="button" class="rs-row-btn" data-detail="${r.id}" title="Ver detalle">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
              <button type="button" class="rs-row-btn danger" data-del="${r.id}" title="Retirar registro">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              </button>
            </td>
          </tr>`;
      }).join('');
      body.querySelectorAll('[data-detail]').forEach((b) =>
        b.addEventListener('click', () => { window.location.href = `/admin/roasted-storage-detail?id=${b.dataset.detail}`; }));
      body.querySelectorAll('[data-del]').forEach((b) =>
        b.addEventListener('click', () => deleteStock(parseInt(b.dataset.del))));
    }

    async function deleteStock(id) {
      if (!confirm('¿Retirar este registro de existencias? Esta acción no se puede deshacer.')) return;
      try {
        const res = await fetch(`/api/coffee/roasted-storage/${id}`, { method: 'DELETE', credentials: 'include' });
        if (!res.ok) throw new Error();
        toast('Registro retirado de bodega.', 'ok');
        loadAll();
      } catch {
        toast('No se pudo retirar el registro.', 'err');
      }
    }

    // ── Cancelar / limpiar ──────────────────────────────────────────────────────────
    function resetPanel() {
      current = null;
      form.reset();
      form.hidden = true;
      $('putawayFlag').hidden = true;
      $('putawayEmpty').hidden = false;
      $('storageDate').value = today;
      $('capacityBox').hidden = true;
      renderWorklist();
    }
    $('clearBtn').addEventListener('click', resetPanel);
    $('refreshBtn').addEventListener('click', () => { resetPanel(); loadAll(); });

    // ── Envío ───────────────────────────────────────────────────────────────────────
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!current) { toast('Seleccione un lote primero.', 'err'); return; }
      const location = $('location').value;
      const container = $('container').value;
      const count = parseInt($('containerCount').value);
      if (!location || !container || !count || count < 1) {
        toast('Complete todos los campos requeridos.', 'err'); return;
      }
      if (CONTAINER_SIZE[container] * count < (Number(current.weight_kg) || 0)) {
        toast('La capacidad de los contenedores no alcanza.', 'err'); return;
      }
      const conditions = Array.from(document.querySelectorAll('input[name="conditions"]:checked')).map((c) => c.value);

      const btn = $('submitBtn');
      btn.disabled = true; btn.innerHTML = 'Registrando…';
      try {
        const res = await fetch('/api/coffee/roasted-storage', {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            roastedId: current.id, location, container,
            containerCount: count, conditions, notes: $('notes').value || '',
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || data.message || 'Error al almacenar');
        toast(`${current.lot_id} almacenado en ${location}.`, 'ok');
        resetPanel();
        loadAll();
      } catch (err) {
        toast('Error: ' + (err.message || 'No se pudo almacenar.'), 'err');
        btn.disabled = false;
      } finally {
        btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Confirmar entrada`;
      }
    });

    // ── Init ────────────────────────────────────────────────────────────────────────
    loadAll();
  </script>
</AdminLayout>
