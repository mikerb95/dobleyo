---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="Almacenar Café Tostado"
  description="Registra el café tostado en el inventario con su ubicación"
>
  <form id="roastedStorageForm">
    <!-- Selección de Café Tostado -->
    <div class="form-group">
      <label for="roastedSelect"
        >Café Tostado para Almacenar <span class="required">*</span></label
      >
      <select id="roastedSelect" name="roasted" required>
        <option value="">Selecciona un café tostado...</option>
      </select>
      <div class="form-hint">Cafés listos para almacenar</div>
    </div>

    <!-- Info del Café Tostado -->
    <div class="card" id="roastedInfoCard" style="display: none;">
      <h3>Información del Café Tostado</h3>
      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.95rem;"
      >
        <div>
          <div style="color: #666; font-size: 0.85rem;">Lote ID</div>
          <div style="font-weight: 600;" id="roastedLotId">—</div>
        </div>
        <div>
          <div style="color: #666; font-size: 0.85rem;">Variedad</div>
          <div style="font-weight: 600;" id="roastedVariety">—</div>
        </div>
        <div>
          <div style="color: #666; font-size: 0.85rem;">Peso Tostado</div>
          <div style="font-weight: 600; color: #c67b4e;" id="roastedWeight">
            —
          </div>
        </div>
        <div>
          <div style="color: #666; font-size: 0.85rem;">Nivel de Tueste</div>
          <div style="font-weight: 600;" id="roastLevel">—</div>
        </div>
      </div>
    </div>

    <!-- Ubicación en Bodega -->
    <div class="form-group">
      <label for="location"
        >Ubicación en Bodega <span class="required">*</span></label
      >
      <select id="location" name="location" required>
        <option value="">Selecciona una ubicación</option>
        <option value="ROASTED-A-01">Sección A - Estante 01 (Tostado)</option>
        <option value="ROASTED-A-02">Sección A - Estante 02 (Tostado)</option>
        <option value="ROASTED-B-01">Sección B - Estante 01 (Tostado)</option>
        <option value="ROASTED-B-02">Sección B - Estante 02 (Tostado)</option>
        <option value="CLIMATE-01">Almacén Climatizado 01 (Premium)</option>
        <option value="CLIMATE-02">Almacén Climatizado 02 (Premium)</option>
      </select>
      <div class="form-hint">Elige dónde se almacenará el café tostado</div>
    </div>

    <!-- Contenedor/Empaque -->
    <div class="form-group">
      <label for="container"
        >Tipo de Contenedor <span class="required">*</span></label
      >
      <select id="container" name="container" required>
        <option value="">Selecciona un contenedor</option>
        <option value="BAG-1KG">Bolsas de 1 kg (para empaque)</option>
        <option value="BAG-5KG">Bolsas de 5 kg (almacenamiento)</option>
        <option value="BUCKET-25">Cubeta de 25 kg</option>
        <option value="SACK-60">Saco de 60 kg</option>
      </select>
    </div>

    <!-- Cantidad de Contenedores -->
    <div class="form-group">
      <label for="containerCount"
        >Cantidad de Contenedores <span class="required">*</span></label
      >
      <input
        type="number"
        id="containerCount"
        name="containerCount"
        placeholder="Ej: 4"
        step="1"
        min="1"
        required
      />
      <div class="form-hint">¿Cuántos contenedores se usarán?</div>
    </div>

    <!-- Cálculo de Distribución -->
    <div class="info-box" id="distributionBox" style="display: none;">
      <strong>Distribución del Peso:</strong>
      <div style="margin-top: 0.75rem; font-size: 0.95rem;">
        <div>
          Total: <span id="distTotal" style="font-weight: 600;">— kg</span>
        </div>
        <div>
          Por Contenedor: <span id="distPerContainer" style="font-weight: 600;"
            >— kg</span
          >
        </div>
        <div>
          Contenedores: <span id="distContainers" style="font-weight: 600;"
            >—</span
          >
        </div>
      </div>
    </div>

    <!-- Fecha de Almacenamiento -->
    <div class="form-group">
      <label for="storageDate">Fecha de Almacenamiento</label>
      <input type="date" id="storageDate" name="storageDate" disabled />
      <div class="form-hint">
        Se registra automáticamente como la fecha actual
      </div>
    </div>

    <!-- Condiciones de Almacenamiento -->
    <div class="form-group">
      <label>Condiciones de Almacenamiento</label>
      <div class="checkbox-group">
        <label class="checkbox-item">
          <input type="checkbox" name="conditions" value="sealed" />
          <span>Sellado herméticas</span>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" name="conditions" value="cool" />
          <span>Lugar fresco y seco</span>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" name="conditions" value="dark" />
          <span>Protegido de luz directa</span>
        </label>
      </div>
    </div>

    <!-- Notas -->
    <div class="form-group">
      <label for="notes">Notas (Opcional)</label>
      <textarea
        id="notes"
        name="notes"
        placeholder="Ej: Almacenado en clima controlado, lotes separados por variedad..."
      ></textarea>
    </div>

    <!-- Resumen -->
    <div class="info-box" id="summaryBox" style="display: none;">
      <strong>Resumen del Almacenamiento Tostado:</strong>
      <div style="margin-top: 0.75rem; font-size: 0.95rem; line-height: 1.6;">
        <div>
          📦 Lote: <span id="summaryLot" style="font-weight: 600;">—</span>
        </div>
        <div>
          ⚖️ Peso: <span id="summaryWeight" style="font-weight: 600;">—</span>
        </div>
        <div>
          📍 Ubicación: <span id="summaryLocation" style="font-weight: 600;"
            >—</span
          >
        </div>
        <div>
          🏠 Contenedores: <span
            id="summaryContainers"
            style="font-weight: 600;">—</span
          >
        </div>
        <div>
          📅 Fecha: <span id="summaryDate" style="font-weight: 600;">—</span>
        </div>
      </div>
    </div>

    <!-- Botones de Acción -->
    <div class="form-actions" style="margin-bottom: 2rem;">
      <button type="reset" class="btn-secondary">Limpiar</button>
      <button type="submit" class="btn-primary">Almacenar</button>
    </div>
  </form>

  <!-- Modal de Éxito -->
  <div id="successModal" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header success">
        <div class="success-icon">✓</div>
      </div>
      <h2 class="modal-title">¡Café Almacenado Correctamente!</h2>
      <div class="modal-body">
        <div class="success-details">
          <div class="success-item">
            <span class="success-label">Lote:</span>
            <span class="success-value" id="modalLot">—</span>
          </div>
          <div class="success-item">
            <span class="success-label">Peso:</span>
            <span class="success-value" id="modalWeight">—</span>
          </div>
          <div class="success-item">
            <span class="success-label">Ubicación:</span>
            <span class="success-value" id="modalLocation">—</span>
          </div>
        </div>
      </div>
      <div class="modal-actions">
        <button
          type="button"
          id="storeAnotherBtn"
          class="btn-secondary"
        >
          Almacenar Otro
        </button>
        <button
          type="button"
          class="btn-primary"
          id="viewDetailBtn"
        >
          Ver Detalle →
        </button>
      </div>
    </div>
  </div>

  <script>
    const roastedSelect = document.getElementById("roastedSelect");
    const storageDate = document.getElementById("storageDate");
    const form = document.getElementById("roastedStorageForm");
    const summaryBox = document.getElementById("summaryBox");
    const roastedInfoCard = document.getElementById("roastedInfoCard");
    const distributionBox = document.getElementById("distributionBox");
    const containerSelect = document.getElementById("container");
    const containerCountInput = document.getElementById("containerCount");

    let currentRoasted = null;

    const containerSizes = {
      "BAG-1KG": 1,
      "BAG-5KG": 5,
      "BUCKET-25": 25,
      "SACK-60": 60,
    };

    // Cargar cafés tostados listos desde API
    async function loadRoastedLots() {
      try {
        const response = await fetch("/api/coffee/roasted-for-storage", {
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
        });
        if (!response.ok) throw new Error("Error al cargar cafés tostados");

        const roastedLots = await response.json();

        roastedSelect.innerHTML =
          '<option value="">Selecciona un café tostado...</option>';
        roastedLots.forEach((record) => {
          const option = document.createElement("option");
          option.value = JSON.stringify(record);
          option.textContent = `${record.lot_id} - ${record.roast_level === "LIGHT" ? "Clara" : record.roast_level === "MEDIUM" ? "Media" : "Oscura"} (${record.weight_kg} kg)`;
          roastedSelect.appendChild(option);
        });
      } catch (error) {
        console.error("Error cargando cafés tostados:", error);
        alert("Error al cargar cafés tostados");
      }
    }

    // Establecer fecha actual
    const today = new Date().toISOString().split("T")[0];
    storageDate.value = today;

    // Actualizar información del café
    roastedSelect.addEventListener("change", () => {
      if (!roastedSelect.value) {
        roastedInfoCard.style.display = "none";
        summaryBox.style.display = "none";
        return;
      }

      currentRoasted = JSON.parse(roastedSelect.value);
      document.getElementById("roastedLotId").textContent =
        currentRoasted.lot_id;
      document.getElementById("roastedVariety").textContent =
        currentRoasted.variety || "—";
      document.getElementById("roastedWeight").textContent =
        `${currentRoasted.weight_kg} kg`;
      document.getElementById("roastLevel").textContent =
        currentRoasted.roast_level === "LIGHT"
          ? "Clara"
          : currentRoasted.roast_level === "MEDIUM"
            ? "Media"
            : "Oscura";

      roastedInfoCard.style.display = "block";
      updateSummary();
    });

    // Calcular distribución
    function updateDistribution() {
      if (
        !containerSelect.value ||
        !containerCountInput.value ||
        !currentRoasted
      ) {
        distributionBox.style.display = "none";
        return;
      }

      const containerSize = containerSizes[containerSelect.value];
      const count = parseInt(containerCountInput.value);
      const capacity = containerSize * count;

      if (capacity < currentRoasted.weight_kg) {
        alert("⚠️ La capacidad de los contenedores no es suficiente");
        distributionBox.style.display = "none";
        return;
      }

      document.getElementById("distTotal").textContent =
        `${currentRoasted.weight_kg} kg`;
      document.getElementById("distPerContainer").textContent =
        `${(currentRoasted.weight_kg / count).toFixed(2)} kg`;
      document.getElementById("distContainers").textContent =
        `${count} × ${containerSize} kg`;
      distributionBox.style.display = "block";
    }

    containerSelect.addEventListener("change", updateDistribution);
    containerCountInput.addEventListener("input", updateDistribution);

    // Actualizar resumen
    function updateSummary() {
      const location = document.getElementById("location").value;
      const container = document.getElementById("container").value;
      const count = containerCountInput.value;

      if (location && container && count && currentRoasted) {
        document.getElementById("summaryLot").textContent =
          currentRoasted.lot_id;
        document.getElementById("summaryWeight").textContent =
          `${currentRoasted.weight_kg} kg`;
        document.getElementById("summaryLocation").textContent = location;
        document.getElementById("summaryContainers").textContent =
          `${count} × ${containerSizes[container]} kg`;
        document.getElementById("summaryDate").textContent = new Date(
          storageDate.value
        ).toLocaleDateString("es-CO");
        summaryBox.style.display = "block";
      } else {
        summaryBox.style.display = "none";
      }
    }

    document
      .getElementById("location")
      .addEventListener("change", updateSummary);
    document
      .getElementById("container")
      .addEventListener("change", updateSummary);
    containerCountInput.addEventListener("input", updateSummary);

    // Enviar formulario a la API
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!currentRoasted) {
        alert("⚠️ Debes seleccionar un café tostado");
        return;
      }

      const location = document.getElementById("location").value;
      const container = document.getElementById("container").value;
      const count = parseInt(containerCountInput.value);

      if (!location || !container || count <= 0) {
        alert("⚠️ Debes completar todos los campos requeridos");
        return;
      }

      const conditions = Array.from(
        document.querySelectorAll('input[name="conditions"]:checked')
      ).map((c) => c.value);

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando...";

      try {
        const response = await fetch("/api/coffee/roasted-storage", {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            roastedId: currentRoasted.id,
            location: location,
            container: container,
            containerCount: count,
            conditions: conditions,
            notes: document.getElementById("notes").value,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.message || "Error al almacenar café");
        }

        const result = await response.json();

        // Mostrar modal de éxito
        document.getElementById("modalLot").textContent = currentRoasted.lot_id;
        document.getElementById("modalWeight").textContent =
          `${currentRoasted.weight_kg} kg`;
        document.getElementById("modalLocation").textContent = location;
        document.getElementById("viewDetailBtn").onclick = () =>
          viewStorageDetail(result.storageId);
        document.getElementById("successModal").style.display = "flex";

        form.reset();
        storageDate.value = today;
        roastedInfoCard.style.display = "none";
        summaryBox.style.display = "none";
        distributionBox.style.display = "none";
        loadRoastedLots();
      } catch (error) {
        console.error("Error:", error);
        alert(`❌ Error: ${error.message || "Error desconocido"}`);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });

    // Cargar cafés al iniciar
    loadRoastedLots();

    // Funciones del modal
    function closeSuccessModal() {
      document.getElementById("successModal").style.display = "none";
    }

    function viewStorageDetail(storageId) {
      window.location.href = `/admin/roasted-storage-detail?id=${storageId}`;
    }

    document.getElementById("storeAnotherBtn")?.addEventListener("click", () => {
      closeSuccessModal();
      document.getElementById("roastedStorageForm").reset();
      document.getElementById("roastedInfoCard").style.display = "none";
      document.getElementById("summaryBox").style.display = "none";
    });
    document.getElementById("viewDetailBtn")?.addEventListener("click", viewStorageDetail);
  </script>
</AdminLayout>
