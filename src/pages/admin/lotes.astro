---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Lotes — DobleYo Admin" section="lotes">
  <style>
    .page-header {
      margin-bottom: 1.75rem;
    }
    .page-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: #251a14;
      margin: 0 0 0.25rem;
    }
    .page-header p {
      margin: 0;
      color: #7a6652;
      font-size: 0.95rem;
    }

    .toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .tab-btn {
      padding: 0.45rem 1rem;
      border-radius: 20px;
      border: 1px solid #ddd;
      background: #fff;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      color: #7a6652;
      transition: all 0.15s;
    }
    .tab-btn.active {
      background: #4a6741;
      color: #fff;
      border-color: #4a6741;
    }
    .tab-btn:hover:not(.active) {
      border-color: #c8a96e;
      color: #251a14;
    }
    .spacer {
      flex: 1;
    }
    .btn-primary {
      padding: 0.5rem 1.1rem;
      background: #4a6741;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-primary:hover {
      background: #3a5331;
    }

    .table-wrap {
      background: #fff;
      border-radius: 8px;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      box-shadow: var(--card-shadow, 0 0 0 1px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.05));
      overflow-x: auto;
      margin-bottom: 1.5rem;
    }

    .badge-lote {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      border: 1px solid transparent;
      white-space: nowrap;
    }
    .badge-verde     { background: var(--c-success-bg, #f1fdf6); color: var(--c-success, #107e3e); border-color: var(--c-success-border, #b5e8cd); }
    .badge-tostado   { background: var(--c-warning-bg, #fef3e2); color: var(--c-warning, #c96800); border-color: var(--c-warning-border, #f5c87a); }
    .badge-en_tostado { background: #fff8f1; color: #92400e; border-color: #fed7aa; }
    .badge-pendiente { background: var(--c-info-bg, #e8f2ff); color: var(--c-info, #0064d9); border-color: var(--c-info-border, #91c2f5); }
    .badge-default   { background: #f0f0f0; color: #555; border-color: #ddd; }

    .btn-action {
      padding: 0.28rem 0.65rem;
      font-size: 0.75rem;
      font-weight: 600;
      border: 1px solid #ddd;
      border-radius: 5px;
      background: #fff;
      cursor: pointer;
      color: #251a14;
      transition: background 0.15s;
    }
    .btn-action:hover {
      background: #f7f3ef;
      border-color: #c8a96e;
    }
    .btn-action.danger {
      border-color: #f8d7da;
      color: #721c24;
    }
    .btn-action.danger:hover {
      background: #f8d7da;
    }

    .empty {
      text-align: center;
      padding: 2.5rem;
      color: #7a6652;
      font-style: italic;
    }

    /* ── Modal ─────────────────────────────────────── */
    .modal-back {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      z-index: 300;
      align-items: flex-start;
      justify-content: center;
      padding: 2rem 1rem;
      overflow-y: auto;
    }
    .modal-back.open {
      display: flex;
    }
    .modal {
      background: #fff;
      border-radius: 12px;
      width: 100%;
      max-width: 580px;
      box-shadow: 0 8px 32px rgba(37, 26, 20, 0.22);
      margin: auto;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 1.5rem;
      border-bottom: 1px solid #ede8e2;
    }
    .modal-header h2 {
      margin: 0;
      font-size: 1.1rem;
      color: #251a14;
    }
    .modal-close {
      background: none;
      border: none;
      cursor: pointer;
      color: #7a6652;
      font-size: 1.4rem;
      line-height: 1;
      padding: 0.2rem;
    }
    .modal-body {
      padding: 1.5rem;
    }
    .form-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: 1fr 1fr;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .form-group.full {
      grid-column: 1 / -1;
    }
    .form-group label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #7a6652;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.55rem 0.75rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.88rem;
      background: #faf8f5;
      color: #251a14;
      outline: none;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: #c8a96e;
    }
    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }
    .modal-footer {
      display: flex;
      gap: 0.75rem;
      justify-content: flex-end;
      padding: 1rem 1.5rem;
      border-top: 1px solid #ede8e2;
    }
    .btn-cancel {
      padding: 0.55rem 1rem;
      background: transparent;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 0.88rem;
      cursor: pointer;
      color: #7a6652;
    }
    .btn-cancel:hover {
      border-color: #bbb;
      color: #251a14;
    }
    .form-msg {
      font-size: 0.82rem;
      margin-top: 0.5rem;
    }
  </style>

  <header class="page-header">
    <h1>Lotes de café</h1>
    <p>Gestión de lotes verdes y tostados · trazabilidad completa</p>
  </header>

  <div class="toolbar">
    <button class="tab-btn active" data-tab="all">Todos</button>
    <button class="tab-btn" data-tab="verde">Verde</button>
    <button class="tab-btn" data-tab="en_tostado">En tostado</button>
    <button class="tab-btn" data-tab="pendiente">Pendiente almacén</button>
    <button class="tab-btn" data-tab="tostado">Tostado</button>
    <span class="spacer"></span>
    <button class="btn-primary" id="btnNewLot">+ Nuevo lote</button>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>ID de lote</th>
          <th>Finca</th>
          <th>Región</th>
          <th>Variedad</th>
          <th>Proceso</th>
          <th>Peso (kg)</th>
          <th>Estado</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody id="lotsBody">
        <tr><td colspan="8" class="empty">Cargando lotes...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Create / Edit modal -->
  <div class="modal-back" id="modalBack">
    <div
      class="modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modalTitle"
    >
      <div class="modal-header">
        <h2 id="modalTitle">Nuevo lote</h2>
        <button class="modal-close" id="modalClose" aria-label="Cerrar"
          >&times;</button
        >
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group">
            <label for="fCode">Código *</label>
            <input type="text" id="fCode" placeholder="DY-2026-001" />
          </div>
          <div class="form-group">
            <label for="fName">Nombre *</label>
            <input
              type="text"
              id="fName"
              placeholder="Sierra Nevada Especial"
            />
          </div>
          <div class="form-group">
            <label for="fOrigin">Origen / Región</label>
            <input
              type="text"
              id="fOrigin"
              placeholder="Sierra Nevada, Magdalena"
            />
          </div>
          <div class="form-group">
            <label for="fFarm">Finca</label>
            <input type="text" id="fFarm" placeholder="Finca La Esperanza" />
          </div>
          <div class="form-group">
            <label for="fProducer">Productor</label>
            <input type="text" id="fProducer" placeholder="Juan Rodríguez" />
          </div>
          <div class="form-group">
            <label for="fVariety">Variedad</label>
            <input
              type="text"
              id="fVariety"
              placeholder="Castillo, Caturra..."
            />
          </div>
          <div class="form-group">
            <label for="fProcess">Proceso</label>
            <select id="fProcess">
              <option value="">Seleccionar...</option>
              <option value="Lavado">Lavado</option>
              <option value="Natural">Natural</option>
              <option value="Honey">Honey</option>
              <option value="Anaeróbico">Anaeróbico</option>
              <option value="Washed">Washed</option>
            </select>
          </div>
          <div class="form-group">
            <label for="fAltitude">Altitud (msnm)</label>
            <input type="number" id="fAltitude" placeholder="1800" />
          </div>
          <div class="form-group">
            <label for="fWeightKg">Peso verde (kg)</label>
            <input type="number" id="fWeightKg" placeholder="120" step="0.1" />
          </div>
          <div class="form-group">
            <label for="fScore">Score SCA</label>
            <input
              type="number"
              id="fScore"
              placeholder="86.5"
              step="0.5"
              min="0"
              max="100"
            />
          </div>
          <div class="form-group">
            <label for="fHarvestDate">Fecha cosecha</label>
            <input type="date" id="fHarvestDate" />
          </div>
          <div class="form-group">
            <label for="fMoisture">Humedad (%)</label>
            <input type="number" id="fMoisture" placeholder="11.5" step="0.1" />
          </div>
          <div class="form-group full">
            <label for="fNotes">Notas de cata / descripción</label>
            <textarea
              id="fNotes"
              placeholder="Notas de sabor, características especiales..."
            ></textarea>
          </div>
        </div>
        <div class="form-msg" id="formMsg"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="modalCancel">Cancelar</button>
        <button class="btn-primary" id="btnSaveLot">Crear lote</button>
      </div>
    </div>
  </div>

  <script>
    // ── State ─────────────────────────────────────────────────
    let allLots: any[] = [];
    let currentTab = "all";

    // ── Formatters ────────────────────────────────────────────
    const fmtDate = (s: string) =>
      s
        ? new Date(s).toLocaleDateString("es-CO", {
            day: "2-digit",
            month: "short",
            year: "numeric",
          })
        : "—";

    const STATUS_LABELS: Record<string, string> = {
      verde: "Verde",
      en_tostado: "En tostado",
      pendiente: "Pendiente almacén",
      tostado: "Tostado",
    };

    function statusBadge(status: string) {
      const cls = ["verde", "tostado", "en_tostado", "pendiente"].includes(status)
        ? `badge-${status}`
        : "badge-default";
      return `<span class="${cls}">${STATUS_LABELS[status] ?? status ?? "—"}</span>`;
    }

    // ── Load lots ─────────────────────────────────────────────
    async function loadLots() {
      const tbody = document.getElementById("lotsBody")!;
      tbody.innerHTML = `<tr><td colspan="8" class="empty">Cargando...</td></tr>`;
      try {
        const res = await fetch("/api/coffee/lots", { credentials: "include" });
        if (!res.ok) throw new Error("Error al cargar");
        const data = await res.json();
        allLots = data.lots ?? [];
        renderTable();
      } catch {
        tbody.innerHTML = `<tr><td colspan="8" class="empty">Error al cargar lotes. Verifica tu sesión.</td></tr>`;
      }
    }

    function renderTable() {
      const tbody = document.getElementById("lotsBody")!;
      const filtered =
        currentTab === "all"
          ? allLots
          : allLots.filter((l) => l.status === currentTab);

      if (filtered.length === 0) {
        tbody.innerHTML = `<tr><td colspan="8" class="empty">No hay lotes${currentTab !== "all" ? " en estado " + (STATUS_LABELS[currentTab] ?? currentTab) : ""}.</td></tr>`;
        return;
      }

      tbody.innerHTML = filtered
        .map(
          (l) => `
        <tr>
          <td><strong style="font-family:monospace;font-size:.82rem">${l.lot_id ?? "—"}</strong></td>
          <td>${l.farm_name ?? "—"}</td>
          <td style="color:#7a6652">${l.region ?? "—"}</td>
          <td style="color:#7a6652">${l.variety ?? "—"}</td>
          <td style="color:#7a6652">${l.process ?? "—"}</td>
          <td>${l.weight != null ? Number(l.weight).toFixed(1) + " kg" : "—"}</td>
          <td>${statusBadge(l.status)}</td>
          <td style="color:#7a6652;font-size:.82rem">${fmtDate(l.created_at)}</td>
        </tr>
      `,
        )
        .join("");
    }

    // ── Tab filter ─────────────────────────────────────────────
    document.querySelectorAll(".tab-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        document
          .querySelectorAll(".tab-btn")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        currentTab = (btn as HTMLElement).dataset.tab ?? "all";
        renderTable();
      });
    });

    // ── Modal helpers ──────────────────────────────────────────
    function getVal(id: string) {
      return (
        (document.getElementById(id) as HTMLInputElement)?.value?.trim() ?? ""
      );
    }
    function setVal(id: string, v: any) {
      const el = document.getElementById(id) as HTMLInputElement;
      if (el) el.value = v ?? "";
    }
    function resetForm() {
      [
        "fCode", "fName", "fOrigin", "fFarm", "fProducer", "fVariety",
        "fProcess", "fAltitude", "fWeightKg", "fScore", "fHarvestDate",
        "fMoisture", "fNotes",
      ].forEach((id) => setVal(id, ""));
      document.getElementById("formMsg")!.textContent = "";
    }
    function openCreateModal() {
      resetForm();
      document.getElementById("modalBack")!.classList.add("open");
    }
    function closeModal() {
      document.getElementById("modalBack")!.classList.remove("open");
    }

    document.getElementById("btnNewLot")?.addEventListener("click", openCreateModal);
    document.getElementById("modalClose")?.addEventListener("click", closeModal);
    document.getElementById("modalCancel")?.addEventListener("click", closeModal);
    document.getElementById("modalBack")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    // ── Save ───────────────────────────────────────────────────
    document.getElementById("btnSaveLot")?.addEventListener("click", async () => {
      const msg = document.getElementById("formMsg")!;
      const btn = document.getElementById("btnSaveLot") as HTMLButtonElement;
      msg.textContent = "";

      const code = getVal("fCode");
      const name = getVal("fName");
      if (!code || !name) {
        msg.textContent = "⚠️ Código y nombre son obligatorios.";
        msg.style.color = "#856404";
        return;
      }

      const body: Record<string, any> = {
        code,
        name,
        origin: getVal("fOrigin") || null,
        farm: getVal("fFarm") || null,
        producer: getVal("fProducer") || null,
        variety: getVal("fVariety") || null,
        process: getVal("fProcess") || null,
        altitude: getVal("fAltitude") ? Number(getVal("fAltitude")) : null,
        weight_kg: getVal("fWeightKg") ? Number(getVal("fWeightKg")) : null,
        score: getVal("fScore") ? Number(getVal("fScore")) : null,
        harvest_date: getVal("fHarvestDate") || null,
        moisture: getVal("fMoisture") ? Number(getVal("fMoisture")) : null,
        notes: getVal("fNotes") || null,
      };

      btn.disabled = true;
      btn.textContent = "Guardando...";

      try {
        const res = await fetch("/api/lots", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error ?? "Error");

        msg.textContent = "✅ Lote creado correctamente.";
        msg.style.color = "#155724";
        await loadLots();
        setTimeout(closeModal, 1200);
      } catch (err: any) {
        msg.textContent = `❌ ${err.message}`;
        msg.style.color = "#721c24";
      } finally {
        btn.disabled = false;
        btn.textContent = "Crear lote";
      }
    });

    // ── Init ──────────────────────────────────────────────────
    loadLots();
  </script>
</AdminLayout>
