---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="Recoger Lote en Finca"
  description="Registra los datos de recolección de café en la finca del caficultor"
>
  <form id="harvestForm">
    <!-- Selección de Finca -->
    <div class="form-group">
      <label for="farmSelect">Finca <span class="required">*</span></label>
      <select id="farmSelect" name="farm" required>
        <option value="">Selecciona una finca</option>
        <option value="finca-la-sierra"
          >La Sierra - Huila (1800m, Franco arcilloso)</option
        >
        <option value="finca-nariño"
          >Nariño Premium - Nariño (1900m, Franco arcilloso)</option
        >
        <option value="finca-cauca"
          >Cauca Estate - Cauca (1750m, Franco arcilloso)</option
        >
      </select>
      <div class="form-hint">
        La información de altura y tipo de suelo se carga automáticamente
      </div>
    </div>

    <!-- Info de la Finca (solo lectura) -->
    <div class="card" id="farmInfo" style="display: none;">
      <h3>Información de la Finca</h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <div style="font-size: 0.85rem; color: #666;">Altura</div>
          <div style="font-weight: 600; font-size: 1.1rem;" id="farmAltitude">
            —
          </div>
        </div>
        <div>
          <div style="font-size: 0.85rem; color: #666;">Tipo de Suelo</div>
          <div style="font-weight: 600; font-size: 1.1rem;" id="farmSoil">
            —
          </div>
        </div>
      </div>
    </div>

    <!-- Variedad de Café -->
    <div class="form-group">
      <label for="variety"
        >Variedad de Café <span class="required">*</span></label
      >
      <select id="variety" name="variety" required>
        <option value="">Selecciona una variedad</option>
        <option value="CAT">Caturra</option>
        <option value="TIP">Típica</option>
        <option value="BOB">Bourbon</option>
        <option value="GER">Geisha</option>
        <option value="PAC">Pacamara</option>
      </select>
      <div class="form-hint">Código de 3 letras (ej: CAT)</div>
    </div>

    <!-- Clima -->
    <div class="form-group">
      <label
        >Clima en la Época de Recolección <span class="required">*</span></label
      >
      <div class="radio-group">
        <label class="radio-item">
          <input type="radio" name="climate" value="SECO" required />
          <span>🌞 Seco</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="climate" value="LLUV" required />
          <span>🌧️ Lluvioso</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="climate" value="TEMP" required />
          <span>🌤️ Templado</span>
        </label>
      </div>
    </div>

    <!-- Proceso -->
    <div class="form-group">
      <label>Proceso <span class="required">*</span></label>
      <div class="radio-group">
        <label class="radio-item">
          <input type="radio" name="process" value="NAT" required />
          <span>Natural (Secado en cereza)</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="process" value="HUM" required />
          <span>Húmedo (Lavado)</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="process" value="ANH" required />
          <span>Anaeróbico</span>
        </label>
      </div>
    </div>

    <!-- Aroma -->
    <div class="form-group">
      <label for="aroma">Aroma Detectado <span class="required">*</span></label>
      <input
        type="text"
        id="aroma"
        name="aroma"
        placeholder="Ej: Chocolate, Frutal, Floral"
        required
      />
      <div class="form-hint">Describe los aromas principales</div>
    </div>

    <!-- Notas de Sabor -->
    <div class="form-group">
      <label for="tasteNotes"
        >Notas de Sabor <span class="required">*</span></label
      >
      <textarea
        id="tasteNotes"
        name="tasteNotes"
        placeholder="Ej: Notas de chocolate amargo, cereza, avellana..."
        required></textarea>
      <div class="form-hint">
        Describe los sabores y características detectadas
      </div>
    </div>

    <!-- ID de Lote Generado -->
    <div class="info-box" id="lotInfo" style="display: none;">
      <strong>ID de Lote Generado:</strong>
      <div
        style="font-size: 1.4rem; font-weight: bold; color: #251a14; margin-top: 0.5rem; font-family: 'Courier New', monospace;"
        id="lotId"
      >
        COL-XXX-0000-XXX-XX-00
      </div>
      <div style="font-size: 0.85rem; color: #666; margin-top: 0.75rem;">
        <strong>Formato:</strong> País-Región-Altura-Variedad-Proceso-Número
      </div>
    </div>

    <!-- Botones de Acción -->
    <div class="form-actions">
      <button type="reset" class="btn-secondary">Limpiar</button>
      <button type="submit" class="btn-primary">Crear Lote</button>
    </div>
  </form>

  <!-- Modal de Confirmación -->
  <div
    id="successModal"
    style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; padding: 1rem;"
  >
    <div
      style="background: white; border-radius: 12px; padding: 2.5rem; max-width: 500px; width: 100%; box-shadow: 0 10px 40px rgba(0,0,0,0.2);"
    >
      <!-- Ícono de éxito -->
      <div style="text-align: center; margin-bottom: 1.5rem;">
        <div
          style="font-size: 3.5rem; color: #4a6741; animation: scaleIn 0.5s ease;"
        >
          ✅
        </div>
      </div>

      <!-- Título -->
      <h2
        style="text-align: center; color: #251a14; margin: 0 0 0.5rem 0; font-size: 1.5rem;"
      >
        ¡Lote Creado!
      </h2>

      <!-- Mensaje -->
      <div
        style="text-align: center; color: #666; margin-bottom: 1.5rem; font-size: 1rem;"
      >
        <p id="successMessage" style="margin: 0.5rem 0;">
          El lote <strong id="newLotId"></strong> ha sido registrado correctamente.
        </p>
        <p style="margin: 0.5rem 0; font-size: 0.9rem; color: #999;">
          Ahora está disponible en la sección de café verde.
        </p>
      </div>

      <!-- Información del lote -->
      <div
        id="lotDetailsInfo"
        style="background: #f9fafb; border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem; display: none;"
      >
        <div style="font-size: 0.85rem; color: #666;">
          <div style="margin-bottom: 0.75rem;">
            <strong>Finca:</strong>
            <span id="detailFinca"></span>
          </div>
          <div style="margin-bottom: 0.75rem;">
            <strong>Variedad:</strong>
            <span id="detailVariedad"></span>
          </div>
          <div style="margin-bottom: 0.75rem;">
            <strong>Clima:</strong>
            <span id="detailClima"></span>
          </div>
          <div>
            <strong>Proceso:</strong>
            <span id="detailProceso"></span>
          </div>
        </div>
      </div>

      <!-- Botones de acción -->
      <div style="display: flex; gap: 1rem; flex-direction: column-reverse;">
        <button
          id="closeHarvestSuccessBtn"
          style="padding: 0.75rem 1.5rem; background: #ddd; color: #333; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.95rem; transition: background 0.2s;"
        >
          Cerrar
        </button>
        <button
          id="goToLotesFromHarvestBtn"
          style="padding: 0.75rem 1.5rem; background: #4a6741; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.95rem; transition: background 0.2s;"
        >
          Ver Lotes de Café Verde
        </button>
      </div>
    </div>
  </div>

  <script>
    // Mapa de fincas: cargado dinámicamente desde la API, con fallback estático
    let farmData = {
      "finca-la-sierra": { altitude: "1800m", soil: "Franco arcilloso", region: "HUI", displayName: "La Sierra - Huila" },
      "finca-nariño":    { altitude: "1900m", soil: "Franco arcilloso", region: "NAR", displayName: "Nariño Premium" },
      "finca-cauca":     { altitude: "1750m", soil: "Franco arcilloso", region: "CAU", displayName: "Cauca Estate" },
    };

    // Cargar fincas del usuario desde la API
    (async function loadFarms() {
      try {
        const res = await fetch("/api/farms/my?list=true", { credentials: "include" });
        if (!res.ok) return;
        const json = await res.json();
        const farms = json.data ?? [];
        if (!farms.length) return;

        // Reconstruir farmData con datos reales
        const newFarmData = {};
        farms.forEach(f => {
          const key = f.slug || `farm-${f.id}`;
          newFarmData[key] = {
            id:          f.id,
            altitude:    f.altitude_min ? `${f.altitude_min}m` : "—",
            altitudeRaw: f.altitude_min ?? 0,
            soil:        "Franco arcilloso", // campo no disponible en select actual
            region:      f.region ?? "COL",
            displayName: f.name,
            municipality: f.municipality ?? "",
          };
        });
        farmData = newFarmData;

        // Repoblar el select con las fincas reales
        const select = document.getElementById("farmSelect");
        if (!select) return;
        // Conservar la primera opción vacía
        while (select.options.length > 1) select.remove(1);
        farms.forEach(f => {
          const key  = f.slug || `farm-${f.id}`;
          const label = `${f.name}${f.municipality ? " — " + f.municipality : ""}${f.altitude_min ? " (" + f.altitude_min + "m)" : ""}`;
          const opt  = new Option(label, key);
          select.appendChild(opt);
        });
      } catch (_) {
        // Si falla, el select ya tiene las opciones hardcodeadas como fallback
      }
    })();

    const varietyMap = {
      CAT: "Caturra",
      TIP: "Típica",
      BOB: "Bourbon",
      GER: "Geisha",
      PAC: "Pacamara",
    };

    const processMap = {
      NAT: "Natural",
      HUM: "Húmedo",
      ANH: "Anaeróbico",
    };

    const form = document.getElementById("harvestForm");
    const farmSelect = document.getElementById("farmSelect");
    const farmInfo = document.getElementById("farmInfo");
    const lotInfo = document.getElementById("lotInfo");

    // Actualizar información de finca
    farmSelect.addEventListener("change", () => {
      const selectedFarm = farmSelect.value;
      if (selectedFarm && farmData[selectedFarm]) {
        const farm = farmData[selectedFarm];
        document.getElementById("farmAltitude").textContent = farm.altitude;
        document.getElementById("farmSoil").textContent = farm.soil;
        farmInfo.style.display = "block";
        generateLotId();
      } else {
        farmInfo.style.display = "none";
        lotInfo.style.display = "none";
      }
    });

    // Mostrar preview del formato de lote (el ID real lo genera el servidor)
    function generateLotId() {
      const farm = farmData[farmSelect.value];
      if (!farm) return;

      const variety = document.getElementById("variety").value;
      const process =
        document.querySelector('input[name="process"]:checked')?.value || "XX";

      if (!variety || !process || process === "XX") {
        lotInfo.style.display = "none";
        return;
      }

      const altitude = (farm.altitudeRaw || farm.altitude.replace("m", ""));
      // Mostrar formato aproximado — el sufijo real lo genera el servidor con crypto
      const lotId = `COL-${farm.region}-${altitude}-${variety}-${process}-****`;
      document.getElementById("lotId").textContent = lotId;
      lotInfo.style.display = "block";
    }

    // Regenerar ID al cambiar variedad o proceso
    document
      .getElementById("variety")
      .addEventListener("change", generateLotId);
    document.querySelectorAll('input[name="process"]').forEach((radio) => {
      radio.addEventListener("change", generateLotId);
    });

    // Enviar formulario a la API
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando...";

      try {
        const response = await fetch("/api/coffee/harvest", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            farm: farmSelect.value,
            region: farmData[farmSelect.value]?.region || "",
            altitude: parseInt(farmData[farmSelect.value]?.altitude || "0"),
            variety: document.getElementById("variety").value,
            climate: document.querySelector('input[name="climate"]:checked')
              .value,
            process: document.querySelector('input[name="process"]:checked')
              .value,
            aroma: document.getElementById("aroma").value,
            tasteNotes: document.getElementById("tasteNotes").value,
          }),
        });

        let data;
        const contentType = response.headers.get("content-type");
        if (contentType && contentType.includes("application/json")) {
          data = await response.json();
        } else {
          const text = await response.text();
          throw new Error(`Respuesta inválida del servidor: ${text}`);
        }

        if (!response.ok) {
          throw new Error(
            data.error || data.message || "Error al registrar lote"
          );
        }

        const lotId = data.lotId;

        // Llenar datos del modal
        document.getElementById("newLotId").textContent = lotId;

        // Llenar información del lote
        const varietyMap = {
          CAT: "Caturra",
          TIP: "Típica",
          BOB: "Bourbon",
          GER: "Geisha",
          PAC: "Pacamara",
        };
        const climateMap = {
          SECO: "🌞 Seco",
          LLUV: "🌧️ Lluvioso",
          TEMP: "🌤️ Templado",
        };
        const processMap = {
          NAT: "Natural (Secado en cereza)",
          HUM: "Húmedo (Lavado)",
          ANH: "Anaeróbico",
        };

        document.getElementById("detailFinca").textContent =
          farmData[farmSelect.value]?.displayName || farmSelect.value;
        document.getElementById("detailVariedad").textContent =
          varietyMap[document.getElementById("variety").value] ||
          document.getElementById("variety").value;
        document.getElementById("detailClima").textContent =
          climateMap[
            document.querySelector('input[name="climate"]:checked').value
          ];
        document.getElementById("detailProceso").textContent =
          processMap[
            document.querySelector('input[name="process"]:checked').value
          ];

        // Mostrar modal de éxito
        document.getElementById("lotDetailsInfo").style.display = "block";
        document.getElementById("successModal").style.display = "flex";
      } catch (error) {
        console.error("Error:", error);
        alert(
          `❌ Error al registrar lote: ${error.message || "Error desconocido"}`
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  </script>
</AdminLayout>
