---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";

const origin = Astro.url.origin;
const cookie = Astro.request.headers.get("cookie") ?? "";
const opts   = { headers: { cookie } };

// ─── Pronóstico de demanda (escrito por api/ml/recompute.py, leído por Node) ──
// Node sí lee la tabla demand_forecasts en local, así que esta sección se ve
// con `npm run dev`. El CRUD de abajo sí requiere la función Python (Vercel).
let forecast: any = { generated_at: null, units: [], revenue: null };
try {
  const rF = await fetch(`${origin}/api/ml/forecast`, opts);
  if (rF.ok) {
    const j = await rF.json();
    if (j?.success && j.data) forecast = j.data;
  }
} catch (_) { /* sección de pronóstico queda vacía */ }

const fcUnits: any[]  = forecast.units ?? [];
const fcRevenue: any  = forecast.revenue;
const fcGeneratedAt   = forecast.generated_at;
const revenueMax = fcRevenue
  ? Math.max(1, ...fcRevenue.points.map((p: any) => p.upper_bound ?? p.forecast_value))
  : 1;
const MODEL_LABEL: Record<string, string> = { holt: "Holt", moving_avg: "Media móvil" };
const fmtCOP  = (n: number) => new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n || 0);
const fmtWeek = (s: string) => new Date(s + "T00:00:00").toLocaleDateString("es-CO", { day: "2-digit", month: "short" });
---

<AdminLayout title="Módulo Python — DobleYo Admin" section="python">
  <header class="page-header">
    <h1>Módulo Python</h1>
    <p>Resultado y operación de la capa Python: pronóstico de demanda y CRUD de registros.</p>
  </header>

  <div class="page-body">
    <div class="info-box" style="margin-top:0">
      <strong>Dos funciones Python en una vista.</strong> Arriba, el
      <strong>pronóstico</strong> que calcula <code>api/ml/recompute.py</code>
      y guarda en <code>demand_forecasts</code> (Node lo lee, por eso se ve aun
      en local). Abajo, el <strong>CRUD</strong> servido por
      <code>api/ml/demand.py</code> sobre Turso; en desarrollo local con Express
      la función no corre (solo en el deploy de Vercel o con <code>vercel dev</code>).
    </div>

    <!-- ═══ 1. Pronóstico (recompute.py) ════════════════════════════════════ -->
    <div class="section-divider" style="margin-top:1.5rem">
      <div>
        <h2>Pronóstico de Demanda</h2>
        <p>Proyección de las próximas 8 semanas desde ventas de MercadoLibre · calculado con Python</p>
        {fcGeneratedAt && (
          <span class="fc-meta">
            Última actualización: {new Date(fcGeneratedAt + " UTC").toLocaleString("es-CO", { dateStyle: "medium", timeStyle: "short" })}
          </span>
        )}
      </div>
      <div>
        <button id="btn-recalc" class="btn-recalc" type="button">Recalcular ahora</button>
        <span id="fc-status" class="fc-status"></span>
      </div>
    </div>

    {(!fcRevenue && fcUnits.length === 0) && (
      <div class="stat-card">
        <p class="stat-empty">
          Aún no hay pronóstico. Pulse <strong>«Recalcular ahora»</strong> o espere a la corrida automática nocturna.
          Requiere ventas registradas en MercadoLibre.
        </p>
      </div>
    )}

    {(fcRevenue || fcUnits.length > 0) && (
      <Fragment>
        {fcRevenue && (
          <div class="kpi-grid">
            <div class="kpi-tile brand">
              <div class="kpi-label">Ingresos proyectados (4 sem)</div>
              <div class="kpi-value" style="font-size:1.4rem">{fmtCOP(fcRevenue.next_4w)}</div>
              <div class="kpi-sub">modelo: {MODEL_LABEL[fcRevenue.model_used] ?? fcRevenue.model_used}</div>
            </div>
            <div class="kpi-tile info">
              <div class="kpi-label">SKUs con demanda</div>
              <div class="kpi-value">{fcUnits.length}</div>
              <div class="kpi-sub">productos pronosticados</div>
            </div>
            <div class="kpi-tile warning">
              <div class="kpi-label">Sugerencias de reorden</div>
              <div class="kpi-value">{fcUnits.filter((u: any) => u.reorder).length}</div>
              <div class="kpi-sub">demanda 4 sem &gt; stock</div>
            </div>
            <div class="kpi-tile success">
              <div class="kpi-label">Historia usada</div>
              <div class="kpi-value">{fcRevenue.history_weeks ?? "—"}</div>
              <div class="kpi-sub">semanas de ventas</div>
            </div>
          </div>
        )}

        <div class="charts-grid">
          {fcRevenue && (
            <div class="stat-card">
              <h3>Ingresos proyectados por semana</h3>
              <div class="bar-chart">
                {fcRevenue.points.map((p: any) => {
                  const pct = Math.round(((p.forecast_value ?? 0) / revenueMax) * 100);
                  return (
                    <div class="bar-col" title={`${fmtCOP(p.lower_bound)} – ${fmtCOP(p.upper_bound)}`}>
                      <div class="bar-fill" style={`background:#c8a96e; height:${Math.max(pct, 2)}%;`}></div>
                      <span class="bar-label">{fmtWeek(p.period_start)}</span>
                    </div>
                  );
                })}
              </div>
              <p class="fc-meta" style="margin-top:.6rem">Pase el cursor sobre cada barra para ver la banda de confianza (~95%).</p>
            </div>
          )}

          <div class="stat-card">
            <h3>Demanda por producto (próximas 4 semanas)</h3>
            {fcUnits.length === 0 ? (
              <p class="stat-empty">Sin demanda por SKU en la última corrida.</p>
            ) : (
              <div style="overflow-x:auto">
                <table class="erp-table">
                  <thead>
                    <tr>
                      <th>Producto</th>
                      <th style="text-align:right">Unidades (4 sem)</th>
                      <th>Stock</th>
                      <th>Reorden</th>
                      <th>Modelo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {fcUnits.slice(0, 12).map((u: any) => (
                      <tr>
                        <td>{u.product_key}</td>
                        <td style="text-align:right; font-weight:700">{u.next_4w}</td>
                        <td>{u.stock_quantity ?? "—"}</td>
                        <td>
                          {u.reorder === true ? (
                            <span class="badge badge--warn">Reordenar</span>
                          ) : u.reorder === false ? (
                            <span class="badge badge--ok">OK</span>
                          ) : (
                            <span class="badge badge--muted">sin match</span>
                          )}
                        </td>
                        <td><span class="badge badge--muted">{MODEL_LABEL[u.model_used] ?? u.model_used}</span></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>

        <div class="fc-note">
          <strong>Nota:</strong> el pronóstico es orientativo. Con MercadoLibre como única fuente y un historial corto,
          úselo como guía de tendencia, no como cifra exacta. La señal de reorden empareja el título del producto de
          MercadoLibre con el catálogo por nombre (best-effort); «sin match» significa que no se encontró en el inventario.
        </div>
      </Fragment>
    )}

    <!-- ═══ 2. CRUD de demanda (demand.py) ══════════════════════════════════ -->
    <div class="section-divider">
      <div>
        <h2>Registros de Demanda</h2>
        <p>Cree, consulte, actualice y elimine registros · servido 100&nbsp;% por <code>api/ml/demand.py</code></p>
      </div>
    </div>

    <div id="alert" class="alert" style="display:none"></div>

    <!-- Formulario de creación -->
    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-header">
        <div>
          <h2 class="card-title">Nuevo registro de demanda</h2>
          <p class="card-subtitle">Los campos marcados con * son obligatorios.</p>
        </div>
      </div>
      <div style="padding:18px">
        <form id="create-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="c-category">Categoría <span class="required">*</span></label>
              <select id="c-category" name="category" required>
                <option value="">Seleccione una categoría…</option>
                <option value="cafe-grano">Café en grano</option>
                <option value="cafe-molido">Café molido</option>
                <option value="accesorios">Accesorios</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="c-product">Producto (opcional)</label>
              <select id="c-product" class="product-select">
                <option value="">— Sin especificar —</option>
              </select>
            </div>
            <div class="form-group form-group--period">
              <label>Período (opcional)</label>
              <div class="period-wrap">
                <div class="period-toggle" id="c-period-toggle">
                  <button type="button" class="period-btn period-btn--on" data-mode="week">Semana</button>
                  <button type="button" class="period-btn" data-mode="month">Mes</button>
                </div>
                <input type="week"  id="c-period-week"  class="period-input" />
                <input type="month" id="c-period-month" class="period-input" style="display:none" />
              </div>
            </div>
            <div class="form-group">
              <label for="c-value">Demanda <span class="required">*</span></label>
              <div class="stepper">
                <button type="button" class="stepper-btn" data-target="c-value" data-delta="-1">−</button>
                <input type="number" id="c-value" name="demand_value" min="0" step="1" value="0" required />
                <button type="button" class="stepper-btn" data-target="c-value" data-delta="1">+</button>
              </div>
            </div>
            <div class="form-group">
              <label for="c-unit">Unidad</label>
              <select id="c-unit" name="unit">
                <option value="units">Unidades</option>
                <option value="kg">Kilogramos (kg)</option>
                <option value="lb">Libras (lb)</option>
                <option value="sacos">Sacos</option>
              </select>
            </div>
            <div class="form-group form-group--wide">
              <button type="button" class="notes-toggle" id="c-notes-toggle">+ Agregar nota</button>
              <textarea id="c-notes" name="notes" placeholder="Observaciones…" style="display:none;margin-top:8px"></textarea>
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-save">Crear registro</button>
            <button type="button" class="btn btn-secondary" id="c-clear-btn">Limpiar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Filtros de exportación -->
    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-header">
        <div>
          <h2 class="card-title">Exportar a Excel</h2>
          <p class="card-subtitle">Aplique los filtros y descargue solo los registros que necesita.</p>
        </div>
      </div>
      <div style="padding:18px">
        <div class="form-grid">
          <div class="form-group">
            <label for="ex-category">Categoría</label>
            <select id="ex-category">
              <option value="">Todas</option>
              <option value="cafe-grano">Café en grano</option>
              <option value="cafe-molido">Café molido</option>
              <option value="accesorios">Accesorios</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div class="form-group">
            <label for="ex-product">Producto</label>
            <select id="ex-product" class="product-select">
              <option value="">Todos</option>
            </select>
          </div>
          <div class="form-group form-group--period">
            <label>Período</label>
            <div class="period-wrap">
              <div class="period-toggle" id="ex-period-toggle">
                <button type="button" class="period-btn period-btn--on" data-mode="none">Cualquiera</button>
                <button type="button" class="period-btn" data-mode="week">Semana</button>
                <button type="button" class="period-btn" data-mode="month">Mes</button>
              </div>
              <input type="week"  id="ex-period-week"  class="period-input" style="display:none" />
              <input type="month" id="ex-period-month" class="period-input" style="display:none" />
            </div>
          </div>
          <div class="form-group">
            <label for="ex-value-min">Demanda mínima</label>
            <input type="number" id="ex-value-min" min="0" step="0.01" placeholder="0" />
          </div>
          <div class="form-group">
            <label for="ex-value-max">Demanda máxima</label>
            <input type="number" id="ex-value-max" min="0" step="0.01" placeholder="sin límite" />
          </div>
          <div class="form-group">
            <label for="ex-limit">Límite de filas</label>
            <input type="number" id="ex-limit" min="1" max="10000" value="5000" />
          </div>
        </div>
        <div class="form-actions">
          <button type="button" id="btn-export" class="btn btn-save">Descargar Excel</button>
          <button type="button" id="btn-export-clear" class="btn btn-secondary">Limpiar filtros</button>
        </div>
      </div>
    </div>

    <!-- Listado -->
    <div class="card">
      <div class="card-header">
        <div>
          <h2 class="card-title">Registros de demanda</h2>
          <p class="card-subtitle" id="count-label">—</p>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <input type="text" id="filter-category" placeholder="Filtrar por categoría…" style="max-width:220px" />
          <button class="btn btn-secondary" id="btn-refresh" type="button">Actualizar</button>
        </div>
      </div>
      <div style="overflow-x:auto">
        <table class="erp-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Categoría</th>
              <th>Producto</th>
              <th>Período</th>
              <th style="text-align:right">Demanda</th>
              <th>Unidad</th>
              <th>Actualizado</th>
              <th style="text-align:right">Acciones</th>
            </tr>
          </thead>
          <tbody id="rows">
            <tr><td colspan="8" class="empty-state">Cargando…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Modal de edición -->
  <div class="modal" id="edit-modal" style="display:none">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Editar registro</h3>
        <button class="btn btn-secondary" id="edit-close" type="button" aria-label="Cerrar">✕</button>
      </div>
      <form id="edit-form">
        <div class="modal-body">
          <input type="hidden" id="e-id" />
          <div class="form-grid">
            <div class="form-group">
              <label for="e-category">Categoría <span class="required">*</span></label>
              <input type="text" id="e-category" required />
            </div>
            <div class="form-group">
              <label for="e-product">Producto</label>
              <input type="text" id="e-product" />
            </div>
            <div class="form-group">
              <label for="e-period">Período</label>
              <input type="text" id="e-period" />
            </div>
            <div class="form-group">
              <label for="e-value">Demanda <span class="required">*</span></label>
              <input type="number" id="e-value" min="0" step="0.01" required />
            </div>
            <div class="form-group">
              <label for="e-unit">Unidad</label>
              <input type="text" id="e-unit" />
            </div>
            <div class="form-group form-group--wide">
              <label for="e-notes">Notas</label>
              <textarea id="e-notes"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" id="edit-cancel">Cancelar</button>
          <button type="submit" class="btn btn-save">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .page-header {
      padding: 1.75rem 2rem 1.25rem;
      background: var(--paper);
      border-bottom: 1px solid var(--rule);
    }
    .page-header h1 { font-size: 1.6rem; font-weight: 700; color: var(--color-primary); margin: 0 0 .25rem; }
    .page-header p  { margin: 0; color: var(--muted); font-size: .92rem; }
    .page-body { padding: 1.5rem 2rem 2rem; }
    @media (max-width: 640px) {
      .page-header { padding: 1.25rem 1rem 1rem; }
      .page-body { padding: 1rem; }
    }
    .row-actions { display: flex; gap: 6px; justify-content: flex-end; }
    code { background: var(--hover); padding: 1px 5px; border-radius: 4px; font-size: .85em; }

    /* ── Pronóstico (copiado del patrón de estadísticas) ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      background: #fff;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      border-radius: 6px;
      box-shadow: var(--card-shadow, 0 0 0 1px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.05));
      padding: 1.25rem 1.5rem;
    }
    .stat-card h3 {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-2, #6a6d70);
      margin: 0 0 0.75rem;
    }
    .stat-empty { color: var(--text-3, #a9b0b8); font-size: 0.88rem; text-align: center; padding: 1.5rem 0; }

    .bar-chart {
      height: 180px;
      display: flex;
      align-items: flex-end;
      gap: 0.4rem;
      border-bottom: 2px solid var(--border, rgba(0,0,0,.09));
      padding-bottom: 0.4rem;
    }
    .bar-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      height: 100%;
      justify-content: flex-end;
    }
    .bar-fill { width: 100%; border-radius: 3px 3px 0 0; }
    .bar-label { font-size: 0.7rem; color: var(--text-2, #6a6d70); }

    .section-divider {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin: 2.5rem 0 1.25rem;
      padding-top: 1.75rem;
      border-top: 2px solid var(--border, rgba(0,0,0,.09));
    }
    .section-divider h2 { font-size: 1.25rem; font-weight: 700; color: #251a14; margin: 0; }
    .section-divider p  { margin: .2rem 0 0; color: #7a6652; font-size: .85rem; }
    .fc-meta { font-size: .78rem; color: var(--text-3, #a9b0b8); }

    .btn-recalc {
      background: #c8a96e;
      color: #251a14;
      border: 0;
      border-radius: 6px;
      padding: .55rem 1.1rem;
      font-size: .85rem;
      font-weight: 700;
      cursor: pointer;
      transition: filter .15s;
    }
    .btn-recalc:hover:not(:disabled) { filter: brightness(.95); }
    .btn-recalc:disabled { opacity: .6; cursor: progress; }
    .fc-status { font-size: .8rem; margin-left: .75rem; color: #7a6652; }

    .badge {
      display: inline-block;
      padding: .15rem .5rem;
      border-radius: 9999px;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .02em;
    }
    .badge--warn  { background: #fbe7d2; color: #8a5a00; }
    .badge--ok    { background: #dff0e4; color: #2d6a4f; }
    .badge--muted { background: var(--border, rgba(0,0,0,.08)); color: var(--text-2, #6a6d70); }

    .fc-note {
      background: #faf8f5;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      border-left: 3px solid #c8a96e;
      border-radius: 4px;
      padding: .7rem 1rem;
      font-size: .82rem;
      color: #6a5a48;
      margin-top: 1rem;
    }
  </style>

  <!-- ── Script 1: recalcular pronóstico (recompute.py) ── -->
  <script>
    const btn = document.getElementById("btn-recalc") as HTMLButtonElement | null;
    const status = document.getElementById("fc-status");
    btn?.addEventListener("click", async () => {
      if (!status) return;
      btn.disabled = true;
      status.textContent = "Calculando…";
      try {
        const r = await fetch("/api/ml/forecast/recompute", { method: "POST", credentials: "include" });
        const j = await r.json();
        if (r.ok && j.success) {
          status.textContent = `Listo: ${j.data?.rows_written ?? 0} filas. Recargando…`;
          setTimeout(() => location.reload(), 900);
        } else {
          status.textContent = j.error || "No se pudo recalcular.";
          btn.disabled = false;
        }
      } catch {
        status.textContent = "Error de red al recalcular.";
        btn.disabled = false;
      }
    });
  </script>

  <!-- ── Script 2: CRUD de demanda (demand.py) ── -->
  <script>
    const API = "/api/ml/demand";
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const rowsEl = $("rows") as HTMLTableSectionElement;
    const alertEl = $("alert");
    const countEl = $("count-label");

    let cache: any[] = [];

    function showAlert(msg: string, kind: "error" | "success" = "error") {
      alertEl.className = "alert alert--" + (kind === "success" ? "success" : "error");
      alertEl.textContent = msg;
      alertEl.style.display = "block";
      if (kind === "success") setTimeout(() => (alertEl.style.display = "none"), 3000);
    }

    function esc(s: any): string {
      return String(s ?? "").replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
    }

    function fmtDate(s: string): string {
      if (!s) return "—";
      const d = new Date(s.replace(" ", "T") + "Z");
      return isNaN(+d) ? s : d.toLocaleString("es-CO", { dateStyle: "short", timeStyle: "short" });
    }

    async function api(method: string, body?: any, qs = ""): Promise<any> {
      const res = await fetch(API + qs, {
        method,
        credentials: "include",
        headers: body ? { "Content-Type": "application/json" } : undefined,
        body: body ? JSON.stringify(body) : undefined,
      });
      let json: any = null;
      try { json = await res.json(); } catch { /* respuesta no-JSON */ }
      if (!res.ok || !json?.success) {
        const err = json?.error || (json?.errors ? json.errors.join(", ") : `Error ${res.status}`);
        throw new Error(err);
      }
      return json;
    }

    function render(records: any[]) {
      cache = records;
      countEl.textContent = `${records.length} registro(s)`;
      if (!records.length) {
        rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">Sin registros. Cree el primero arriba.</td></tr>`;
        return;
      }
      rowsEl.innerHTML = records.map((r) => `
        <tr>
          <td>${r.id}</td>
          <td><span class="badge badge-neutral">${esc(r.category)}</span></td>
          <td>${esc(r.product_key) || "—"}</td>
          <td>${esc(r.period) || "—"}</td>
          <td style="text-align:right;font-weight:700;font-variant-numeric:tabular-nums">${esc(r.demand_value)}</td>
          <td>${esc(r.unit)}</td>
          <td style="white-space:nowrap">${fmtDate(r.updated_at)}</td>
          <td>
            <div class="row-actions">
              <button class="btn btn-secondary" data-edit="${r.id}" type="button">Editar</button>
              <button class="btn btn-danger" data-del="${r.id}" type="button">Borrar</button>
            </div>
          </td>
        </tr>`).join("");
    }

    async function load() {
      const cat = ($("filter-category") as HTMLInputElement).value.trim();
      rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">Cargando…</td></tr>`;
      try {
        const json = await api("GET", undefined, cat ? `?category=${encodeURIComponent(cat)}` : "");
        render(json.data || []);
      } catch (e: any) {
        rowsEl.innerHTML = `<tr><td colspan="8" class="empty-state">No se pudo cargar: ${esc(e.message)}</td></tr>`;
      }
    }

    // ── Crear ──
    ($("create-form") as HTMLFormElement).addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const f = ev.target as HTMLFormElement;
      const payload = {
        category: (f.elements.namedItem("category") as HTMLInputElement).value,
        product_key: (f.elements.namedItem("product_key") as HTMLInputElement).value,
        period: (f.elements.namedItem("period") as HTMLInputElement).value,
        demand_value: (f.elements.namedItem("demand_value") as HTMLInputElement).value,
        unit: (f.elements.namedItem("unit") as HTMLInputElement).value,
        notes: (f.elements.namedItem("notes") as HTMLTextAreaElement).value,
      };
      try {
        await api("POST", payload);
        f.reset();
        (f.elements.namedItem("unit") as HTMLInputElement).value = "units";
        showAlert("Registro creado correctamente.", "success");
        load();
      } catch (e: any) { showAlert(e.message); }
    });

    // ── Editar / Borrar (delegación) ──
    rowsEl.addEventListener("click", async (ev) => {
      const t = ev.target as HTMLElement;
      const editId = t.getAttribute("data-edit");
      const delId = t.getAttribute("data-del");
      if (editId) openEdit(Number(editId));
      if (delId) {
        if (!confirm("¿Eliminar este registro de demanda? Esta acción no se puede deshacer.")) return;
        try {
          await api("DELETE", undefined, `?id=${delId}`);
          showAlert("Registro eliminado.", "success");
          load();
        } catch (e: any) { showAlert(e.message); }
      }
    });

    function openEdit(id: number) {
      const r = cache.find((x) => x.id === id);
      if (!r) return;
      ($("e-id") as HTMLInputElement).value = String(r.id);
      ($("e-category") as HTMLInputElement).value = r.category ?? "";
      ($("e-product") as HTMLInputElement).value = r.product_key ?? "";
      ($("e-period") as HTMLInputElement).value = r.period ?? "";
      ($("e-value") as HTMLInputElement).value = r.demand_value ?? "";
      ($("e-unit") as HTMLInputElement).value = r.unit ?? "";
      ($("e-notes") as HTMLTextAreaElement).value = r.notes ?? "";
      $("edit-modal").style.display = "grid";
    }
    function closeEdit() { $("edit-modal").style.display = "none"; }
    $("edit-close").addEventListener("click", closeEdit);
    $("edit-cancel").addEventListener("click", closeEdit);

    ($("edit-form") as HTMLFormElement).addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const id = ($("e-id") as HTMLInputElement).value;
      const payload = {
        category: ($("e-category") as HTMLInputElement).value,
        product_key: ($("e-product") as HTMLInputElement).value,
        period: ($("e-period") as HTMLInputElement).value,
        demand_value: ($("e-value") as HTMLInputElement).value,
        unit: ($("e-unit") as HTMLInputElement).value,
        notes: ($("e-notes") as HTMLTextAreaElement).value,
      };
      try {
        await api("PUT", payload, `?id=${id}`);
        closeEdit();
        showAlert("Registro actualizado.", "success");
        load();
      } catch (e: any) { showAlert(e.message); }
    });

    $("btn-refresh").addEventListener("click", load);

    $("btn-export").addEventListener("click", () => {
      const val = (id: string) => ($(`ex-${id}`) as HTMLInputElement).value.trim();
      const qs = new URLSearchParams({ export: "xlsx" });
      if (val("category"))  qs.set("category",  val("category"));
      if (val("product"))   qs.set("product",   val("product"));
      if (val("period"))    qs.set("period",    val("period"));
      if (val("value-min")) qs.set("value_min", val("value-min"));
      if (val("value-max")) qs.set("value_max", val("value-max"));
      if (val("limit"))     qs.set("limit",     val("limit"));
      window.location.href = `${API}?${qs.toString()}`;
    });

    $("btn-export-clear").addEventListener("click", () => {
      ["category","product","period","value-min","value-max"].forEach(
        (id) => { ($(`ex-${id}`) as HTMLInputElement).value = ""; }
      );
      ($("ex-limit") as HTMLInputElement).value = "5000";
    });
    let filterTimer: any;
    ($("filter-category") as HTMLInputElement).addEventListener("input", () => {
      clearTimeout(filterTimer);
      filterTimer = setTimeout(load, 350);
    });

    load();
  </script>
</AdminLayout>
