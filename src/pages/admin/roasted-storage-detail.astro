---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout
  title="Detalle de Café Almacenado"
  description="Información completa del café tostado en almacén"
>
  <div id="detailContainer" style="display: none;">
    <!-- Header con Lote ID -->
    <div class="detail-header">
      <h2 id="headerTitle">Café Tostado Almacenado</h2>
      <div class="header-badge" id="statusBadge">En Almacén</div>
    </div>

    <!-- Información del Lote -->
    <div class="card">
      <h3>Información del Lote de Café</h3>
      <div class="detail-grid">
        <div class="detail-item">
          <div class="detail-label">ID del Lote</div>
          <div class="detail-value" id="detailLotId">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Variedad</div>
          <div class="detail-value" id="detailVariety">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Clima de Cultivo</div>
          <div class="detail-value" id="detailClimate">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Región Productora</div>
          <div class="detail-value" id="detailRegion">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Altitud</div>
          <div class="detail-value" id="detailAltitude">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Método de Procesamiento</div>
          <div class="detail-value" id="detailProcess">—</div>
        </div>
      </div>
    </div>

    <!-- Características del Café -->
    <div class="card">
      <h3>Perfil Sensorial</h3>
      <div class="detail-grid">
        <div class="detail-item">
          <div class="detail-label">Aroma</div>
          <div class="detail-value" id="detailAroma">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Notas de Sabor</div>
          <div class="detail-value" id="detailTaste">—</div>
        </div>
      </div>
    </div>

    <!-- Información de Tostión -->
    <div class="card">
      <h3>Detalles de la Tostión</h3>
      <div class="detail-grid">
        <div class="detail-item">
          <div class="detail-label">Nivel de Tueste</div>
          <div class="detail-value detail-roast" id="detailRoastLevel">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Peso Tostado</div>
          <div class="detail-value" id="detailWeight">—</div>
        </div>
      </div>
    </div>

    <!-- Información de Almacenamiento -->
    <div class="card">
      <h3>Información de Almacenamiento</h3>
      <div class="detail-grid">
        <div class="detail-item">
          <div class="detail-label">Ubicación en Bodega</div>
          <div class="detail-value" id="detailLocation">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Tipo de Contenedor</div>
          <div class="detail-value" id="detailContainerType">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Cantidad de Contenedores</div>
          <div class="detail-value" id="detailContainerCount">—</div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Fecha de Almacenamiento</div>
          <div class="detail-value" id="detailStorageDate">—</div>
        </div>
      </div>
    </div>

    <!-- Condiciones de Almacenamiento -->
    <div class="card" id="conditionsCard" style="display: none;">
      <h3>Condiciones de Almacenamiento</h3>
      <div class="conditions-list" id="conditionsList"></div>
    </div>

    <!-- Notas -->
    <div class="card" id="notesCard" style="display: none;">
      <h3>Notas</h3>
      <div class="notes-content" id="notesContent"></div>
    </div>

    <!-- Botones de Acción -->
    <div class="action-buttons">
      <button
        type="button"
        class="btn-secondary"
        onclick="window.location.href='/admin/roasted-storage'"
      >
        ← Volver a Almacenar
      </button>
      <button
        type="button"
        class="btn-primary"
        id="goToPackagingBtn"
        onclick="goToPackaging()"
      >
        Ir a Empaquetado →
      </button>
    </div>
  </div>

  <!-- Estado de Carga -->
  <div id="loadingState">
    <div class="loading-spinner"></div>
    <p>Cargando detalles del café almacenado...</p>
  </div>

  <!-- Estado de Error -->
  <div id="errorState" style="display: none;">
    <div class="error-box">
      <p id="errorMessage">Error al cargar los detalles</p>
      <button
        type="button"
        class="btn-secondary"
        onclick="window.location.href='/admin/roasted-storage'"
      >
        Volver
      </button>
    </div>
  </div>

  <script>
    let currentStorageId = null;

    async function loadStorageDetail() {
      // Obtener el ID de almacenamiento de la URL
      const params = new URLSearchParams(window.location.search);
      const storageId = params.get("id");

      if (!storageId) {
        showError("No se especificó un café para mostrar");
        return;
      }

      currentStorageId = storageId;

      try {
        // Obtener detalles del almacenamiento
        const response = await fetch(
          `/api/coffee/roasted-storage/${storageId}`,
          {
            credentials: "include",
            headers: {
              "Content-Type": "application/json",
            },
          }
        );

        if (!response.ok) {
          throw new Error("Error al cargar los detalles");
        }

        const data = await response.json();
        populateDetails(data);
      } catch (error) {
        console.error("Error:", error);
        showError(error.message || "Error al cargar los detalles");
      }
    }

    function populateDetails(data) {
      // Validar que los datos existan
      if (!data) {
        console.error("[Roasted Storage Detail] Data is null or undefined");
        showError("Los datos del café almacenado no se cargaron correctamente");
        return;
      }

      console.log("[Roasted Storage Detail] Populating with data:", data);

      // Información del lote
      document.getElementById("detailLotId").textContent = data.lot_id || "—";
      document.getElementById("detailVariety").textContent =
        data.variety || "—";
      document.getElementById("detailClimate").textContent =
        data.climate || "—";
      document.getElementById("detailRegion").textContent = data.region || "—";
      document.getElementById("detailAltitude").textContent = data.altitude
        ? `${data.altitude} msnm`
        : "—";
      document.getElementById("detailProcess").textContent =
        data.process || "—";

      // Perfil sensorial
      document.getElementById("detailAroma").textContent = data.aroma || "—";
      document.getElementById("detailTaste").textContent =
        data.taste_notes || "—";

      // Tostión
      const roastLevels = {
        LIGHT: "Clara",
        MEDIUM: "Media",
        DARK: "Oscura",
      };
      document.getElementById("detailRoastLevel").textContent =
        roastLevels[data.roast_level] || data.roast_level || "—";
      document.getElementById("detailWeight").textContent = data.weight_kg
        ? `${data.weight_kg} kg`
        : "—";

      // Almacenamiento
      document.getElementById("detailLocation").textContent =
        data.location || "—";

      const containerLabels = {
        "BAG-1KG": "Bolsas de 1 kg",
        "BAG-5KG": "Bolsas de 5 kg",
        "BUCKET-25": "Cubeta de 25 kg",
        "SACK-60": "Saco de 60 kg",
      };
      document.getElementById("detailContainerType").textContent =
        containerLabels[data.container] || data.container || "—";
      document.getElementById("detailContainerCount").textContent =
        data.container_count || "—";
      document.getElementById("detailStorageDate").textContent =
        data.storage_date
          ? new Date(data.storage_date).toLocaleDateString("es-CO", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          : "—";

      // Condiciones
      if (data.conditions && data.conditions.length > 0) {
        const conditionLabels = {
          sealed: "✓ Sellado herméticas",
          cool: "✓ Lugar fresco y seco",
          dark: "✓ Protegido de luz directa",
        };
        const conditionsList = document.getElementById("conditionsList");
        conditionsList.innerHTML = data.conditions
          .map(
            (c) =>
              `<div class="condition-item">${conditionLabels[c] || c}</div>`
          )
          .join("");
        document.getElementById("conditionsCard").style.display = "block";
      }

      // Notas
      if (data.notes) {
        document.getElementById("notesContent").textContent = data.notes;
        document.getElementById("notesCard").style.display = "block";
      }

      // Mostrar detalles y ocultar carga
      document.getElementById("detailContainer").style.display = "block";
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("headerTitle").textContent =
        `Café ${data.lot_id} - Almacenado`;
    }

    function showError(message) {
      document.getElementById("errorMessage").textContent = message;
      document.getElementById("errorState").style.display = "block";
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("detailContainer").style.display = "none";
    }

    function goToPackaging() {
      console.log(
        "[Roasted Storage Detail] goToPackaging called with storageId:",
        currentStorageId
      );
      // Navegar a la página de packaging
      window.location.href = "/admin/packaging";
    }

    loadStorageDetail();
  </script>
</AdminLayout>
