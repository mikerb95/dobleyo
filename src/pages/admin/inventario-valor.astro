---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Valor de Inventario — DobleYo Admin" section="inventario">
  <!-- Page Header -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">
          <a href="/admin/inventario">← Inventario</a>
        </div>
        <div class="page-title">Valor de Inventario</div>
      </div>
      <div class="page-header-actions">
        <button class="btn btn-secondary" id="btnRefresh" title="Actualizar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"/>
            <polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          Actualizar
        </button>
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="erp-body">

    <!-- KPI row -->
    <div class="kpi-row" id="kpiRow">
      <div class="kpi-tile brand">
        <div class="kpi-label">Valor total</div>
        <div class="kpi-value" id="kpiTotal">—</div>
        <div class="kpi-sub">Inventario activo</div>
      </div>
      <div class="kpi-tile success">
        <div class="kpi-label">Productos activos</div>
        <div class="kpi-value" id="kpiProducts">—</div>
        <div class="kpi-sub">Con stock disponible</div>
      </div>
      <div class="kpi-tile info">
        <div class="kpi-label">Unidades en stock</div>
        <div class="kpi-value" id="kpiUnits">—</div>
        <div class="kpi-sub">Total de unidades</div>
      </div>
    </div>

    <!-- Table card -->
    <div class="card" id="tableCard">
      <div class="card-header">
        <div>
          <div class="card-title">Desglose por producto</div>
          <div class="card-subtitle">Ordenado por valor total descendente</div>
        </div>
      </div>
      <div style="overflow-x:auto">
        <table class="erp-table" id="valorTable">
          <thead>
            <tr>
              <th style="width:36px">#</th>
              <th>Producto</th>
              <th>Categoría</th>
              <th style="text-align:right">Precio unit.</th>
              <th style="text-align:right">Stock</th>
              <th style="text-align:right">Valor total</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr>
              <td colspan="6">
                <div class="empty-state">
                  <div class="skeleton" style="width:120px;margin:0 auto 8px"></div>
                  <div class="skeleton" style="width:80px;margin:0 auto"></div>
                </div>
              </td>
            </tr>
          </tbody>
          <tfoot id="tableFoot" style="display:none">
            <tr>
              <td colspan="5" style="padding:12px 16px;font-weight:700;border-top:2px solid var(--border);background:#fafafa;font-size:13px">
                Total inventario activo (<span id="footCount">0</span> productos)
              </td>
              <td style="text-align:right;padding:12px 16px;font-weight:700;border-top:2px solid var(--border);background:#fafafa;font-size:13px" id="footTotal">—</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

  </div>
</AdminLayout>

<style>
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .kpi-row { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .kpi-row { grid-template-columns: 1fr; }
  }

  .cat-cafe       { background: #fff8f1; color: #92400e; border: 1px solid #fed7aa; }
  .cat-accesorio  { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
  .cat-merchandising { background: #fdf4ff; color: #6b21a8; border: 1px solid #e9d5ff; }

  .value-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-content: flex-end;
  }
  .value-bar-bg {
    width: 60px;
    height: 5px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .value-bar-fill {
    height: 100%;
    background: var(--brand);
    border-radius: 99px;
    transition: width 0.5s ease;
  }

  .sku-text {
    font-size: 11px;
    color: var(--brand-dark);
    font-weight: 500;
  }
</style>

<script>
  function formatCOP(n: number) {
    return new Intl.NumberFormat("es-CO", {
      style: "currency",
      currency: "COP",
      minimumFractionDigits: 0,
    }).format(n);
  }

  async function loadData() {
    try {
      const res = await fetch("/api/inventory/products?active=true&sortBy=name", {
        credentials: "include",
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.error ?? "Error al cargar");

      const rows = (data.products ?? [])
        .map((p: any) => ({ ...p, valor: (p.stock_quantity ?? 0) * (p.price ?? 0) }))
        .sort((a: any, b: any) => b.valor - a.valor);

      const totalVal = rows.reduce((s: number, r: any) => s + r.valor, 0);
      const totalUnits = rows.reduce((s: number, r: any) => s + (r.stock_quantity ?? 0), 0);
      const maxValor = rows[0]?.valor || 1;

      (document.getElementById("kpiTotal") as HTMLElement).textContent = formatCOP(totalVal);
      (document.getElementById("kpiProducts") as HTMLElement).textContent = String(rows.length);
      (document.getElementById("kpiUnits") as HTMLElement).textContent = totalUnits.toLocaleString("es-CO");

      const tbody = document.getElementById("tableBody")!;
      tbody.innerHTML = rows.map((p: any, i: number) => {
        const stockClass =
          p.stock_quantity === 0 ? "badge-error"
          : p.stock_quantity <= (p.stock_min ?? 5) ? "badge-warning"
          : "badge-success";
        const catClass = p.category === "cafe" ? "cat-cafe"
          : p.category === "accesorio" ? "cat-accesorio"
          : "cat-merchandising";
        const barPct = Math.round((p.valor / maxValor) * 100);

        return `
          <tr>
            <td style="color:var(--text-3);font-size:12px">${i + 1}</td>
            <td>
              <strong style="font-size:13px">${p.name}</strong>
              ${p.sku ? `<br><span class="sku-text">${p.sku}</span>` : ""}
            </td>
            <td>
              <span class="badge ${catClass}">${p.category}</span>
            </td>
            <td style="text-align:right;font-variant-numeric:tabular-nums">${formatCOP(p.price ?? 0)}</td>
            <td style="text-align:right">
              <span class="badge ${stockClass}">${p.stock_quantity ?? 0}</span>
            </td>
            <td style="text-align:right">
              <div class="value-bar-wrap">
                <div class="value-bar-bg">
                  <div class="value-bar-fill" style="width:${barPct}%"></div>
                </div>
                <strong style="font-variant-numeric:tabular-nums;white-space:nowrap">${formatCOP(p.valor)}</strong>
              </div>
            </td>
          </tr>
        `;
      }).join("");

      (document.getElementById("footCount") as HTMLElement).textContent = String(rows.length);
      (document.getElementById("footTotal") as HTMLElement).textContent = formatCOP(totalVal);
      (document.getElementById("tableFoot") as HTMLElement).style.display = "";

    } catch (err: any) {
      (document.getElementById("tableBody") as HTMLElement).innerHTML = `
        <tr><td colspan="6"><div class="empty-state" style="color:var(--c-error)">${err.message}</div></td></tr>
      `;
    }
  }

  document.getElementById("btnRefresh")?.addEventListener("click", loadData);
  loadData();
</script>
