---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SalesHeatmap from "../../components/SalesHeatmap.jsx";
---

<AdminLayout title="Mapa de Ventas — DobleYo Admin" section="sales-map">
  <!-- ── Encabezado de página ──────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header-top">
      <div>
        <div class="page-breadcrumb">Analítica · Geografía de ventas</div>
        <h1 class="page-title">Mapa de Calor de Ventas</h1>
        <p class="page-subtitle">
          Distribución geográfica combinada de la tienda web y MercadoLibre. Filtre por período, canal o producto.
        </p>
      </div>
    </div>
  </div>

  <div class="erp-body sm-page">

    <!-- ── Panel de geocodificación ──────────────────────────────────── -->
    <div class="card sm-geo">
      <div class="sm-geo-icon" id="geo-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <div class="sm-geo-info">
        <div class="sm-geo-label">Geocodificación de órdenes</div>
        <p id="geocoding-status">Consultando estado…</p>
      </div>
      <div class="sm-geo-actions">
        <span id="backfill-msg"></span>
        <button id="btn-backfill" class="btn btn-save" disabled>Geocodificar pendientes</button>
      </div>
    </div>

    <!-- ── Mapa (React island) ───────────────────────────────────────── -->
    <SalesHeatmap client:only="react" />

    <!-- ── Cómo funciona ─────────────────────────────────────────────── -->
    <div class="card sm-info">
      <div class="card-header">
        <h3 class="card-title">¿Cómo funciona este mapa?</h3>
      </div>
      <div class="sm-info-body">
        <ul>
          <li><strong>Datos combinados:</strong> integra pedidos de la tienda web y de MercadoLibre en una sola vista.</li>
          <li><strong>Filtros:</strong> por período (7 / 30 / 90 / 365 días o todo el tiempo), canal de venta o nombre de producto.</li>
          <li><strong>Intensidad de calor:</strong> de amarillo claro (pocas ventas) a rojo oscuro (muchas ventas).</li>
          <li><strong>Marcadores:</strong> haga clic en cualquier círculo para ver ciudad, pedidos, ventas en COP y desglose por canal.</li>
          <li><strong>Geocodificación:</strong> las nuevas órdenes se geocodifican automáticamente. Use el botón <em>«Geocodificar pendientes»</em> para procesar órdenes antiguas sin coordenadas.</li>
          <li><strong>Exportar:</strong> descargue los datos del filtro activo como CSV con el botón <em>«↓ CSV»</em>.</li>
        </ul>
      </div>
    </div>

  </div>

  <style is:global>
    /* =================================================================
       Mapa de ventas — Claude Design
       ============================================================== */
    .sm-page { max-width: 1280px; }

    /* Panel de geocodificación */
    .sm-geo {
      display: flex; align-items: center; gap: 16px;
      padding: 16px 18px; margin-bottom: 20px;
    }
    .sm-geo-icon {
      width: 42px; height: 42px; border-radius: 10px; flex-shrink: 0;
      display: grid; place-items: center;
      background: var(--active-bg); color: var(--color-accent);
    }
    .sm-geo-icon.ok { background: var(--c-success-bg); color: var(--c-success); }
    .sm-geo-icon.warn { background: var(--c-warning-bg); color: var(--c-warning); }
    .sm-geo-info { flex: 1; min-width: 180px; }
    .sm-geo-label { font-size: 13px; font-weight: 600; color: var(--color-primary); }
    #geocoding-status { margin: 2px 0 0; font-size: 12.5px; color: var(--muted); }
    .sm-geo-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    #backfill-msg { font-size: 12px; color: var(--ok); font-weight: 600; display: none; }
    #btn-backfill:disabled { opacity: .5; cursor: not-allowed; }

    /* ===== Componente heatmap ===== */
    .hm-root { display: block; }

    .hm-filters {
      display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;
      background: var(--paper); border: 1px solid var(--rule);
      border-radius: var(--radius); padding: 16px 18px; margin-bottom: 18px;
      box-shadow: var(--card-shadow);
    }
    .hm-field { margin-bottom: 0; min-width: 150px; }
    .hm-field--grow { flex: 1; min-width: 180px; }
    .hm-filter-actions { display: flex; gap: 8px; align-items: flex-end; flex-wrap: wrap; }

    .hm-kpis { margin-bottom: 18px; }
    .hm-kpi-value { font-size: 20px; }

    /* Mapa */
    .hm-map-card { padding: 0; overflow: hidden; margin-bottom: 20px; }
    .hm-map-wrap { position: relative; width: 100%; }
    .hm-map {
      width: 100%;
      height: clamp(420px, 58vh, 640px);
      background: color-mix(in oklab, var(--color-primary) 4%, white);
    }
    .leaflet-container { font-family: inherit; background: color-mix(in oklab, var(--color-primary) 4%, white); }

    .hm-map-overlay {
      position: absolute; inset: 0; z-index: 500;
      display: flex; align-items: center; justify-content: center; gap: 10px;
      background: color-mix(in oklab, var(--paper) 78%, transparent);
      backdrop-filter: blur(1.5px);
      color: var(--muted); font-size: 13.5px; font-weight: 500;
      text-align: center; padding: 24px;
    }
    .hm-empty { display: grid; justify-items: center; gap: 12px; max-width: 360px; }
    .hm-empty svg { color: var(--rule-2); }
    .hm-empty b { color: var(--color-primary); }
    .hm-empty p { margin: 0; line-height: 1.6; }

    /* Leyenda */
    .hm-legend {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
      padding: 12px 18px; border-top: 1px solid var(--rule);
      background: color-mix(in oklab, var(--color-primary) 2%, white);
    }
    .hm-legend-label {
      font-size: 11px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted);
    }
    .hm-legend-scale { display: flex; align-items: center; gap: 6px; }
    .hm-legend-scale > span { font-size: 11.5px; color: var(--muted); }
    .hm-legend-swatch {
      width: 30px; height: 12px; border-radius: 3px;
      border: 1px solid color-mix(in oklab, var(--color-primary) 10%, transparent);
    }

    /* Tabla top ciudades */
    .hm-table-card { padding: 0; overflow: hidden; }
    .hm-rank {
      text-align: center; font-weight: 700; color: var(--color-accent);
      font-variant-numeric: tabular-nums;
    }
    .hm-sales {
      text-align: right; font-weight: 600; color: var(--ok);
      font-variant-numeric: tabular-nums;
    }

    /* Info panel */
    .sm-info { margin-top: 20px; }
    .sm-info-body { padding: 16px 18px; }
    .sm-info-body ul {
      margin: 0; padding-left: 18px; color: var(--color-text);
      line-height: 1.8; font-size: 13.5px;
    }
    .sm-info-body strong { color: var(--color-primary); }
    .sm-info-body em { color: var(--color-accent); font-style: normal; font-weight: 600; }

    /* Popups de Leaflet con estética del sistema */
    .leaflet-popup-content-wrapper { border-radius: var(--radius-sm); }
    .leaflet-bar a, .leaflet-touch .leaflet-bar a { color: var(--color-primary); }
  </style>

  <script>
    // Consultar estado de geocodificación y manejar backfill
    (async () => {
      const statusEl = document.getElementById("geocoding-status");
      const iconEl = document.getElementById("geo-icon");
      const btn = document.getElementById("btn-backfill");
      const msgEl = document.getElementById("backfill-msg");

      try {
        const res = await fetch("/api/heatmap/stats", { credentials: "include" });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error ?? "Error");

        const { pending_geocoding, total_orders } = json.data ?? {};
        if (pending_geocoding === 0) {
          statusEl.textContent = `Todas las órdenes están geocodificadas (${total_orders ?? "—"} en total).`;
          iconEl.classList.add("ok");
        } else {
          statusEl.textContent = `${pending_geocoding} órdenes sin coordenadas de ${total_orders ?? "?"} totales.`;
          iconEl.classList.add("warn");
          btn.disabled = false;
        }
      } catch (err) {
        statusEl.textContent = "No se pudo consultar el estado de geocodificación.";
        iconEl.classList.add("warn");
        console.error(err);
      }

      btn.addEventListener("click", async () => {
        btn.disabled = true;
        btn.textContent = "Geocodificando…";
        msgEl.style.display = "none";
        try {
          const res = await fetch("/api/heatmap/backfill", {
            method: "POST",
            credentials: "include",
          });
          const json = await res.json();
          if (!res.ok) throw new Error(json.error ?? "Error");
          const { geocoded, failed, remaining } = json.data ?? {};
          msgEl.textContent = `Procesadas: ${geocoded ?? 0} ok · ${failed ?? 0} fallidas · ${remaining ?? 0} restantes.`;
          msgEl.style.color = "var(--ok)";
          msgEl.style.display = "inline";
          statusEl.textContent =
            remaining > 0
              ? `Aún quedan ${remaining} órdenes pendientes.`
              : "Sin órdenes pendientes.";
          if (remaining > 0) btn.disabled = false;
          btn.textContent = "Geocodificar pendientes";
        } catch (err) {
          msgEl.textContent = "Error al geocodificar. Intente de nuevo.";
          msgEl.style.color = "var(--danger)";
          msgEl.style.display = "inline";
          btn.disabled = false;
          btn.textContent = "Geocodificar pendientes";
          console.error(err);
        }
      });
    })();
  </script>
</AdminLayout>
