---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SalesHeatmap from "../../components/SalesHeatmap.jsx";
---

<AdminLayout title="Mapa de Ventas — DobleYo Admin" section="sales-map">
  <style>
    .page-header {
      padding: 1.75rem 2rem 1.5rem;
      background: #fff;
      border-bottom: 1px solid rgba(0,0,0,.08);
    }
    .page-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: #251a14;
      margin: 0 0 0.3rem;
    }
    .page-header p {
      margin: 0;
      color: #7a6652;
      font-size: 0.95rem;
    }
    .page-body {
      padding: 1.75rem 2rem 2rem;
    }
    .geocoding-panel {
      background: #fffbf5;
      border: 1px solid #e8d9c5;
      border-radius: 8px;
      padding: 1.1rem 1.4rem;
      margin-bottom: 1.5rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
    }
    .geocoding-panel__info { flex: 1; min-width: 200px; }
    .geocoding-panel__label { font-size: 0.9rem; font-weight: 600; color: #251a14; }
    #geocoding-status { margin: 0.2rem 0 0; font-size: 0.84rem; color: #7a6652; }
    #btn-backfill {
      background: #c8a96e;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 0.55rem 1.1rem;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    #btn-backfill:hover:not(:disabled) { background: #a8874a; }
    #btn-backfill:disabled { opacity: 0.5; cursor: not-allowed; }
    #backfill-msg { font-size: 0.82rem; color: #2d5016; display: none; font-weight: 600; }
    .map-card {
      background: #fff;
      border-radius: 8px;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      box-shadow: var(--card-shadow, 0 0 0 1px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.05));
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .info-panel {
      background: #fafafa;
      border-radius: 8px;
      border: 1px solid var(--border, rgba(0,0,0,.09));
      padding: 1.25rem 1.5rem;
    }
    .info-panel h3 {
      margin: 0 0 0.75rem;
      color: #251a14;
      font-size: 0.95rem;
      font-weight: 700;
    }
    .info-panel ul {
      color: #7a6652;
      line-height: 1.9;
      margin: 0;
      padding-left: 1.4rem;
      font-size: 0.9rem;
    }
  </style>

  <header class="page-header">
    <h1>Mapa de Calor de Ventas</h1>
    <p>Distribución geográfica combinada: tienda web + MercadoLibre. Filtra por período, canal o producto.</p>
  </header>

  <div class="page-body">

    <div class="geocoding-panel" id="geocoding-panel">
      <div class="geocoding-panel__info">
        <div class="geocoding-panel__label">Geocodificación de órdenes</div>
        <p id="geocoding-status">Consultando estado…</p>
      </div>
      <button id="btn-backfill" disabled>Geocodificar pendientes</button>
      <div id="backfill-msg"></div>
    </div>

    <div class="map-card">
      <SalesHeatmap client:load />
    </div>

    <div class="info-panel">
      <h3>¿Cómo funciona este mapa?</h3>
      <ul>
        <li><strong>Datos combinados:</strong> Integra pedidos de la tienda web y de MercadoLibre en una sola vista.</li>
        <li><strong>Filtros:</strong> Filtra por período (7 / 30 / 90 / 365 días o todo el tiempo), canal de venta, o nombre de producto.</li>
        <li><strong>Intensidad de calor:</strong> Los colores van de amarillo claro (pocas ventas) a rojo oscuro (muchas ventas).</li>
        <li><strong>Marcadores:</strong> Haz clic en cualquier círculo para ver ciudad, pedidos, ventas en COP y desglose por canal.</li>
        <li><strong>Geocodificación:</strong> Las nuevas órdenes se geocodifican automáticamente. Si hay órdenes antiguas sin coordenadas, usa el botón <em>"Geocodificar pendientes"</em> para procesarlas.</li>
        <li><strong>Exportar:</strong> Descarga los datos del filtro activo como CSV con el botón <em>"↓ CSV"</em>.</li>
      </ul>
    </div>

  </div>
</AdminLayout>

<script>
  // Consultar estado de geocodificación y manejar backfill
  (async () => {
    const statusEl = document.getElementById("geocoding-status");
    const btn = document.getElementById("btn-backfill");
    const msgEl = document.getElementById("backfill-msg");

    try {
      const res = await fetch("/api/heatmap/stats", { credentials: "include" });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error ?? "Error");

      const { pending_geocoding, total_orders } = json.data ?? {};
      if (pending_geocoding === 0) {
        statusEl.textContent = `✅ Todas las órdenes geocodificadas (${total_orders ?? "—"} en total).`;
      } else {
        statusEl.textContent = `⚠️ ${pending_geocoding} órdenes sin coordenadas de ${total_orders ?? "?"} totales.`;
        btn.disabled = false;
      }
    } catch (err) {
      statusEl.textContent =
        "No se pudo consultar el estado de geocodificación.";
      console.error(err);
    }

    btn.addEventListener("click", async () => {
      btn.disabled = true;
      btn.textContent = "Geocodificando…";
      msgEl.style.display = "none";
      try {
        const res = await fetch("/api/heatmap/backfill", {
          method: "POST",
          credentials: "include",
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error ?? "Error");
        const { geocoded, failed, remaining } = json.data ?? {};
        msgEl.textContent = `✅ Procesadas: ${geocoded ?? 0} ok, ${failed ?? 0} fallidas, ${remaining ?? 0} restantes.`;
        msgEl.style.display = "inline";
        statusEl.textContent =
          remaining > 0
            ? `⚠️ Aún quedan ${remaining} órdenes pendientes.`
            : "✅ Sin órdenes pendientes.";
        if (remaining > 0) btn.disabled = false;
        btn.textContent = "Geocodificar pendientes";
      } catch (err) {
        msgEl.textContent = "❌ Error al geocodificar. Intenta de nuevo.";
        msgEl.style.color = "#c00";
        msgEl.style.display = "inline";
        btn.disabled = false;
        btn.textContent = "Geocodificar pendientes";
        console.error(err);
      }
    });
  })();
</script>
