---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products";
import { getCanonicalUrl } from "../i18n/index.ts";

export const prerender = false;

const accesorios = products.filter((p) => p.category === "Accesorios");

const pageTitle = "Accesorios — DobleYo Café";
const pageDescription =
  "Molinillos, métodos de preparación y accesorios para disfrutar el café de especialidad colombiano en casa. Calidad seleccionada por DobleYo Café.";
---

<Layout
  lang="es"
  title={pageTitle}
  description={pageDescription}
  canonical={getCanonicalUrl("/accesorios", "es")}
>
  <PageHero
    eyebrow="Accesorios"
    title="Todo para una taza perfecta"
    subtitle="Molinillos, prensas y métodos de preparación seleccionados para sacarle el máximo a cada lote de café de especialidad."
  />

  <section class="acc-list">
    <div class="container">
      {accesorios.length === 0 ? (
        <p class="acc-empty">
          Pronto encontrará aquí nuestra selección de accesorios. Mientras tanto,
          explore <a href="/tienda" data-link>nuestros cafés</a>.
        </p>
      ) : (
        <div class="acc-grid">
          {accesorios.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; }

  .acc-list { background: #fff; padding: 3rem 0 4rem; }
  .acc-empty { text-align: center; color: var(--ink, #666); padding: 2rem 0; }
  .acc-empty a { color: var(--accent); }

  .acc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 480px) { .acc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 768px) { .acc-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .acc-grid { grid-template-columns: repeat(4, 1fr); } }
</style>
