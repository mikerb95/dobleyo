---
import Layout from "../../layouts/Layout.astro";
import { getCanonicalUrl, getHreflangPair } from "../../i18n/index.ts";

const hreflang = getHreflangPair("/trazabilidad");
---

<Layout
    title="Coffee Traceability — DobleYo Café"
    description="Discover the full journey of your DobleYo coffee. Scan the QR on your packaging or enter a lot code to see farm, harvest, roast and more."
    lang="en"
    canonical={getCanonicalUrl("/traceability", "en")}
    hreflangEs={hreflang?.es}
    hreflangEn={hreflang?.en}
>
    <section class="trace-layout" aria-label="Coffee traceability lookup">
        <div class="trace-left">
            <div class="card">
                <div class="p">
                    <div class="scan-frame">
                        <video
                            id="qrVideo"
                            autoplay
                            playsinline
                            muted
                            class="scan-video"></video>
                        <canvas id="qrOverlay"></canvas>
                        <div class="scan-overlay"></div>
                        <div class="scan-line" aria-hidden="true"></div>
                    </div>
                    <div class="trace-controls">
                        <button id="startScan" class="btn" type="button"
                            >Start scanner</button
                        >
                        <button id="stopScan" class="icon-btn" type="button"
                            >Stop</button
                        >
                        <button
                            id="restartScan"
                            class="icon-btn"
                            type="button"
                            hidden>Restart scan</button
                        >
                    </div>
                    <div id="scanStatus" class="muted trace-status">
                        Ready to scan.
                    </div>

                    <p class="muted trace-hint">
                        If your browser doesn't allow camera access, enter the
                        lot code manually below.
                    </p>

                    <form
                        id="manualForm"
                        class="form trace-form"
                    >
                        <label for="lotInput">Lot code</label>
                        <div class="trace-form-row">
                            <input
                                id="lotInput"
                                placeholder="E.g.: COL-HUI-1800 or LBL-LOT-0001-0001"
                                aria-label="Lot code"
                            />
                            <button id="lookupBtn" class="btn" type="button"
                                >Look up</button
                            >
                        </div>
                    </form>
                    <div id="lotError" class="trace-error" style="display:none">
                    </div>
                </div>
            </div>
        </div>

        <div class="trace-right">
            <div class="card trace-result">
                <div class="p">
                    <h2>Result</h2>
                    <div id="resultEmpty" class="muted">
                        No data yet. Scan a QR code or enter a lot code.
                    </div>
                    <div id="result" style="display:none">
                        <h3 id="resName">—</h3>
                        <div class="muted" id="resLot">—</div>
                        <div class="trace-chips" id="resChips"></div>
                        <dl class="trace-details" id="resDetails"></dl>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="p">
                    <h3>How does it work?</h3>
                    <ul>
                        <li>
                            Scan the QR code on your packaging or enter the lot
                            code.
                        </li>
                        <li>
                            You'll see farm, producer, altitude, process,
                            harvest date and roast profile.
                        </li>
                        <li>
                            Every lot is unique and traceable from tree to cup.
                        </li>
                    </ul>
                    <p class="muted" style="margin-top:1rem;font-size:.9rem">
                        Our traceability system records each coffee's journey:
                        from farm harvest through green coffee storage,
                        roasting, packaging, and sale. Each bag carries a unique
                        QR code linked to its lot data.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script is:inline src="/assets/js/en-traceability.js"></script>
