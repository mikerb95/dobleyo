---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Icon from "../../components/Icon.astro";
import { getCanonicalUrl, getHreflangPair } from "../../i18n/index.ts";

const hreflang = getHreflangPair("/contacto");
---

<Layout
    title="Contact Us — DobleYo Café"
    description="Get in touch with DobleYo Café. Questions about orders, products, or wholesale? We're here to help."
    lang="en"
    canonical={getCanonicalUrl("/contact", "en")}
    hreflangEs={hreflang?.es}
    hreflangEn={hreflang?.en}
>
    <div class="contact-page">
        <PageHero
            title="Contact Us"
            subtitle="We're here to answer your questions and hear your feedback"
        />

        <section class="contact-content">
            <div class="container">
                <div class="contact-grid">
                    <!-- Contact Information -->
                    <div class="contact-info">
                        <h2>Contact Information</h2>

                        <div class="contact-item">
                            <div class="contact-icon"><Icon name="mail" size={22} /></div>
                            <div>
                                <h3>Email</h3>
                                <a href="mailto:hello@dobleyo.cafe"
                                    >hello@dobleyo.cafe</a
                                >
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon"><Icon name="whatsapp" size={22} /></div>
                            <div>
                                <h3>WhatsApp</h3>
                                <a
                                    href="https://wa.me/573001234567"
                                    target="_blank"
                                    rel="noopener">+57 300 123 4567</a
                                >
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon"><Icon name="map-pin" size={22} /></div>
                            <div>
                                <h3>Location</h3>
                                <p>Bogotá, Colombia</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon"><Icon name="clock" size={22} /></div>
                            <div>
                                <h3>Business Hours</h3>
                                <p>Monday to Friday: 9:00 AM – 6:00 PM (COT)</p>
                                <p>Saturday: 10:00 AM – 2:00 PM (COT)</p>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon"><Icon name="package" size={22} /></div>
                            <div>
                                <h3>Wholesale &amp; Export</h3>
                                <p>
                                    Interested in B2B sourcing or export orders?
                                    Reach us by email for sample requests and
                                    pricing.
                                </p>
                                <a
                                    href="mailto:export@dobleyo.cafe"
                                    class="btn btn-primary contact-item__cta"
                                >
                                    Request Samples
                                </a>
                            </div>
                        </div>

                        <div class="social-links">
                            <h3>Follow us</h3>
                            <div class="social-icons">
                                <a
                                    href="https://instagram.com/dobleyo.cafe"
                                    target="_blank"
                                    rel="noopener"
                                    aria-label="Instagram"
                                >
                                    <svg
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                                        ></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Form -->
                    <div class="contact-form-container">
                        <h2>Send us a Message</h2>
                        <form id="contactForm" class="contact-form">
                            <div class="form-group">
                                <label for="name">Full name *</label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    placeholder="Your name"
                                />
                            </div>
                            <div class="form-group">
                                <label for="email">Email address *</label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    placeholder="you@example.com"
                                />
                            </div>
                            <div class="form-group">
                                <label for="subject">Subject</label>
                                <select id="subject" name="subject">
                                    <option value="order"
                                        >Inquiry about my order</option
                                    >
                                    <option value="product"
                                        >Product information</option
                                    >
                                    <option value="wholesale"
                                        >Wholesale / B2B</option
                                    >
                                    <option value="export"
                                        >Export / Sourcing</option
                                    >
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="message">Message *</label>
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    placeholder="How can we help you?"
                                ></textarea>
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary contact-form__submit"
                                id="submitBtn">Send message</button
                            >
                            <div id="formStatus" class="form-status"></div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<script is:inline src="/assets/js/en-contact.js"></script>

<style>
    .contact-page {
        min-height: 100vh;
    }

    .contact-content {
        padding: 0 0 var(--space-16);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: var(--space-16);
        max-width: var(--page-width);
        margin: 0 auto;
    }

    .contact-info h2,
    .contact-form-container h2 {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        color: var(--fg);
        margin-bottom: var(--space-8);
        font-weight: 700;
    }

    .contact-item {
        display: flex;
        gap: var(--space-4);
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-8);
        border-bottom: 1px solid var(--border);
    }

    .contact-item:last-of-type {
        border-bottom: none;
    }

    .contact-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: var(--radius-md);
        background: var(--leaf-bg);
        color: var(--leaf);
    }

    .contact-item h3 {
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--fg);
        margin: 0 0 var(--space-2);
    }

    .contact-item p,
    .contact-item a {
        color: var(--muted-fg);
        text-decoration: none;
        line-height: 1.6;
        margin: 0;
    }

    .contact-item a:hover {
        color: var(--accent);
    }

    .contact-item__cta {
        margin-top: var(--space-3);
        color: var(--accent-contrast);
    }

    .contact-item__cta:hover {
        color: var(--accent-contrast);
    }

    .social-links {
        margin-top: var(--space-12);
    }

    .social-links h3 {
        font-size: var(--text-base);
        font-weight: 600;
        color: var(--fg);
        margin-bottom: var(--space-4);
    }

    .social-icons {
        display: flex;
        gap: var(--space-4);
    }

    .social-icons a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        background: var(--card);
        border: 1px solid var(--border);
        color: var(--muted-fg);
        transition: background-color var(--dur) var(--ease), color var(--dur) var(--ease), transform var(--dur) var(--ease);
    }

    .social-icons a:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--accent-contrast);
        transform: translateY(-2px);
    }

    .contact-form-container {
        background: var(--card);
        border: 1px solid var(--border);
        padding: var(--space-8);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
    }

    .form-group {
        margin-bottom: var(--space-6);
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--fg);
        margin-bottom: var(--space-2);
        font-size: var(--text-sm);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: var(--space-3);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        font-size: var(--text-base);
        background: #fff;
        color: var(--fg);
        transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(var(--caramel-rgb), 0.15);
    }

    .form-group textarea {
        resize: vertical;
        font-family: inherit;
    }

    .contact-form__submit {
        width: 100%;
        justify-content: center;
        padding: var(--space-4);
        font-size: var(--text-base);
    }

    .contact-form__submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .form-status {
        margin-top: var(--space-4);
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-sm);
        text-align: center;
        font-size: var(--text-sm);
        display: none;
    }

    .form-status.success {
        display: block;
        background: var(--leaf-bg);
        color: var(--leaf);
    }

    .form-status.error {
        display: block;
        background: var(--danger-bg);
        color: var(--danger);
    }

    @media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: var(--space-12);
        }

        .contact-form-container {
            padding: var(--space-6);
        }
    }
</style>
