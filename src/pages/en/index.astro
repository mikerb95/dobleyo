---
import Layout from "../../layouts/Layout.astro";
import { getCanonicalUrl, getHreflangPair, formatPrice } from "../../i18n/index.ts";
import { parseTastingNotes } from "../../../server/utils/tasting.js";

export const prerender = false;

const hreflang = getHreflangPair("/");

// Cafés destacados desde BD (precios en USD)
let coffees: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const { rows } = await query(
    `SELECT id, name, name_en, origin, process, roast, tasting_notes,
            price_usd, image_url AS image
     FROM products
     WHERE is_active = 1 AND category = 'cafe'
     ORDER BY is_bestseller DESC, is_new DESC, rating DESC
     LIMIT 3`
  );
  coffees = rows.map((p: any) => ({
    ...p,
    name: p.name_en || p.name,
    price_usd: p.price_usd ?? Math.round(Number(p.price_usd) || 0),
    notes: parseTastingNotes(p.tasting_notes)?.en ?? parseTastingNotes(p.tasting_notes)?.es ?? [],
  }));
} catch (_) { /* BD no disponible */ }
---

<Layout
  title="DobleYo Café — Colombian Specialty Coffee, Farm to Cup"
  description="Single-origin Colombian specialty coffee, freshly roasted and shipped worldwide. Full QR traceability from farm to your cup."
  lang="en"
  canonical={getCanonicalUrl("/", "en")}
  hreflangEs={hreflang?.es}
  hreflangEn={hreflang?.en}
>
  <section class="b2c-hero">
    <div class="b2c-hero__inner">
      <p class="b2c-hero__eyebrow">Colombian Specialty Coffee</p>
      <h1 class="b2c-hero__title">From our farms to your cup</h1>
      <p class="b2c-hero__sub">
        Single-origin lots, freshly roasted within 15 days and shipped to your door.
        Every bag carries a QR code with its full story — farm, harvest, roast and cupping.
      </p>
      <div class="b2c-hero__cta">
        <a class="b2c-btn b2c-btn--primary" href="/shop" data-link>Shop coffee</a>
        <a class="b2c-btn b2c-btn--ghost" href="/traceability" data-link>Trace your coffee</a>
      </div>
    </div>
  </section>

  <div class="b2c-strip" aria-hidden="true">
    <span>Colombia · Single origin</span><span>·</span>
    <span>1,400–1,900 masl</span><span>·</span>
    <span>Washed · Honey · Natural</span><span>·</span>
    <span>Roasted within 15 days</span>
  </div>

  <section class="b2c-feat">
    <div class="b2c-container">
      <div class="b2c-feat__head">
        <h2>Our coffees</h2>
        <a href="/shop" data-link class="b2c-all">Shop all →</a>
      </div>
      {coffees.length === 0 ? (
        <p class="b2c-empty">Our shop is being restocked. Please check back soon.</p>
      ) : (
        <div class="b2c-grid">
          {coffees.map((p) => (
            <article class="b2c-card">
              <a href={`/product/${p.id}`} class="b2c-card__imglink" data-link>
                <img src={p.image} alt={p.name} class="b2c-card__img" loading="lazy" width="400" height="420" />
              </a>
              <div class="b2c-card__body">
                <p class="b2c-card__meta">{[p.origin, p.process].filter(Boolean).join(" · ")}</p>
                <h3 class="b2c-card__name"><a href={`/product/${p.id}`} data-link>{p.name}</a></h3>
                {p.notes?.length > 0 && <p class="b2c-card__notes">{p.notes.join(" · ")}</p>}
                <div class="b2c-card__foot">
                  <span class="b2c-card__price">{formatPrice(Number(p.price_usd), "en")}</span>
                  <button
                    class="b2c-card__add"
                    data-id={p.id}
                    data-name={p.name}
                    data-price={p.price_usd}
                    data-image={p.image}
                    aria-label={`Add ${p.name} to cart`}
                  >Add to cart</button>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="b2c-value">
    <div class="b2c-container b2c-value__grid">
      <div><span aria-hidden="true">🔍</span><h3>Full traceability</h3><p>A QR per lot: farm, harvest, roast and SCA cupping.</p></div>
      <div><span aria-hidden="true">🔥</span><h3>Freshly roasted</h3><p>We roast within 15 days of delivery.</p></div>
      <div><span aria-hidden="true">🤝</span><h3>Direct trade</h3><p>Bought straight from farmers, at a fair price.</p></div>
      <div><span aria-hidden="true">🌎</span><h3>Worldwide shipping</h3><p>Prices in USD, delivered to your door.</p></div>
    </div>
  </section>

  <section class="b2c-wholesale">
    <div class="b2c-container">
      <h2>Are you a roaster or importer?</h2>
      <p>We supply green and roasted Colombian coffee for business. Traceable lots, FOB/CIF, consistent quality.</p>
      <a class="b2c-btn b2c-btn--primary" href="/wholesale" data-link>Wholesale & export →</a>
    </div>
  </section>

  <script is:inline src="/assets/js/cart.js"></script>
  <script>
    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".b2c-card__add");
      if (!btn || !window.Cart) return;
      window.Cart.add({
        id: btn.dataset.id, name: btn.dataset.name,
        price: Number(btn.dataset.price), image: btn.dataset.image, quantity: 1,
      });
      const orig = btn.textContent;
      btn.textContent = "✓ Added";
      setTimeout(() => { btn.textContent = orig; }, 1600);
    });
  </script>

  <style>
    .b2c-container { max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; }
    .b2c-hero { background: var(--coffee); color: var(--cream); padding: 4rem 1.5rem; text-align: center; }
    .b2c-hero__inner { max-width: 720px; margin: 0 auto; }
    .b2c-hero__eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .8rem; opacity: .75; margin: 0 0 .75rem; }
    .b2c-hero__title { font-family: var(--font-heading, serif); font-size: clamp(2rem, 5vw, 3.2rem); margin: 0 0 1rem; line-height: 1.1; }
    .b2c-hero__sub { font-size: 1.05rem; line-height: 1.6; opacity: .92; margin: 0 0 1.75rem; }
    .b2c-hero__cta { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .b2c-btn { display: inline-block; padding: .75rem 1.5rem; border-radius: 999px; font-weight: 700; text-decoration: none; min-height: 44px; line-height: 1.7; }
    .b2c-btn--primary { background: var(--accent); color: #fff; }
    .b2c-btn--ghost { border: 1.5px solid var(--cream); color: var(--cream); }
    .b2c-btn--ghost:hover { background: var(--cream); color: var(--coffee); }

    .b2c-strip { background: var(--cream); display: flex; flex-wrap: wrap; gap: .6rem; justify-content: center; padding: .85rem 1rem; font-size: .82rem; color: var(--coffee); }
    .b2c-strip span:nth-child(even) { opacity: .4; }

    .b2c-feat { padding: 3.5rem 0; }
    .b2c-feat__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; }
    .b2c-feat__head h2 { font-family: var(--font-heading, serif); color: var(--coffee); margin: 0; font-size: clamp(1.5rem, 3vw, 2rem); }
    .b2c-all { color: var(--accent); text-decoration: none; font-weight: 600; }
    .b2c-empty { text-align: center; color: #666; padding: 2rem 0; }
    .b2c-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @media (min-width: 640px) { .b2c-grid { grid-template-columns: repeat(3, 1fr); } }

    .b2c-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 5px rgba(0,0,0,.08); display: flex; flex-direction: column; }
    .b2c-card__imglink { display: block; aspect-ratio: 1/1; overflow: hidden; }
    .b2c-card__img { width: 100%; height: 100%; object-fit: cover; }
    .b2c-card__body { padding: 1rem 1.1rem 1.1rem; display: flex; flex-direction: column; flex: 1; }
    .b2c-card__meta { font-size: .75rem; text-transform: uppercase; letter-spacing: .04em; color: var(--accent); margin: 0 0 .25rem; }
    .b2c-card__name { margin: 0 0 .4rem; font-size: 1.15rem; }
    .b2c-card__name a { color: var(--coffee); text-decoration: none; }
    .b2c-card__notes { font-size: .85rem; color: #666; margin: 0 0 .85rem; }
    .b2c-card__foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: .5rem; }
    .b2c-card__price { font-weight: 700; color: var(--coffee); font-size: 1.05rem; }
    .b2c-card__add { background: var(--accent); color: #fff; border: none; border-radius: 999px; padding: .5rem .9rem; font-size: .85rem; font-weight: 600; cursor: pointer; }
    .b2c-card__add:hover { filter: brightness(1.05); }

    .b2c-value { background: var(--cream); padding: 3rem 0; }
    .b2c-value__grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @media (min-width: 768px) { .b2c-value__grid { grid-template-columns: repeat(4, 1fr); } }
    .b2c-value span { font-size: 1.6rem; }
    .b2c-value h3 { margin: .5rem 0 .25rem; color: var(--coffee); font-size: 1rem; }
    .b2c-value p { margin: 0; font-size: .9rem; color: #555; line-height: 1.5; }

    .b2c-wholesale { padding: 3rem 1.5rem; text-align: center; }
    .b2c-wholesale h2 { font-family: var(--font-heading, serif); color: var(--coffee); margin: 0 0 .5rem; }
    .b2c-wholesale p { color: #555; margin: 0 0 1.25rem; }
  </style>
</Layout>
