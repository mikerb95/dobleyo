---
import Layout from "../../layouts/Layout.astro";
import { getCanonicalUrl, getHreflangPair, formatPrice } from "../../i18n/index.ts";
import { parseTastingNotes } from "../../../server/utils/tasting.js";

const _hreflang = getHreflangPair("/");

// Featured coffees from DB (USD prices)
let coffeeProducts: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const result = await query(
    `SELECT id, name, name_en, origin, process, roast, tasting_notes, price_usd,
            is_bestseller AS bestseller, is_new AS new, image_url AS image,
            stock_quantity AS stock
     FROM products
     WHERE is_active = 1 AND category = 'cafe'
     ORDER BY is_bestseller DESC, is_new DESC, rating DESC
     LIMIT 3`
  );
  if (result.rows.length > 0) {
    coffeeProducts = result.rows.map((p: any) => ({
      ...p,
      name: p.name_en || p.name,
      notes: parseTastingNotes(p.tasting_notes)?.en ?? parseTastingNotes(p.tasting_notes)?.es ?? [],
    }));
  }
} catch (_) {}

// Featured farms
let featuredFarms: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const result = await query(
    `SELECT name, slug, region, altitude_min, altitude_max, cover_image_url
     FROM farms WHERE is_published = 1 ORDER BY created_at DESC LIMIT 3`
  );
  featuredFarms = result.rows;
} catch (_) {}

// Recent blog posts
let recentPosts: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const result = await query(
    `SELECT slug, title, excerpt, cover_image_url, reading_time_min, published_at
     FROM blog_posts WHERE is_published = 1 ORDER BY published_at DESC LIMIT 3`
  );
  recentPosts = result.rows;
} catch (_) {}

// Gift kits
let featuredKits: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const result = await query(
    `SELECT id, name, name_en, description, price_usd, image_url AS image
     FROM products WHERE is_gift_set = 1 AND is_active = 1
     ORDER BY price_usd ASC LIMIT 3`
  );
  featuredKits = result.rows.map((k: any) => ({
    ...k,
    name: k.name_en || k.name,
  }));
} catch (_) {}

// Featured reviews
let featuredReviews: any[] = [];
try {
  const { query } = await import("../../../server/db.js");
  const result = await query(
    `SELECT r.reviewer_name, r.rating, r.comment, p.name_en AS product_name_en, p.name AS product_name
     FROM product_reviews r
     JOIN products p ON p.id = r.product_id
     WHERE r.is_approved = 1 AND r.comment IS NOT NULL AND r.comment != ''
     ORDER BY r.created_at DESC LIMIT 3`
  );
  featuredReviews = result.rows.map((r: any) => ({
    ...r,
    product_name: r.product_name_en || r.product_name,
  }));
} catch (_) {}
---

<Layout
  title="DobleYo Café — Colombian Specialty Coffee, Farm to Cup"
  description="Single-origin Colombian specialty coffee, freshly roasted and shipped worldwide. Full QR traceability from farm to your cup."
  lang="en"
  canonical={getCanonicalUrl("/", "en")}
  hreflangEs={_hreflang?.es}
  hreflangEn={_hreflang?.en}
>
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video
        src="/assets/vids/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        disablePictureInPicture
        preload="metadata"></video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <h1>More than coffee, a heritage in every cup.</h1>
    <p>
      We are the reflection of Colombia's cultural richness and the effort of
      generations who cultivate in the heart of our land.<br />Discover the
      flavor of our tradition and the passion of our soil.
    </p>
    <p><a class="btn" href="/shop" data-link>Shop now</a></p>
  </section>

  <!-- Origin data strip -->
  <div class="origin-strip" aria-hidden="true">
    <div class="origin-strip__inner">
      <span>Colombia · Single origin</span>
      <span class="origin-strip__div"></span>
      <span>1,400 – 1,900 masl</span>
      <span class="origin-strip__div"></span>
      <span>Washed · Honey · Natural</span>
      <span class="origin-strip__div"></span>
      <span>Freshly roasted within 15 days</span>
    </div>
  </div>

  <!-- Featured coffees -->
  <section class="cs-section" aria-labelledby="csSectionTitle">
    <div class="cs-header container">
      <div>
        <p class="cs-eyebrow">Our coffees</p>
        <h2 id="csSectionTitle" class="cs-title">Traceable origin, fresh roast</h2>
      </div>
      <a href="/shop" class="cs-all-link" data-link>Shop all products →</a>
    </div>

    <div class="cs-grid container">
      {
        coffeeProducts.map((p) => (
          <article class="cs-card">
            <div class="cs-card__img-wrap">
              <img src={p.image} alt={p.name} class="cs-card__img" loading="lazy" width="400" height="480" />
              {p.bestseller && <span class="cs-card__flag">Best seller</span>}
              {p.new && !p.bestseller && <span class="cs-card__flag cs-card__flag--new">New</span>}
            </div>
            <div class="cs-card__body">
              <p class="cs-card__meta">
                {p.origin}
                {p.process && <span class="cs-card__dot" aria-hidden="true">·</span>}
                {p.process && <span>{p.process}</span>}
              </p>
              <h3 class="cs-card__name">{p.name}</h3>
              {p.notes && p.notes.length > 0 && (
                <p class="cs-card__notes">{p.notes.join(" · ")}</p>
              )}
              <div class="cs-card__footer">
                <span class="cs-card__price">{formatPrice(Number(p.price_usd), "en")}</span>
                <button
                  class="cs-card__add btn-add"
                  aria-label={`Add ${p.name} to cart`}
                  data-id={p.id}
                  data-name={p.name}
                  data-price={p.price_usd}
                  data-image={p.image}
                >
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Traceability pipeline -->
  <section class="pipeline-section" aria-labelledby="pipelineTitle">
    <div class="container">
      <div class="pipeline-header">
        <p class="pipeline-eyebrow">Full traceability</p>
        <h2 id="pipelineTitle" class="pipeline-title">From bean to cup</h2>
        <p class="pipeline-sub">
          Every bag carries a QR code that documents this complete journey
        </p>
      </div>

      <div class="pipeline-track" role="list">
        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">01</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Harvest</h3>
          <p class="pipeline-step__desc">Farm, farmer, municipality and altitude recorded for each lot</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">02</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3C7 3 3 7.03 3 12s4 9 9 9 9-4.03 9-9-4-9-9-9z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Processing</h3>
          <p class="pipeline-step__desc">Method documented: washed, honey or natural according to the lot profile</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">03</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2v4M6.34 6.34 3.51 3.51M2 12H6M6.34 17.66l-2.83 2.83M12 18v4M17.66 17.66l2.83 2.83M22 12h-4M17.66 6.34l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Roast</h3>
          <p class="pipeline-step__desc">Roast curve, temperature and exact date. Within 15 days before your order</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">04</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="6" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 10h18M8 6V4M16 6V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M8 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Your bag</h3>
          <p class="pipeline-step__desc">QR on the package with the lot's full history, from the farm to your hands</p>
        </div>
      </div>

      <div class="trace-cta">
        <div class="trace-cta__glow" aria-hidden="true"></div>
        <div class="trace-cta__visual" aria-hidden="true">
          <div class="trace-cta__qr">
            <svg viewBox="0 0 100 100" width="116" height="116" fill="none">
              <rect x="6" y="6" width="26" height="26" rx="3" stroke="currentColor" stroke-width="4"/>
              <rect x="14" y="14" width="10" height="10" rx="1.5" fill="currentColor"/>
              <rect x="68" y="6" width="26" height="26" rx="3" stroke="currentColor" stroke-width="4"/>
              <rect x="76" y="14" width="10" height="10" rx="1.5" fill="currentColor"/>
              <rect x="6" y="68" width="26" height="26" rx="3" stroke="currentColor" stroke-width="4"/>
              <rect x="14" y="76" width="10" height="10" rx="1.5" fill="currentColor"/>
              <path d="M44 8h8v8h-8zM60 8h-8v16h8zM44 24h8v8h-8z M68 40h8v8h-8zM84 40h8v8h-8zM44 40h16v8H44zM8 44h24v8H8z M44 60h8v8h-8zM60 60h8v8h-8zM84 60h8v8h-8z M44 76h8v16h8v-8h8v8h8v-8h-8v-8h-8v8h-8z M76 76h8v8h-8z" fill="currentColor"/>
            </svg>
            <span class="trace-cta__scan" aria-hidden="true"></span>
          </div>
        </div>
        <div class="trace-cta__copy">
          <p class="trace-cta__eyebrow">QR Traceability · Verified origin</p>
          <h3 class="trace-cta__title">Every cup holds a story.<br />Discover it before you brew.</h3>
          <p class="trace-cta__sub">
            Scan the code on your bag or enter the lot number and trace the
            complete journey of your coffee: the farm that grew it, the farmer
            behind the bean, the exact roast date and the quality control of
            your lot.
          </p>
          <div class="trace-cta__actions">
            <a href="/traceability" class="btn trace-cta__btn" data-link>Trace my coffee</a>
            <span class="trace-cta__hint">No sign-up · Instant results</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="manifesto-strip" aria-label="Our philosophy">
    <div class="manifesto-inner container">
      <blockquote class="manifesto-quote">
        In Colombia, coffee is history accumulated in every bean.<br />
        We are the bridge between those who grow it with care<br class="manifesto-br" />
        and those who enjoy it with intention.
      </blockquote>
      <p class="manifesto-attr">DobleYo Café — Bogotá, Colombia</p>
    </div>
  </section>

  <!-- Our Farms -->
  {
    featuredFarms.length > 0 && (
      <section class="home-farms" aria-labelledby="homeFarmsTitle">
        <div class="container">
          <div class="home-farms__header">
            <h2 id="homeFarmsTitle" class="home-farms__title">
              Our Farms
            </h2>
            <a href="/farms" class="home-farms__link">
              View all farms →
            </a>
          </div>
          <ul class="home-farms__grid" role="list">
            {featuredFarms.map((farm: any) => (
              <li class="home-farm-card">
                <a href={`/farm/${farm.slug}`} class="home-farm-card__link">
                  {farm.cover_image_url ? (
                    <img
                      src={farm.cover_image_url}
                      alt={`Farm ${farm.name} — ${farm.region}`}
                      loading="lazy"
                      class="home-farm-card__img"
                      width="400"
                      height="240"
                    />
                  ) : (
                    <div
                      class="home-farm-card__img home-farm-card__img--ph"
                      aria-hidden="true"
                    >
                      🌿
                    </div>
                  )}
                  <div class="home-farm-card__info">
                    <span class="home-farm-card__region">{farm.region}</span>
                    <strong class="home-farm-card__name">{farm.name}</strong>
                    {farm.altitude_min && (
                      <span class="home-farm-card__alt">
                        {farm.altitude_min}
                        {farm.altitude_max ? `–${farm.altitude_max}` : ""} masl
                      </span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Why DobleYo -->
  <section class="why-section" aria-labelledby="whyTitle">
    <div class="container">
      <div class="why-header">
        <p class="why-eyebrow">Why choose us</p>
        <h2 id="whyTitle" class="why-title">Coffee with purpose, from farm to cup</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          </div>
          <h3 class="why-card__title">QR traceability per lot</h3>
          <p class="why-card__desc">Every bag includes a QR code documenting the farm, farmer, altitude and roast curve of the exact lot.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="why-card__title">Fresh roast within 15 days</h3>
          <p class="why-card__desc">We roast in small batches and ship within 15 days of roasting. Never warehouse coffee.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="why-card__title">Direct trade with farmers</h3>
          <p class="why-card__desc">We work directly with Colombian farms. No middlemen: better price for the producer, better quality for you.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3 class="why-card__title">Free shipping over $50</h3>
          <p class="why-card__desc">Worldwide shipping available. Free on orders over $50 USD.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gift kits -->
  {featuredKits.length > 0 && (
    <section class="kits-section" aria-labelledby="kitsTitle">
      <div class="container">
        <div class="kits-header">
          <div>
            <p class="kits-eyebrow">Gift sets</p>
            <h2 id="kitsTitle" class="kits-title">Kits designed to delight</h2>
          </div>
          <a href="/shop" class="kits-link" data-link>Shop all kits →</a>
        </div>
        <div class="kits-grid">
          {featuredKits.map((kit: any) => (
            <a href={`/product/${kit.id}`} class="kit-card" data-link>
              <div class="kit-card__img-wrap">
                <img
                  src={kit.image || 'https://images.unsplash.com/photo-1559496417-e7f25cb247f3?q=80&w=600&auto=format&fit=crop'}
                  alt={kit.name}
                  loading="lazy"
                  class="kit-card__img"
                />
              </div>
              <div class="kit-card__body">
                <span class="kit-card__tag">Gift set</span>
                <h3 class="kit-card__name">{kit.name}</h3>
                {kit.description && <p class="kit-card__desc">{kit.description.slice(0, 90)}…</p>}
                <span class="kit-card__price">{formatPrice(Number(kit.price_usd), "en")}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="newsletter-section" aria-labelledby="nlTitle">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-copy">
          <p class="newsletter-eyebrow">Newsletter</p>
          <h2 id="nlTitle" class="newsletter-title">10% off your first order</h2>
          <p class="newsletter-sub">Subscribe and receive your code instantly. We'll also keep you posted on new harvests and releases.</p>
        </div>
        <form class="newsletter-form" id="homeNewsletterForm" novalidate>
          <input
            type="email"
            id="homeNlEmail"
            class="newsletter-input"
            placeholder="your@email.com"
            required
            aria-label="Email address"
          />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
        <p class="newsletter-msg" id="homeNlMsg" style="display:none"></p>
      </div>
    </div>
  </section>

  <!-- Recent blog posts -->
  {recentPosts.length > 0 && (
    <section class="blog-section" aria-labelledby="blogTitle">
      <div class="container">
        <div class="blog-home-header">
          <div>
            <p class="blog-eyebrow">Blog</p>
            <h2 id="blogTitle" class="blog-home-title">Recipes, tasting notes and guides</h2>
          </div>
          <a href="/blog" class="blog-home-link" data-link>View all posts →</a>
        </div>
        <div class="blog-home-grid">
          {recentPosts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="blog-home-card" data-link>
              <div class="blog-home-card__img-wrap">
                <img
                  src={post.cover_image_url || 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=600&auto=format&fit=crop'}
                  alt={post.title}
                  loading="lazy"
                  class="blog-home-card__img"
                />
              </div>
              <div class="blog-home-card__body">
                <h3 class="blog-home-card__title">{post.title}</h3>
                {post.excerpt && <p class="blog-home-card__exc">{post.excerpt.slice(0, 80)}…</p>}
                <span class="blog-home-card__time">{post.reading_time_min ?? 3} min read</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Reviews -->
  {featuredReviews.length > 0 && (
    <section class="reviews-home" aria-labelledby="reviewsHomeTitle">
      <div class="container">
        <div class="reviews-home-header">
          <p class="reviews-eyebrow">What our customers say</p>
          <h2 id="reviewsHomeTitle" class="reviews-home-title">Verified reviews</h2>
        </div>
        <div class="reviews-home-grid">
          {featuredReviews.map((r: any) => (
            <div class="review-home-card">
              <div class="review-home-card__stars" aria-label={`${r.rating} stars`}>
                {"★".repeat(r.rating)}{"☆".repeat(5 - r.rating)}
              </div>
              <p class="review-home-card__comment">"{r.comment}"</p>
              <div class="review-home-card__meta">
                <strong>{r.reviewer_name}</strong>
                {r.product_name && <span>on {r.product_name}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <script is:inline src="/assets/js/home-en.js"></script>
  <style>
    /* =============================================
       ORIGIN STRIP
    ============================================= */
    .origin-strip {
      background: var(--coffee);
      color: rgba(255,255,255,.72);
      font-size: .72rem;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      letter-spacing: .12em;
      text-transform: uppercase;
      overflow: hidden;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .origin-strip__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: .75rem 1.5rem;
      padding: .75rem 1.25rem;
      max-width: var(--page-width);
      margin: 0 auto;
    }
    .origin-strip__div {
      display: inline-block;
      width: 1px;
      height: 10px;
      background: rgba(255,255,255,.25);
      flex-shrink: 0;
    }
    @media (max-width: 640px) {
      .origin-strip__div { display: none; }
      .origin-strip__inner { gap: .5rem 1rem; }
    }

    /* =============================================
       COFFEE SECTION
    ============================================= */
    .cs-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
