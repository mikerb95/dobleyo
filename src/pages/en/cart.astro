---
import Layout from "../../layouts/Layout.astro";
import { getCanonicalUrl } from "../../i18n/index.ts";
---

<Layout
  lang="en"
  title="Your cart — DobleYo Café"
  description="Review your Colombian specialty coffee order."
  canonical={getCanonicalUrl("/cart", "en")}
  noindex={true}
>
  <section class="cart-page">
    <h1 class="cart-title">Your cart</h1>

    <div id="cartEmpty" class="cart-empty" style="display:none">
      <p>Your cart is empty.</p>
      <a href="/shop" class="cart-btn">Browse coffee</a>
    </div>

    <div id="cartLayout" class="cart-layout" style="display:none">
      <div class="cart-items" id="cartItems"></div>
      <aside class="cart-summary">
        <h2>Order summary</h2>
        <div class="cart-sum-line"><span>Subtotal</span><strong id="cartSubtotal">$0</strong></div>
        <div class="cart-sum-line cart-sum-line--muted"><span>Shipping</span><span>Free worldwide</span></div>
        <a href="/checkout" class="cart-btn cart-btn--full">Checkout</a>
        <a href="/shop" class="cart-continue">← Continue shopping</a>
      </aside>
    </div>
  </section>

  <script is:inline src="/assets/js/cart.js"></script>
  <script>
    (function () {
      const fmt = (n) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(Number(n) || 0);
      function render() {
        if (!window.Cart) return setTimeout(render, 40);
        const cart = window.Cart.getCart();
        const empty = document.getElementById("cartEmpty");
        const layout = document.getElementById("cartLayout");
        if (!cart.length) { empty.style.display = "block"; layout.style.display = "none"; return; }
        empty.style.display = "none"; layout.style.display = "grid";
        document.getElementById("cartItems").innerHTML = cart.map((p) => `
          <div class="cart-item" data-id="${p.id}">
            <img src="${p.image || '/assets/logo.png'}" alt="${(p.name||'').replace(/"/g,'&quot;')}" class="cart-item__img" />
            <div class="cart-item__info">
              <p class="cart-item__name">${p.name || ''}</p>
              <p class="cart-item__price">${fmt(p.price)}</p>
            </div>
            <div class="cart-item__qty">
              <button data-act="dec" aria-label="Decrease">−</button>
              <span>${p.qty || 1}</span>
              <button data-act="inc" aria-label="Increase">+</button>
            </div>
            <span class="cart-item__line">${fmt((p.price||0)*(p.qty||1))}</span>
            <button class="cart-item__rm" data-act="rm" aria-label="Remove">✕</button>
          </div>`).join("");
        document.getElementById("cartSubtotal").textContent = fmt(window.Cart.subtotal());
      }
      document.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-act]");
        if (!btn || !window.Cart) return;
        const row = btn.closest(".cart-item"); if (!row) return;
        const id = row.dataset.id;
        const item = window.Cart.getCart().find((p) => p.id === id);
        const act = btn.dataset.act;
        if (act === "rm") window.Cart.removeFromCart(id);
        else if (act === "inc") window.Cart.updateQty(id, (item?.qty || 1) + 1);
        else if (act === "dec") window.Cart.updateQty(id, Math.max(1, (item?.qty || 1) - 1));
        render();
      });
      render();
    })();
  </script>

  <style>
    .cart-page { max-width: 980px; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
    .cart-title { font-family: var(--font-heading, serif); color: var(--coffee); margin: 0 0 1.5rem; }
    .cart-empty { text-align: center; padding: 3rem 0; color: #666; }
    .cart-btn { display: inline-block; background: var(--accent); color: #fff; padding: .7rem 1.5rem; border-radius: 999px; text-decoration: none; font-weight: 700; margin-top: 1rem; }
    .cart-btn--full { display: block; text-align: center; margin: 1rem 0 .5rem; }
    .cart-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
    @media (min-width: 768px) { .cart-layout { grid-template-columns: 1fr 300px; align-items: start; } }
    .cart-items { display: flex; flex-direction: column; gap: .75rem; }
    .cart-item { display: grid; grid-template-columns: 56px 1fr auto auto auto; align-items: center; gap: .75rem; background: #fff; border: 1px solid var(--border, #eee); border-radius: 10px; padding: .65rem .85rem; }
    .cart-item__img { width: 56px; height: 56px; object-fit: cover; border-radius: 8px; }
    .cart-item__name { margin: 0; font-weight: 600; color: var(--coffee); font-size: .92rem; }
    .cart-item__price { margin: .15rem 0 0; font-size: .8rem; color: #888; }
    .cart-item__qty { display: flex; align-items: center; gap: .5rem; border: 1px solid var(--border, #ddd); border-radius: 8px; padding: .15rem .4rem; }
    .cart-item__qty button { background: none; border: none; cursor: pointer; font-size: 1rem; color: var(--accent); width: 1.5rem; }
    .cart-item__line { font-weight: 700; color: var(--coffee); font-size: .92rem; }
    .cart-item__rm { background: none; border: none; cursor: pointer; color: #bbb; font-size: .9rem; }
    .cart-summary { background: var(--cream); border-radius: 12px; padding: 1.25rem; }
    .cart-summary h2 { margin: 0 0 1rem; font-size: 1rem; color: var(--coffee); }
    .cart-sum-line { display: flex; justify-content: space-between; margin-bottom: .5rem; font-size: .92rem; }
    .cart-sum-line--muted { color: #16a34a; }
    .cart-continue { display: block; text-align: center; color: var(--accent); text-decoration: none; font-size: .85rem; }
  </style>
</Layout>
