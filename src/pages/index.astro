---
import Layout from "../layouts/Layout.astro";
import { products as staticProducts } from "../data/products.ts";
import { getCanonicalUrl, getHreflangPair } from "../i18n/index.ts";

const _hreflang = getHreflangPair("/");

// Productos desde BD (fallback a estáticos)
let coffeeProducts: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const result = await query(
    `SELECT id, name, origin, process, roast, price, rating,
            is_bestseller AS bestseller, is_new AS new, image_url AS image,
            stock_quantity AS stock
     FROM products
     WHERE is_active = 1 AND category = 'cafe'
     ORDER BY is_bestseller DESC, is_new DESC, rating DESC
     LIMIT 3`
  );
  if (result.rows.length > 0) {
    coffeeProducts = result.rows.map((p: any) => ({
      ...p,
      notes: p.tasting_notes?.es ?? null,
    }));
  }
} catch (_) {}

if (!coffeeProducts.length) {
  coffeeProducts = staticProducts
    .filter((p) => p.category === "Cafés")
    .slice(0, 3)
    .map((p) => ({ ...p, notes: p.notes }));
}

// Fincas destacadas
let featuredFarms: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const result = await query(
    `SELECT name, slug, region, altitude_min, altitude_max, cover_image_url
     FROM farms WHERE is_published = 1 ORDER BY created_at DESC LIMIT 3`
  );
  featuredFarms = result.rows;
} catch (_) {}

// Últimos posts del blog
let recentPosts: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const result = await query(
    `SELECT slug, title, excerpt, cover_image_url, reading_time_min, published_at
     FROM blog_posts WHERE is_published = 1 ORDER BY published_at DESC LIMIT 3`
  );
  recentPosts = result.rows;
} catch (_) {}

// Kits de regalo
let featuredKits: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const result = await query(
    `SELECT id, name, description, price, image_url AS image
     FROM products WHERE is_gift_set = 1 AND is_active = 1
     ORDER BY price ASC LIMIT 3`
  );
  featuredKits = result.rows;
} catch (_) {}

// Reseñas destacadas
let featuredReviews: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const result = await query(
    `SELECT r.reviewer_name, r.rating, r.comment, p.name AS product_name
     FROM product_reviews r
     JOIN products p ON p.id = r.product_id
     WHERE r.is_approved = 1 AND r.comment IS NOT NULL AND r.comment != ''
     ORDER BY r.created_at DESC LIMIT 3`
  );
  featuredReviews = result.rows;
} catch (_) {}
---

<Layout
  lang="es"
  canonical={getCanonicalUrl("/", "es")}
  hreflangEs={_hreflang?.es}
  hreflangEn={_hreflang?.en}
>
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video
        src="/assets/vids/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        disablePictureInPicture
        preload="metadata"></video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <h1>Más que café, una herencia en cada taza.</h1>
    <p>
      Somos el reflejo de la riqueza cultural y el esfuerzo de generaciones que
      cultivan en el corazón de Colombia.<br />Descubre el sabor de nuestra
      tradición y la pasión de nuestra tierra.
    </p>
    <p><a class="btn" href="/tienda" data-link>Ver tienda</a></p>
  </section>

  <!-- Banda de datos de origen -->
  <div class="origin-strip" aria-hidden="true">
    <div class="origin-strip__inner">
      <span>Colombia · Origen único</span>
      <span class="origin-strip__div"></span>
      <span>1.400 – 1.900 msnm</span>
      <span class="origin-strip__div"></span>
      <span>Lavado · Honey · Natural</span>
      <span class="origin-strip__div"></span>
      <span>Tueste fresco en menos de 15 días</span>
    </div>
  </div>

  <!-- Cafés en venta -->
  <section class="cs-section" aria-labelledby="csSectionTitle">
    <div class="cs-header container">
      <div>
        <p class="cs-eyebrow">Nuestros cafés</p>
        <h2 id="csSectionTitle" class="cs-title">Origen trazable, tueste fresco</h2>
      </div>
      <a href="/tienda" class="cs-all-link" data-link>Ver todos los productos →</a>
    </div>

    <div class="cs-grid container">
      {
        coffeeProducts.map((p) => (
          <article class="cs-card">
            <div class="cs-card__img-wrap">
              <img src={p.image} alt={p.name} class="cs-card__img" loading="lazy" width="400" height="480" />
              {p.bestseller && <span class="cs-card__flag">Más vendido</span>}
              {p.new && !p.bestseller && <span class="cs-card__flag cs-card__flag--new">Nuevo</span>}
            </div>
            <div class="cs-card__body">
              <p class="cs-card__meta">
                {p.origin}
                {p.process && <span class="cs-card__dot" aria-hidden="true">·</span>}
                {p.process && <span>{p.process}</span>}
              </p>
              <h3 class="cs-card__name">{p.name}</h3>
              {p.notes && (
                <p class="cs-card__notes">{p.notes.join(" · ")}</p>
              )}
              <div class="cs-card__footer">
                <span class="cs-card__price">${p.price.toLocaleString("es-CO")}</span>
                <button
                  class="cs-card__add btn-add"
                  aria-label={`Agregar ${p.name} al carrito`}
                  data-id={p.id}
                  data-name={p.name}
                  data-price={p.price}
                  data-image={p.image}
                >
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Pipeline de trazabilidad -->
  <section class="pipeline-section" aria-labelledby="pipelineTitle">
    <div class="container">
      <div class="pipeline-header">
        <p class="pipeline-eyebrow">Trazabilidad completa</p>
        <h2 id="pipelineTitle" class="pipeline-title">Del grano a tu taza</h2>
        <p class="pipeline-sub">
          Cada bolsa lleva un código QR que documenta este recorrido completo
        </p>
      </div>

      <div class="pipeline-track" role="list">
        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">01</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Cosecha</h3>
          <p class="pipeline-step__desc">Finca, caficultor, municipio y altitud registrados en cada lote</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">02</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3C7 3 3 7.03 3 12s4 9 9 9 9-4.03 9-9-4-9-9-9z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Procesado</h3>
          <p class="pipeline-step__desc">Método documentado: lavado, honey o natural según el perfil del lote</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">03</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2v4M6.34 6.34 3.51 3.51M2 12H6M6.34 17.66l-2.83 2.83M12 18v4M17.66 17.66l2.83 2.83M22 12h-4M17.66 6.34l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Tueste</h3>
          <p class="pipeline-step__desc">Curva de tueste, temperatura y fecha exacta. Máximo 15 días antes de tu pedido</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">04</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="6" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 10h18M8 6V4M16 6V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M8 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Tu bolsa</h3>
          <p class="pipeline-step__desc">QR en el empaque con todo el historial del lote, de la finca a tus manos</p>
        </div>
      </div>

      <div class="pipeline-cta">
        <a href="/trazabilidad" class="btn" data-link>Explorar trazabilidad</a>
      </div>
    </div>
  </section>

  <!-- Manifiesto -->
  <section class="manifesto-strip" aria-label="Nuestra filosofía">
    <div class="manifesto-inner container">
      <blockquote class="manifesto-quote">
        En Colombia, el café es historia acumulada en cada grano.<br />
        Nosotros somos el puente entre quien lo cultiva con cuidado<br class="manifesto-br" />
        y quien lo disfruta con intención.
      </blockquote>
      <p class="manifesto-attr">DobleYo Café — Bogotá, Colombia</p>
    </div>
  </section>

  <!-- Sección: Nuestras Fincas -->
  {
    featuredFarms.length > 0 && (
      <section class="home-farms" aria-labelledby="homeFarmsTitle">
        <div class="container">
          <div class="home-farms__header">
            <h2 id="homeFarmsTitle" class="home-farms__title">
              Nuestras Fincas
            </h2>
            <a href="/fincas" class="home-farms__link">
              Ver todas las fincas →
            </a>
          </div>
          <ul class="home-farms__grid" role="list">
            {featuredFarms.map((farm: any) => (
              <li class="home-farm-card">
                <a href={`/finca/${farm.slug}`} class="home-farm-card__link">
                  {farm.cover_image_url ? (
                    <img
                      src={farm.cover_image_url}
                      alt={`Finca ${farm.name} — ${farm.region}`}
                      loading="lazy"
                      class="home-farm-card__img"
                      width="400"
                      height="240"
                    />
                  ) : (
                    <div
                      class="home-farm-card__img home-farm-card__img--ph"
                      aria-hidden="true"
                    >
                      🌿
                    </div>
                  )}
                  <div class="home-farm-card__info">
                    <span class="home-farm-card__region">{farm.region}</span>
                    <strong class="home-farm-card__name">{farm.name}</strong>
                    {farm.altitude_min && (
                      <span class="home-farm-card__alt">
                        {farm.altitude_min}
                        {farm.altitude_max ? `–${farm.altitude_max}` : ""} msnm
                      </span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }


  <!-- Por qué DobleYo -->
  <section class="why-section" aria-labelledby="whyTitle">
    <div class="container">
      <div class="why-header">
        <p class="why-eyebrow">Por qué elegirnos</p>
        <h2 id="whyTitle" class="why-title">Café con propósito, de la finca a tu taza</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          </div>
          <h3 class="why-card__title">Trazabilidad QR por lote</h3>
          <p class="why-card__desc">Cada bolsa incluye un código QR que documenta la finca, el caficultor, la altitud y la curva de tueste del lote exacto.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="why-card__title">Tueste fresco en 15 días</h3>
          <p class="why-card__desc">Tostamos en pequeños lotes y despachamos en menos de 15 días desde el tueste. Nunca café de bodega.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="why-card__title">Compra directa al caficultor</h3>
          <p class="why-card__desc">Trabajamos directamente con fincas colombianas. Sin intermediarios: mejor precio para el productor, mejor calidad para ti.</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3 class="why-card__title">Envío gratis desde $120.000</h3>
          <p class="why-card__desc">Despachos a todo el territorio nacional. Gratis en pedidos superiores a $120.000 COP.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kits de regalo -->
  {featuredKits.length > 0 && (
    <section class="kits-section" aria-labelledby="kitsTitle">
      <div class="container">
        <div class="kits-header">
          <div>
            <p class="kits-eyebrow">Para regalar</p>
            <h2 id="kitsTitle" class="kits-title">Kits diseñados para sorprender</h2>
          </div>
          <a href="/regalos" class="kits-link" data-link>Ver todos los kits →</a>
        </div>
        <div class="kits-grid">
          {featuredKits.map((kit: any) => (
            <a href={`/producto/${kit.id}`} class="kit-card" data-link>
              <div class="kit-card__img-wrap">
                <img
                  src={kit.image || 'https://images.unsplash.com/photo-1559496417-e7f25cb247f3?q=80&w=600&auto=format&fit=crop'}
                  alt={kit.name}
                  loading="lazy"
                  class="kit-card__img"
                />
              </div>
              <div class="kit-card__body">
                <span class="kit-card__tag">Kit regalo</span>
                <h3 class="kit-card__name">{kit.name}</h3>
                {kit.description && <p class="kit-card__desc">{kit.description.slice(0, 90)}…</p>}
                <span class="kit-card__price">${Number(kit.price).toLocaleString('es-CO')}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter en home -->
  <section class="newsletter-section" aria-labelledby="nlTitle">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-copy">
          <p class="newsletter-eyebrow">Newsletter</p>
          <h2 id="nlTitle" class="newsletter-title">10% de descuento en tu primera compra</h2>
          <p class="newsletter-sub">Suscríbete y recibe el código al instante. También te avisamos de nuevas cosechas y lanzamientos.</p>
        </div>
        <form class="newsletter-form" id="homeNewsletterForm" novalidate>
          <input
            type="email"
            id="homeNlEmail"
            class="newsletter-input"
            placeholder="tu@correo.com"
            required
            aria-label="Correo electrónico"
          />
          <button type="submit" class="newsletter-btn">Suscribirse</button>
        </form>
        <p class="newsletter-msg" id="homeNlMsg" style="display:none"></p>
      </div>
    </div>
  </section>

  <!-- Últimas entradas del blog -->
  {recentPosts.length > 0 && (
    <section class="blog-section" aria-labelledby="blogTitle">
      <div class="container">
        <div class="blog-home-header">
          <div>
            <p class="blog-eyebrow">Blog</p>
            <h2 id="blogTitle" class="blog-home-title">Recetas, notas de cata y guías</h2>
          </div>
          <a href="/blog" class="blog-home-link" data-link>Ver todas las entradas →</a>
        </div>
        <div class="blog-home-grid">
          {recentPosts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="blog-home-card" data-link>
              <div class="blog-home-card__img-wrap">
                <img
                  src={post.cover_image_url || 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=600&auto=format&fit=crop'}
                  alt={post.title}
                  loading="lazy"
                  class="blog-home-card__img"
                />
              </div>
              <div class="blog-home-card__body">
                <h3 class="blog-home-card__title">{post.title}</h3>
                {post.excerpt && <p class="blog-home-card__exc">{post.excerpt.slice(0, 80)}…</p>}
                <span class="blog-home-card__time">{post.reading_time_min ?? 3} min de lectura</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Reseñas -->
  {featuredReviews.length > 0 && (
    <section class="reviews-home" aria-labelledby="reviewsHomeTitle">
      <div class="container">
        <div class="reviews-home-header">
          <p class="reviews-eyebrow">Lo que dicen nuestros clientes</p>
          <h2 id="reviewsHomeTitle" class="reviews-home-title">Reseñas verificadas</h2>
        </div>
        <div class="reviews-home-grid">
          {featuredReviews.map((r: any) => (
            <div class="review-home-card">
              <div class="review-home-card__stars" aria-label={`${r.rating} estrellas`}>
                {"★".repeat(r.rating)}{"☆".repeat(5 - r.rating)}
              </div>
              <p class="review-home-card__comment">"{r.comment}"</p>
              <div class="review-home-card__meta">
                <strong>{r.reviewer_name}</strong>
                {r.product_name && <span>sobre {r.product_name}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Script: newsletter de home -->
  <!-- Newsletter + botones "+" del grid (externalizado por CSP estricta) -->
  <script is:inline src="/assets/js/home.js"></script>
  <style>
    /* =============================================
       ORIGIN STRIP
    ============================================= */
    .origin-strip {
      background: var(--coffee);
      color: rgba(255,255,255,.72);
      font-size: .72rem;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      letter-spacing: .12em;
      text-transform: uppercase;
      overflow: hidden;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .origin-strip__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: .75rem 1.5rem;
      padding: .75rem 1.25rem;
      max-width: var(--page-width);
      margin: 0 auto;
    }
    .origin-strip__div {
      display: inline-block;
      width: 1px;
      height: 10px;
      background: rgba(255,255,255,.25);
      flex-shrink: 0;
    }
    @media (max-width: 640px) {
      .origin-strip__div { display: none; }
      .origin-strip__inner { gap: .5rem 1rem; }
    }

    /* =============================================
       COFFEE SECTION
    ============================================= */
    .cs-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
    }
    .cs-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }
    .cs-eyebrow {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 .5rem;
    }
    .cs-title {
      font-size: clamp(1.4rem, 3vw, 2rem);
      color: var(--coffee);
      margin: 0;
      line-height: 1.1;
    }
    .cs-all-link {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: .85rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      padding-bottom: 1px;
      border-bottom: 1px solid transparent;
      transition: border-color .15s;
    }
    .cs-all-link:hover { border-bottom-color: var(--accent); }

    .cs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 900px) { .cs-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
