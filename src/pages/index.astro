---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products.ts";
import { getCanonicalUrl, getHreflangPair } from "../i18n/index.ts";

const _hreflang = getHreflangPair("/");

// Fuente única: productos desde src/data/products.ts
const coffeeProducts = products.filter((p) => p.category === "Cafés");

// Fincas destacadas (máx. 3 publicadas)
let featuredFarms: any[] = [];
try {
  const res = await fetch(`${Astro.url.origin}/api/farms?limit=3`);
  if (res.ok) {
    const data = await res.json();
    featuredFarms = data.data ?? [];
  }
} catch (_) {}
---

<Layout
  lang="es"
  canonical={getCanonicalUrl("/", "es")}
  hreflangEs={_hreflang?.es}
  hreflangEn={_hreflang?.en}
>
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video
        src="/assets/vids/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        disablePictureInPicture
        preload="metadata"></video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <h1>Más que café, una herencia en cada taza.</h1>
    <p>
      Somos el reflejo de la riqueza cultural y el esfuerzo de generaciones que
      cultivan en el corazón de Colombia.<br />Descubre el sabor de nuestra
      tradición y la pasión de nuestra tierra.
    </p>
    <p><a class="btn" href="/tienda" data-link>Ver tienda</a></p>
  </section>

  <!-- Banda de datos de origen -->
  <div class="origin-strip" aria-hidden="true">
    <div class="origin-strip__inner">
      <span>Colombia · Origen único</span>
      <span class="origin-strip__div"></span>
      <span>1.400 – 1.900 msnm</span>
      <span class="origin-strip__div"></span>
      <span>Lavado · Honey · Natural</span>
      <span class="origin-strip__div"></span>
      <span>Tueste fresco en menos de 15 días</span>
    </div>
  </div>

  <!-- Cafés en venta -->
  <section class="cs-section" aria-labelledby="csSectionTitle">
    <div class="cs-header container">
      <div>
        <p class="cs-eyebrow">Nuestros cafés</p>
        <h2 id="csSectionTitle" class="cs-title">Origen trazable, tueste fresco</h2>
      </div>
      <a href="/tienda" class="cs-all-link" data-link>Ver todos los productos →</a>
    </div>

    <div class="cs-grid container">
      {
        coffeeProducts.map((p) => (
          <article class="cs-card">
            <div class="cs-card__img-wrap">
              <img src={p.image} alt={p.name} class="cs-card__img" loading="lazy" width="400" height="480" />
              {p.bestseller && <span class="cs-card__flag">Más vendido</span>}
              {p.new && !p.bestseller && <span class="cs-card__flag cs-card__flag--new">Nuevo</span>}
            </div>
            <div class="cs-card__body">
              <p class="cs-card__meta">
                {p.origin}
                {p.process && <span class="cs-card__dot" aria-hidden="true">·</span>}
                {p.process && <span>{p.process}</span>}
              </p>
              <h3 class="cs-card__name">{p.name}</h3>
              {p.notes && (
                <p class="cs-card__notes">{p.notes.join(" · ")}</p>
              )}
              <div class="cs-card__footer">
                <span class="cs-card__price">${p.price.toLocaleString("es-CO")}</span>
                <button
                  class="cs-card__add btn-add"
                  aria-label={`Agregar ${p.name} al carrito`}
                  data-id={p.id}
                  data-name={p.name}
                  data-price={p.price}
                  data-image={p.image}
                >
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Pipeline de trazabilidad -->
  <section class="pipeline-section" aria-labelledby="pipelineTitle">
    <div class="container">
      <div class="pipeline-header">
        <p class="pipeline-eyebrow">Trazabilidad completa</p>
        <h2 id="pipelineTitle" class="pipeline-title">Del grano a tu taza</h2>
        <p class="pipeline-sub">
          Cada bolsa lleva un código QR que documenta este recorrido completo
        </p>
      </div>

      <div class="pipeline-track" role="list">
        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">01</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Cosecha</h3>
          <p class="pipeline-step__desc">Finca, caficultor, municipio y altitud registrados en cada lote</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">02</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3C7 3 3 7.03 3 12s4 9 9 9 9-4.03 9-9-4-9-9-9z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Procesado</h3>
          <p class="pipeline-step__desc">Método documentado: lavado, honey o natural según el perfil del lote</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">03</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2v4M6.34 6.34 3.51 3.51M2 12H6M6.34 17.66l-2.83 2.83M12 18v4M17.66 17.66l2.83 2.83M22 12h-4M17.66 6.34l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <h3 class="pipeline-step__title">Tueste</h3>
          <p class="pipeline-step__desc">Curva de tueste, temperatura y fecha exacta. Máximo 15 días antes de tu pedido</p>
        </div>

        <div class="pipeline-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="pipeline-step" role="listitem">
          <span class="pipeline-step__num" aria-hidden="true">04</span>
          <svg class="pipeline-step__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="6" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 10h18M8 6V4M16 6V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M8 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <h3 class="pipeline-step__title">Tu bolsa</h3>
          <p class="pipeline-step__desc">QR en el empaque con todo el historial del lote, de la finca a tus manos</p>
        </div>
      </div>

      <div class="pipeline-cta">
        <a href="/trazabilidad" class="btn" data-link>Explorar trazabilidad</a>
      </div>
    </div>
  </section>

  <!-- Manifiesto -->
  <section class="manifesto-strip" aria-label="Nuestra filosofía">
    <div class="manifesto-inner container">
      <blockquote class="manifesto-quote">
        En Colombia, el café es historia acumulada en cada grano.<br />
        Nosotros somos el puente entre quien lo cultiva con cuidado<br class="manifesto-br" />
        y quien lo disfruta con intención.
      </blockquote>
      <p class="manifesto-attr">DobleYo Café — Bogotá, Colombia</p>
    </div>
  </section>

  <!-- Sección: Nuestras Fincas -->
  {
    featuredFarms.length > 0 && (
      <section class="home-farms" aria-labelledby="homeFarmsTitle">
        <div class="container">
          <div class="home-farms__header">
            <h2 id="homeFarmsTitle" class="home-farms__title">
              Nuestras Fincas
            </h2>
            <a href="/fincas" class="home-farms__link">
              Ver todas las fincas →
            </a>
          </div>
          <ul class="home-farms__grid" role="list">
            {featuredFarms.map((farm: any) => (
              <li class="home-farm-card">
                <a href={`/finca/${farm.slug}`} class="home-farm-card__link">
                  {farm.cover_image_url ? (
                    <img
                      src={farm.cover_image_url}
                      alt={`Finca ${farm.name} — ${farm.region}`}
                      loading="lazy"
                      class="home-farm-card__img"
                      width="400"
                      height="240"
                    />
                  ) : (
                    <div
                      class="home-farm-card__img home-farm-card__img--ph"
                      aria-hidden="true"
                    >
                      🌿
                    </div>
                  )}
                  <div class="home-farm-card__info">
                    <span class="home-farm-card__region">{farm.region}</span>
                    <strong class="home-farm-card__name">{farm.name}</strong>
                    {farm.altitude_min && (
                      <span class="home-farm-card__alt">
                        {farm.altitude_min}
                        {farm.altitude_max ? `–${farm.altitude_max}` : ""} msnm
                      </span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }


  <!-- Script: conectar botones "+" al carrito -->
  <script>
    document.querySelector(".cs-grid")?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(
        ".btn-add",
      ) as HTMLButtonElement | null;
      if (!btn) return;
      const { id, name, price, image } = btn.dataset;
      if (id && name && price && image && (window as any).Cart) {
        (window as any).Cart.addToCart({
          id,
          name,
          price: parseInt(price, 10),
          image,
          qty: 1,
        });
        // feedback visual breve
        btn.classList.add("cs-card__add--added");
        setTimeout(() => btn.classList.remove("cs-card__add--added"), 900);
      }
    });
  </script>
  <style>
    /* =============================================
       ORIGIN STRIP
    ============================================= */
    .origin-strip {
      background: var(--coffee);
      color: rgba(255,255,255,.72);
      font-size: .72rem;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      letter-spacing: .12em;
      text-transform: uppercase;
      overflow: hidden;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .origin-strip__inner {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: .75rem 1.5rem;
      padding: .75rem 1.25rem;
      max-width: var(--page-width);
      margin: 0 auto;
    }
    .origin-strip__div {
      display: inline-block;
      width: 1px;
      height: 10px;
      background: rgba(255,255,255,.25);
      flex-shrink: 0;
    }
    @media (max-width: 640px) {
      .origin-strip__div { display: none; }
      .origin-strip__inner { gap: .5rem 1rem; }
    }

    /* =============================================
       COFFEE SECTION
    ============================================= */
    .cs-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
    }
    .cs-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }
    .cs-eyebrow {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 .5rem;
    }
    .cs-title {
      font-size: clamp(1.4rem, 3vw, 2rem);
      color: var(--coffee);
      margin: 0;
      line-height: 1.1;
    }
    .cs-all-link {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: .85rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      padding-bottom: 1px;
      border-bottom: 1px solid transparent;
      transition: border-color .15s;
    }
    .cs-all-link:hover { border-bottom-color: var(--accent); }

    .cs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 900px) { .cs-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
    @media (max-width: 540px)  { .cs-grid { grid-template-columns: 1fr; gap: 1rem; } }

    .cs-card {
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: .875rem;
      overflow: hidden;
      transition: box-shadow .2s ease, transform .2s ease;
    }
    .cs-card:hover {
      box-shadow: 0 8px 32px rgba(37,26,20,.1);
      transform: translateY(-3px);
    }

    .cs-card__img-wrap {
      position: relative;
      overflow: hidden;
      background: #f5f0eb;
      aspect-ratio: 4 / 5;
    }
    .cs-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .4s ease;
    }
    .cs-card:hover .cs-card__img { transform: scale(1.04); }

    .cs-card__flag {
      position: absolute;
      top: .875rem;
      left: .875rem;
      background: var(--coffee);
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: .25rem .6rem;
      border-radius: .25rem;
    }
    .cs-card__flag--new { background: #16a34a; }

    .cs-card__body {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: .375rem;
      flex: 1;
    }
    .cs-card__meta {
      font-family: 'Inter', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0;
    }
    .cs-card__dot { margin: 0 .2rem; opacity: .5; }
    .cs-card__name {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--coffee);
      margin: 0;
      line-height: 1.2;
    }
    .cs-card__notes {
      font-size: .8rem;
      color: var(--muted-fg);
      margin: 0;
      line-height: 1.5;
    }
    .cs-card__footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      padding-top: .875rem;
      border-top: 1px solid var(--border);
    }
    .cs-card__price {
      font-family: 'Inter', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--coffee);
    }
    .cs-card__add {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--coffee);
      color: #fff;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .15s, transform .15s;
      flex-shrink: 0;
    }
    .cs-card__add:hover { background: var(--accent); }
    .cs-card__add--added {
      background: #16a34a;
      transform: scale(.92);
    }

    /* =============================================
       PIPELINE
    ============================================= */
    .pipeline-section {
      padding: 5rem 0;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }
    .pipeline-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .pipeline-eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 .75rem;
    }
    .pipeline-title {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      color: var(--coffee);
      margin: 0 0 .875rem;
      line-height: 1.1;
    }
    .pipeline-sub {
      font-size: .95rem;
      color: var(--muted-fg);
      max-width: 50ch;
      margin: 0 auto;
      line-height: 1.6;
    }

    .pipeline-track {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
      align-items: start;
      gap: 0;
      margin-bottom: 3rem;
    }

    .pipeline-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1rem;
    }
    .pipeline-step__num {
      font-family: 'Inter', sans-serif;
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .1em;
      color: var(--accent);
      margin-bottom: .875rem;
    }
    .pipeline-step__icon {
      width: 40px;
      height: 40px;
      color: var(--coffee);
      margin-bottom: 1rem;
      stroke-width: 1.3;
    }
    .pipeline-step__title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--coffee);
      margin: 0 0 .5rem;
    }
    .pipeline-step__desc {
      font-size: .8rem;
      color: var(--muted-fg);
      line-height: 1.55;
      margin: 0;
      max-width: 18ch;
    }

    .pipeline-connector {
      display: flex;
      align-items: flex-start;
      padding-top: 2.25rem; /* align with icon center */
      color: var(--border);
    }
    .pipeline-connector svg { width: 20px; height: 20px; flex-shrink: 0; }

    .pipeline-cta {
      display: flex;
      justify-content: center;
    }

    @media (max-width: 900px) {
      .pipeline-track {
        grid-template-columns: 1fr;
        max-width: 360px;
        margin: 0 auto 3rem;
      }
      .pipeline-connector {
        justify-content: center;
        padding-top: 0;
        padding: .75rem 0;
        transform: rotate(90deg);
      }
      .pipeline-step { padding: 0; }
      .pipeline-step__desc { max-width: 30ch; }
    }

    /* =============================================
       MANIFESTO STRIP
    ============================================= */
    .manifesto-strip {
      background: var(--coffee);
      padding: 5rem 0;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .manifesto-inner { max-width: 760px; }
    .manifesto-quote {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(1.25rem, 3.5vw, 1.9rem);
      font-weight: 600;
      line-height: 1.6;
      color: rgba(255,255,255,.95);
      margin: 0 0 1.75rem;
      font-style: italic;
      letter-spacing: .01em;
      quotes: none;
    }
    .manifesto-attr {
      font-family: 'Inter', sans-serif;
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.4);
      margin: 0;
    }
    @media (max-width: 640px) {
      .manifesto-strip { padding: 3.5rem 1.25rem; }
      .manifesto-br { display: none; }
    }
  </style>
</Layout>
