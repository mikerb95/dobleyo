---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products.ts";
import { getCanonicalUrl, getHreflangPair } from "../i18n/index.ts";

const _hreflang = getHreflangPair("/");

// Fuente única: productos desde src/data/products.ts
const coffeeProducts = products.filter((p) => p.category === "Cafés");

// Fincas destacadas (máx. 3 publicadas)
let featuredFarms: any[] = [];
try {
  const res = await fetch(`${Astro.url.origin}/api/farms?limit=3`);
  if (res.ok) {
    const data = await res.json();
    featuredFarms = data.data ?? [];
  }
} catch (_) {}
---

<Layout
  lang="es"
  canonical={getCanonicalUrl("/", "es")}
  hreflangEs={_hreflang?.es}
  hreflangEn={_hreflang?.en}
>
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <video
        src="/assets/vids/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        disablePictureInPicture
        preload="metadata"></video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <h1>Más que café, una herencia en cada taza.</h1>
    <p>
      Somos el reflejo de la riqueza cultural y el esfuerzo de generaciones que
      cultivan en el corazón de Colombia.<br />Descubre el sabor de nuestra
      tradición y la pasión de nuestra tierra.
    </p>
    <p><a class="btn" href="/tienda" data-link>Ver tienda</a></p>
  </section>

  <!-- Sección de cafés en venta — datos desde src/data/products.ts -->
  <section class="coffee-shop" aria-labelledby="coffeeShopTitle">
    <div class="coffee-shop-header">
      <h2 id="coffeeShopTitle" class="coffee-shop-title">Cafés en venta</h2>
      <a href="/tienda" class="coffee-shop-link" data-link>Ver todos →</a>
    </div>

    <div class="coffee-scroll">
      {
        coffeeProducts.map((p) => (
          <article class="coffee-card">
            <img src={p.image} alt={p.name} class="coffee-img" loading="lazy" />
            <span class="coffee-badge">
              {p.bestseller ? "Más Vendido" : `Tueste ${p.roast}`}
            </span>
            <h3 class="coffee-name">{p.name}</h3>
            <p class="coffee-notes">{p.notes?.join(", ")}</p>
            <div class="coffee-footer">
              <span class="coffee-price">
                ${p.price.toLocaleString("es-CO")}
              </span>
              <button
                class="btn-add"
                aria-label={`Agregar ${p.name} al carrito`}
                data-id={p.id}
                data-name={p.name}
                data-price={p.price}
                data-image={p.image}
              >
                +
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Sección de Trazabilidad -->
  <section class="traceability-section" aria-labelledby="traceabilityTitle">
    <div class="container">
      <div class="traceability-content">
        <div class="traceability-text">
          <h2 id="traceabilityTitle">Transparencia del grano a la taza</h2>
          <p class="traceability-subtitle">
            Cada bolsa incluye un código QR con toda la información del lote
          </p>

          <div class="traceability-features">
            <div class="feature-item">
              <div class="feature-icon">🌱</div>
              <div>
                <h3>Trazabilidad Total</h3>
                <p>
                  Finca, región, altura y caficultor. Sabe exactamente de dónde
                  viene tu café
                </p>
              </div>
            </div>

            <div class="feature-item">
              <div class="feature-icon">👨‍🌾</div>
              <div>
                <h3>Productor Verificado</h3>
                <p>
                  Conoce al cultivador, sus métodos sostenibles y la historia
                  detrás de cada cosecha
                </p>
              </div>
            </div>

            <div class="feature-item">
              <div class="feature-icon">☕</div>
              <div>
                <h3>Diseñado para tu Paladar</h3>
                <p>
                  Notas de cata precisas y recomendaciones personalizadas.
                  Guarda tus favoritos en tu perfil
                </p>
              </div>
            </div>

            <div class="feature-item">
              <div class="feature-icon">📅</div>
              <div>
                <h3>Tostado Bajo Pedido</h3>
                <p>
                  Tueste fresco en los últimos 15 días. Sin café de estante:
                  máxima calidad garantizada
                </p>
              </div>
            </div>
          </div>

          <div class="traceability-cta">
            <a href="/trazabilidad" class="btn" data-link
              >Ver ejemplo de trazabilidad</a
            >
            <p class="cta-note">
              Escanea el código QR de tu bolsa para ver toda la información
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Artículos destacados -->
  <section class="featured" aria-labelledby="featuredTitle">
    <div class="featured-inner container">
      <h2 id="featuredTitle" class="featured-title">Artículos destacados</h2>
      <div class="featured-grid">
        <article class="card featured-card">
          <img
            class="featured-img"
            src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1200&auto=format&fit=crop"
            alt="Origen Sierra Nevada"
            loading="lazy"
          />
          <div class="p featured-body">
            <h3 class="featured-h3">Sierra Nevada: notas a cacao y caramelo</h3>
            <p class="featured-desc muted">
              Un perfil equilibrado con dulzor marcado, ideal para espresso y
              preparaciones con leche. Origen trazable y tueste fresco.
            </p>
            <a class="btn small" href="/tienda" data-link>Ver producto</a>
          </div>
        </article>
        <article class="card featured-card">
          <img
            class="featured-img"
            src="https://images.unsplash.com/photo-1507133750040-4a8f57021524?q=80&w=1200&auto=format&fit=crop"
            alt="Guía de molienda"
            loading="lazy"
          />
          <div class="p featured-body">
            <h3 class="featured-h3">Guía rápida de molienda por método</h3>
            <p class="featured-desc muted">
              Mejora tu taza ajustando la molienda según tu método: V60, Chemex,
              prensa o espresso. Reglas simples para resultados consistentes.
            </p>
            <a class="btn outline small" href="/blog" data-link>Leer más</a>
          </div>
        </article>
        <article class="card featured-card">
          <img
            class="featured-img"
            src="https://images.unsplash.com/photo-1529070538774-1843cb3265df?q=80&w=1200&auto=format&fit=crop"
            alt="Productor aliado"
            loading="lazy"
          />
          <div class="p featured-body">
            <h3 class="featured-h3">
              Productores aliados: historias de origen
            </h3>
            <p class="featured-desc muted">
              Conoce a los caficultores detrás de cada lote. Transparencia,
              relaciones directas y sostenibilidad en cada paso.
            </p>
            <a class="btn outline small" href="/nosotros" data-link
              >Conocer más</a
            >
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Sección: Nuestras Fincas -->
  {
    featuredFarms.length > 0 && (
      <section class="home-farms" aria-labelledby="homeFarmsTitle">
        <div class="container">
          <div class="home-farms__header">
            <h2 id="homeFarmsTitle" class="home-farms__title">
              Nuestras Fincas
            </h2>
            <a href="/fincas" class="home-farms__link">
              Ver todas las fincas →
            </a>
          </div>
          <ul class="home-farms__grid" role="list">
            {featuredFarms.map((farm: any) => (
              <li class="home-farm-card">
                <a href={`/finca/${farm.slug}`} class="home-farm-card__link">
                  {farm.cover_image_url ? (
                    <img
                      src={farm.cover_image_url}
                      alt={`Finca ${farm.name} — ${farm.region}`}
                      loading="lazy"
                      class="home-farm-card__img"
                      width="400"
                      height="240"
                    />
                  ) : (
                    <div
                      class="home-farm-card__img home-farm-card__img--ph"
                      aria-hidden="true"
                    >
                      🌿
                    </div>
                  )}
                  <div class="home-farm-card__info">
                    <span class="home-farm-card__region">{farm.region}</span>
                    <strong class="home-farm-card__name">{farm.name}</strong>
                    {farm.altitude_min && (
                      <span class="home-farm-card__alt">
                        {farm.altitude_min}
                        {farm.altitude_max ? `–${farm.altitude_max}` : ""} msnm
                      </span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Evidencia social -->
  <section class="evidence-section" aria-labelledby="evidenceTitle">
    <img
      class="e-beans e-beans-left"
      src="/assets/beans.svg"
      alt=""
      aria-hidden="true"
    />
    <img
      class="e-beans e-beans-right"
      src="/assets/beans.svg"
      alt=""
      aria-hidden="true"
    />
    <div class="evidence-inner container">
      <div class="evidence-grid">
        <div class="e-left">
          <h2 id="evidenceTitle" class="e-title">
            A diferencia de cualquier otro café
          </h2>
        </div>

        <div class="e-stat e-stat-a">
          <div class="e-number">9 de 10</div>
          <p class="e-sub">De los compradores de DobleYo dicen que</p>
          <p class="e-sub">funciona</p>
        </div>

        <div class="e-stat e-stat-b">
          <div class="e-number">94%</div>
          <p class="e-sub">de los compradores planean</p>
          <p class="e-sub">volver a comprar</p>
        </div>

        <div class="e-mid">
          <div
            class="e-badge"
            role="img"
            aria-label="#1 en satisfacción del consumidor"
          >
            <span class="e-badge-num">#1</span>
            <span class="e-badge-label">en Satisfacción del Consumidor</span>
          </div>
          <p class="e-desc">
            Clasificado por los compradores de DobleYo como el más alto en sabor
            y eficacia frente a los compradores de productos competitivos.
          </p>
        </div>

        <div class="e-reasons">
          <h3 class="e-reasons-title">
            La gente se cambia a DobleYo<br class="md-break" /> por estas razones:
          </h3>
          <ol class="e-list">
            <li><span class="e-dot">1</span> Mejor sabor</li>
            <li><span class="e-dot">2</span> Mejores ingredientes</li>
            <li><span class="e-dot">3</span> Mejores resultados*</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Script: conectar botones "+" al carrito -->
  <script>
    document.querySelector(".coffee-scroll")?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(
        ".btn-add",
      ) as HTMLButtonElement | null;
      if (!btn) return;
      const { id, name, price, image } = btn.dataset;
      if (id && name && price && image && (window as any).Cart) {
        (window as any).Cart.addToCart({
          id,
          name,
          price: parseInt(price, 10),
          image,
          qty: 1,
        });
      }
    });
  </script>
</Layout>
