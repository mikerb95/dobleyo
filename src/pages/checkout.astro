---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Pagar — DobleYo Café"
  description="Finaliza tu pedido de café de especialidad. Envíos nacionales en Colombia."
  hideWhatsApp={true}
>
  <div class="co-page">

    <!-- Barra de progreso -->
    <div class="co-progress" aria-label="Pasos del proceso de compra">
      <a href="/cart" class="co-step co-step--done">
        <span class="co-step__dot">
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M1.5 5.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        Carrito
      </a>
      <div class="co-step__line co-step__line--done"></div>
      <div class="co-step co-step--active">
        <span class="co-step__dot co-step__dot--active">2</span>
        Datos &amp; Pago
      </div>
      <div class="co-step__line"></div>
      <div class="co-step co-step--pending">
        <span class="co-step__dot co-step__dot--pending">3</span>
        Confirmación
      </div>
    </div>

    <!-- Carrito vacío -->
    <div id="cartEmpty" class="co-empty" style="display:none;">
      <p class="co-empty__text">Tu carrito está vacío.</p>
      <a href="/tienda" class="co-btn-primary" style="display:inline-flex; width:auto; padding:.75rem 2rem;">Ver tienda</a>
    </div>

    <!-- Layout checkout -->
    <div id="checkoutLayout" class="co-layout" style="display:none;">

      <!-- Columna formulario -->
      <div class="co-form-col">

        <!-- Aviso de sesión: usuario registrado o invitado -->
        <div id="coAuthBanner" class="co-auth-banner" style="display:none;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 13.5c0-2.76 2.46-5 5.5-5s5.5 2.24 5.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          <span id="coAuthBannerText"></span>
        </div>

        <!-- Sección envío -->
        <section class="co-section" id="sectionShipping">
          <div class="co-section__header">
            <span class="co-section__num">1</span>
            <h2 class="co-section__title">Información de envío</h2>
          </div>

          <form id="shipForm" novalidate class="co-form">
            <div class="co-field">
              <label class="co-label" for="fName">Nombre completo <span class="co-req">*</span></label>
              <div class="co-input-wrap">
                <svg class="co-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 13.5c0-2.76 2.46-5 5.5-5s5.5 2.24 5.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                <input id="fName" type="text" class="co-input" placeholder="Juan García" required autocomplete="name" />
              </div>
            </div>

            <div class="co-field-row">
              <div class="co-field">
                <label class="co-label" for="fEmail">Correo electrónico <span class="co-req">*</span></label>
                <div class="co-input-wrap">
                  <svg class="co-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="3.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M1.5 5.5l6.5 4 6.5-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  <input id="fEmail" type="email" class="co-input" placeholder="tu@correo.com" required autocomplete="email" />
                </div>
              </div>

              <!-- Teléfono con selector de país -->
              <div class="co-field">
                <label class="co-label" for="fPhone">Teléfono</label>
                <div class="co-phone-wrap">
                  <button type="button" class="co-phone-trigger" id="phoneTrigger" aria-expanded="false" aria-haspopup="listbox" aria-label="Seleccionar código de país">
                    <span id="phoneFlag">🇨🇴</span>
                    <span id="phoneCodeLabel">+57</span>
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <div class="co-phone-dropdown" id="phoneDropdown" role="listbox" style="display:none;"></div>
                  <input id="fPhone" type="tel" class="co-input co-input--phone-field" placeholder="300 000 0000" inputmode="tel" autocomplete="tel-national" />
                </div>
              </div>
            </div>

            <div class="co-field">
              <label class="co-label" for="fAddr">Dirección de entrega <span class="co-req">*</span></label>
              <div class="co-input-wrap">
                <svg class="co-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1.5C5.52 1.5 3.5 3.52 3.5 6c0 3.5 4.5 8.5 4.5 8.5S12.5 9.5 12.5 6c0-2.48-2.02-4.5-4.5-4.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
                <input id="fAddr" type="text" class="co-input" placeholder="Calle 123 # 45-67, Apto 8" required autocomplete="street-address" />
              </div>
            </div>

            <!-- Departamento primero, luego ciudad filtrada -->
            <div class="co-field-row">
              <div class="co-field">
                <label class="co-label" for="fDept">Departamento <span class="co-req">*</span></label>
                <div class="co-select-wrap">
                  <svg class="co-select-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1.5C5.52 1.5 3.5 3.52 3.5 6c0 3.5 4.5 8.5 4.5 8.5S12.5 9.5 12.5 6c0-2.48-2.02-4.5-4.5-4.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
                  <select id="fDept" class="co-select" required>
                    <option value="">Selecciona departamento…</option>
                  </select>
                  <svg class="co-select-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 4.5l3.5 3.5 3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
              <div class="co-field">
                <label class="co-label" for="fCity">Ciudad <span class="co-req">*</span></label>
                <div class="co-select-wrap">
                  <svg class="co-select-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="7" width="12" height="7.5" rx="1" stroke="currentColor" stroke-width="1.4"/><path d="M5 14.5v-4h2.5v4M8.5 14.5v-4H11v4M1 7l7-5.5L15 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <select id="fCity" class="co-select" required disabled>
                    <option value="">Primero selecciona departamento</option>
                  </select>
                  <svg class="co-select-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 4.5l3.5 3.5 3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
            </div>
          </form>
        </section>

        <!-- Sección pago -->
        <section class="co-section">
          <div class="co-section__header">
            <span class="co-section__num">2</span>
            <h2 class="co-section__title">Método de pago</h2>
          </div>

          <div class="co-pay-methods">
            <label class="co-pay-option co-pay-option--selected" id="payOptionWompi">
              <input type="radio" name="payMethod" value="wompi" checked class="co-radio" />
              <div class="co-pay-option__body">
                <div class="co-pay-option__top">
                  <div class="co-pay-option__name">
                    <span class="co-pay-badge">Wompi</span>
                    <span class="co-pay-desc">Tarjeta, PSE, Nequi, Daviplata</span>
                  </div>
                  <div class="co-pay-chips">
                    <span class="co-chip">PSE</span>
                    <span class="co-chip">Visa</span>
                    <span class="co-chip">MC</span>
                    <span class="co-chip">Nequi</span>
                  </div>
                </div>
              </div>
            </label>
            <label class="co-pay-option" id="payOptionCod">
              <input type="radio" name="payMethod" value="cod" class="co-radio" />
              <div class="co-pay-option__body">
                <div class="co-pay-option__top">
                  <div class="co-pay-option__name">
                    <span class="co-pay-badge">Contraentrega</span>
                    <span class="co-pay-desc">Pague en efectivo o datáfono al recibir su pedido</span>
                  </div>
                </div>
              </div>
            </label>
          </div>

          <div id="codNote" class="co-legal" style="display:none;">
            Disponible únicamente para envíos dentro de Colombia. El mensajero le cobrará el valor total del pedido al momento de la entrega.
          </div>

          <div id="payError" class="co-error" style="display:none;" role="alert"></div>

          <button class="co-btn-primary" id="payBtn" type="button">
            <span id="payBtnText">Confirmar y pagar</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="4.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M1.5 8h13M5 4.5V3a3 3 0 016 0v1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </button>

          <p class="co-legal">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" style="flex-shrink:0"><path d="M6 1L2 3v2.5c0 2.4 1.7 4.6 4 5.2 2.3-.6 4-2.8 4-5.2V3L6 1z" stroke="#9ca3af" stroke-width="1" stroke-linejoin="round"/></svg>
            Pago cifrado y seguro. Al continuar aceptas nuestros
            <a href="/terminos">Términos y Condiciones</a>.
          </p>
        </section>
      </div>

      <!-- Resumen lateral -->
      <aside class="co-summary-col">
        <div class="co-summary-card">
          <h2 class="co-summary-title">Tu pedido</h2>

          <div id="sumList" class="co-sum-list"></div>

          <div class="co-sum-lines">
            <div class="co-sum-line">
              <span>Subtotal</span>
              <span id="sumSubtotal">$0</span>
            </div>
            <div class="co-sum-line">
              <span>Envío</span>
              <span id="sumShipping">—</span>
            </div>
          </div>

          <div id="shipNote" class="co-ship-note" style="display:none;">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M1.5 6.5l3 3 7-7" stroke="#16a34a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Envío gratis en este pedido
          </div>

          <div class="co-sum-total">
            <span>Total</span>
            <div>
              <span id="sumTotal" class="co-total-amount">$0</span>
              <span class="co-total-tax">COP · IVA incluido</span>
            </div>
          </div>

          <div class="co-sum-trust">
            <div class="co-sum-trust-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1L2 3.5V7c0 2.7 2 5.1 5 5.7 3-0.6 5-3 5-5.7V3.5L7 1z" stroke="#4a6741" stroke-width="1.2" stroke-linejoin="round"/></svg>
              <span>Pago 100% seguro con SSL</span>
            </div>
            <div class="co-sum-trust-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5.5" stroke="#4a6741" stroke-width="1.2"/><path d="M4.5 7l2 2 3-3.5" stroke="#4a6741" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Devolución garantizada 5 días</span>
            </div>
            <div class="co-sum-trust-item co-sum-trust-item--legal">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="2" y="1.5" width="10" height="11" rx="1.5" stroke="#4a6741" stroke-width="1.2"/><path d="M4.5 5h5M4.5 7.5h5M4.5 10h3" stroke="#4a6741" stroke-width="1.2" stroke-linecap="round"/></svg>
              <span>No Responsable de IVA · Documento soporte de transacción</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- Barra inferior fija — solo móvil -->
  <div id="coMobileBar" class="co-mobile-bar" aria-hidden="true">
    <div class="co-mb-info">
      <span class="co-mb-label">Total</span>
      <span id="coMbTotal" class="co-mb-amount">$0</span>
    </div>
    <button id="coMbPayBtn" class="co-mb-btn" type="button">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1" y="4" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M1 8h12M5 4V3a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span id="coMbPayText">Confirmar y pagar</span>
    </button>
  </div>

  <!-- Widget Checkout de Wompi (modal embebido, no redirige fuera de la página) -->
  <script is:inline src="https://checkout.wompi.co/widget.js"></script>

  <script>
    // @ts-nocheck — script vanilla del navegador; usa globales inyectados por
    // scripts externos (window.Cart de cart.js, window.WidgetCheckout de widget.js).
    (function () {
      const FREE_SHIP = 120000;
      const SHIP_COST = 12000;
      function fmt(n) { return '$' + Number(n || 0).toLocaleString('es-CO'); }
      function ready(fn) { if (document.readyState !== 'loading') fn(); else document.addEventListener('DOMContentLoaded', fn); }
      function whenCart(fn) { if (window.Cart) fn(); else setTimeout(() => whenCart(fn), 40); }

      // ── Datos Colombia: departamentos y ciudades ──────────────────────────
      const CO_DATA = {
        'Amazonas':             ['Leticia', 'Puerto Nariño'],
        'Antioquia':            ['Medellín', 'Bello', 'Envigado', 'Itagüí', 'Sabaneta', 'Rionegro', 'Apartadó', 'Turbo', 'Caucasia', 'Itaguí'],
        'Arauca':               ['Arauca', 'Saravena', 'Tame', 'Fortul'],
        'Atlántico':            ['Barranquilla', 'Soledad', 'Malambo', 'Sabanalarga', 'Galapa', 'Puerto Colombia'],
        'Bogotá D.C.':          ['Bogotá D.C.'],
        'Bolívar':              ['Cartagena', 'Magangué', 'El Carmen de Bolívar', 'Mompós'],
        'Boyacá':               ['Tunja', 'Duitama', 'Sogamoso', 'Chiquinquirá', 'Paipa', 'Villa de Leyva'],
        'Caldas':               ['Manizales', 'La Dorada', 'Chinchiná', 'Riosucio', 'Villamaría'],
        'Caquetá':              ['Florencia', 'San Vicente del Caguán', 'Puerto Rico'],
        'Casanare':             ['Yopal', 'Aguazul', 'Villanueva', 'Paz de Ariporo'],
        'Cauca':                ['Popayán', 'Santander de Quilichao', 'Puerto Tejada', 'Patía'],
        'Cesar':                ['Valledupar', 'Aguachica', 'Codazzi', 'Bosconia'],
        'Chocó':                ['Quibdó', 'Istmina', 'Tadó', 'Riosucio'],
        'Córdoba':              ['Montería', 'Cereté', 'Lorica', 'Sahagún', 'Montelíbano'],
        'Cundinamarca':         ['Soacha', 'Zipaquirá', 'Facatativá', 'Chía', 'Mosquera', 'Madrid', 'Fusagasugá', 'Girardot', 'Cajicá', 'La Mesa'],
        'Guainía':              ['Inírida'],
        'Guaviare':             ['San José del Guaviare', 'El Retorno'],
        'Huila':                ['Neiva', 'Pitalito', 'Garzón', 'La Plata', 'Campoalegre'],
        'La Guajira':           ['Riohacha', 'Maicao', 'Uribia', 'Manaure'],
        'Magdalena':            ['Santa Marta', 'Ciénaga', 'Fundación', 'Plato'],
        'Meta':                 ['Villavicencio', 'Acacías', 'Granada', 'Puerto López'],
        'Nariño':               ['Pasto', 'Tumaco', 'Ipiales', 'Túquerres'],
        'Norte de Santander':   ['Cúcuta', 'Ocaña', 'Pamplona', 'Villa del Rosario', 'Los Patios'],
        'Putumayo':             ['Mocoa', 'Puerto Asís', 'Valle del Guamuez'],
        'Quindío':              ['Armenia', 'Calarcá', 'Montenegro', 'Quimbaya', 'La Tebaida'],
        'Risaralda':            ['Pereira', 'Dosquebradas', 'Santa Rosa de Cabal', 'La Virginia'],
        'San Andrés y Providencia': ['San Andrés', 'Providencia'],
        'Santander':            ['Bucaramanga', 'Barrancabermeja', 'Floridablanca', 'Girón', 'Piedecuesta', 'Socorro'],
        'Sucre':                ['Sincelejo', 'Corozal', 'San Marcos', 'Sampués'],
        'Tolima':               ['Ibagué', 'Espinal', 'Melgar', 'Honda', 'Líbano'],
        'Valle del Cauca':      ['Cali', 'Buenaventura', 'Palmira', 'Tuluá', 'Buga', 'Cartago', 'Yumbo', 'Jamundí', 'Candelaria'],
        'Vaupés':               ['Mitú'],
        'Vichada':              ['Puerto Carreño'],
      };

      // ── Países con indicativo ─────────────────────────────────────────────
      const COUNTRIES = [
        { flag: '🇨🇴', name: 'Colombia',          code: '+57'  },
        { flag: '🇺🇸', name: 'Estados Unidos',     code: '+1'   },
        { flag: '🇲🇽', name: 'México',             code: '+52'  },
        { flag: '🇪🇸', name: 'España',             code: '+34'  },
        { flag: '🇻🇪', name: 'Venezuela',          code: '+58'  },
        { flag: '🇪🇨', name: 'Ecuador',            code: '+593' },
        { flag: '🇵🇪', name: 'Perú',               code: '+51'  },
        { flag: '🇨🇱', name: 'Chile',              code: '+56'  },
        { flag: '🇦🇷', name: 'Argentina',          code: '+54'  },
        { flag: '🇧🇷', name: 'Brasil',             code: '+55'  },
        { flag: '🇵🇦', name: 'Panamá',             code: '+507' },
        { flag: '🇨🇷', name: 'Costa Rica',         code: '+506' },
        { flag: '🇩🇴', name: 'Rep. Dominicana',    code: '+1'   },
        { flag: '🇬🇧', name: 'Reino Unido',        code: '+44'  },
        { flag: '🇨🇦', name: 'Canadá',             code: '+1'   },
      ];
      let selectedCountry = COUNTRIES[0];

      ready(() => whenCart(function () {
        const cart    = window.Cart.getCart();
        const layout  = document.getElementById('checkoutLayout');
        const emptyMsg = document.getElementById('cartEmpty');

        if (!cart.length) { emptyMsg.style.display = 'block'; return; }
        layout.style.display = 'grid';
        const coMobileBar = document.getElementById('coMobileBar');
        if (coMobileBar) { coMobileBar.setAttribute('aria-hidden', 'false'); coMobileBar.classList.add('co-mobile-bar--visible'); }

        const sumList     = document.getElementById('sumList');
        const sumSubtotal = document.getElementById('sumSubtotal');
        const sumShipping = document.getElementById('sumShipping');
        const sumTotal    = document.getElementById('sumTotal');
        const shipNote    = document.getElementById('shipNote');
        const payBtn      = document.getElementById('payBtn');
        const payBtnText  = document.getElementById('payBtnText');
        const payError    = document.getElementById('payError');
        const fDeptEl     = document.getElementById('fDept');
        const fCityEl     = document.getElementById('fCity');
        const codNote     = document.getElementById('codNote');
        const payOptionWompi = document.getElementById('payOptionWompi');
        const payOptionCod   = document.getElementById('payOptionCod');

        function getPaymentMethod() {
          const checked = document.querySelector('input[name="payMethod"]:checked');
          return checked ? checked.value : 'wompi';
        }
        function updatePayMethodUI() {
          const method = getPaymentMethod();
          payOptionWompi.classList.toggle('co-pay-option--selected', method === 'wompi');
          payOptionCod.classList.toggle('co-pay-option--selected', method === 'cod');
          if (codNote) codNote.style.display = method === 'cod' ? 'block' : 'none';
          const label = method === 'cod' ? 'Confirmar pedido' : 'Confirmar y pagar';
          payBtnText.textContent = label;
          if (coMbPayText) coMbPayText.textContent = label;
        }
        document.querySelectorAll('input[name="payMethod"]').forEach((el) => {
          el.addEventListener('change', updatePayMethodUI);
        });

        // Cupón aplicado desde el carrito
        let appliedCoupon = (() => {
          try { return JSON.parse(sessionStorage.getItem('dy_coupon') || 'null'); } catch { return null; }
        })();

        function getDiscount(sub) {
          if (!appliedCoupon) return 0;
          if (appliedCoupon.discountType === 'percent')
            return Math.round(sub * appliedCoupon.discountValue / 100);
          return Math.min(Math.round(appliedCoupon.discountValue), sub);
        }

        function renderSummary() {
          const c        = window.Cart.getCart();
          const sub      = window.Cart.subtotal();
          const discount = getDiscount(sub);
          const ship     = (sub - discount) >= FREE_SHIP ? 0 : SHIP_COST;
          const tot      = (sub - discount) + ship;

          sumList.innerHTML = c.map(p => `
            <div class="co-sum-item">
              <div class="co-sum-item__img-wrap">
                <img src="${p.image || '/assets/img/placeholder.webp'}" alt="${(p.name||'').replace(/</g,'&lt;')}" width="48" height="48" loading="lazy" />
                <span class="co-sum-item__qty">${p.qty || 1}</span>
              </div>
              <span class="co-sum-item__name">${p.name || ''}</span>
              <span class="co-sum-item__price">${fmt((p.price || 0) * (p.qty || 1))}</span>
            </div>
          `).join('');

          sumSubtotal.textContent = fmt(sub);

          // Línea de descuento
          let sumDiscountLine = document.getElementById('sumDiscountLine');
          if (!sumDiscountLine && discount > 0) {
            sumDiscountLine = document.createElement('div');
            sumDiscountLine.id = 'sumDiscountLine';
            sumDiscountLine.className = 'co-sum-line';
            sumDiscountLine.style.color = '#16a34a';
            sumDiscountLine.innerHTML = `<span>Descuento${appliedCoupon ? ` (${appliedCoupon.code})` : ''}</span><span id="sumDiscount"></span>`;
            sumSubtotal.closest('.co-sum-line').insertAdjacentElement('afterend', sumDiscountLine);
          }
          if (sumDiscountLine) {
            sumDiscountLine.style.display = discount > 0 ? '' : 'none';
            const sumDiscountVal = document.getElementById('sumDiscount');
            if (sumDiscountVal) sumDiscountVal.textContent = `-${fmt(discount)}`;
          }

          sumShipping.textContent = ship === 0 ? 'Gratis' : fmt(ship);
          if (ship === 0) { sumShipping.style.color = '#16a34a'; sumShipping.style.fontWeight = '600'; }
          sumTotal.textContent = fmt(tot);
          shipNote.style.display = ship === 0 ? 'flex' : 'none';

          const mbTotal = document.getElementById('coMbTotal');
          if (mbTotal) mbTotal.textContent = fmt(tot);
        }
        renderSummary();

        // ── Selector de país para teléfono ──────────────────────────────
        const phoneDropdown = document.getElementById('phoneDropdown');
        const phoneTrigger  = document.getElementById('phoneTrigger');
        const phoneFlagEl   = document.getElementById('phoneFlag');
        const phoneCodeEl   = document.getElementById('phoneCodeLabel');

        phoneDropdown.innerHTML = COUNTRIES.map((c, i) => `
          <button type="button" class="co-phone-option${i === 0 ? ' co-phone-option--selected' : ''}" data-index="${i}" role="option" aria-selected="${i === 0}">
            <span>${c.flag}</span>
            <span class="co-phone-option__name">${c.name}</span>
            <span class="co-phone-option__code">${c.code}</span>
          </button>
        `).join('');

        phoneTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = phoneDropdown.style.display !== 'none';
          phoneDropdown.style.display = isOpen ? 'none' : 'block';
          phoneTrigger.setAttribute('aria-expanded', String(!isOpen));
        });

        phoneDropdown.addEventListener('click', (e) => {
          const btn = e.target.closest('.co-phone-option');
          if (!btn) return;
          const idx = Number(btn.dataset.index);
          selectedCountry = COUNTRIES[idx];
          phoneFlagEl.textContent = selectedCountry.flag;
          phoneCodeEl.textContent = selectedCountry.code;
          phoneDropdown.querySelectorAll('.co-phone-option').forEach((el, i) => {
            el.classList.toggle('co-phone-option--selected', i === idx);
            el.setAttribute('aria-selected', String(i === idx));
          });
          phoneDropdown.style.display = 'none';
          phoneTrigger.setAttribute('aria-expanded', 'false');
        });

        document.addEventListener('click', (e) => {
          if (!e.target.closest('.co-phone-wrap')) {
            phoneDropdown.style.display = 'none';
            phoneTrigger.setAttribute('aria-expanded', 'false');
          }
        });

        // ── Departamentos y ciudades ────────────────────────────────────
        function populateDepts() {
          Object.keys(CO_DATA).sort().forEach(dept => {
            const opt = document.createElement('option');
            opt.value = dept;
            opt.textContent = dept;
            fDeptEl.appendChild(opt);
          });
        }

        function populateCities(dept) {
          fCityEl.innerHTML = '';
          if (!dept) {
            fCityEl.innerHTML = '<option value="">Primero selecciona departamento</option>';
            fCityEl.disabled = true;
            return;
          }
          const cities = CO_DATA[dept] || [];
          const placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = 'Selecciona ciudad…';
          fCityEl.appendChild(placeholder);
          cities.forEach(city => {
            const opt = document.createElement('option');
            opt.value = city;
            opt.textContent = city;
            fCityEl.appendChild(opt);
          });
          fCityEl.disabled = false;
        }

        populateDepts();
        populateCities('');

        // ── Sesión: precargar datos si el usuario está registrado ───────
        const authBanner     = document.getElementById('coAuthBanner');
        const authBannerText = document.getElementById('coAuthBannerText');

        function setVal(id, value) {
          const el = document.getElementById(id);
          if (el && value && !el.value) el.value = value;
        }

        function prefillFromUser(user) {
          const fullName = (user.name && user.name.trim())
            || [user.first_name, user.last_name].filter(Boolean).join(' ').trim();
          setVal('fName', fullName);
          setVal('fEmail', user.email);
          setVal('fAddr', user.address);

          // Teléfono: separar indicativo si viene con prefijo conocido.
          const rawPhone = user.mobile_phone || user.landline_phone;
          if (rawPhone) {
            const phoneEl = document.getElementById('fPhone');
            const match = COUNTRIES.find(c => String(rawPhone).startsWith(c.code));
            if (match) {
              selectedCountry = match;
              phoneFlagEl.textContent = match.flag;
              phoneCodeEl.textContent = match.code;
              if (phoneEl && !phoneEl.value) phoneEl.value = String(rawPhone).slice(match.code.length).trim();
            } else if (phoneEl && !phoneEl.value) {
              phoneEl.value = String(rawPhone).trim();
            }
          }

          // Departamento → ciudad (best-effort por coincidencia de nombre).
          if (user.state_province && !fDeptEl.value) {
            const deptMatch = Array.from(fDeptEl.options).find(
              o => o.value.toLowerCase() === String(user.state_province).toLowerCase()
            );
            if (deptMatch) {
              fDeptEl.value = deptMatch.value;
              populateCities(deptMatch.value);
              if (user.city) {
                const cityMatch = Array.from(fCityEl.options).find(
                  o => o.value.toLowerCase() === String(user.city).toLowerCase()
                );
                if (cityMatch) fCityEl.value = cityMatch.value;
              }
            }
          }
        }

        (async function loadSession() {
          try {
            const res = await fetch('/api/auth/me', { credentials: 'include' });
            if (res.ok) {
              const user = await res.json();
              prefillFromUser(user);
              authBannerText.textContent = `Comprando como ${user.email}. Hemos completado tus datos; puedes editarlos.`;
              authBanner.classList.remove('co-auth-banner--guest');
              authBanner.style.display = 'flex';
            } else {
              authBanner.classList.add('co-auth-banner--guest');
              authBannerText.innerHTML = '¿Ya tiene cuenta? <a href="/login?redirect=/checkout">Inicie sesión</a> para agilizar su compra, o continúe como invitado.';
              authBanner.style.display = 'flex';
            }
          } catch {
            // Sin conexión al verificar sesión → continuar como invitado, sin aviso.
          }
        })();

        fDeptEl.addEventListener('change', () => {
          populateCities(fDeptEl.value);
          clearError(fDeptEl);
          clearError(fCityEl);
        });
        fCityEl.addEventListener('change', () => clearError(fCityEl));

        // ── Validación inline ────────────────────────────────────────────
        function setError(input, msg) {
          input.classList.add('co-input--error');
          const field = input.closest('.co-field');
          let hint = field && field.querySelector('.co-input-hint');
          if (!hint) {
            hint = document.createElement('p');
            hint.className = 'co-input-hint';
            (field || input.parentElement).appendChild(hint);
          }
          hint.textContent = msg;
        }
        function clearError(input) {
          input.classList.remove('co-input--error');
          const field = input.closest('.co-field');
          const hint = field && field.querySelector('.co-input-hint');
          if (hint) hint.textContent = '';
        }

        ['fName', 'fEmail', 'fAddr'].forEach(id => {
          const el = document.getElementById(id);
          if (el) el.addEventListener('input', () => clearError(el));
        });

        const coMbPayBtn  = document.getElementById('coMbPayBtn');
        const coMbPayText = document.getElementById('coMbPayText');
        if (coMbPayBtn) coMbPayBtn.addEventListener('click', () => payBtn.click());

        payBtn.addEventListener('click', async () => {
          payError.style.display = 'none';

          const fName      = document.getElementById('fName').value.trim();
          const fEmail     = document.getElementById('fEmail').value.trim();
          const fPhoneRaw  = document.getElementById('fPhone').value.trim();
          const fAddr      = document.getElementById('fAddr').value.trim();
          const fDept      = fDeptEl.value;
          const fCity      = fCityEl.value;
          const fPhone     = fPhoneRaw ? `${selectedCountry.code} ${fPhoneRaw}` : undefined;

          let hasError = false;
          if (!fName)  { setError(document.getElementById('fName'),  'Campo obligatorio'); hasError = true; }
          if (!fEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(fEmail)) {
            setError(document.getElementById('fEmail'), !fEmail ? 'Campo obligatorio' : 'Correo inválido');
            hasError = true;
          }
          if (!fAddr)  { setError(document.getElementById('fAddr'),  'Campo obligatorio'); hasError = true; }
          if (!fDept)  { setError(fDeptEl, 'Selecciona un departamento'); hasError = true; }
          if (!fCity)  { setError(fCityEl, 'Selecciona una ciudad'); hasError = true; }
          if (hasError) return;

          payBtn.disabled = true;
          payBtnText.textContent = 'Procesando…';
          payBtn.classList.add('co-btn-primary--loading');
          if (coMbPayBtn) { coMbPayBtn.disabled = true; if (coMbPayText) coMbPayText.textContent = 'Procesando…'; }

          try {
            const currentCart = window.Cart.getCart();
            const res = await fetch('/api/orders', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({
                customerName:       fName,
                customerEmail:      fEmail,
                customerPhone:      fPhone,
                shippingAddress:    fAddr,
                shippingCity:       fCity,
                shippingDepartment: fDept || undefined,
                couponCode:         appliedCoupon ? appliedCoupon.code : undefined,
                items: currentCart.map(p => ({
                  productId: p.id,
                  quantity:  p.qty,
                })),
              }),
            });
            const data = await res.json();

            if (!res.ok) {
              payError.textContent = data.errors?.[0]?.msg || data.error || 'Error al crear la orden';
              payError.style.display = 'block';
              payBtn.disabled = false;
              payBtnText.textContent = 'Confirmar y pagar';
              payBtn.classList.remove('co-btn-primary--loading');
              if (coMbPayBtn) { coMbPayBtn.disabled = false; if (coMbPayText) coMbPayText.textContent = 'Confirmar y pagar'; }
              return;
            }

            const reference = data.data.reference;
            const confirmUrl = `/confirmacion?ref=${reference}`;
            const wompi = data.data.wompi;

            function resetPayBtn() {
              payBtn.disabled = false;
              payBtnText.textContent = 'Confirmar y pagar';
              payBtn.classList.remove('co-btn-primary--loading');
              if (coMbPayBtn) { coMbPayBtn.disabled = false; if (coMbPayText) coMbPayText.textContent = 'Confirmar y pagar'; }
            }

            // Widget embebido: abre el checkout de Wompi como modal sobre la página.
            if (wompi && typeof window.WidgetCheckout === 'function') {
              const checkout = new window.WidgetCheckout({
                currency:      wompi.currency,
                amountInCents: wompi.amountInCents,
                reference:     wompi.reference,
                publicKey:     wompi.publicKey,
                signature:     { integrity: wompi.signature },
                redirectUrl:   wompi.redirectUrl,
                customerData: {
                  email:    fEmail,
                  fullName: fName,
                  ...(fPhoneRaw ? { phoneNumber: fPhoneRaw, phoneNumberPrefix: selectedCountry.code } : {}),
                },
              });

              checkout.open(function (result) {
                if (result && result.transaction) {
                  // Pago iniciado/completado — el webhook confirma el estado real.
                  if (window.Cart.clearCart) window.Cart.clearCart();
                  sessionStorage.removeItem('dy_coupon');
                  window.location.href = confirmUrl;
                } else {
                  // El usuario cerró el modal sin completar el pago: permitir reintento.
                  resetPayBtn();
                }
              });
              return;
            }

            // Fallback: checkout hosted (redirección) si el widget no está disponible.
            if (window.Cart.clearCart) window.Cart.clearCart();
            sessionStorage.removeItem('dy_coupon');
            window.location.href = data.data.checkoutUrl || confirmUrl;

          } catch {
            payError.textContent = 'Error de conexión. Inténtalo de nuevo.';
            payError.style.display = 'block';
            payBtn.disabled = false;
            payBtnText.textContent = 'Confirmar y pagar';
            payBtn.classList.remove('co-btn-primary--loading');
            if (coMbPayBtn) { coMbPayBtn.disabled = false; if (coMbPayText) coMbPayText.textContent = 'Confirmar y pagar'; }
          }
        });
      }));
    })();
  </script>

