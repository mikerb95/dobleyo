---
import Layout from "../layouts/Layout.astro";
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
---

<Layout>
  <section class="card" style="max-width:440px; margin:2rem auto 0">
    <div class="p">
      <h1>Iniciar sesión</h1>
      <p class="muted" style="margin-top:-.4rem">
        Accede para ver tu cuenta y pedidos.
      </p>

      <!-- Google Sign-In -->
      {googleClientId && (
        <div id="googleBtnWrap" style="margin-top:1rem">
          <div id="g_id_onload"
            data-client_id={googleClientId}
            data-callback="handleGoogleCredential"
            data-auto_prompt="false">
          </div>
          <div class="g_id_signin"
            data-type="standard"
            data-size="large"
            data-theme="outline"
            data-text="signin_with"
            data-shape="rectangular"
            data-logo_alignment="left"
            data-width="380">
          </div>
        </div>
      )}

      <div class="divider">
        <span>o continúa con tu correo</span>
      </div>

      <form
        id="loginForm"
        class="form"
        onsubmit="return false"
        style="display:grid; gap:.75rem"
      >
        <label
          >Correo<input
            id="loginEmail"
            type="email"
            placeholder="tu@correo.com"
            required
          /></label
        >
        <label
          >Contraseña<input
            id="loginPass"
            type="password"
            placeholder="••••••••"
            required
          /></label
        >
        <button class="btn" id="loginBtn" type="submit">Entrar</button>
      </form>
      <div
        id="loginError"
        class="muted"
        style="color:#b91c1c; display:none; margin-top:.35rem"
      >
      </div>
      <p style="text-align:center; margin-top:1rem; font-size:0.9rem">
        ¿No tienes cuenta? <a href="/registro" style="color:#c67b4e"
          >Crear cuenta</a
        >
      </p>
    </div>
  </section>

  <!-- Google Identity Services -->
  <script src="https://accounts.google.com/gsi/client" async></script>

  <script>
    // Inyectar GOOGLE_CLIENT_ID desde meta tag (evita hardcodear en JS)
    const GOOGLE_CLIENT_ID = document.querySelector('meta[name="google-client-id"]')?.getAttribute('content') || '';
    const onloadEl = document.getElementById('g_id_onload');
    if (onloadEl && GOOGLE_CLIENT_ID) onloadEl.setAttribute('data-client_id', GOOGLE_CLIENT_ID);

    // Callback que invoca Google GSI con el credential (ID token)
    window.handleGoogleCredential = async function (response) {
      const err = document.getElementById('loginError');
      err.style.display = 'none';

      try {
        const res = await fetch('/api/auth/google', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ credential: response.credential }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error al iniciar sesión con Google');

        redirectAfterLogin(data.user?.role);
      } catch (e) {
        err.textContent = e.message;
        err.style.display = 'block';
      }
    };

    // Login con email/contraseña
    (function () {
      const f = document.getElementById("loginForm");
      const err = document.getElementById("loginError");
      const btn = document.getElementById("loginBtn");

      f.addEventListener("submit", async function () {
        const email = (document.getElementById("loginEmail").value || "").trim();
        const password = (document.getElementById("loginPass").value || "").trim();

        if (!email || !password) {
          showError("Completa todos los campos.");
          return;
        }

        btn.disabled = true;
        btn.textContent = "Entrando...";
        err.style.display = "none";

        try {
          const res = await fetch("/api/auth/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ email, password }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "Error al iniciar sesión");

          if (data.user?.devUser === true) {
            window.location.href = "/admin";
            return;
          }

          redirectAfterLogin(data.user?.role);
        } catch (e) {
          showError(e.message);
          btn.disabled = false;
          btn.textContent = "Entrar";
        }
      });

      function showError(msg) {
        err.textContent = msg;
        err.style.display = "block";
      }
    })();

    function redirectAfterLogin(role) {
      const urlParams = new URLSearchParams(window.location.search);
      const redirect = urlParams.get("redirect");

      if (redirect) {
        if (redirect.startsWith("/app")) {
          if (role === "caficultor" || role === "admin") {
            window.location.href = redirect;
          } else {
            document.getElementById('loginError').textContent = "No tienes permisos para acceder a esa sección.";
            document.getElementById('loginError').style.display = 'block';
          }
        } else if (redirect.startsWith("/admin") || redirect.includes("admin.html")) {
          if (role === "admin") {
            window.location.href = redirect;
          } else {
            document.getElementById('loginError').textContent = "Solo administradores pueden acceder a esa sección.";
            document.getElementById('loginError').style.display = 'block';
          }
        } else {
          window.location.href = redirect;
        }
      } else {
        if (role === "admin" || role === "caficultor") {
          window.location.href = "/app";
        } else {
          window.location.href = "/cuenta";
        }
      }
    }
  </script>

  <style>
    .divider {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin: 1.125rem 0 1rem;
      color: var(--muted-fg);
      font-size: .8rem;
    }
    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* Centrar el botón de Google */
    #googleBtnWrap {
      display: flex;
      justify-content: center;
    }
    .g_id_signin {
      width: 100% !important;
    }
  </style>
</Layout>
