---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { getCanonicalUrl } from "../i18n/index.ts";

export const prerender = false;

const pageTitle = "Guías de preparación — DobleYo Café";
const pageDescription =
  "Aprenda a preparar el mejor café de especialidad en casa: molienda, proporciones, temperatura y métodos paso a paso. Guías prácticas de DobleYo Café.";

const guias = [
  {
    icon: "⚗️",
    titulo: "Método V60",
    resumen:
      "Un filtrado limpio que resalta las notas florales y cítricas de los cafés de origen.",
    ratio: "1:16 (15 g de café · 240 ml de agua)",
    molienda: "Media",
    tiempo: "2:30 – 3:00 min",
    temperatura: "92 – 94 °C",
  },
  {
    icon: "🧪",
    titulo: "Chemex",
    resumen:
      "Filtro grueso para una taza nítida y de cuerpo ligero, ideal para compartir.",
    ratio: "1:15 (40 g de café · 600 ml de agua)",
    molienda: "Media-gruesa",
    tiempo: "4:00 – 5:00 min",
    temperatura: "93 – 95 °C",
  },
  {
    icon: "🫖",
    titulo: "Prensa francesa",
    resumen:
      "Inmersión total para un café con cuerpo y mayor presencia de aceites.",
    ratio: "1:14 (30 g de café · 420 ml de agua)",
    molienda: "Gruesa",
    tiempo: "4:00 min",
    temperatura: "93 °C",
  },
  {
    icon: "☕",
    titulo: "Moka / Greca",
    resumen:
      "El clásico de la cocina colombiana: intenso, concentrado y rápido.",
    ratio: "Llenar el embudo sin presionar",
    molienda: "Fina-media",
    tiempo: "4:00 – 5:00 min",
    temperatura: "Fuego medio-bajo",
  },
];

const consejos = [
  "Use agua filtrada: el café es 98% agua, su calidad importa.",
  "Muela justo antes de preparar para conservar los aromas.",
  "Pese el café y el agua con una balanza para resultados consistentes.",
  "Consuma el café dentro de las 4 semanas posteriores al tueste.",
  "Guarde el grano en un recipiente hermético, lejos de luz y calor.",
];
---

<Layout
  lang="es"
  title={pageTitle}
  description={pageDescription}
  canonical={getCanonicalUrl("/guias", "es")}
>
  <PageHero
    eyebrow="Guías"
    title="Prepare un mejor café en casa"
    subtitle="Recetas paso a paso para sacarle todo el potencial a nuestros cafés de especialidad, sin importar el método que prefiera."
  />

  <section class="gu-methods reveal">
    <div class="container">
      <h2 class="gu-h2 gu-h2--center">Métodos de preparación</h2>
      <ul class="gu-grid" role="list">
        {guias.map((g) => (
          <li class="gu-card">
            <span class="gu-card__icon" aria-hidden="true">{g.icon}</span>
            <h3 class="gu-card__title">{g.titulo}</h3>
            <p class="gu-card__resumen">{g.resumen}</p>
            <dl class="gu-card__specs">
              <div><dt>Proporción</dt><dd>{g.ratio}</dd></div>
              <div><dt>Molienda</dt><dd>{g.molienda}</dd></div>
              <div><dt>Tiempo</dt><dd>{g.tiempo}</dd></div>
              <div><dt>Temperatura</dt><dd>{g.temperatura}</dd></div>
            </dl>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="gu-tips">
    <div class="container gu-tips__inner">
      <h2 class="gu-h2">5 consejos esenciales</h2>
      <ul class="gu-tips__list">
        {consejos.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <section class="gu-cta">
    <div class="gu-cta__inner">
      <h2>Ponga en práctica estas guías</h2>
      <p>Elija un café de especialidad y empiece a experimentar en su taza.</p>
      <div class="gu-cta__btns">
        <a class="btn-primary" href="/tienda" data-link>Ver la tienda</a>
        <a class="btn-ghost" href="/accesorios" data-link>Ver accesorios</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.25rem; }
  .gu-h2 {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--coffee);
    margin: 0 0 1.5rem;
  }
  .gu-h2--center { text-align: center; }

  .gu-methods { background: #fff; padding: 3.5rem 0; }
  .gu-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
  }
  @media (min-width: 640px) { .gu-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .gu-grid { grid-template-columns: repeat(4, 1fr); } }

  .gu-card {
    background: var(--cream);
    border-radius: 14px;
    padding: 1.5rem 1.25rem;
    box-shadow: 0 1px 5px rgba(0, 0, 0, 0.08);
  }
  .gu-card__icon { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
  .gu-card__title { margin: 0 0 0.4rem; font-size: 1.15rem; color: var(--coffee); }
  .gu-card__resumen { margin: 0 0 1rem; font-size: 0.9rem; line-height: 1.55; color: var(--ink, #555); }
  .gu-card__specs { margin: 0; display: grid; gap: 0.6rem; }
  .gu-card__specs dt { font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 0.04em; }
  .gu-card__specs dd { margin: 0; font-size: 0.9rem; font-weight: 600; color: var(--coffee); }

  .gu-tips { background: var(--cream); padding: 3rem 0; }
  .gu-tips__inner { max-width: 760px; }
  .gu-tips__list { margin: 0; padding-left: 1.25rem; line-height: 1.8; color: var(--ink, #444); }
  .gu-tips__list li { margin: 0.3rem 0; }

  .gu-cta { background: var(--coffee); color: var(--cream); padding: 3rem 1.5rem; text-align: center; }
  .gu-cta__inner { max-width: 600px; margin: 0 auto; }
  .gu-cta h2 { font-family: var(--font-heading, serif); font-size: clamp(1.5rem, 4vw, 2.2rem); margin: 0 0 0.6rem; }
  .gu-cta p { opacity: 0.9; margin: 0 0 1.5rem; }
  .gu-cta__btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary, .btn-ghost {
    display: inline-block; padding: 0.7rem 1.5rem; border-radius: 999px;
    font-weight: 600; text-decoration: none; min-height: 44px; line-height: 1.6;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { filter: brightness(1.05); }
  .btn-ghost { border: 1.5px solid var(--cream); color: var(--cream); }
  .btn-ghost:hover { background: var(--cream); color: var(--coffee); }
</style>
