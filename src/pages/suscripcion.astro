---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { getCanonicalUrl, getHreflangPair } from "../i18n/index.ts";

export const prerender = false;

const _hreflang = getHreflangPair("/suscripcion");

// Cafés disponibles para suscripción
let coffees: any[] = [];
try {
  const { query } = await import("../../server/db.js");
  const { rows } = await query(
    `SELECT id, name, origin, roast, price, image_url AS image
     FROM products
     WHERE is_active = 1 AND category = 'cafe'
     ORDER BY is_bestseller DESC, rating DESC`
  );
  coffees = rows;
} catch (_) { /* BD no disponible */ }

const pageTitle = "Suscripción de café — DobleYo Café";
const pageDescription =
  "Reciba café de especialidad colombiano recién tostado en su casa cada 15 o 30 días, con descuento de suscriptor. Cancele cuando quiera.";
---

<Layout
  lang="es"
  title={pageTitle}
  description={pageDescription}
  canonical={getCanonicalUrl("/suscripcion", "es")}
  hreflangEs={_hreflang?.es}
  hreflangEn={_hreflang?.en}
>
  <PageHero
    eyebrow="Suscripción"
    title="Café fresco, sin que se le acabe"
  >
    <p class="page-hero__sub" slot="subtitle">
      Reciba su café de especialidad recién tostado cada 15 o 30 días, con
      <strong>descuento de suscriptor</strong> y envío incluido. Cancele cuando quiera.
    </p>
  </PageHero>

  <div class="container sub-wrap">
    {coffees.length === 0 ? (
      <p class="sub-empty">La suscripción no está disponible por el momento. Intente más tarde.</p>
    ) : (
      <form id="subForm" class="sub-form" novalidate>
        <!-- 1. Café -->
        <fieldset class="sub-step">
          <legend><span class="sub-step__n">1</span> Elija su café</legend>
          <div class="sub-coffees" id="subCoffees">
            {coffees.map((c, i) => (
              <label class:list={["sub-coffee", { active: i === 0 }]}>
                <input type="radio" name="coffee" value={c.id} data-price={c.price} data-name={c.name} checked={i === 0} />
                <img src={c.image} alt={c.name} class="sub-coffee__img" loading="lazy" />
                <span class="sub-coffee__name">{c.name}</span>
                <span class="sub-coffee__meta">{[c.origin, c.roast].filter(Boolean).join(" · ")}</span>
                <span class="sub-coffee__price">${Number(c.price).toLocaleString("es-CO")}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- 2. Frecuencia y cantidad -->
        <fieldset class="sub-step">
          <legend><span class="sub-step__n">2</span> Frecuencia y cantidad</legend>
          <div class="sub-row">
            <div class="sub-field">
              <label>Frecuencia</label>
              <div class="sub-toggle" id="subFreq">
                <button type="button" class="sub-toggle__btn active" data-freq="30">Cada 30 días</button>
                <button type="button" class="sub-toggle__btn" data-freq="15">Cada 15 días</button>
              </div>
            </div>
            <div class="sub-field">
              <label for="subQty">Bolsas por entrega</label>
              <input id="subQty" name="quantity" type="number" min="1" max="10" value="1" class="sub-input" />
            </div>
          </div>
        </fieldset>

        <!-- 3. Datos de envío -->
        <fieldset class="sub-step">
          <legend><span class="sub-step__n">3</span> Datos de envío</legend>
          <div class="sub-grid">
            <div class="sub-field"><label for="cName">Nombre completo *</label><input id="cName" name="customerName" class="sub-input" required /></div>
            <div class="sub-field"><label for="cEmail">Correo *</label><input id="cEmail" name="customerEmail" type="email" class="sub-input" required /></div>
            <div class="sub-field"><label for="cPhone">Teléfono</label><input id="cPhone" name="customerPhone" class="sub-input" /></div>
            <div class="sub-field sub-field--full"><label for="cAddr">Dirección *</label><input id="cAddr" name="shippingAddress" class="sub-input" required /></div>
            <div class="sub-field"><label for="cCity">Ciudad *</label><input id="cCity" name="shippingCity" class="sub-input" required /></div>
            <div class="sub-field"><label for="cDept">Departamento</label><input id="cDept" name="shippingDepartment" class="sub-input" /></div>
          </div>
        </fieldset>

        <!-- 4. Pago -->
        <fieldset class="sub-step">
          <legend><span class="sub-step__n">4</span> Tarjeta</legend>
          <p class="sub-secure"><Icon name="lock" size={16} /> Procesado de forma segura por Wompi. Sus datos de tarjeta no se almacenan en nuestros servidores.</p>
          <div class="sub-grid">
            <div class="sub-field sub-field--full"><label for="ccNum">Número de tarjeta *</label><input id="ccNum" inputmode="numeric" autocomplete="cc-number" class="sub-input" placeholder="4242 4242 4242 4242" required /></div>
            <div class="sub-field"><label for="ccName">Titular *</label><input id="ccName" autocomplete="cc-name" class="sub-input" required /></div>
            <div class="sub-field"><label for="ccExp">Vence (MM/AA) *</label><input id="ccExp" autocomplete="cc-exp" class="sub-input" placeholder="MM/AA" required /></div>
            <div class="sub-field"><label for="ccCvc">CVC *</label><input id="ccCvc" inputmode="numeric" autocomplete="cc-csc" class="sub-input" placeholder="123" required /></div>
          </div>
          <label class="sub-accept">
            <input type="checkbox" id="subAccept" required />
            <span>Acepto el <a href="#" id="acceptLink" target="_blank" rel="noopener">reglamento y la autorización de datos personales</a> y el cobro recurrente.</span>
          </label>
        </fieldset>

        <!-- Resumen + acción -->
        <div class="sub-summary">
          <div class="sub-summary__line">
            <span>Por entrega (<span id="sumDiscount">0</span>% dto.)</span>
            <strong id="sumTotal">$0</strong>
          </div>
          <p class="sub-summary__note" id="sumNote">Primer cobro hoy, luego cada 30 días. Cancele cuando quiera.</p>
          <div id="subMsg" class="sub-msg" style="display:none"></div>
          <button type="submit" id="subSubmit" class="sub-submit">Suscribirme</button>
        </div>
      </form>
    )}

    <!-- Beneficios -->
    <aside class="sub-benefits">
      <h2>¿Por qué suscribirse?</h2>
      <ul>
        <li><Icon name="flame" size={18} /> Café siempre fresco, tostado para usted.</li>
        <li><Icon name="percent" size={18} /> Descuento exclusivo de suscriptor.</li>
        <li><Icon name="truck" size={18} /> Envío incluido en cada entrega.</li>
        <li><Icon name="pause" size={18} /> Pause o cancele cuando quiera.</li>
      </ul>
    </aside>
  </div>

  <script is:inline src="/assets/js/suscripcion.js"></script>

  <style>
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.25rem; }

    .sub-hero { background: var(--espresso); color: var(--cream); padding: var(--space-12) 1.5rem var(--space-10); text-align: center; }
    .sub-hero__inner { max-width: 640px; margin: 0 auto; }
    .sub-hero__eyebrow { font-family: var(--font-body); text-transform: uppercase; letter-spacing: .12em; font-size: var(--text-xs); font-weight: 600; color: var(--caramel); margin: 0 0 var(--space-2); }
    .sub-hero__title { font-family: var(--font-display); font-size: var(--text-3xl); margin: 0 0 var(--space-3); color: #fff; }
    .sub-hero__sub { font-size: var(--text-lg); line-height: 1.6; color: rgba(255,255,255,.88); margin: 0; }

    .sub-wrap { display: grid; grid-template-columns: 1fr; gap: var(--space-8); padding: var(--space-10) 1.25rem var(--space-16); }
    @media (min-width: 1024px) { .sub-wrap { grid-template-columns: 1fr 300px; align-items: start; } }
    .sub-empty { text-align: center; color: var(--ink-muted); padding: var(--space-8) 0; }

    .sub-form { display: flex; flex-direction: column; gap: var(--space-6); }
    .sub-step { border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-5); margin: 0; background: var(--card); }
    .sub-step legend { font-family: var(--font-body); font-weight: 700; color: var(--espresso); padding: 0 .5rem; display: flex; align-items: center; gap: var(--space-2); }
    .sub-step__n { background: var(--caramel); color: #fff; width: 1.5rem; height: 1.5rem; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: var(--text-sm); }

    .sub-coffees { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
    @media (min-width: 640px) { .sub-coffees { grid-template-columns: repeat(3, 1fr); } }
    .sub-coffee { position: relative; display: flex; flex-direction: column; align-items: center; text-align: center; border: 2px solid var(--border); border-radius: var(--radius-md); padding: var(--space-4) .5rem; cursor: pointer; transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease); }
    .sub-coffee.active { border-color: var(--caramel); background: var(--cream); }
    .sub-coffee input { position: absolute; opacity: 0; }
    .sub-coffee__img { width: 64px; height: 64px; object-fit: cover; border-radius: 50%; margin-bottom: var(--space-2); }
    .sub-coffee__name { font-family: var(--font-body); font-weight: 700; color: var(--espresso); font-size: var(--text-sm); }
    .sub-coffee__meta { font-size: var(--text-xs); color: var(--ink-muted); }
    .sub-coffee__price { font-size: var(--text-sm); font-weight: 600; color: var(--caramel); margin-top: .2rem; }

    .sub-row { display: flex; flex-wrap: wrap; gap: var(--space-5); }
    .sub-field { display: flex; flex-direction: column; gap: .35rem; flex: 1; min-width: 140px; }
    .sub-field label { font-size: var(--text-xs); color: var(--ink-muted); font-weight: 600; }
    .sub-input { padding: .6rem .75rem; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-size: var(--text-base); font-family: var(--font-body); min-height: 44px; }
    .sub-input:focus-visible { outline: 2px solid var(--caramel); outline-offset: 1px; border-color: var(--caramel); }
    .sub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
    .sub-field--full { grid-column: 1 / -1; }

    .sub-toggle { display: flex; border: 1.5px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
    .sub-toggle__btn { flex: 1; padding: .6rem; background: transparent; border: none; cursor: pointer; font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; color: var(--espresso); min-height: 44px; }
    .sub-toggle__btn.active { background: var(--caramel); color: #fff; }

    .sub-secure { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--leaf); margin: 0 0 var(--space-4); }
    .sub-accept { display: flex; gap: var(--space-2); align-items: flex-start; margin-top: var(--space-4); font-size: var(--text-sm); color: var(--ink-muted); }
    .sub-accept a { color: var(--caramel); text-decoration: underline; }

    .sub-summary { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-5); }
    .sub-summary__line { display: flex; justify-content: space-between; align-items: baseline; font-size: var(--text-base); }
    .sub-summary__line strong { font-family: var(--font-display); font-size: var(--text-xl); color: var(--caramel); }
    .sub-summary__note { font-size: var(--text-sm); color: var(--ink-muted); margin: var(--space-2) 0 var(--space-4); }
    .sub-submit { width: 100%; padding: .85rem; background: var(--caramel); color: #fff; border: none; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: var(--text-base); font-weight: 700; cursor: pointer; min-height: 48px; transition: background var(--dur) var(--ease); }
    .sub-submit:hover { background: var(--caramel-deep); }
    .sub-submit:focus-visible { outline: 2px solid var(--caramel); outline-offset: 2px; }
    .sub-submit:disabled { opacity: .6; cursor: not-allowed; }
    .sub-msg { padding: .65rem .9rem; border-radius: var(--radius-sm); font-size: var(--text-sm); margin-bottom: var(--space-4); }
    .sub-msg.success { background: var(--leaf-bg); color: var(--leaf); }
    .sub-msg.error { background: var(--danger-bg); color: var(--danger); }

    .sub-benefits { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-6); }
    .sub-benefits h2 { font-size: var(--text-lg); color: var(--espresso); margin: 0 0 var(--space-4); }
    .sub-benefits ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
    .sub-benefits li { display: flex; align-items: flex-start; gap: var(--space-3); font-size: var(--text-sm); color: var(--ink-muted); line-height: 1.4; }
    .sub-benefits li :global(svg) { color: var(--caramel); flex-shrink: 0; margin-top: 1px; }
  </style>
</Layout>
