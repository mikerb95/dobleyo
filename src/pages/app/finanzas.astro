---
// Página de Finanzas — Vista de Caficultor
// Muestra las facturas de compra (pagos recibidos por cosechas) desde la BD real
import AppLayout from "../../layouts/AppLayout.astro";

// Fetch server-side a la API de finanzas
let invoices = [];
let summary = { total_facturado: 0, total_pagado: 0, total_pendiente: 0, facturas_pendientes: 0 };
let fetchError = null;

try {
  const resp = await fetch(`${Astro.url.origin}/api/finance/my-invoices?limit=50`, {
    headers: { cookie: Astro.request.headers.get("cookie") ?? "" },
  });
  if (resp.ok) {
    const json = await resp.json();
    if (json.success) {
      invoices = json.data ?? [];
      summary = json.summary ?? summary;
    } else {
      fetchError = json.error;
    }
  } else if (resp.status !== 401) {
    fetchError = `Error del servidor (${resp.status})`;
  }
} catch (e) {
  fetchError = "No se pudo conectar con la base de datos";
}

// Formateadores
function fmtCOP(val) {
  return new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(Number(val ?? 0));
}
function fmtDate(d) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("es-CO", { day: "2-digit", month: "short", year: "numeric" });
}
function stateLabel(state) {
  const map = {
    borrador: { text: "Borrador", bg: "#f3f4f6", color: "#374151" },
    confirmada: { text: "Pendiente de pago", bg: "#fef3c7", color: "#92400e" },
    pagada_parcial: { text: "Pago parcial", bg: "#dbeafe", color: "#1e40af" },
    pagada: { text: "Pagado", bg: "#d1fae5", color: "#065f46" },
    cancelada: { text: "Cancelada", bg: "#fee2e2", color: "#991b1b" },
  };
  return map[state] ?? { text: state, bg: "#f3f4f6", color: "#374151" };
}
---

<AppLayout>
  <section class="finanzas-page">
    <!-- Encabezado -->
    <div class="fin-header">
      <a href="/app" class="fin-back">← Volver al Inicio</a>
      <h1 class="fin-title">💰 Mis Finanzas</h1>
      <p class="fin-subtitle">Seguimiento de pagos por tus entregas de café</p>
    </div>

    {fetchError && (
      <div class="fin-error">
        <strong>No se pudo cargar la información:</strong> {fetchError}
      </div>
    )}

    <!-- Tarjetas de resumen -->
    <div class="fin-summary-grid">
      <div class="fin-card fin-card--green">
        <div class="fin-card__label">Total Facturado</div>
        <div class="fin-card__value">{fmtCOP(summary.total_facturado)}</div>
        <div class="fin-card__sub">Histórico acumulado</div>
      </div>
      <div class="fin-card fin-card--blue">
        <div class="fin-card__label">Total Pagado</div>
        <div class="fin-card__value">{fmtCOP(summary.total_pagado)}</div>
        <div class="fin-card__sub">Ingresos recibidos</div>
      </div>
      <div class="fin-card fin-card--amber">
        <div class="fin-card__label">Por Cobrar</div>
        <div class="fin-card__value">{fmtCOP(summary.total_pendiente)}</div>
        <div class="fin-card__sub">{summary.facturas_pendientes} factura(s) pendiente(s)</div>
      </div>
    </div>

    <!-- Listado de facturas -->
    <div class="fin-section">
      <h2 class="fin-section__title">📋 Historial de Liquidaciones</h2>

      {invoices.length === 0 && !fetchError && (
        <div class="fin-empty">
          <div class="fin-empty__icon">📄</div>
          <p>Aún no tienes liquidaciones registradas.</p>
          <p class="fin-empty__sub">Las facturas por tus cosechas aparecerán aquí cuando sean emitidas por el equipo de DobleYo.</p>
        </div>
      )}

      {invoices.length > 0 && invoices.map((inv) => {
        const badge = stateLabel(inv.state);
        return (
          <details class="fin-invoice-item">
            <summary class="fin-invoice-summary">
              <div class="fin-invoice-header">
                <span class="fin-invoice-num">{inv.invoice_number}</span>
                <span class="fin-invoice-date">{fmtDate(inv.invoice_date)}</span>
                <span class="fin-invoice-total">{fmtCOP(inv.total_amount)}</span>
                <span class="fin-badge" style={`background:${badge.bg};color:${badge.color}`}>{badge.text}</span>
              </div>
              {inv.amount_due > 0 && inv.state !== 'pagada' && (
                <div class="fin-invoice-due">
                  Por cobrar: <strong>{fmtCOP(inv.amount_due)}</strong>
                  &nbsp;· Vence {fmtDate(inv.due_date)}
                </div>
              )}
            </summary>
            <div class="fin-invoice-body">
              {inv.lines && inv.lines.length > 0 && (
                <div class="fin-table-wrap">
                  <table class="fin-table">
                    <thead>
                      <tr>
                        <th>Descripción</th>
                        <th>Lote</th>
                        <th>Cantidad</th>
                        <th>Precio Unit.</th>
                        <th>Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      {inv.lines.map((line) => (
                        <tr>
                          <td>{line.description}</td>
                          <td class="fin-table__lot">{line.lot_reference ?? "—"}</td>
                          <td>{Number(line.quantity).toLocaleString("es-CO")} kg</td>
                          <td>{fmtCOP(line.unit_price)}/kg</td>
                          <td class="fin-table__total">{fmtCOP(line.total)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              {inv.notes && (
                <p class="fin-invoice-notes"><strong>Notas:</strong> {inv.notes}</p>
              )}
              {inv.amount_paid > 0 && (
                <p class="fin-invoice-paid">✅ Pagado: <strong>{fmtCOP(inv.amount_paid)}</strong></p>
              )}
            </div>
          </details>
        );
      })}
    </div>

    <!-- Acciones -->
    <div class="fin-actions">
      <a href="/app" class="fin-btn fin-btn--secondary">← Volver</a>
      <button onclick="window.location.reload()" class="fin-btn fin-btn--primary">↺ Actualizar</button>
    </div>
  </section>
</AppLayout>

<style>
  .finanzas-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.25rem;
  }

  .fin-header { margin-bottom: 2rem; }
  .fin-back {
    color: var(--coffee, #8b6f47);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .fin-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ink, #251a14);
    margin: 0 0 0.375rem;
  }
  .fin-subtitle { color: #6b7280; font-size: 1rem; margin: 0; }

  .fin-error {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .fin-summary-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 480px) {
    .fin-summary-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .fin-card {
    padding: 1.5rem;
    border-radius: 0.75rem;
    color: white;
  }
  .fin-card--green { background: linear-gradient(135deg, #2d6a4f, #1e5a3f); }
  .fin-card--blue  { background: linear-gradient(135deg, #1d4ed8, #1e40af); }
  .fin-card--amber { background: linear-gradient(135deg, #d97706, #b45309); }
  .fin-card__label { font-size: 0.8rem; opacity: 0.85; margin-bottom: 0.375rem; }
  .fin-card__value { font-size: 1.75rem; font-weight: 700; line-height: 1.2; margin-bottom: 0.25rem; }
  .fin-card__sub   { font-size: 0.8rem; opacity: 0.75; }

  .fin-section { margin-bottom: 2rem; }
  .fin-section__title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink, #251a14);
    margin: 0 0 1.25rem;
  }

  .fin-empty {
    text-align: center;
    padding: 3rem 1.5rem;
    background: #f9fafb;
    border-radius: 0.75rem;
    color: #6b7280;
  }
  .fin-empty__icon { font-size: 3rem; margin-bottom: 0.75rem; }
  .fin-empty__sub  { font-size: 0.875rem; margin-top: 0.5rem; }

  .fin-invoice-item {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .fin-invoice-item[open] { border-color: var(--coffee, #8b6f47); }

  .fin-invoice-summary {
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .fin-invoice-summary::-webkit-details-marker { display: none; }

  .fin-invoice-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .fin-invoice-num  { font-weight: 600; color: var(--ink, #251a14); min-width: 120px; }
  .fin-invoice-date { color: #6b7280; font-size: 0.9rem; flex: 1; }
  .fin-invoice-total { font-weight: 700; color: #2d6a4f; }

  .fin-badge {
    padding: 0.25rem 0.7rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .fin-invoice-due {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: #92400e;
  }

  .fin-invoice-body {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid #f3f4f6;
  }

  .fin-table-wrap { overflow-x: auto; }
  .fin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin-top: 0.875rem;
  }
  .fin-table th {
    padding: 0.5rem 0.625rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    border-bottom: 1px solid #e5e7eb;
  }
  .fin-table td {
    padding: 0.5rem 0.625rem;
    border-bottom: 1px solid #f9fafb;
    color: #374151;
  }
  .fin-table__lot   { font-family: monospace; font-size: 0.8rem; color: #6b7280; }
  .fin-table__total { font-weight: 600; color: #2d6a4f; }

  .fin-invoice-notes {
    margin-top: 0.875rem;
    font-size: 0.875rem;
    color: #6b7280;
    background: #f9fafb;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
  }
  .fin-invoice-paid {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: #065f46;
  }

  .fin-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  .fin-btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .fin-btn--primary   { background: var(--coffee, #8b6f47); color: white; }
  .fin-btn--secondary { background: #f3f4f6; color: #374151; }
  .fin-btn:hover { opacity: 0.9; }
</style>
