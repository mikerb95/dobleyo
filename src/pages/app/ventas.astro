---
import AppLayout from "../../layouts/AppLayout.astro";
import SalesHeatmap from "../../components/SalesHeatmap.jsx";
---

<AppLayout>
  <div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <!-- Encabezado -->
    <div style="margin-bottom: 1.5rem;">
      <h1
        style="font-size: 1.7rem; font-weight: 700; color: var(--coffee, #251a14); margin-bottom: 0.4rem;"
      >
        🗺️ Mapa de Calor de Ventas
      </h1>
      <p style="color: #666; margin: 0; font-size: 0.95rem;">
        Distribución geográfica combinada — tienda web y MercadoLibre. Filtra
        por período, canal o producto y exporta los datos como CSV.
      </p>
    </div>

    <!-- Mapa interactivo -->
    <div
      style="background: white; padding: 1.5rem; border-radius: 10px; border: 1px solid #e6e6e6; margin-bottom: 1.5rem;"
    >
      <SalesHeatmap client:load />
    </div>

    <!-- Tips rápidos -->
    <div
      style="background: #f9f7f4; border-radius: 8px; padding: 1.25rem 1.5rem; border: 1px solid #e6e6e6;"
    >
      <h3 style="color: #251a14; margin: 0 0 0.8rem; font-size: 0.95rem;">
        Guía rápida
      </h3>
      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.9rem;"
      >
        {
          [
            {
              icon: "🎨",
              title: "Intensidad de calor",
              desc: "Amarillo = pocas ventas → Rojo oscuro = muchas ventas.",
            },
