# Variables de entorno para DobleYo Café
# Copia este archivo a .env en la raíz del proyecto y completa los valores.
# NUNCA subas el archivo .env real al repositorio.

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
SITE_BASE_URL=https://dobleyo.cafe

# ── Base de Datos (PostgreSQL) ────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# Proveedores compatibles: Neon, Supabase, Railway, Aiven (PostgreSQL), local
DATABASE_URL=postgresql://usuario:contraseña@host:5432/dobleyo

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Usar: openssl rand -base64 48
JWT_SECRET=cambia_esto_en_produccion_minimo_32_chars
JWT_REFRESH_SECRET=cambia_esto_en_produccion_minimo_32_chars_refresh

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@dobleyo.cafe

# ── Admin inicial (solo para script de setup) ─────────────────────────────────
ADMIN_EMAIL=admin@dobleyo.cafe
ADMIN_PASSWORD=contraseña_segura_min_12_chars
SETUP_SECRET_KEY=string_aleatorio_para_proteger_endpoint_setup

# ── Pasarelas de Pago ─────────────────────────────────────────────────────────

# Wompi (Colombia) — https://dashboard.wompi.co/
WOMPI_PUBLIC_KEY=pub_prod_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_PRIVATE_KEY=prv_prod_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_EVENTS_SECRET=prod_events_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# MercadoPago (Colombia/LATAM) — https://www.mercadopago.com.co/
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MercadoLibre (sincronización de órdenes) ──────────────────────────────────
ML_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
ML_SELLER_ID=123456789

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com/ → APIs & Services → Credentials
# Tipo: OAuth 2.0 Client ID (Web application)
# Authorized JS origins: https://dobleyo.cafe
# Nota: el prefijo PUBLIC_ expone la variable al cliente (requerido por Astro)
PUBLIC_GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com

# ── Credenciales de desarrollo (acceso directo al panel admin) ───────────────
# Si están definidas, permiten login con estas credenciales sin consultar la BD.
# Omitir en producción o dejar vacías para deshabilitar.
DEV_USER=
DEV_PASSWORD=

# ── Tests / CI ────────────────────────────────────────────────────────────────
# Para tests locales con Playwright E2E
PLAYWRIGHT_BASE_URL=http://localhost:4321
